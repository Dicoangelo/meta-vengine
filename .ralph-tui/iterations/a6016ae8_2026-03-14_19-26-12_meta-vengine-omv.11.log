ility</div>\n            </div>\n            <div class=\"intel-metric\">\n              <div class=\"metric-value\" id=\"smaxSycophancy\" style=\"color:var(--accent-red);font-size:1rem;\">--</div>\n              <div class=\"metric-label\">Sycophancy Flags</div>\n            </div>\n          </div>\n        </div>\n        <div class=\"intel-sub\">\n          <h4>Disagreement Dimensions</h4>\n          <div id=\"smaxDivergentDims\"></div>\n        </div>\n        <div class=\"intel-sub\" style=\"margin-top:12px;\">\n          <canvas id=\"smaxAgentChart\" style=\"max-height:160px;\"></canvas>\n        </div>\n      </div>\n\n      <!-- Graph Signal Panel -->\n      <div class=\"intel-panel graph-signal\">\n        <h3>Graph Signal — Confidence Intelligence</h3>\n        <div class=\"intel-metrics\">\n          <div class=\"intel-metric\">\n            <div class=\"metric-value\" id=\"gsigAvgConf\" style=\"color:var(--accent-green)\">--</div>\n            <div class=\"metric-label\">Avg Confidence</div>\n          </div>\n          <div class=\"intel-metric\">\n            <div class=\"metric-value\" id=\"gsigModified\" style=\"color:var(--accent-blue)\">--</div>\n            <div class=\"metric-label\">Modified Links</div>\n          </div>\n          <div class=\"intel-metric\">\n            <div class=\"metric-value\" id=\"gsigSparseFlags\" style=\"color:var(--accent-red)\">--</div>\n            <div class=\"metric-label\">Sparse Flags</div>\n          </div>\n        </div>\n        <div class=\"intel-sub\">\n          <h4>Confidence Distribution Heatmap</h4>\n          <div class=\"confidence-heatmap\" id=\"gsigHeatmap\"></div>\n          <div style=\"display:flex;justify-content:space-between;font-size:0.55rem;color:var(--text-muted);margin-top:2px;\">\n            <span>0.0</span><span>0.5</span><span>1.0</span>\n          </div>\n        </div>\n        <div class=\"intel-sub\">\n          <h4>Signal Weights</h4>\n          <div id=\"gsigWeights\"></div>\n        </div>\n        <div class=\"intel-sub\">\n          <h4>Write-Direction Activity</h4>\n          <div class=\"write-activity-row\">\n            <span class=\"label\">Snapshots:</span> <span id=\"gsigSnapshots\">0</span>\n            <span class=\"boost\">+<span id=\"gsigBoosts\">0</span> boosts</span>\n            <span class=\"degrade\">-<span id=\"gsigDegrades\">0</span> degrades</span>\n          </div>\n        </div>\n        <div class=\"intel-sub\" style=\"margin-top:12px;\">\n          <canvas id=\"gsigConfChart\" style=\"max-height:160px;\"></canvas>\n        </div>\n      </div>\n\n    </div>\n\n    <!-- Activity Feed -->\n    <div class=\"feed-section\">","originalFile":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Antigravity Ecosystem — Unified Intelligence</title>\n<script src=\"https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js\"></script>\n<style>\n  :root {\n    --bg-dark: #0a0e17;\n    --bg-card: rgba(255,255,255,0.04);\n    --bg-card-hover: rgba(255,255,255,0.07);\n    --border: rgba(255,255,255,0.08);\n    --text: #e4e8f1;\n    --text-dim: rgba(255,255,255,0.45);\n    --text-muted: rgba(255,255,255,0.3);\n    --accent-red: #e94560;\n    --accent-blue: #48dbfb;\n    --accent-yellow: #feca57;\n    --accent-green: #00ff88;\n    --accent-purple: #a855f7;\n    --font-mono: 'JetBrains Mono', 'SF Mono', 'Fira Code', monospace;\n    --font-sans: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;\n  }\n\n  * { margin: 0; padding: 0; box-sizing: border-box; }\n\n  body {\n    background: var(--bg-dark);\n    color: var(--text);\n    font-family: var(--font-sans);\n    min-height: 100vh;\n    overflow-x: hidden;\n  }\n\n  /* Background gradient */\n  body::before {\n    content: '';\n    position: fixed;\n    top: 0; left: 0; right: 0; bottom: 0;\n    background:\n      radial-gradient(ellipse at 20% 20%, rgba(233,69,96,0.08) 0%, transparent 50%),\n      radial-gradient(ellipse at 80% 80%, rgba(72,219,251,0.06) 0%, transparent 50%),\n      radial-gradient(ellipse at 50% 50%, rgba(0,255,136,0.04) 0%, transparent 60%);\n    pointer-events: none;\n    z-index: 0;\n  }\n\n  .container {\n    max-width: 1400px;\n    margin: 0 auto;\n    padding: 20px;\n    position: relative;\n    z-index: 1;\n  }\n\n  /* ─── Header ─── */\n  .header {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    padding: 16px 0 24px;\n    border-bottom: 1px solid var(--border);\n    margin-bottom: 24px;\n  }\n\n  .header-left h1 {\n    font-size: 1.6rem;\n    font-weight: 700;\n    background: linear-gradient(135deg, #e94560, #48dbfb, #00ff88);\n    -webkit-background-clip: text;\n    -webkit-text-fill-color: transparent;\n    background-clip: text;\n  }\n\n  .header-left .subtitle {\n    font-size: 0.75rem;\n    color: var(--text-dim);\n    font-family: var(--font-mono);\n    margin-top: 4px;\n  }\n\n  .header-right {\n    display: flex;\n    align-items: center;\n    gap: 16px;\n  }\n\n  .status-indicator {\n    display: flex;\n    align-items: center;\n    gap: 6px;\n    font-family: var(--font-mono);\n    font-size: 0.7rem;\n    color: var(--text-dim);\n  }\n\n  .status-dot {\n    width: 8px; height: 8px;\n    border-radius: 50%;\n    background: var(--accent-red);\n    transition: background 0.3s, box-shadow 0.3s;\n  }\n\n  .status-dot.connected {\n    background: var(--accent-green);\n    box-shadow: 0 0 10px var(--accent-green);\n  }\n\n  .nav-link {\n    font-family: var(--font-mono);\n    font-size: 0.7rem;\n    color: var(--accent-blue);\n    text-decoration: none;\n    padding: 6px 12px;\n    border: 1px solid rgba(72,219,251,0.3);\n    border-radius: 6px;\n    transition: all 0.2s;\n  }\n\n  .nav-link:hover {\n    background: rgba(72,219,251,0.1);\n    border-color: var(--accent-blue);\n  }\n\n  /* ─── Hero Totals Bar ─── */\n  .hero-bar {\n    display: grid;\n    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));\n    gap: 12px;\n    margin-bottom: 24px;\n  }\n\n  .hero-stat {\n    background: var(--bg-card);\n    border: 1px solid var(--border);\n    border-radius: 12px;\n    padding: 16px;\n    text-align: center;\n    backdrop-filter: blur(12px);\n    transition: all 0.2s;\n  }\n\n  .hero-stat:hover {\n    background: var(--bg-card-hover);\n    border-color: rgba(255,255,255,0.15);\n    transform: translateY(-1px);\n  }\n\n  .hero-stat .value {\n    font-size: 1.5rem;\n    font-weight: 700;\n    font-family: var(--font-mono);\n    line-height: 1.2;\n  }\n\n  .hero-stat .label {\n    font-size: 0.65rem;\n    color: var(--text-dim);\n    text-transform: uppercase;\n    letter-spacing: 0.5px;\n    margin-top: 4px;\n  }\n\n  .hero-stat.sessions .value { color: var(--accent-blue); }\n  .hero-stat.events .value { color: var(--accent-yellow); }\n  .hero-stat.findings .value { color: var(--accent-red); }\n  .hero-stat.memory .value { color: var(--accent-green); }\n  .hero-stat.links .value { color: var(--accent-purple); }\n  .hero-stat.dq .value { color: var(--accent-blue); }\n  .hero-stat.learnings .value { color: var(--accent-yellow); }\n  .hero-stat.papers .value { color: var(--accent-red); }\n\n  /* ─── Database Cards ─── */\n  .db-grid {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 20px;\n    margin-bottom: 24px;\n  }\n\n  @media (max-width: 1000px) {\n    .db-grid { grid-template-columns: 1fr; }\n  }\n\n  .db-card {\n    background: var(--bg-card);\n    border: 1px solid var(--border);\n    border-radius: 16px;\n    padding: 24px;\n    backdrop-filter: blur(12px);\n    transition: all 0.3s;\n  }\n\n  .db-card:hover {\n    background: var(--bg-card-hover);\n    border-color: rgba(255,255,255,0.12);\n  }\n\n  .db-card-header {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    margin-bottom: 16px;\n    padding-bottom: 12px;\n    border-bottom: 1px solid var(--border);\n  }\n\n  .db-card-header .db-name {\n    font-size: 0.95rem;\n    font-weight: 600;\n  }\n\n  .db-card-header .db-status {\n    display: flex;\n    align-items: center;\n    gap: 5px;\n    font-family: var(--font-mono);\n    font-size: 0.6rem;\n    color: var(--text-dim);\n  }\n\n  .db-card-header .db-dot {\n    width: 6px; height: 6px;\n    border-radius: 50%;\n    background: var(--accent-green);\n    box-shadow: 0 0 6px var(--accent-green);\n  }\n\n  .db-card-header .db-dot.error {\n    background: var(--accent-red);\n    box-shadow: 0 0 6px var(--accent-red);\n  }\n\n  .db-card.claude .db-name { color: var(--accent-blue); }\n  .db-card.antigravity .db-name { color: var(--accent-red); }\n  .db-card.supermemory .db-name { color: var(--accent-green); }\n\n  .db-metrics {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 8px;\n    margin-bottom: 16px;\n  }\n\n  .db-metric {\n    padding: 8px 10px;\n    background: rgba(255,255,255,0.02);\n    border-radius: 8px;\n    border: 1px solid rgba(255,255,255,0.04);\n  }\n\n  .db-metric .metric-value {\n    font-size: 1.1rem;\n    font-weight: 600;\n    font-family: var(--font-mono);\n    color: var(--text);\n  }\n\n  .db-metric .metric-label {\n    font-size: 0.6rem;\n    color: var(--text-dim);\n    text-transform: uppercase;\n    letter-spacing: 0.3px;\n  }\n\n  .db-breakdown {\n    margin-top: 12px;\n  }\n\n  .db-breakdown h4 {\n    font-size: 0.7rem;\n    color: var(--text-dim);\n    text-transform: uppercase;\n    letter-spacing: 0.5px;\n    margin-bottom: 8px;\n  }\n\n  .breakdown-bar {\n    display: flex;\n    align-items: center;\n    gap: 8px;\n    margin-bottom: 4px;\n    font-size: 0.72rem;\n    font-family: var(--font-mono);\n  }\n\n  .breakdown-bar .bar-label {\n    width: 90px;\n    color: var(--text-dim);\n    overflow: hidden;\n    text-overflow: ellipsis;\n    white-space: nowrap;\n  }\n\n  .breakdown-bar .bar-track {\n    flex: 1;\n    height: 6px;\n    background: rgba(255,255,255,0.06);\n    border-radius: 3px;\n    overflow: hidden;\n  }\n\n  .breakdown-bar .bar-fill {\n    height: 100%;\n    border-radius: 3px;\n    transition: width 0.5s ease;\n  }\n\n  .breakdown-bar .bar-count {\n    width: 50px;\n    text-align: right;\n    color: var(--text);\n  }\n\n  .db-card.claude .bar-fill { background: linear-gradient(90deg, var(--accent-blue), #6c5ce7); }\n  .db-card.antigravity .bar-fill { background: linear-gradient(90deg, var(--accent-red), var(--accent-yellow)); }\n  .db-card.supermemory .bar-fill { background: linear-gradient(90deg, var(--accent-green), var(--accent-blue)); }\n\n  /* ─── Chart Section ─── */\n  .chart-section {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 20px;\n    margin-bottom: 24px;\n  }\n\n  @media (max-width: 800px) {\n    .chart-section { grid-template-columns: 1fr; }\n  }\n\n  .chart-card {\n    background: var(--bg-card);\n    border: 1px solid var(--border);\n    border-radius: 16px;\n    padding: 20px;\n    backdrop-filter: blur(12px);\n  }\n\n  .chart-card h3 {\n    font-size: 0.8rem;\n    color: var(--text-dim);\n    text-transform: uppercase;\n    letter-spacing: 0.5px;\n    margin-bottom: 12px;\n  }\n\n  .chart-card canvas {\n    max-height: 200px;\n  }\n\n  /* ─── Activity Feed ─── */\n  .feed-section {\n    background: var(--bg-card);\n    border: 1px solid var(--border);\n    border-radius: 16px;\n    padding: 24px;\n    backdrop-filter: blur(12px);\n  }\n\n  .feed-section h3 {\n    font-size: 0.85rem;\n    color: var(--text-dim);\n    text-transform: uppercase;\n    letter-spacing: 0.5px;\n    margin-bottom: 16px;\n  }\n\n  .feed-list {\n    display: flex;\n    flex-direction: column;\n    gap: 8px;\n    max-height: 400px;\n    overflow-y: auto;\n  }\n\n  .feed-item {\n    display: flex;\n    gap: 12px;\n    padding: 10px 12px;\n    background: rgba(255,255,255,0.02);\n    border-radius: 8px;\n    border: 1px solid rgba(255,255,255,0.04);\n    font-size: 0.78rem;\n    transition: background 0.2s;\n  }\n\n  .feed-item:hover {\n    background: rgba(255,255,255,0.05);\n  }\n\n  .feed-item .feed-badge {\n    font-family: var(--font-mono);\n    font-size: 0.6rem;\n    padding: 2px 8px;\n    border-radius: 4px;\n    white-space: nowrap;\n    height: fit-content;\n    font-weight: 600;\n  }\n\n  .feed-badge.finding {\n    background: rgba(233,69,96,0.15);\n    color: var(--accent-red);\n    border: 1px solid rgba(233,69,96,0.3);\n  }\n\n  .feed-badge.learning {\n    background: rgba(0,255,136,0.1);\n    color: var(--accent-green);\n    border: 1px solid rgba(0,255,136,0.3);\n  }\n\n  .feed-item .feed-content {\n    flex: 1;\n    color: var(--text);\n    line-height: 1.4;\n    overflow: hidden;\n    display: -webkit-box;\n    -webkit-line-clamp: 2;\n    -webkit-box-orient: vertical;\n  }\n\n  .feed-item .feed-time {\n    font-family: var(--font-mono);\n    font-size: 0.6rem;\n    color: var(--text-muted);\n    white-space: nowrap;\n    margin-top: 2px;\n  }\n\n  /* ─── Today Panel ─── */\n  .today-panel {\n    background: linear-gradient(135deg, rgba(72,219,251,0.08), rgba(0,255,136,0.05));\n    border: 1px solid rgba(72,219,251,0.2);\n    border-radius: 12px;\n    padding: 14px 20px;\n    margin-bottom: 24px;\n    display: flex;\n    align-items: center;\n    gap: 24px;\n    font-family: var(--font-mono);\n    font-size: 0.75rem;\n  }\n\n  .today-panel .today-label {\n    color: var(--accent-blue);\n    font-weight: 600;\n    text-transform: uppercase;\n    font-size: 0.65rem;\n    letter-spacing: 1px;\n  }\n\n  .today-panel .today-stat {\n    color: var(--text);\n  }\n\n  .today-panel .today-stat span {\n    color: var(--text-dim);\n    margin-left: 4px;\n  }\n\n  /* ─── Scrollbar ─── */\n  ::-webkit-scrollbar { width: 6px; }\n  ::-webkit-scrollbar-track { background: transparent; }\n  ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 3px; }\n  ::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,0.2); }\n\n  /* ─── Intelligence Panels (SUPERMAX v2 + Graph Signal) ─── */\n  .intel-grid {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 20px;\n    margin-bottom: 24px;\n  }\n\n  @media (max-width: 1000px) {\n    .intel-grid { grid-template-columns: 1fr; }\n  }\n\n  .intel-panel {\n    background: var(--bg-card);\n    border: 1px solid var(--border);\n    border-radius: 16px;\n    padding: 24px;\n    backdrop-filter: blur(12px);\n  }\n\n  .intel-panel.supermax { border-left: 3px solid var(--accent-purple); }\n  .intel-panel.graph-signal { border-left: 3px solid var(--accent-green); }\n\n  .intel-panel h3 {\n    font-size: 0.85rem;\n    font-weight: 600;\n    margin-bottom: 16px;\n    display: flex;\n    align-items: center;\n    gap: 8px;\n  }\n\n  .intel-panel.supermax h3 { color: var(--accent-purple); }\n  .intel-panel.graph-signal h3 { color: var(--accent-green); }\n\n  .intel-metrics {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 8px;\n    margin-bottom: 16px;\n  }\n\n  .intel-metric {\n    padding: 10px;\n    background: rgba(255,255,255,0.02);\n    border-radius: 8px;\n    border: 1px solid rgba(255,255,255,0.04);\n    text-align: center;\n  }\n\n  .intel-metric .metric-value {\n    font-size: 1.2rem;\n    font-weight: 700;\n    font-family: var(--font-mono);\n  }\n\n  .intel-metric .metric-label {\n    font-size: 0.6rem;\n    color: var(--text-dim);\n    text-transform: uppercase;\n    letter-spacing: 0.3px;\n    margin-top: 2px;\n  }\n\n  .intel-sub {\n    margin-top: 12px;\n    font-size: 0.75rem;\n    font-family: var(--font-mono);\n  }\n\n  .intel-sub h4 {\n    font-size: 0.65rem;\n    color: var(--text-dim);\n    text-transform: uppercase;\n    letter-spacing: 0.5px;\n    margin-bottom: 6px;\n  }\n\n  .intel-bar-row {\n    display: flex;\n    align-items: center;\n    gap: 6px;\n    margin-bottom: 3px;\n  }\n\n  .intel-bar-row .bar-label {\n    width: 70px;\n    color: var(--text-dim);\n    font-size: 0.65rem;\n    overflow: hidden;\n    text-overflow: ellipsis;\n    white-space: nowrap;\n  }\n\n  .intel-bar-row .bar-track {\n    flex: 1;\n    height: 5px;\n    background: rgba(255,255,255,0.06);\n    border-radius: 3px;\n    overflow: hidden;\n  }\n\n  .intel-bar-row .bar-fill {\n    height: 100%;\n    border-radius: 3px;\n    transition: width 0.5s ease;\n  }\n\n  .intel-bar-row .bar-count {\n    width: 40px;\n    text-align: right;\n    color: var(--text);\n    font-size: 0.65rem;\n  }\n\n  .supermax .bar-fill { background: linear-gradient(90deg, var(--accent-purple), #6c5ce7); }\n  .graph-signal .bar-fill { background: linear-gradient(90deg, var(--accent-green), var(--accent-blue)); }\n\n  .confidence-heatmap {\n    display: flex;\n    gap: 2px;\n    margin-top: 6px;\n    height: 24px;\n    border-radius: 4px;\n    overflow: hidden;\n  }\n\n  .confidence-heatmap .hm-bar {\n    flex: 1;\n    position: relative;\n    transition: all 0.3s;\n  }\n\n  .confidence-heatmap .hm-bar:hover {\n    opacity: 0.8;\n  }\n\n  .write-activity-row {\n    display: flex;\n    align-items: center;\n    gap: 12px;\n    margin-top: 8px;\n    font-size: 0.72rem;\n    font-family: var(--font-mono);\n  }\n\n  .write-activity-row .boost { color: var(--accent-green); }\n  .write-activity-row .degrade { color: var(--accent-red); }\n  .write-activity-row .label { color: var(--text-dim); }\n\n  /* ─── Loading State ─── */\n  .loading {\n    text-align: center;\n    padding: 60px;\n    color: var(--text-dim);\n    font-family: var(--font-mono);\n    font-size: 0.85rem;\n  }\n\n  .loading::after {\n    content: '';\n    display: inline-block;\n    width: 16px; height: 16px;\n    border: 2px solid var(--text-muted);\n    border-top-color: var(--accent-blue);\n    border-radius: 50%;\n    animation: spin 0.8s linear infinite;\n    margin-left: 10px;\n    vertical-align: middle;\n  }\n\n  @keyframes spin { to { transform: rotate(360deg); } }\n\n  .error-state {\n    color: var(--accent-red);\n    font-family: var(--font-mono);\n    font-size: 0.75rem;\n    padding: 8px;\n    text-align: center;\n  }\n</style>\n</head>\n<body>\n\n<div class=\"container\">\n  <!-- Header -->\n  <div class=\"header\">\n    <div class=\"header-left\">\n      <h1>Antigravity Ecosystem</h1>\n      <div class=\"subtitle\">Unified Intelligence across 3 databases</div>\n    </div>\n    <div class=\"header-right\">\n      <div class=\"status-indicator\">\n        <div class=\"status-dot\" id=\"sseDot\"></div>\n        <span id=\"sseLabel\">CONNECTING</span>\n      </div>\n      <a href=\"/dashboard\" class=\"nav-link\">CCC Dashboard</a>\n    </div>\n  </div>\n\n  <!-- Loading state -->\n  <div class=\"loading\" id=\"loadingState\">Loading ecosystem data</div>\n\n  <!-- Main content (hidden until data loads) -->\n  <div id=\"mainContent\" style=\"display:none;\">\n\n    <!-- Today Panel -->\n    <div class=\"today-panel\" id=\"todayPanel\">\n      <div class=\"today-label\">Today</div>\n      <div class=\"today-stat\"><strong id=\"todayMessages\">0</strong><span>messages</span></div>\n      <div class=\"today-stat\"><strong id=\"todaySessions\">0</strong><span>sessions</span></div>\n      <div class=\"today-stat\"><strong id=\"todayTools\">0</strong><span>tools</span></div>\n    </div>\n\n    <!-- Hero Totals Bar -->\n    <div class=\"hero-bar\">\n      <div class=\"hero-stat sessions\">\n        <div class=\"value\" id=\"totalSessions\">--</div>\n        <div class=\"label\">Total Sessions</div>\n      </div>\n      <div class=\"hero-stat events\">\n        <div class=\"value\" id=\"totalEvents\">--</div>\n        <div class=\"label\">Total Events</div>\n      </div>\n      <div class=\"hero-stat findings\">\n        <div class=\"value\" id=\"totalFindings\">--</div>\n        <div class=\"label\">Findings</div>\n      </div>\n      <div class=\"hero-stat papers\">\n        <div class=\"value\" id=\"totalPapers\">--</div>\n        <div class=\"label\">Papers</div>\n      </div>\n      <div class=\"hero-stat memory\">\n        <div class=\"value\" id=\"totalMemory\">--</div>\n        <div class=\"label\">Memory Items</div>\n      </div>\n      <div class=\"hero-stat learnings\">\n        <div class=\"value\" id=\"totalLearnings\">--</div>\n        <div class=\"label\">Learnings</div>\n      </div>\n      <div class=\"hero-stat links\">\n        <div class=\"value\" id=\"totalLinks\">--</div>\n        <div class=\"label\">Graph Links</div>\n      </div>\n      <div class=\"hero-stat dq\">\n        <div class=\"value\" id=\"totalDQ\">--</div>\n        <div class=\"label\">DQ Scores</div>\n      </div>\n    </div>\n\n    <!-- 3 Database Cards -->\n    <div class=\"db-grid\">\n\n      <!-- Claude Code Card -->\n      <div class=\"db-card claude\">\n        <div class=\"db-card-header\">\n          <div class=\"db-name\">Claude Code Telemetry</div>\n          <div class=\"db-status\">\n            <div class=\"db-dot\" id=\"claudeDot\"></div>\n            <span id=\"claudeStatus\">connected</span>\n          </div>\n        </div>\n        <div class=\"db-metrics\">\n          <div class=\"db-metric\">\n            <div class=\"metric-value\" id=\"claudeSessions\">--</div>\n            <div class=\"metric-label\">Sessions</div>\n          </div>\n          <div class=\"db-metric\">\n            <div class=\"metric-value\" id=\"claudeActivity\">--</div>\n            <div class=\"metric-label\">Activity Events</div>\n          </div>\n          <div class=\"db-metric\">\n            <div class=\"metric-value\" id=\"claudeTools\">--</div>\n            <div class=\"metric-label\">Tool Events</div>\n          </div>\n          <div class=\"db-metric\">\n            <div class=\"metric-value\" id=\"claudeDQ\">--</div>\n            <div class=\"metric-label\">DQ Scores</div>\n          </div>\n          <div class=\"db-metric\">\n            <div class=\"metric-value\" id=\"claudeHeal\">--</div>\n            <div class=\"metric-label\">Self-Heal</div>\n          </div>\n          <div class=\"db-metric\">\n            <div class=\"metric-value\" id=\"claudeRouting\">--</div>\n            <div class=\"metric-label\">Routing</div>\n          </div>\n        </div>\n        <div class=\"db-breakdown\" id=\"claudeBreakdown\"></div>\n      </div>\n\n      <!-- Antigravity Card -->\n      <div class=\"db-card antigravity\">\n        <div class=\"db-card-header\">\n          <div class=\"db-name\">Research & UCW Intelligence</div>\n          <div class=\"db-status\">\n            <div class=\"db-dot\" id=\"antigravityDot\"></div>\n            <span id=\"antigravityStatus\">connected</span>\n          </div>\n        </div>\n        <div class=\"db-metrics\">\n          <div class=\"db-metric\">\n            <div class=\"metric-value\" id=\"agFindings\">--</div>\n            <div class=\"metric-label\">Findings</div>\n          </div>\n          <div class=\"db-metric\">\n            <div class=\"metric-value\" id=\"agPapers\">--</div>\n            <div class=\"metric-label\">Papers</div>\n          </div>\n          <div class=\"db-metric\">\n            <div class=\"metric-value\" id=\"agSessions\">--</div>\n            <div class=\"metric-label\">UCW Sessions</div>\n          </div>\n          <div class=\"db-metric\">\n            <div class=\"metric-value\" id=\"agURLs\">--</div>\n            <div class=\"metric-label\">URLs Tracked</div>\n          </div>\n          <div class=\"db-metric\">\n            <div class=\"metric-value\" id=\"agDQCount\">--</div>\n            <div class=\"metric-label\">DQ Scores</div>\n          </div>\n          <div class=\"db-metric\">\n            <div class=\"metric-value\" id=\"agAvgDQ\">--</div>\n            <div class=\"metric-label\">Avg DQ</div>\n          </div>\n        </div>\n        <div class=\"db-breakdown\" id=\"agBreakdown\"></div>\n      </div>\n\n      <!-- Supermemory Card -->\n      <div class=\"db-card supermemory\">\n        <div class=\"db-card-header\">\n          <div class=\"db-name\">Long-Term Memory</div>\n          <div class=\"db-status\">\n            <div class=\"db-dot\" id=\"supermemoryDot\"></div>\n            <span id=\"supermemoryStatus\">connected</span>\n          </div>\n        </div>\n        <div class=\"db-metrics\">\n          <div class=\"db-metric\">\n            <div class=\"metric-value\" id=\"smItems\">--</div>\n            <div class=\"metric-label\">Memory Items</div>\n          </div>\n          <div class=\"db-metric\">\n            <div class=\"metric-value\" id=\"smLearnings\">--</div>\n            <div class=\"metric-label\">Learnings</div>\n          </div>\n          <div class=\"db-metric\">\n            <div class=\"metric-value\" id=\"smLinks\">--</div>\n            <div class=\"metric-label\">Graph Links</div>\n          </div>\n          <div class=\"db-metric\">\n            <div class=\"metric-value\" id=\"smSessions\">--</div>\n            <div class=\"metric-label\">Sessions</div>\n          </div>\n        </div>\n        <div class=\"db-breakdown\" id=\"smBreakdown\"></div>\n      </div>\n    </div>\n\n    <!-- Charts -->\n    <div class=\"chart-section\">\n      <div class=\"chart-card\">\n        <h3>DQ Score Trend (14 days)</h3>\n        <canvas id=\"dqChart\"></canvas>\n      </div>\n      <div class=\"chart-card\">\n        <h3>Memory Sessions (14 days)</h3>\n        <canvas id=\"sessionChart\"></canvas>\n      </div>\n    </div>\n\n    <!-- Activity Feed -->\n    <div class=\"feed-section\">\n      <h3>Recent Activity Feed</h3>\n      <div class=\"feed-list\" id=\"feedList\">\n        <div class=\"loading\" style=\"padding:20px;\">Loading feed</div>\n      </div>\n    </div>\n  </div>\n</div>\n\n<script>\n(function() {\n  'use strict';\n\n  // ─── Helpers ───\n  function fmt(n) {\n    if (n == null || isNaN(n)) return '--';\n    if (n >= 1e9) return (n / 1e9).toFixed(2) + 'B';\n    if (n >= 1e6) return (n / 1e6).toFixed(2) + 'M';\n    if (n >= 1e3) return (n / 1e3).toFixed(1) + 'K';\n    return String(n);\n  }\n\n  function fmtTime(ts) {\n    if (!ts) return '';\n    try {\n      const d = new Date(ts);\n      const now = new Date();\n      const diff = now - d;\n      if (diff < 60000) return 'just now';\n      if (diff < 3600000) return Math.floor(diff / 60000) + 'm ago';\n      if (diff < 86400000) return Math.floor(diff / 3600000) + 'h ago';\n      return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });\n    } catch(e) { return ts; }\n  }\n\n  function truncate(s, len) {\n    if (!s) return '';\n    return s.length > len ? s.substring(0, len) + '...' : s;\n  }\n\n  // ─── Chart instances ───\n  let dqChartInstance = null;\n  let sessionChartInstance = null;\n\n  const chartDefaults = {\n    responsive: true,\n    maintainAspectRatio: false,\n    plugins: {\n      legend: { display: false },\n    },\n    scales: {\n      x: {\n        grid: { color: 'rgba(255,255,255,0.04)' },\n        ticks: { color: 'rgba(255,255,255,0.3)', font: { size: 10, family: \"'JetBrains Mono', monospace\" } },\n      },\n      y: {\n        grid: { color: 'rgba(255,255,255,0.04)' },\n        ticks: { color: 'rgba(255,255,255,0.3)', font: { size: 10, family: \"'JetBrains Mono', monospace\" } },\n      },\n    },\n  };\n\n  // ─── Render Breakdown Bars ───\n  function renderBreakdown(containerId, title, items, labelKey, countKey, maxItems) {\n    const container = document.getElementById(containerId);\n    if (!container || !items || items.length === 0) return;\n    const max = Math.max(...items.map(i => i[countKey] || 0), 1);\n    const shown = items.slice(0, maxItems || 5);\n    let html = '<h4>' + title + '</h4>';\n    shown.forEach(item => {\n      const pct = Math.round(((item[countKey] || 0) / max) * 100);\n      html += '<div class=\"breakdown-bar\">' +\n        '<span class=\"bar-label\" title=\"' + (item[labelKey] || '') + '\">' + (item[labelKey] || 'unknown') + '</span>' +\n        '<div class=\"bar-track\"><div class=\"bar-fill\" style=\"width:' + pct + '%\"></div></div>' +\n        '<span class=\"bar-count\">' + fmt(item[countKey] || 0) + '</span>' +\n        '</div>';\n    });\n    container.innerHTML = html;\n  }\n\n  // ─── Render Charts ───\n  function renderDQChart(trend) {\n    const ctx = document.getElementById('dqChart');\n    if (!ctx || !trend || trend.length === 0) return;\n    const labels = trend.map(t => t.day ? t.day.substring(5) : '');\n    const data = trend.map(t => t.avg_dq || 0);\n\n    if (dqChartInstance) dqChartInstance.destroy();\n    dqChartInstance = new Chart(ctx, {\n      type: 'line',\n      data: {\n        labels: labels,\n        datasets: [{\n          data: data,\n          borderColor: '#48dbfb',\n          backgroundColor: 'rgba(72,219,251,0.1)',\n          fill: true,\n          tension: 0.4,\n          pointRadius: 3,\n          pointBackgroundColor: '#48dbfb',\n          borderWidth: 2,\n        }],\n      },\n      options: {\n        ...chartDefaults,\n        scales: {\n          ...chartDefaults.scales,\n          y: {\n            ...chartDefaults.scales.y,\n            min: 0.5,\n            max: 1.0,\n          },\n        },\n      },\n    });\n  }\n\n  function renderSessionChart(trend) {\n    const ctx = document.getElementById('sessionChart');\n    if (!ctx || !trend || trend.length === 0) return;\n    const labels = trend.map(t => t.day ? t.day.substring(5) : '');\n    const data = trend.map(t => t.count || 0);\n\n    if (sessionChartInstance) sessionChartInstance.destroy();\n    sessionChartInstance = new Chart(ctx, {\n      type: 'bar',\n      data: {\n        labels: labels,\n        datasets: [{\n          data: data,\n          backgroundColor: 'rgba(0,255,136,0.3)',\n          borderColor: '#00ff88',\n          borderWidth: 1,\n          borderRadius: 4,\n        }],\n      },\n      options: chartDefaults,\n    });\n  }\n\n  // ─── Render Activity Feed ───\n  function renderFeed(findings, learnings) {\n    const list = document.getElementById('feedList');\n    if (!list) return;\n\n    const items = [];\n\n    if (findings && findings.length > 0) {\n      findings.forEach(f => {\n        items.push({\n          type: 'finding',\n          content: f.content || '(no content)',\n          meta: f.type || f.project || '',\n          time: f.created_at,\n        });\n      });\n    }\n\n    if (learnings && learnings.length > 0) {\n      learnings.forEach(l => {\n        items.push({\n          type: 'learning',\n          content: l.content || '(no content)',\n          meta: l.category || l.project || '',\n          time: l.created_at,\n        });\n      });\n    }\n\n    // Sort by time descending\n    items.sort((a, b) => {\n      if (!a.time) return 1;\n      if (!b.time) return -1;\n      return b.time.localeCompare(a.time);\n    });\n\n    if (items.length === 0) {\n      list.innerHTML = '<div style=\"color:var(--text-dim);text-align:center;padding:20px;font-size:0.8rem;\">No recent activity</div>';\n      return;\n    }\n\n    list.innerHTML = items.slice(0, 20).map(item =>\n      '<div class=\"feed-item\">' +\n        '<span class=\"feed-badge ' + item.type + '\">' + item.type + '</span>' +\n        '<div class=\"feed-content\">' + truncate(item.content, 200) + '</div>' +\n        '<div class=\"feed-time\">' + fmtTime(item.time) + '</div>' +\n      '</div>'\n    ).join('');\n  }\n\n  // ─── Update Dashboard from API Data ───\n  function updateDashboard(data) {\n    document.getElementById('loadingState').style.display = 'none';\n    document.getElementById('mainContent').style.display = 'block';\n\n    const t = data.totals || {};\n    document.getElementById('totalSessions').textContent = fmt(t.total_sessions);\n    document.getElementById('totalEvents').textContent = fmt(t.total_events);\n    document.getElementById('totalFindings').textContent = fmt(t.total_findings);\n    document.getElementById('totalPapers').textContent = fmt(t.total_papers);\n    document.getElementById('totalMemory').textContent = fmt(t.total_memory_items);\n    document.getElementById('totalLearnings').textContent = fmt(t.total_learnings);\n    document.getElementById('totalLinks').textContent = fmt(t.total_links);\n    document.getElementById('totalDQ').textContent = fmt(t.total_dq_scores);\n\n    const dbs = data.databases || {};\n\n    // Claude\n    const cl = dbs.claude || {};\n    if (cl.error) {\n      document.getElementById('claudeDot').classList.add('error');\n      document.getElementById('claudeStatus').textContent = 'error';\n    } else {\n      document.getElementById('claudeDot').classList.remove('error');\n      document.getElementById('claudeStatus').textContent = 'connected';\n      document.getElementById('claudeSessions').textContent = fmt(cl.sessions);\n      document.getElementById('claudeActivity').textContent = fmt(cl.activity_events);\n      document.getElementById('claudeTools').textContent = fmt(cl.tool_events);\n      document.getElementById('claudeDQ').textContent = fmt(cl.dq_scores);\n      document.getElementById('claudeHeal').textContent = fmt(cl.self_heal_events);\n      document.getElementById('claudeRouting').textContent = fmt(cl.routing_decisions);\n\n      if (cl.today) {\n        document.getElementById('todayMessages').textContent = fmt(cl.today.messages);\n        document.getElementById('todaySessions').textContent = fmt(cl.today.sessions);\n        document.getElementById('todayTools').textContent = fmt(cl.today.tools);\n      }\n\n      renderDQChart(cl.dq_trend);\n    }\n\n    // Antigravity\n    const ag = dbs.antigravity || {};\n    if (ag.error) {\n      document.getElementById('antigravityDot').classList.add('error');\n      document.getElementById('antigravityStatus').textContent = 'error';\n    } else {\n      document.getElementById('antigravityDot').classList.remove('error');\n      document.getElementById('antigravityStatus').textContent = 'connected';\n      document.getElementById('agFindings').textContent = fmt(ag.findings);\n      document.getElementById('agPapers').textContent = fmt(ag.papers);\n      document.getElementById('agSessions').textContent = fmt(ag.sessions);\n      document.getElementById('agURLs').textContent = fmt(ag.urls);\n      document.getElementById('agDQCount').textContent = fmt(ag.dq_scores);\n      document.getElementById('agAvgDQ').textContent = ag.avg_dq ? ag.avg_dq.toFixed(3) : '--';\n\n      renderBreakdown('agBreakdown', 'Findings by Type', ag.findings_by_type, 'type', 'count', 5);\n    }\n\n    // Supermemory\n    const sm = dbs.supermemory || {};\n    if (sm.error) {\n      document.getElementById('supermemoryDot').classList.add('error');\n      document.getElementById('supermemoryStatus').textContent = 'error';\n    } else {\n      document.getElementById('supermemoryDot').classList.remove('error');\n      document.getElementById('supermemoryStatus').textContent = 'connected';\n      document.getElementById('smItems').textContent = fmt(sm.items);\n      document.getElementById('smLearnings').textContent = fmt(sm.learnings);\n      document.getElementById('smLinks').textContent = fmt(sm.links);\n      document.getElementById('smSessions').textContent = fmt(sm.sessions);\n\n      renderBreakdown('smBreakdown', 'Items by Source', sm.items_by_source, 'source', 'count', 5);\n      renderSessionChart(sm.session_trend);\n    }\n\n    // Activity Feed\n    renderFeed(ag.recent_findings, sm.recent_learnings);\n  }\n\n  // ─── Update from SSE ecosystem pulse (lightweight) ───\n  function updateFromPulse(data) {\n    if (data.claude && !data.claude.error) {\n      document.getElementById('claudeSessions').textContent = fmt(data.claude.sessions);\n      document.getElementById('claudeActivity').textContent = fmt(data.claude.events);\n      document.getElementById('claudeTools').textContent = fmt(data.claude.tools);\n    }\n    if (data.antigravity && !data.antigravity.error) {\n      document.getElementById('agFindings').textContent = fmt(data.antigravity.findings);\n      document.getElementById('agPapers').textContent = fmt(data.antigravity.papers);\n      document.getElementById('agSessions').textContent = fmt(data.antigravity.sessions);\n    }\n    if (data.supermemory && !data.supermemory.error) {\n      document.getElementById('smItems').textContent = fmt(data.supermemory.items);\n      document.getElementById('smLearnings').textContent = fmt(data.supermemory.learnings);\n      document.getElementById('smLinks').textContent = fmt(data.supermemory.links);\n    }\n\n    // Recalculate totals\n    const cs = (data.claude && !data.claude.error) ? data.claude.sessions || 0 : 0;\n    const as_ = (data.antigravity && !data.antigravity.error) ? data.antigravity.sessions || 0 : 0;\n    const ss = (data.supermemory && !data.supermemory.error) ? 0 : 0;  // sessions not in pulse for supermemory\n    // Only update what we can from pulse data\n  }\n\n  // ─── Fetch initial data ───\n  fetch('/api/ecosystem')\n    .then(r => r.json())\n    .then(data => updateDashboard(data))\n    .catch(err => {\n      document.getElementById('loadingState').innerHTML =\n        '<div class=\"error-state\">Failed to load ecosystem data: ' + err.message + '</div>';\n    });\n\n  // ─── SSE Connection ───\n  let retries = 0;\n  const MAX_RETRIES = 50;\n\n  function connectSSE() {\n    const es = new EventSource('/api/stream');\n\n    es.onopen = function() {\n      retries = 0;\n      document.getElementById('sseDot').classList.add('connected');\n      document.getElementById('sseLabel').textContent = 'LIVE';\n    };\n\n    es.addEventListener('ecosystem', function(e) {\n      try {\n        const data = JSON.parse(e.data);\n        updateFromPulse(data);\n      } catch(err) {}\n    });\n\n    es.addEventListener('stats', function(e) {\n      // Update today panel from main stats stream\n      try {\n        const data = JSON.parse(e.data);\n        if (data.today) {\n          document.getElementById('todayMessages').textContent = fmt(data.today.messages);\n          document.getElementById('todaySessions').textContent = fmt(data.today.sessions);\n          document.getElementById('todayTools').textContent = fmt(data.today.tools);\n        }\n      } catch(err) {}\n    });\n\n    es.onerror = function() {\n      document.getElementById('sseDot').classList.remove('connected');\n      document.getElementById('sseLabel').textContent = 'OFFLINE';\n      es.close();\n      if (retries < MAX_RETRIES) {\n        retries++;\n        setTimeout(connectSSE, 3000);\n      }\n    };\n  }\n\n  connectSSE();\n\n  // ─── Periodic full refresh (every 60s) ───\n  setInterval(function() {\n    fetch('/api/ecosystem')\n      .then(r => r.json())\n      .then(data => updateDashboard(data))\n      .catch(() => {});\n  }, 60000);\n\n})();\n</script>\n\n</body>\n</html>\n","structuredPatch":[{"oldStart":838,"oldLines":6,"newStart":838,"newLines":95,"lines":["       </div>","     </div>"," ","+    <!-- Intelligence Panels: SUPERMAX v2 + Graph Signal -->","+    <div class=\"intel-grid\">","+","+      <!-- SUPERMAX v2 Panel -->","+      <div class=\"intel-panel supermax\">","+        <h3>SUPERMAX v2 — Adaptive Consensus</h3>","+        <div class=\"intel-metrics\">","+          <div class=\"intel-metric\">","+            <div class=\"metric-value\" id=\"smaxQueries\" style=\"color:var(--accent-purple)\">--</div>","+            <div class=\"metric-label\">Queries</div>","+          </div>","+          <div class=\"intel-metric\">","+            <div class=\"metric-value\" id=\"smaxEscalations\" style=\"color:var(--accent-yellow)\">--</div>","+            <div class=\"metric-label\">Escalations</div>","+          </div>","+          <div class=\"intel-metric\">","+            <div class=\"metric-value\" id=\"smaxCostSave\" style=\"color:var(--accent-green)\">--</div>","+            <div class=\"metric-label\">Cost Savings</div>","+          </div>","+        </div>","+        <div class=\"intel-sub\">","+          <h4>Agent Count Distribution</h4>","+          <div id=\"smaxAgentDist\"></div>","+        </div>","+        <div class=\"intel-sub\">","+          <h4>Trajectory Stability</h4>","+          <div class=\"intel-metrics\" style=\"grid-template-columns:1fr 1fr; margin-bottom:0;\">","+            <div class=\"intel-metric\">","+              <div class=\"metric-value\" id=\"smaxAvgStab\" style=\"color:var(--accent-blue);font-size:1rem;\">--</div>","+              <div class=\"metric-label\">Avg Stability</div>","+            </div>","+            <div class=\"intel-metric\">","+              <div class=\"metric-value\" id=\"smaxSycophancy\" style=\"color:var(--accent-red);font-size:1rem;\">--</div>","+              <div class=\"metric-label\">Sycophancy Flags</div>","+            </div>","+          </div>","+        </div>","+        <div class=\"intel-sub\">","+          <h4>Disagreement Dimensions</h4>","+          <div id=\"smaxDivergentDims\"></div>","+        </div>","+        <div class=\"intel-sub\" style=\"margin-top:12px;\">","+          <canvas id=\"smaxAgentChart\" style=\"max-height:160px;\"></canvas>","+        </div>","+      </div>","+","+      <!-- Graph Signal Panel -->","+      <div class=\"intel-panel graph-signal\">","+        <h3>Graph Signal — Confidence Intelligence</h3>","+        <div class=\"intel-metrics\">","+          <div class=\"intel-metric\">","+            <div class=\"metric-value\" id=\"gsigAvgConf\" style=\"color:var(--accent-green)\">--</div>","+            <div class=\"metric-label\">Avg Confidence</div>","+          </div>","+          <div class=\"intel-metric\">","+            <div class=\"metric-value\" id=\"gsigModified\" style=\"color:var(--accent-blue)\">--</div>","+            <div class=\"metric-label\">Modified Links</div>","+          </div>","+          <div class=\"intel-metric\">","+            <div class=\"metric-value\" id=\"gsigSparseFlags\" style=\"color:var(--accent-red)\">--</div>","+            <div class=\"metric-label\">Sparse Flags</div>","+          </div>","+        </div>","+        <div class=\"intel-sub\">","+          <h4>Confidence Distribution Heatmap</h4>","+          <div class=\"confidence-heatmap\" id=\"gsigHeatmap\"></div>","+          <div style=\"display:flex;justify-content:space-between;font-size:0.55rem;color:var(--text-muted);margin-top:2px;\">","+            <span>0.0</span><span>0.5</span><span>1.0</span>","+          </div>","+        </div>","+        <div class=\"intel-sub\">","+          <h4>Signal Weights</h4>","+          <div id=\"gsigWeights\"></div>","+        </div>","+        <div class=\"intel-sub\">","+          <h4>Write-Direction Activity</h4>","+          <div class=\"write-activity-row\">","+            <span class=\"label\">Snapshots:</span> <span id=\"gsigSnapshots\">0</span>","+            <span class=\"boost\">+<span id=\"gsigBoosts\">0</span> boosts</span>","+            <span class=\"degrade\">-<span id=\"gsigDegrades\">0</span> degrades</span>","+          </div>","+        </div>","+        <div class=\"intel-sub\" style=\"margin-top:12px;\">","+          <canvas id=\"gsigConfChart\" style=\"max-height:160px;\"></canvas>","+        </div>","+      </div>","+","+    </div>","+","     <!-- Activity Feed -->","     <div class=\"feed-section\">","       <h3>Recent Activity Feed</h3>"]}],"userModified":false,"replaceAll":false}}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01HjydGdFhPxPCAhsrBKN627","type":"message","role":"assistant","content":[{"type":"text","text":"Now add the JavaScript functions to fetch and render the new panels, plus SSE listeners. I'll add them before the closing `})();`:"}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1440,"cache_read_input_tokens":78627,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1440},"output_tokens":5,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"cacc1f91-0b46-45d1-9778-ff7a3c602d11","uuid":"978c5b07-fb68-429c-98c0-0a93baf0ba38"}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01HjydGdFhPxPCAhsrBKN627","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_0173RSaUsw1x8NjrigaJFiH8","name":"Edit","input":{"replace_all":false,"file_path":"/Users/dicoangelo/.claude/dashboard/ecosystem.html","old_string":"  // ─── Fetch initial data ───\n  fetch('/api/ecosystem')\n    .then(r => r.json())\n    .then(data => updateDashboard(data))\n    .catch(err => {\n      document.getElementById('loadingState').innerHTML =\n        '<div class=\"error-state\">Failed to load ecosystem data: ' + err.message + '</div>';\n    });","new_string":"  // ─── SUPERMAX v2 Panel Rendering ───\n  let smaxAgentChartInstance = null;\n\n  function renderSupermaxPanel(data) {\n    document.getElementById('smaxQueries').textContent = fmt(data.totalQueries || 0);\n    document.getElementById('smaxEscalations').textContent = fmt((data.escalations || {}).total || 0);\n\n    const savings = data.costSavings || {};\n    document.getElementById('smaxCostSave').textContent =\n      savings.savings_pct ? savings.savings_pct + '%' : '--';\n\n    // Agent count distribution bars\n    const dist = data.agentCountDistribution || {};\n    const distContainer = document.getElementById('smaxAgentDist');\n    const maxCount = Math.max(...Object.values(dist).map(Number), 1);\n    const agentLabels = ['1', '2', '3', '4', '5'];\n    distContainer.innerHTML = agentLabels.map(function(n) {\n      var count = dist[n] || 0;\n      var pct = Math.round((count / maxCount) * 100);\n      return '<div class=\"intel-bar-row\">' +\n        '<span class=\"bar-label\">' + n + ' agent' + (n !== '1' ? 's' : '') + '</span>' +\n        '<div class=\"bar-track\"><div class=\"bar-fill\" style=\"width:' + pct + '%\"></div></div>' +\n        '<span class=\"bar-count\">' + count + '</span></div>';\n    }).join('');\n\n    // Trajectory stats\n    var ts = data.trajectoryStats || {};\n    document.getElementById('smaxAvgStab').textContent =\n      ts.avgStability != null ? ts.avgStability.toFixed(3) : '--';\n    document.getElementById('smaxSycophancy').textContent = fmt(ts.sycophancyFlags || 0);\n\n    // Divergent dimensions\n    var dims = (data.escalations || {}).divergentDimensions || {};\n    var dimsContainer = document.getElementById('smaxDivergentDims');\n    var dimMax = Math.max(...Object.values(dims).map(Number), 1);\n    dimsContainer.innerHTML = Object.entries(dims).map(function(pair) {\n      var pct = Math.round((pair[1] / dimMax) * 100);\n      return '<div class=\"intel-bar-row\">' +\n        '<span class=\"bar-label\">' + pair[0] + '</span>' +\n        '<div class=\"bar-track\"><div class=\"bar-fill\" style=\"width:' + pct + '%\"></div></div>' +\n        '<span class=\"bar-count\">' + pair[1] + '</span></div>';\n    }).join('') || '<span style=\"color:var(--text-muted);font-size:0.7rem;\">No escalations yet</span>';\n\n    // Agent count distribution chart\n    var chartCtx = document.getElementById('smaxAgentChart');\n    if (chartCtx && Object.keys(dist).length > 0) {\n      if (smaxAgentChartInstance) smaxAgentChartInstance.destroy();\n      smaxAgentChartInstance = new Chart(chartCtx, {\n        type: 'doughnut',\n        data: {\n          labels: agentLabels.map(function(n) { return n + ' agent' + (n !== '1' ? 's' : ''); }),\n          datasets: [{\n            data: agentLabels.map(function(n) { return dist[n] || 0; }),\n            backgroundColor: [\n              'rgba(168,85,247,0.6)', 'rgba(72,219,251,0.6)', 'rgba(0,255,136,0.6)',\n              'rgba(254,202,87,0.6)', 'rgba(233,69,96,0.6)'\n            ],\n            borderWidth: 0,\n          }],\n        },\n        options: {\n          responsive: true,\n          maintainAspectRatio: false,\n          plugins: {\n            legend: {\n              position: 'right',\n              labels: { color: 'rgba(255,255,255,0.5)', font: { size: 10, family: \"'JetBrains Mono', monospace\" } },\n            },\n          },\n        },\n      });\n    }\n  }\n\n  // ─── Graph Signal Panel Rendering ───\n  let gsigConfChartInstance = null;\n\n  function renderGraphSignalPanel(data) {\n    document.getElementById('gsigAvgConf').textContent =\n      data.avgConfidence != null ? data.avgConfidence.toFixed(4) : '--';\n    document.getElementById('gsigModified').textContent = fmt(data.modifiedLinks || 0);\n    document.getElementById('gsigSparseFlags').textContent =\n      fmt((data.sparseSubgraphFlags || {}).total || 0);\n\n    // Confidence heatmap\n    var buckets = data.confidenceDistribution || [];\n    var hmContainer = document.getElementById('gsigHeatmap');\n    if (buckets.length > 0) {\n      var maxBucket = Math.max(...buckets.map(function(b) { return b.count; }), 1);\n      var colors = [\n        '#e94560', '#e94560', '#feca57', '#feca57', '#feca57',\n        '#48dbfb', '#48dbfb', '#00ff88', '#00ff88', '#00ff88'\n      ];\n      hmContainer.innerHTML = buckets.map(function(b, i) {\n        var intensity = Math.max(0.15, b.count / maxBucket);\n        return '<div class=\"hm-bar\" title=\"' + b.bucket + ': ' + b.count + ' links\" ' +\n          'style=\"background:' + colors[i] + ';opacity:' + intensity + '\"></div>';\n      }).join('');\n    } else {\n      hmContainer.innerHTML = '<div style=\"color:var(--text-muted);font-size:0.65rem;padding:4px;\">No confidence data</div>';\n    }\n\n    // Signal weights\n    var weights = data.weights || {};\n    var wContainer = document.getElementById('gsigWeights');\n    var wEntries = Object.entries(weights);\n    if (wEntries.length > 0) {\n      wContainer.innerHTML = wEntries.map(function(pair) {\n        var pct = Math.round(pair[1] * 100);\n        return '<div class=\"intel-bar-row\">' +\n          '<span class=\"bar-label\">' + pair[0] + '</span>' +\n          '<div class=\"bar-track\"><div class=\"bar-fill\" style=\"width:' + pct + '%\"></div></div>' +\n          '<span class=\"bar-count\">' + pct + '%</span></div>';\n      }).join('');\n    }\n\n    // Write activity\n    var wa = data.writeActivity || {};\n    document.getElementById('gsigSnapshots').textContent = wa.totalSnapshots || 0;\n    document.getElementById('gsigBoosts').textContent = wa.totalBoosts || 0;\n    document.getElementById('gsigDegrades').textContent = wa.totalDegradations || 0;\n\n    // Confidence distribution bar chart\n    var chartCtx = document.getElementById('gsigConfChart');\n    if (chartCtx && buckets.length > 0) {\n      if (gsigConfChartInstance) gsigConfChartInstance.destroy();\n      gsigConfChartInstance = new Chart(chartCtx, {\n        type: 'bar',\n        data: {\n          labels: buckets.map(function(b) { return b.bucket; }),\n          datasets: [{\n            data: buckets.map(function(b) { return b.count; }),\n            backgroundColor: 'rgba(0,255,136,0.3)',\n            borderColor: '#00ff88',\n            borderWidth: 1,\n            borderRadius: 3,\n          }],\n        },\n        options: {\n          ...chartDefaults,\n          plugins: { legend: { display: false } },\n          scales: {\n            x: {\n              grid: { color: 'rgba(255,255,255,0.04)' },\n              ticks: { color: 'rgba(255,255,255,0.3)', font: { size: 8, family: \"'JetBrains Mono', monospace\" }, maxRotation: 45 },\n            },\n            y: {\n              grid: { color: 'rgba(255,255,255,0.04)' },\n              ticks: { color: 'rgba(255,255,255,0.3)', font: { size: 9, family: \"'JetBrains Mono', monospace\" } },\n            },\n          },\n        },\n      });\n    }\n  }\n\n  // ─── Fetch initial data ───\n  fetch('/api/ecosystem')\n    .then(r => r.json())\n    .then(data => updateDashboard(data))\n    .catch(err => {\n      document.getElementById('loadingState').innerHTML =\n        '<div class=\"error-state\">Failed to load ecosystem data: ' + err.message + '</div>';\n    });\n\n  // Fetch SUPERMAX v2 and Graph Signal data\n  fetch('/api/supermax')\n    .then(r => r.json())\n    .then(data => renderSupermaxPanel(data))\n    .catch(() => {});\n\n  fetch('/api/graph-signal')\n    .then(r => r.json())\n    .then(data => renderGraphSignalPanel(data))\n    .catch(() => {});"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1440,"cache_read_input_tokens":78627,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1440},"output_tokens":5,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"cacc1f91-0b46-45d1-9778-ff7a3c602d11","uuid":"3e835444-0adb-405e-8590-3424a608421c"}
