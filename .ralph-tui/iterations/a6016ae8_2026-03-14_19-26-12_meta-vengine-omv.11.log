COUNT(*) as sessions,\n   974→                       (SELECT COUNT(*) FROM activity_events) as activity_events,\n   975→                       (SELECT COUNT(*) FROM tool_events) as tool_events,\n   976→                       (SELECT COUNT(*) FROM routing_decisions) as routing_decisions,\n   977→                       (SELECT COUNT(*) FROM self_heal_events) as self_heal_events,\n   978→                       (SELECT COUNT(*) FROM dq_score_events) as dq_scores,\n   979→                       (SELECT COUNT(*) FROM cost_events) as cost_events,\n   980→                       (SELECT COUNT(*) FROM error_catalog) as errors,\n   981→                       (SELECT COUNT(*) FROM git_events) as git_events\n   982→                FROM sessions\n   983→            \"\"\").fetchone()\n   984→\n   985→            # DQ score trend\n   986→            dq_trend = [dict(r) for r in conn.execute(\"\"\"\n   987→                SELECT date(timestamp, 'unixepoch', 'localtime') as day,\n   988→                       ROUND(AVG(dq_score), 3) as avg_dq,\n   989→                       COUNT(*) as count\n   990→                FROM dq_score_events\n   991→                GROUP BY day ORDER BY day DESC LIMIT 14\n   992→            \"\"\").fetchall()]\n   993→\n   994→            # Today's activity\n   995→            today = datetime.now().strftime(\"%Y-%m-%d\")\n   996→            today_row = conn.execute(\"\"\"\n   997→                SELECT opus_messages + sonnet_messages + haiku_messages as messages,\n   998→                       session_count as sessions, tool_calls as tools\n   999→                FROM daily_stats WHERE date = ?\n  1000→            \"\"\", (today,)).fetchone()\n  1001→\n  1002→            result[\"databases\"][\"claude\"] = {\n  1003→                \"name\": \"Claude Code Telemetry\",\n  1004→                \"path\": str(DB_PATH),\n  1005→                \"sessions\": row[\"sessions\"],\n  1006→                \"activity_events\": row[\"activity_events\"],\n  1007→     