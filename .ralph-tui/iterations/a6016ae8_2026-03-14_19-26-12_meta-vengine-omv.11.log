 var(--accent-blue);\n   448→    font-weight: 600;\n   449→    text-transform: uppercase;\n   450→    font-size: 0.65rem;\n   451→    letter-spacing: 1px;\n   452→  }\n   453→\n   454→  .today-panel .today-stat {\n   455→    color: var(--text);\n   456→  }\n   457→\n   458→  .today-panel .today-stat span {\n   459→    color: var(--text-dim);\n   460→    margin-left: 4px;\n   461→  }\n   462→\n   463→  /* ─── Scrollbar ─── */\n   464→  ::-webkit-scrollbar { width: 6px; }\n   465→  ::-webkit-scrollbar-track { background: transparent; }\n   466→  ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 3px; }\n   467→  ::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,0.2); }\n   468→\n   469→  /* ─── Loading State ─── */\n   470→  .loading {\n   471→    text-align: center;\n   472→    padding: 60px;\n   473→    color: var(--text-dim);\n   474→    font-family: var(--font-mono);\n   475→    font-size: 0.85rem;\n   476→  }\n   477→\n   478→  .loading::after {\n   479→    content: '';\n   480→    display: inline-block;\n   481→    width: 16px; height: 16px;\n   482→    border: 2px solid var(--text-muted);\n   483→    border-top-color: var(--accent-blue);\n   484→    border-radius: 50%;\n   485→    animation: spin 0.8s linear infinite;\n   486→    margin-left: 10px;\n   487→    vertical-align: middle;\n   488→  }\n   489→\n   490→  @keyframes spin { to { transform: rotate(360deg); } }\n   491→\n   492→  .error-state {\n   493→    color: var(--accent-red);\n   494→    font-family: var(--font-mono);\n   495→    font-size: 0.75rem;\n   496→    padding: 8px;\n   497→    text-align: center;\n   498→  }\n   499→</style>\n   500→</head>\n   501→<body>\n   502→\n   503→<div class=\"container\">\n   504→  <!-- Header -->\n   505→  <div class=\"header\">\n   506→    <div class=\"header-left\">\n   507→      <h1>Antigravity Ecosystem</h1>\n   508→      <div class=\"subtitle\">Unified Intelligence across 3 databases</div>\n   509→    </div>\n   510→    <div class=\"header-right\">\n   511→      <div class=\"status-indicator\">\n   512→        <div class=\"status-dot\" id=\"sseDot\"></div>\n   513→        <span id=\"sseLabel\">CONNECTING</span>\n   514→      </div>\n   515→      <a href=\"/dashboard\" class=\"nav-link\">CCC Dashboard</a>\n   516→    </div>\n   517→  </div>\n   518→\n   519→  <!-- Loading state -->\n   520→  <div class=\"loading\" id=\"loadingState\">Loading ecosystem data</div>\n   521→\n   522→  <!-- Main content (hidden until data loads) -->\n   523→  <div id=\"mainContent\" style=\"display:none;\">\n   524→\n   525→    <!-- Today Panel -->\n   526→    <div class=\"today-panel\" id=\"todayPanel\">\n   527→      <div class=\"today-label\">Today</div>\n   528→      <div class=\"today-stat\"><strong id=\"todayMessages\">0</strong><span>messages</span></div>\n   529→      <div class=\"today-stat\"><strong id=\"todaySessions\">0</strong><span>sessions</span></div>\n   530→      <div class=\"today-stat\"><strong id=\"todayTools\">0</strong><span>tools</span></div>\n   531→    </div>\n   532→\n   533→    <!-- Hero Totals Bar -->\n   534→    <div class=\"hero-bar\">\n   535→      <div class=\"hero-stat sessions\">\n   536→        <div class=\"value\" id=\"totalSessions\">--</div>\n   537→        <div class=\"label\">Total Sessions</div>\n   538→      </div>\n   539→      <div class=\"hero-stat events\">\n   540→        <div class=\"value\" id=\"totalEvents\">--</div>\n   541→        <div class=\"label\">Total Events</div>\n   542→      </div>\n   543→      <div class=\"hero-stat findings\">\n   544→        <div class=\"value\" id=\"totalFindings\">--</div>\n   545→        <div class=\"label\">Findings</div>\n   546→      </div>\n   547→      <div class=\"hero-stat papers\">\n   548→        <div class=\"value\" id=\"totalPapers\">--</div>\n   549→        <div class=\"label\">Papers</div>\n   550→      </div>\n   551→      <div class=\"hero-stat memory\">\n   552→        <div class=\"value\" id=\"totalMemory\">--</div>\n   553→        <div class=\"label\">Memory Items</div>\n   554→      </div>\n   555→      <div class=\"hero-stat learnings\">\n   556→        <div class=\"value\" id=\"totalLearnings\">--</div>\n   557→        <div class=\"label\">Learnings</div>\n   558→      </div>\n   559→      <div class=\"hero-stat links\">\n   560→        <div class=\"value\" id=\"totalLinks\">--</div>\n   561→        <div class=\"label\">Graph Links</div>\n   562→      </div>\n   563→      <div class=\"hero-stat dq\">\n   564→        <div class=\"value\" id=\"totalDQ\">--</div>\n   565→        <div class=\"label\">DQ Scores</div>\n   566→      </div>\n   567→    </div>\n   568→\n   569→    <!-- 3 Database Cards -->\n   570→    <div class=\"db-grid\">\n   571→\n   572→      <!-- Claude Code Card -->\n   573→      <div class=\"db-card claude\">\n   574→        <div class=\"db-card-header\">\n   575→          <div class=\"db-name\">Claude Code Telemetry</div>\n   576→          <div class=\"db-status\">\n   577→            <div class=\"db-dot\" id=\"claudeDot\"></div>\n   578→            <span id=\"claudeStatus\">connected</span>\n   579→          </div>\n   580→        </div>\n   581→        <div class=\"db-metrics\">\n   582→          <div class=\"db-metric\">\n   583→            <div class=\"metric-value\" id=\"claudeSessions\">--</div>\n   584→            <div class=\"metric-label\">Sessions</div>\n   585→          </div>\n   586→          <div class=\"db-metric\">\n   587→            <div class=\"metric-value\" id=\"claudeActivity\">--</div>\n   588→            <div class=\"metric-label\">Activity Events</div>\n   589→          </div>\n   590→          <div class=\"db-metric\">\n   591→            <div class=\"metric-value\" id=\"claudeTools\">--</div>\n   592→            <div class=\"metric-label\">Tool Events</div>\n   593→          </div>\n   594→          <div class=\"db-metric\">\n   595→            <div class=\"metric-value\" id=\"claudeDQ\">--</div>\n   596→            <div class=\"metric-label\">DQ Scores</div>\n   597→          </div>\n   598→          <div class=\"db-metric\">\n   599→            <div class=\"metric-value\" id=\"claudeHeal\">--</div>\n   600→            <div class=\"metric-label\">Self-Heal</div>\n   601→          </div>\n   602→          <div class=\"db-metric\">\n   603→            <div class=\"metric-value\" id=\"claudeRouting\">--</div>\n   604→            <div class=\"metric-label\">Routing</div>\n   605→          </div>\n   606→        </div>\n   607→        <div class=\"db-breakdown\" id=\"claudeBreakdown\"></div>\n   608→      </div>\n   609→\n   610→      <!-- Antigravity Card -->\n   611→      <div class=\"db-card antigravity\">\n   612→        <div class=\"db-card-header\">\n   613→          <div class=\"db-name\">Research & UCW Intelligence</div>\n   614→          <div class=\"db-status\">\n   615→            <div class=\"db-dot\" id=\"antigravityDot\"></div>\n   616→            <span id=\"antigravityStatus\">connected</span>\n   617→          </div>\n   618→        </div>\n   619→        <div class=\"db-metrics\">\n   620→          <div class=\"db-metric\">\n   621→            <div class=\"metric-value\" id=\"agFindings\">--</div>\n   622→            <div class=\"metric-label\">Findings</div>\n   623→          </div>\n   624→          <div class=\"db-metric\">\n   625→            <div class=\"metric-value\" id=\"agPapers\">--</div>\n   626→            <div class=\"metric-label\">Papers</div>\n   627→          </div>\n   628→          <div class=\"db-metric\">\n   629→            <div class=\"metric-value\" id=\"agSessions\">--</div>\n   630→            <div class=\"metric-label\">UCW Sessions</div>\n   631→          </div>\n   632→          <div class=\"db-metric\">\n   633→            <div class=\"metric-value\" id=\"agURLs\">--</div>\n   634→            <div class=\"metric-label\">URLs Tracked</div>\n   635→          </div>\n   636→          <div class=\"db-metric\">\n   637→            <div class=\"metric-value\" id=\"agDQCount\">--</div>\n   638→            <div class=\"metric-label\">DQ Scores</div>\n   639→          </div>\n   640→          <div class=\"db-metric\">\n   641→            <div class=\"metric-value\" id=\"agAvgDQ\">--</div>\n   642→            <div class=\"metric-label\">Avg DQ</div>\n   643→          </div>\n   644→        </div>\n   645→        <div class=\"db-breakdown\" id=\"agBreakdown\"></div>\n   646→      </div>\n   647→\n   648→      <!-- Supermemory Card -->\n   649→      <div class=\"db-card supermemory\">\n   650→        <div class=\"db-card-header\">\n   651→          <div class=\"db-name\">Long-Term Memory</div>\n   652→          <div class=\"db-status\">\n   653→            <div class=\"db-dot\" id=\"supermemoryDot\"></div>\n   654→            <span id=\"supermemoryStatus\">connected</span>\n   655→          </div>\n   656→        </div>\n   657→        <div class=\"db-metrics\">\n   658→          <div class=\"db-metric\">\n   659→            <div class=\"metric-value\" id=\"smItems\">--</div>\n   660→            <div class=\"metric-label\">Memory Items</div>\n   661→          </div>\n   662→          <div class=\"db-metric\">\n   663→            <div class=\"metric-value\" id=\"smLearnings\">--</div>\n   664→            <div class=\"metric-label\">Learnings</div>\n   665→          </div>\n   666→          <div class=\"db-metric\">\n   667→            <div class=\"metric-value\" id=\"smLinks\">--</div>\n   668→            <div class=\"metric-label\">Graph Links</div>\n   669→          </div>\n   670→          <div class=\"db-metric\">\n   671→            <div class=\"metric-value\" id=\"smSessions\">--</div>\n   672→            <div class=\"metric-label\">Sessions</div>\n   673→          </div>\n   674→        </div>\n   675→        <div class=\"db-breakdown\" id=\"smBreakdown\"></div>\n   676→      </div>\n   677→    </div>\n   678→\n   679→    <!-- Charts -->\n   680→    <div class=\"chart-section\">\n   681→      <div class=\"chart-card\">\n   682→        <h3>DQ Score Trend (14 days)</h3>\n   683→        <canvas id=\"dqChart\"></canvas>\n   684→      </div>\n   685→      <div class=\"chart-card\">\n   686→        <h3>Memory Sessions (14 days)</h3>\n   687→        <canvas id=\"sessionChart\"></canvas>\n   688→      </div>\n   689→    </div>\n   690→\n   691→    <!-- Activity Feed -->\n   692→    <div class=\"feed-section\">\n   693→      <h3>Recent Activity Feed</h3>\n   694→      <div class=\"feed-list\" id=\"feedList\">\n   695→        <div class=\"loading\" style=\"padding:20px;\">Loading feed</div>\n   696→      </div>\n   697→    </div>\n   698→  </div>\n   699→</div>\n   700→\n   701→<script>\n   702→(function() {\n   703→  'use strict';\n   704→\n   705→  // ─── Helpers ───\n   706→  function fmt(n) {\n   707→    if (n == null || isNaN(n)) return '--';\n   708→    if (n >= 1e9) return (n / 1e9).toFixed(2) + 'B';\n   709→    if (n >= 1e6) return (n / 1e6).toFixed(2) + 'M';\n   710→    if (n >= 1e3) return (n / 1e3).toFixed(1) + 'K';\n   711→    return String(n);\n   712→  }\n   713→\n   714→  function fmtTime(ts) {\n   715→    if (!ts) return '';\n   716→    try {\n   717→      const d = new Date(ts);\n   718→      const now = new Date();\n   719→      const diff = now - d;\n   720→      if (diff < 60000) return 'just now';\n   721→      if (diff < 3600000) return Math.floor(diff / 60000) + 'm ago';\n   722→      if (diff < 86400000) return Math.floor(diff / 3600000) + 'h ago';\n   723→      return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });\n   724→    } catch(e) { return ts; }\n   725→  }\n   726→\n   727→  function truncate(s, len) {\n   728→    if (!s) return '';\n   729→    return s.length > len ? s.substring(0, len) + '...' : s;\n   730→  }\n   731→\n   732→  // ─── Chart instances ───\n   733→  let dqChartInstance = null;\n   734→  let sessionChartInstance = null;\n   735→\n   736→  const chartDefaults = {\n   737→    responsive: true,\n   738→    maintainAspectRatio: false,\n   739→    plugins: {\n   740→      legend: { display: false },\n   741→    },\n   742→    scales: {\n   743→      x: {\n   744→        grid: { color: 'rgba(255,255,255,0.04)' },\n   745→        ticks: { color: 'rgba(255,255,255,0.3)', font: { size: 10, family: \"'JetBrains Mono', monospace\" } },\n   746→      },\n   747→      y: {\n   748→        grid: { color: 'rgba(255,255,255,0.04)' },\n   749→        ticks: { color: 'rgba(255,255,255,0.3)', font: { size: 10, family: \"'JetBrains Mono', monospace\" } },\n   750→      },\n   751→    },\n   752→  };\n   753→\n   754→  // ─── Render Breakdown Bars ───\n   755→  function renderBreakdown(containerId, title, items, labelKey, countKey, maxItems) {\n   756→    const container = document.getElementById(containerId);\n   757→    if (!container || !items || items.length === 0) return;\n   758→    const max = Math.max(...items.map(i => i[countKey] || 0), 1);\n   759→    const shown = items.slice(0, maxItems || 5);\n   760→    let html = '<h4>' + title + '</h4>';\n   761→    shown.forEach(item => {\n   762→      const pct = Math.round(((item[countKey] || 0) / max) * 100);\n   763→      html += '<div class=\"breakdown-bar\">' +\n   764→        '<span class=\"bar-label\" title=\"' + (item[labelKey] || '') + '\">' + (item[labelKey] || 'unknown') + '</span>' +\n   765→        '<div class=\"bar-track\"><div class=\"bar-fill\" style=\"width:' + pct + '%\"></div></div>' +\n   766→        '<span class=\"bar-count\">' + fmt(item[countKey] || 0) + '</span>' +\n   767→        '</div>';\n   768→    });\n   769→    container.innerHTML = html;\n   770→  }\n   771→\n   772→  // ─── Render Charts ───\n   773→  function renderDQChart(trend) {\n   774→    const ctx = document.getElementById('dqChart');\n   775→    if (!ctx || !trend || trend.length === 0) return;\n   776→    const labels = trend.map(t => t.day ? t.day.substring(5) : '');\n   777→    const data = trend.map(t => t.avg_dq || 0);\n   778→\n   779→    if (dqChartInstance) dqChartInstance.destroy();\n   780→    dqChartInstance = new Chart(ctx, {\n   781→      type: 'line',\n   782→      data: {\n   783→        labels: labels,\n   784→        datasets: [{\n   785→          data: data,\n   786→          borderColor: '#48dbfb',\n   787→          backgroundColor: 'rgba(72,219,251,0.1)',\n   788→          fill: true,\n   789→          tension: 0.4,\n   790→          pointRadius: 3,\n   791→          pointBackgroundColor: '#48dbfb',\n   792→          borderWidth: 2,\n   793→        }],\n   794→      },\n   795→      options: {\n   796→        ...chartDefaults,\n   797→        scales: {\n   798→          ...chartDefaults.scales,\n   799→          y: {\n   800→            ...chartDefaults.scales.y,\n   801→            min: 0.5,\n   802→            max: 1.0,\n   803→          },\n   804→        },\n   805→      },\n   806→    });\n   807→  }\n   808→\n   809→  function renderSessionChart(trend) {\n   810→    const ctx = document.getElementById('sessionChart');\n   811→    if (!ctx || !trend || trend.length === 0) return;\n   812→    const labels = trend.map(t => t.day ? t.day.substring(5) : '');\n   813→    const data = trend.map(t => t.count || 0);\n   814→\n   815→    if (sessionChartInstance) sessionChartInstance.destroy();\n   816→    sessionChartInstance = new Chart(ctx, {\n   817→      type: 'bar',\n   818→      data: {\n   819→        labels: labels,\n   820→        datasets: [{\n   821→          data: data,\n   822→          backgroundColor: 'rgba(0,255,136,0.3)',\n   823→          borderColor: '#00ff88',\n   824→          borderWidth: 1,\n   825→          borderRadius: 4,\n   826→        }],\n   827→      },\n   828→      options: chartDefaults,\n   829→    });\n   830→  }\n   831→\n   832→  // ─── Render Activity Feed ───\n   833→  function renderFeed(findings, learnings) {\n   834→    const list = document.getElementById('feedList');\n   835→    if (!list) return;\n   836→\n   837→    const items = [];\n   838→\n   839→    if (findings && findings.length > 0) {\n   840→      findings.forEach(f => {\n   841→        items.push({\n   842→          type: 'finding',\n   843→          content: f.content || '(no content)',\n   844→          meta: f.type || f.project || '',\n   845→          time: f.created_at,\n   846→        });\n   847→      });\n   848→    }\n   849→\n   850→    if (learnings && learnings.length > 0) {\n   851→      learnings.forEach(l => {\n   852→        items.push({\n   853→          type: 'learning',\n   854→          content: l.content || '(no content)',\n   855→          meta: l.category || l.project || '',\n   856→          time: l.created_at,\n   857→        });\n   858→      });\n   859→    }\n   860→\n   861→    // Sort by time descending\n   862→    items.sort((a, b) => {\n   863→      if (!a.time) return 1;\n   864→      if (!b.time) return -1;\n   865→      return b.time.localeCompare(a.time);\n   866→    });\n   867→\n   868→    if (items.length === 0) {\n   869→      list.innerHTML = '<div style=\"color:var(--text-dim);text-align:center;padding:20px;font-size:0.8rem;\">No recent activity</div>';\n   870→      return;\n   871→    }\n   872→\n   873→    list.innerHTML = items.slice(0, 20).map(item =>\n   874→      '<div class=\"feed-item\">' +\n   875→        '<span class=\"feed-badge ' + item.type + '\">' + item.type + '</span>' +\n   876→        '<div class=\"feed-content\">' + truncate(item.content, 200) + '</div>' +\n   877→        '<div class=\"feed-time\">' + fmtTime(item.time) + '</div>' +\n   878→      '</div>'\n   879→    ).join('');\n   880→  }\n   881→\n   882→  // ─── Update Dashboard from API Data ───\n   883→  function updateDashboard(data) {\n   884→    document.getElementById('loadingState').style.display = 'none';\n   885→    document.getElementById('mainContent').style.display = 'block';\n   886→\n   887→    const t = data.totals || {};\n   888→    document.getElementById('totalSessions').textContent = fmt(t.total_sessions);\n   889→    document.getElementById('totalEvents').textContent = fmt(t.total_events);\n   890→    document.getElementById('totalFindings').textContent = fmt(t.total_findings);\n   891→    document.getElementById('totalPapers').textContent = fmt(t.total_papers);\n   892→    document.getElementById('totalMemory').textContent = fmt(t.total_memory_items);\n   893→    document.getElementById('totalLearnings').textContent = fmt(t.total_learnings);\n   894→    document.getElementById('totalLinks').textContent = fmt(t.total_links);\n   895→    document.getElementById('totalDQ').textContent = fmt(t.total_dq_scores);\n   896→\n   897→    const dbs = data.databases || {};\n   898→\n   899→    // Claude\n   900→    const cl = dbs.claude || {};\n   901→    if (cl.error) {\n   902→      document.getElementById('claudeDot').classList.add('error');\n   903→      document.getElementById('claudeStatus').textContent = 'error';\n   904→    } else {\n   905→      document.getElementById('claudeDot').classList.remove('error');\n   906→      document.getElementById('claudeStatus').textContent = 'connected';\n   907→      document.getElementById('claudeSessions').textContent = fmt(cl.sessions);\n   908→      document.getElementById('claudeActivity').textContent = fmt(cl.activity_events);\n   909→      document.getElementById('claudeTools').textContent = fmt(cl.tool_events);\n   910→      document.getElementById('claudeDQ').textContent = fmt(cl.dq_scores);\n   911→      document.getElementById('claudeHeal').textContent = fmt(cl.self_heal_events);\n   912→      document.getElementById('claudeRouting').textContent = fmt(cl.routing_decisions);\n   913→\n   914→      if (cl.today) {\n   915→        document.getElementById('todayMessages').textContent = fmt(cl.today.messages);\n   916→        document.getElementById('todaySessions').textContent = fmt(cl.today.sessions);\n   917→        document.getElementById('todayTools').textContent = fmt(cl.today.tools);\n   918→      }\n   919→\n   920→      renderDQChart(cl.dq_trend);\n   921→    }\n   922→\n   923→    // Antigravity\n   924→    const ag = dbs.antigravity || {};\n   925→    if (ag.error) {\n   926→      document.getElementById('antigravityDot').classList.add('error');\n   927→      document.getElementById('antigravityStatus').textContent = 'error';\n   928→    } else {\n   929→      document.getElementById('antigravityDot').classList.remove('error');\n   930→      document.getElementById('antigravityStatus').textContent = 'connected';\n   931→      document.getElementById('agFindings').textContent = fmt(ag.findings);\n   932→      document.getElementById('agPapers').textContent = fmt(ag.papers);\n   933→      document.getElementById('agSessions').textContent = fmt(ag.sessions);\n   934→      document.getElementById('agURLs').textContent = fmt(ag.urls);\n   935→      document.getElementById('agDQCount').textContent = fmt(ag.dq_scores);\n   936→      document.getElementById('agAvgDQ').textContent = ag.avg_dq ? ag.avg_dq.toFixed(3) : '--';\n   937→\n   938→      renderBreakdown('agBreakdown', 'Findings by Type', ag.findings_by_type, 'type', 'count', 5);\n   939→    }\n   940→\n   941→    // Supermemory\n   942→    const sm = dbs.supermemory || {};\n   943→    if (sm.error) {\n   944→      document.getElementById('supermemoryDot').classList.add('error');\n   945→      document.getElementById('supermemoryStatus').textContent = 'error';\n   946→    } else {\n   947→      document.getElementById('supermemoryDot').classList.remove('error');\n   948→      document.getElementById('supermemoryStatus').textContent = 'connected';\n   949→      document.getElementById('smItems').textContent = fmt(sm.items);\n   950→      document.getElementById('smLearnings').textContent = fmt(sm.learnings);\n   951→      document.getElementById('smLinks').textContent = fmt(sm.links);\n   952→      document.getElementById('smSessions').textContent = fmt(sm.sessions);\n   953→\n   954→      renderBreakdown('smBreakdown', 'Items by Source', sm.items_by_source, 'source', 'count', 5);\n   955→      renderSessionChart(sm.session_trend);\n   956→    }\n   957→\n   958→    // Activity Feed\n   959→    renderFeed(ag.recent_findings, sm.recent_learnings);\n   960→  }\n   961→\n   962→  // ─── Update from SSE ecosystem pulse (lightweight) ───\n   963→  function updateFromPulse(data) {\n   964→    if (data.claude && !data.claude.error) {\n   965→      document.getElementById('claudeSessions').textContent = fmt(data.claude.sessions);\n   966→      document.getElementById('claudeActivity').textContent = fmt(data.claude.events);\n   967→      document.getElementById('claudeTools').textContent = fmt(data.claude.tools);\n   968→    }\n   969→    if (data.antigravity && !data.antigravity.error) {\n   970→      document.getElementById('agFindings').textContent = fmt(data.antigravity.findings);\n   971→      document.getElementById('agPapers').textContent = fmt(data.antigravity.papers);\n   972→      document.getElementById('agSessions').textContent = fmt(data.antigravity.sessions);\n   973→    }\n   974→    if (data.supermemory && !data.supermemory.error) {\n   975→      document.getElementById('smItems').textContent = fmt(data.supermemory.items);\n   976→      document.getElementById('smLearnings').textContent = fmt(data.supermemory.learnings);\n   977→      document.getElementById('smLinks').textContent = fmt(data.supermemory.links);\n   978→    }\n   979→\n   980→    // Recalculate totals\n   981→    const cs = (data.claude && !data.claude.error) ? data.claude.sessions || 0 : 0;\n   982→    const as_ = (data.antigravity && !data.antigravity.error) ? data.antigravity.sessions || 0 : 0;\n   983→    const ss = (data.supermemory && !data.supermemory.error) ? 0 : 0;  // sessions not in pulse for supermemory\n   984→    // Only update what we can from pulse data\n   985→  }\n   986→\n   987→  // ─── Fetch initial data ───\n   988→  fetch('/api/ecosystem')\n   989→    .then(r => r.json())\n   990→    .then(data => updateDashboard(data))\n   991→    .catch(err => {\n   992→      document.getElementById('loadingState').innerHTML =\n   993→        '<div class=\"error-state\">Failed to load ecosystem data: ' + err.message + '</div>';\n   994→    });\n   995→\n   996→  // ─── SSE Connection ───\n   997→  let retries = 0;\n   998→  const MAX_RETRIES = 50;\n   999→\n  1000→  function connectSSE() {\n  1001→    const es = new EventSource('/api/stream');\n  1002→\n  1003→    es.onopen = function() {\n  1004→      retries = 0;\n  1005→      document.getElementById('sseDot').classList.add('connected');\n  1006→      document.getElementById('sseLabel').textContent = 'LIVE';\n  1007→    };\n  1008→\n  1009→    es.addEventListener('ecosystem', function(e) {\n  1010→      try {\n  1011→        const data = JSON.parse(e.data);\n  1012→        updateFromPulse(data);\n  1013→      } catch(err) {}\n  1014→    });\n  1015→\n  1016→    es.addEventListener('stats', function(e) {\n  1017→      // Update today panel from main stats stream\n  1018→      try {\n  1019→        const data = JSON.parse(e.data);\n  1020→        if (data.today) {\n  1021→          document.getElementById('todayMessages').textContent = fmt(data.today.messages);\n  1022→          document.getElementById('todaySessions').textContent = fmt(data.today.sessions);\n  1023→          document.getElementById('todayTools').textContent = fmt(data.today.tools);\n  1024→        }\n  1025→      } catch(err) {}\n  1026→    });\n  1027→\n  1028→    es.onerror = function() {\n  1029→      document.getElementById('sseDot').classList.remove('connected');\n  1030→      document.getElementById('sseLabel').textContent = 'OFFLINE';\n  1031→      es.close();\n  1032→      if (retries < MAX_RETRIES) {\n  1033→        retries++;\n  1034→        setTimeout(connectSSE, 3000);\n  1035→      }\n  1036→    };\n  1037→  }\n  1038→\n  1039→  connectSSE();\n  1040→\n  1041→  // ─── Periodic full refresh (every 60s) ───\n  1042→  setInterval(function() {\n  1043→    fetch('/api/ecosystem')\n  1044→      .then(r => r.json())\n  1045→      .then(data => updateDashboard(data))\n  1046→      .catch(() => {});\n  1047→  }, 60000);\n  1048→\n  1049→})();\n  1050→</script>\n  1051→\n  1052→</body>\n  1053→</html>\n  1054→"}]},"parent_tool_use_id":null,"session_id":"cacc1f91-0b46-45d1-9778-ff7a3c602d11","uuid":"b93b406e-373b-4021-b6b3-c758c25f3df9","tool_use_result":{"type":"text","file":{"filePath":"/Users/dicoangelo/.claude/dashboard/ecosystem.html","content":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Antigravity Ecosystem — Unified Intelligence</title>\n<script src=\"https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js\"></script>\n<style>\n  :root {\n    --bg-dark: #0a0e17;\n    --bg-card: rgba(255,255,255,0.04);\n    --bg-card-hover: rgba(255,255,255,0.07);\n    --border: rgba(255,255,255,0.08);\n    --text: #e4e8f1;\n    --text-dim: rgba(255,255,255,0.45);\n    --text-muted: rgba(255,255,255,0.3);\n    --accent-red: #e94560;\n    --accent-blue: #48dbfb;\n    --accent-yellow: #feca57;\n    --accent-green: #00ff88;\n    --accent-purple: #a855f7;\n    --font-mono: 'JetBrains Mono', 'SF Mono', 'Fira Code', monospace;\n    --font-sans: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;\n  }\n\n  * { margin: 0; padding: 0; box-sizing: border-box; }\n\n  body {\n    background: var(--bg-dark);\n    color: var(--text);\n    font-family: var(--font-sans);\n    min-height: 100vh;\n    overflow-x: hidden;\n  }\n\n  /* Background gradient */\n  body::before {\n    content: '';\n    position: fixed;\n    top: 0; left: 0; right: 0; bottom: 0;\n    background:\n      radial-gradient(ellipse at 20% 20%, rgba(233,69,96,0.08) 0%, transparent 50%),\n      radial-gradient(ellipse at 80% 80%, rgba(72,219,251,0.06) 0%, transparent 50%),\n      radial-gradient(ellipse at 50% 50%, rgba(0,255,136,0.04) 0%, transparent 60%);\n    pointer-events: none;\n    z-index: 0;\n  }\n\n  .container {\n    max-width: 1400px;\n    margin: 0 auto;\n    padding: 20px;\n    position: relative;\n    z-index: 1;\n  }\n\n  /* ─── Header ─── */\n  .header {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    padding: 16px 0 24px;\n    border-bottom: 1px solid var(--border);\n    margin-bottom: 24px;\n  }\n\n  .header-left h1 {\n    font-size: 1.6rem;\n    font-weight: 700;\n    background: linear-gradient(135deg, #e94560, #48dbfb, #00ff88);\n    -webkit-background-clip: text;\n    -webkit-text-fill-color: transparent;\n    background-clip: text;\n  }\n\n  .header-left .subtitle {\n    font-size: 0.75rem;\n    color: var(--text-dim);\n    font-family: var(--font-mono);\n    margin-top: 4px;\n  }\n\n  .header-right {\n    display: flex;\n    align-items: center;\n    gap: 16px;\n  }\n\n  .status-indicator {\n    display: flex;\n    align-items: center;\n    gap: 6px;\n    font-family: var(--font-mono);\n    font-size: 0.7rem;\n    color: var(--text-dim);\n  }\n\n  .status-dot {\n    width: 8px; height: 8px;\n    border-radius: 50%;\n    background: var(--accent-red);\n    transition: background 0.3s, box-shadow 0.3s;\n  }\n\n  .status-dot.connected {\n    background: var(--accent-green);\n    box-shadow: 0 0 10px var(--accent-green);\n  }\n\n  .nav-link {\n    font-family: var(--font-mono);\n    font-size: 0.7rem;\n    color: var(--accent-blue);\n    text-decoration: none;\n    padding: 6px 12px;\n    border: 1px solid rgba(72,219,251,0.3);\n    border-radius: 6px;\n    transition: all 0.2s;\n  }\n\n  .nav-link:hover {\n    background: rgba(72,219,251,0.1);\n    border-color: var(--accent-blue);\n  }\n\n  /* ─── Hero Totals Bar ─── */\n  .hero-bar {\n    display: grid;\n    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));\n    gap: 12px;\n    margin-bottom: 24px;\n  }\n\n  .hero-stat {\n    background: var(--bg-card);\n    border: 1px solid var(--border);\n    border-radius: 12px;\n    padding: 16px;\n    text-align: center;\n    backdrop-filter: blur(12px);\n    transition: all 0.2s;\n  }\n\n  .hero-stat:hover {\n    background: var(--bg-card-hover);\n    border-color: rgba(255,255,255,0.15);\n    transform: translateY(-1px);\n  }\n\n  .hero-stat .value {\n    font-size: 1.5rem;\n    font-weight: 700;\n    font-family: var(--font-mono);\n    line-height: 1.2;\n  }\n\n  .hero-stat .label {\n    font-size: 0.65rem;\n    color: var(--text-dim);\n    text-transform: uppercase;\n    letter-spacing: 0.5px;\n    margin-top: 4px;\n  }\n\n  .hero-stat.sessions .value { color: var(--accent-blue); }\n  .hero-stat.events .value { color: var(--accent-yellow); }\n  .hero-stat.findings .value { color: var(--accent-red); }\n  .hero-stat.memory .value { color: var(--accent-green); }\n  .hero-stat.links .value { color: var(--accent-purple); }\n  .hero-stat.dq .value { color: var(--accent-blue); }\n  .hero-stat.learnings .value { color: var(--accent-yellow); }\n  .hero-stat.papers .value { color: var(--accent-red); }\n\n  /* ─── Database Cards ─── */\n  .db-grid {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 20px;\n    margin-bottom: 24px;\n  }\n\n  @media (max-width: 1000px) {\n    .db-grid { grid-template-columns: 1fr; }\n  }\n\n  .db-card {\n    background: var(--bg-card);\n    border: 1px solid var(--border);\n    border-radius: 16px;\n    padding: 24px;\n    backdrop-filter: blur(12px);\n    transition: all 0.3s;\n  }\n\n  .db-card:hover {\n    background: var(--bg-card-hover);\n    border-color: rgba(255,255,255,0.12);\n  }\n\n  .db-card-header {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    margin-bottom: 16px;\n    padding-bottom: 12px;\n    border-bottom: 1px solid var(--border);\n  }\n\n  .db-card-header .db-name {\n    font-size: 0.95rem;\n    font-weight: 600;\n  }\n\n  .db-card-header .db-status {\n    display: flex;\n    align-items: center;\n    gap: 5px;\n    font-family: var(--font-mono);\n    font-size: 0.6rem;\n    color: var(--text-dim);\n  }\n\n  .db-card-header .db-dot {\n    width: 6px; height: 6px;\n    border-radius: 50%;\n    background: var(--accent-green);\n    box-shadow: 0 0 6px var(--accent-green);\n  }\n\n  .db-card-header .db-dot.error {\n    background: var(--accent-red);\n    box-shadow: 0 0 6px var(--accent-red);\n  }\n\n  .db-card.claude .db-name { color: var(--accent-blue); }\n  .db-card.antigravity .db-name { color: var(--accent-red); }\n  .db-card.supermemory .db-name { color: var(--accent-green); }\n\n  .db-metrics {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 8px;\n    margin-bottom: 16px;\n  }\n\n  .db-metric {\n    padding: 8px 10px;\n    background: rgba(255,255,255,0.02);\n    border-radius: 8px;\n    border: 1px solid rgba(255,255,255,0.04);\n  }\n\n  .db-metric .metric-value {\n    font-size: 1.1rem;\n    font-weight: 600;\n    font-family: var(--font-mono);\n    color: var(--text);\n  }\n\n  .db-metric .metric-label {\n    font-size: 0.6rem;\n    color: var(--text-dim);\n    text-transform: uppercase;\n    letter-spacing: 0.3px;\n  }\n\n  .db-breakdown {\n    margin-top: 12px;\n  }\n\n  .db-breakdown h4 {\n    font-size: 0.7rem;\n    color: var(--text-dim);\n    text-transform: uppercase;\n    letter-spacing: 0.5px;\n    margin-bottom: 8px;\n  }\n\n  .breakdown-bar {\n    display: flex;\n    align-items: center;\n    gap: 8px;\n    margin-bottom: 4px;\n    font-size: 0.72rem;\n    font-family: var(--font-mono);\n  }\n\n  .breakdown-bar .bar-label {\n    width: 90px;\n    color: var(--text-dim);\n    overflow: hidden;\n    text-overflow: ellipsis;\n    white-space: nowrap;\n  }\n\n  .breakdown-bar .bar-track {\n    flex: 1;\n    height: 6px;\n    background: rgba(255,255,255,0.06);\n    border-radius: 3px;\n    overflow: hidden;\n  }\n\n  .breakdown-bar .bar-fill {\n    height: 100%;\n    border-radius: 3px;\n    transition: width 0.5s ease;\n  }\n\n  .breakdown-bar .bar-count {\n    width: 50px;\n    text-align: right;\n    color: var(--text);\n  }\n\n  .db-card.claude .bar-fill { background: linear-gradient(90deg, var(--accent-blue), #6c5ce7); }\n  .db-card.antigravity .bar-fill { background: linear-gradient(90deg, var(--accent-red), var(--accent-yellow)); }\n  .db-card.supermemory .bar-fill { background: linear-gradient(90deg, var(--accent-green), var(--accent-blue)); }\n\n  /* ─── Chart Section ─── */\n  .chart-section {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 20px;\n    margin-bottom: 24px;\n  }\n\n  @media (max-width: 800px) {\n    .chart-section { grid-template-columns: 1fr; }\n  }\n\n  .chart-card {\n    background: var(--bg-card);\n    border: 1px solid var(--border);\n    border-radius: 16px;\n    padding: 20px;\n    backdrop-filter: blur(12px);\n  }\n\n  .chart-card h3 {\n    font-size: 0.8rem;\n    color: var(--text-dim);\n    text-transform: uppercase;\n    letter-spacing: 0.5px;\n    margin-bottom: 12px;\n  }\n\n  .chart-card canvas {\n    max-height: 200px;\n  }\n\n  /* ─── Activity Feed ─── */\n  .feed-section {\n    background: var(--bg-card);\n    border: 1px solid var(--border);\n    border-radius: 16px;\n    padding: 24px;\n    backdrop-filter: blur(12px);\n  }\n\n  .feed-section h3 {\n    font-size: 0.85rem;\n    color: var(--text-dim);\n    text-transform: uppercase;\n    letter-spacing: 0.5px;\n    margin-bottom: 16px;\n  }\n\n  .feed-list {\n    display: flex;\n    flex-direction: column;\n    gap: 8px;\n    max-height: 400px;\n    overflow-y: auto;\n  }\n\n  .feed-item {\n    display: flex;\n    gap: 12px;\n    padding: 10px 12px;\n    background: rgba(255,255,255,0.02);\n    border-radius: 8px;\n    border: 1px solid rgba(255,255,255,0.04);\n    font-size: 0.78rem;\n    transition: background 0.2s;\n  }\n\n  .feed-item:hover {\n    background: rgba(255,255,255,0.05);\n  }\n\n  .feed-item .feed-badge {\n    font-family: var(--font-mono);\n    font-size: 0.6rem;\n    padding: 2px 8px;\n    border-radius: 4px;\n    white-space: nowrap;\n    height: fit-content;\n    font-weight: 600;\n  }\n\n  .feed-badge.finding {\n    background: rgba(233,69,96,0.15);\n    color: var(--accent-red);\n    border: 1px solid rgba(233,69,96,0.3);\n  }\n\n  .feed-badge.learning {\n    background: rgba(0,255,136,0.1);\n    color: var(--accent-green);\n    border: 1px solid rgba(0,255,136,0.3);\n  }\n\n  .feed-item .feed-content {\n    flex: 1;\n    color: var(--text);\n    line-height: 1.4;\n    overflow: hidden;\n    display: -webkit-box;\n    -webkit-line-clamp: 2;\n    -webkit-box-orient: vertical;\n  }\n\n  .feed-item .feed-time {\n    font-family: var(--font-mono);\n    font-size: 0.6rem;\n    color: var(--text-muted);\n    white-space: nowrap;\n    margin-top: 2px;\n  }\n\n  /* ─── Today Panel ─── */\n  .today-panel {\n    background: linear-gradient(135deg, rgba(72,219,251,0.08), rgba(0,255,136,0.05));\n    border: 1px solid rgba(72,219,251,0.2);\n    border-radius: 12px;\n    padding: 14px 20px;\n    margin-bottom: 24px;\n    display: flex;\n    align-items: center;\n    gap: 24px;\n    font-family: var(--font-mono);\n    font-size: 0.75rem;\n  }\n\n  .today-panel .today-label {\n    color: var(--accent-blue);\n    font-weight: 600;\n    text-transform: uppercase;\n    font-size: 0.65rem;\n    letter-spacing: 1px;\n  }\n\n  .today-panel .today-stat {\n    color: var(--text);\n  }\n\n  .today-panel .today-stat span {\n    color: var(--text-dim);\n    margin-left: 4px;\n  }\n\n  /* ─── Scrollbar ─── */\n  ::-webkit-scrollbar { width: 6px; }\n  ::-webkit-scrollbar-track { background: transparent; }\n  ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 3px; }\n  ::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,0.2); }\n\n  /* ─── Loading State ─── */\n  .loading {\n    text-align: center;\n    padding: 60px;\n    color: var(--text-dim);\n    font-family: var(--font-mono);\n    font-size: 0.85rem;\n  }\n\n  .loading::after {\n    content: '';\n    display: inline-block;\n    width: 16px; height: 16px;\n    border: 2px solid var(--text-muted);\n    border-top-color: var(--accent-blue);\n    border-radius: 50%;\n    animation: spin 0.8s linear infinite;\n    margin-left: 10px;\n    vertical-align: middle;\n  }\n\n  @keyframes spin { to { transform: rotate(360deg); } }\n\n  .error-state {\n    color: var(--accent-red);\n    font-family: var(--font-mono);\n    font-size: 0.75rem;\n    padding: 8px;\n    text-align: center;\n  }\n</style>\n</head>\n<body>\n\n<div class=\"container\">\n  <!-- Header -->\n  <div class=\"header\">\n    <div class=\"header-left\">\n      <h1>Antigravity Ecosystem</h1>\n      <div class=\"subtitle\">Unified Intelligence across 3 databases</div>\n    </div>\n    <div class=\"header-right\">\n      <div class=\"status-indicator\">\n        <div class=\"status-dot\" id=\"sseDot\"></div>\n        <span id=\"sseLabel\">CONNECTING</span>\n      </div>\n      <a href=\"/dashboard\" class=\"nav-link\">CCC Dashboard</a>\n    </div>\n  </div>\n\n  <!-- Loading state -->\n  <div class=\"loading\" id=\"loadingState\">Loading ecosystem data</div>\n\n  <!-- Main content (hidden until data loads) -->\n  <div id=\"mainContent\" style=\"display:none;\">\n\n    <!-- Today Panel -->\n    <div class=\"today-panel\" id=\"todayPanel\">\n      <div class=\"today-label\">Today</div>\n      <div class=\"today-stat\"><strong id=\"todayMessages\">0</strong><span>messages</span></div>\n      <div class=\"today-stat\"><strong id=\"todaySessions\">0</strong><span>sessions</span></div>\n      <div class=\"today-stat\"><strong id=\"todayTools\">0</strong><span>tools</span></div>\n    </div>\n\n    <!-- Hero Totals Bar -->\n    <div class=\"hero-bar\">\n      <div class=\"hero-stat sessions\">\n        <div class=\"value\" id=\"totalSessions\">--</div>\n        <div class=\"label\">Total Sessions</div>\n      </div>\n      <div class=\"hero-stat events\">\n        <div class=\"value\" id=\"totalEvents\">--</div>\n        <div class=\"label\">Total Events</div>\n      </div>\n      <div class=\"hero-stat findings\">\n        <div class=\"value\" id=\"totalFindings\">--</div>\n        <div class=\"label\">Findings</div>\n      </div>\n      <div class=\"hero-stat papers\">\n        <div class=\"value\" id=\"totalPapers\">--</div>\n        <div class=\"label\">Papers</div>\n      </div>\n      <div class=\"hero-stat memory\">\n        <div class=\"value\" id=\"totalMemory\">--</div>\n        <div class=\"label\">Memory Items</div>\n      </div>\n      <div class=\"hero-stat learnings\">\n        <div class=\"value\" id=\"totalLearnings\">--</div>\n        <div class=\"label\">Learnings</div>\n      </div>\n      <div class=\"hero-stat links\">\n        <div class=\"value\" id=\"totalLinks\">--</div>\n        <div class=\"label\">Graph Links</div>\n      </div>\n      <div class=\"hero-stat dq\">\n        <div class=\"value\" id=\"totalDQ\">--</div>\n        <div class=\"label\">DQ Scores</div>\n      </div>\n    </div>\n\n    <!-- 3 Database Cards -->\n    <div class=\"db-grid\">\n\n      <!-- Claude Code Card -->\n      <div class=\"db-card claude\">\n        <div class=\"db-card-header\">\n          <div class=\"db-name\">Claude Code Telemetry</div>\n          <div class=\"db-status\">\n            <div class=\"db-dot\" id=\"claudeDot\"></div>\n            <span id=\"claudeStatus\">connected</span>\n          </div>\n        </div>\n        <div class=\"db-metrics\">\n          <div class=\"db-metric\">\n            <div class=\"metric-value\" id=\"claudeSessions\">--</div>\n            <div class=\"metric-label\">Sessions</div>\n          </div>\n          <div class=\"db-metric\">\n            <div class=\"metric-value\" id=\"claudeActivity\">--</div>\n            <div class=\"metric-label\">Activity Events</div>\n          </div>\n          <div class=\"db-metric\">\n            <div class=\"metric-value\" id=\"claudeTools\">--</div>\n            <div class=\"metric-label\">Tool Events</div>\n          </div>\n          <div class=\"db-metric\">\n            <div class=\"metric-value\" id=\"claudeDQ\">--</div>\n            <div class=\"metric-label\">DQ Scores</div>\n          </div>\n          <div class=\"db-metric\">\n            <div class=\"metric-value\" id=\"claudeHeal\">--</div>\n            <div class=\"metric-label\">Self-Heal</div>\n          </div>\n          <div class=\"db-metric\">\n            <div class=\"metric-value\" id=\"claudeRouting\">--</div>\n            <div class=\"metric-label\">Routing</div>\n          </div>\n        </div>\n        <div class=\"db-breakdown\" id=\"claudeBreakdown\"></div>\n      </div>\n\n      <!-- Antigravity Card -->\n      <div class=\"db-card antigravity\">\n        <div class=\"db-card-header\">\n          <div class=\"db-name\">Research & UCW Intelligence</div>\n          <div class=\"db-status\">\n            <div class=\"db-dot\" id=\"antigravityDot\"></div>\n            <span id=\"antigravityStatus\">connected</span>\n          </div>\n        </div>\n        <div class=\"db-metrics\">\n          <div class=\"db-metric\">\n            <div class=\"metric-value\" id=\"agFindings\">--</div>\n            <div class=\"metric-label\">Findings</div>\n          </div>\n          <div class=\"db-metric\">\n            <div class=\"metric-value\" id=\"agPapers\">--</div>\n            <div class=\"metric-label\">Papers</div>\n          </div>\n          <div class=\"db-metric\">\n            <div class=\"metric-value\" id=\"agSessions\">--</div>\n            <div class=\"metric-label\">UCW Sessions</div>\n          </div>\n          <div class=\"db-metric\">\n            <div class=\"metric-value\" id=\"agURLs\">--</div>\n            <div class=\"metric-label\">URLs Tracked</div>\n          </div>\n          <div class=\"db-metric\">\n            <div class=\"metric-value\" id=\"agDQCount\">--</div>\n            <div class=\"metric-label\">DQ Scores</div>\n          </div>\n          <div class=\"db-metric\">\n            <div class=\"metric-value\" id=\"agAvgDQ\">--</div>\n            <div class=\"metric-label\">Avg DQ</div>\n          </div>\n        </div>\n        <div class=\"db-breakdown\" id=\"agBreakdown\"></div>\n      </div>\n\n      <!-- Supermemory Card -->\n      <div class=\"db-card supermemory\">\n        <div class=\"db-card-header\">\n          <div class=\"db-name\">Long-Term Memory</div>\n          <div class=\"db-status\">\n            <div class=\"db-dot\" id=\"supermemoryDot\"></div>\n            <span id=\"supermemoryStatus\">connected</span>\n          </div>\n        </div>\n        <div class=\"db-metrics\">\n          <div class=\"db-metric\">\n            <div class=\"metric-value\" id=\"smItems\">--</div>\n            <div class=\"metric-label\">Memory Items</div>\n          </div>\n          <div class=\"db-metric\">\n            <div class=\"metric-value\" id=\"smLearnings\">--</div>\n            <div class=\"metric-label\">Learnings</div>\n          </div>\n          <div class=\"db-metric\">\n            <div class=\"metric-value\" id=\"smLinks\">--</div>\n            <div class=\"metric-label\">Graph Links</div>\n          </div>\n          <div class=\"db-metric\">\n            <div class=\"metric-value\" id=\"smSessions\">--</div>\n            <div class=\"metric-label\">Sessions</div>\n          </div>\n        </div>\n        <div class=\"db-breakdown\" id=\"smBreakdown\"></div>\n      </div>\n    </div>\n\n    <!-- Charts -->\n    <div class=\"chart-section\">\n      <div class=\"chart-card\">\n        <h3>DQ Score Trend (14 days)</h3>\n        <canvas id=\"dqChart\"></canvas>\n      </div>\n      <div class=\"chart-card\">\n        <h3>Memory Sessions (14 days)</h3>\n        <canvas id=\"sessionChart\"></canvas>\n      </div>\n    </div>\n\n    <!-- Activity Feed -->\n    <div class=\"feed-section\">\n      <h3>Recent Activity Feed</h3>\n      <div class=\"feed-list\" id=\"feedList\">\n        <div class=\"loading\" style=\"padding:20px;\">Loading feed</div>\n      </div>\n    </div>\n  </div>\n</div>\n\n<script>\n(function() {\n  'use strict';\n\n  // ─── Helpers ───\n  function fmt(n) {\n    if (n == null || isNaN(n)) return '--';\n    if (n >= 1e9) return (n / 1e9).toFixed(2) + 'B';\n    if (n >= 1e6) return (n / 1e6).toFixed(2) + 'M';\n    if (n >= 1e3) return (n / 1e3).toFixed(1) + 'K';\n    return String(n);\n  }\n\n  function fmtTime(ts) {\n    if (!ts) return '';\n    try {\n      const d = new Date(ts);\n      const now = new Date();\n      const diff = now - d;\n      if (diff < 60000) return 'just now';\n      if (diff < 3600000) return Math.floor(diff / 60000) + 'm ago';\n      if (diff < 86400000) return Math.floor(diff / 3600000) + 'h ago';\n      return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });\n    } catch(e) { return ts; }\n  }\n\n  function truncate(s, len) {\n    if (!s) return '';\n    return s.length > len ? s.substring(0, len) + '...' : s;\n  }\n\n  // ─── Chart instances ───\n  let dqChartInstance = null;\n  let sessionChartInstance = null;\n\n  const chartDefaults = {\n    responsive: true,\n    maintainAspectRatio: false,\n    plugins: {\n      legend: { display: false },\n    },\n    scales: {\n      x: {\n        grid: { color: 'rgba(255,255,255,0.04)' },\n        ticks: { color: 'rgba(255,255,255,0.3)', font: { size: 10, family: \"'JetBrains Mono', monospace\" } },\n      },\n      y: {\n        grid: { color: 'rgba(255,255,255,0.04)' },\n        ticks: { color: 'rgba(255,255,255,0.3)', font: { size: 10, family: \"'JetBrains Mono', monospace\" } },\n      },\n    },\n  };\n\n  // ─── Render Breakdown Bars ───\n  function renderBreakdown(containerId, title, items, labelKey, countKey, maxItems) {\n    const container = document.getElementById(containerId);\n    if (!container || !items || items.length === 0) return;\n    const max = Math.max(...items.map(i => i[countKey] || 0), 1);\n    const shown = items.slice(0, maxItems || 5);\n    let html = '<h4>' + title + '</h4>';\n    shown.forEach(item => {\n      const pct = Math.round(((item[countKey] || 0) / max) * 100);\n      html += '<div class=\"breakdown-bar\">' +\n        '<span class=\"bar-label\" title=\"' + (item[labelKey] || '') + '\">' + (item[labelKey] || 'unknown') + '</span>' +\n        '<div class=\"bar-track\"><div class=\"bar-fill\" style=\"width:' + pct + '%\"></div></div>' +\n        '<span class=\"bar-count\">' + fmt(item[countKey] || 0) + '</span>' +\n        '</div>';\n    });\n    container.innerHTML = html;\n  }\n\n  // ─── Render Charts ───\n  function renderDQChart(trend) {\n    const ctx = document.getElementById('dqChart');\n    if (!ctx || !trend || trend.length === 0) return;\n    const labels = trend.map(t => t.day ? t.day.substring(5) : '');\n    const data = trend.map(t => t.avg_dq || 0);\n\n    if (dqChartInstance) dqChartInstance.destroy();\n    dqChartInstance = new Chart(ctx, {\n      type: 'line',\n      data: {\n        labels: labels,\n        datasets: [{\n          data: data,\n          borderColor: '#48dbfb',\n          backgroundColor: 'rgba(72,219,251,0.1)',\n          fill: true,\n          tension: 0.4,\n          pointRadius: 3,\n          pointBackgroundColor: '#48dbfb',\n          borderWidth: 2,\n        }],\n      },\n      options: {\n        ...chartDefaults,\n        scales: {\n          ...chartDefaults.scales,\n          y: {\n            ...chartDefaults.scales.y,\n            min: 0.5,\n            max: 1.0,\n          },\n        },\n      },\n    });\n  }\n\n  function renderSessionChart(trend) {\n    const ctx = document.getElementById('sessionChart');\n    if (!ctx || !trend || trend.length === 0) return;\n    const labels = trend.map(t => t.day ? t.day.substring(5) : '');\n    const data = trend.map(t => t.count || 0);\n\n    if (sessionChartInstance) sessionChartInstance.destroy();\n    sessionChartInstance = new Chart(ctx, {\n      type: 'bar',\n      data: {\n        labels: labels,\n        datasets: [{\n          data: data,\n          backgroundColor: 'rgba(0,255,136,0.3)',\n          borderColor: '#00ff88',\n          borderWidth: 1,\n          borderRadius: 4,\n        }],\n      },\n      options: chartDefaults,\n    });\n  }\n\n  // ─── Render Activity Feed ───\n  function renderFeed(findings, learnings) {\n    const list = document.getElementById('feedList');\n    if (!list) return;\n\n    const items = [];\n\n    if (findings && findings.length > 0) {\n      findings.forEach(f => {\n        items.push({\n          type: 'finding',\n          content: f.content || '(no content)',\n          meta: f.type || f.project || '',\n          time: f.created_at,\n        });\n      });\n    }\n\n    if (learnings && learnings.length > 0) {\n      learnings.forEach(l => {\n        items.push({\n          type: 'learning',\n          content: l.content || '(no content)',\n          meta: l.category || l.project || '',\n          time: l.created_at,\n        });\n      });\n    }\n\n    // Sort by time descending\n    items.sort((a, b) => {\n      if (!a.time) return 1;\n      if (!b.time) return -1;\n      return b.time.localeCompare(a.time);\n    });\n\n    if (items.length === 0) {\n      list.innerHTML = '<div style=\"color:var(--text-dim);text-align:center;padding:20px;font-size:0.8rem;\">No recent activity</div>';\n      return;\n    }\n\n    list.innerHTML = items.slice(0, 20).map(item =>\n      '<div class=\"feed-item\">' +\n        '<span class=\"feed-badge ' + item.type + '\">' + item.type + '</span>' +\n        '<div class=\"feed-content\">' + truncate(item.content, 200) + '</div>' +\n        '<div class=\"feed-time\">' + fmtTime(item.time) + '</div>' +\n      '</div>'\n    ).join('');\n  }\n\n  // ─── Update Dashboard from API Data ───\n  function updateDashboard(data) {\n    document.getElementById('loadingState').style.display = 'none';\n    document.getElementById('mainContent').style.display = 'block';\n\n    const t = data.totals || {};\n    document.getElementById('totalSessions').textContent = fmt(t.total_sessions);\n    document.getElementById('totalEvents').textContent = fmt(t.total_events);\n    document.getElementById('totalFindings').textContent = fmt(t.total_findings);\n    document.getElementById('totalPapers').textContent = fmt(t.total_papers);\n    document.getElementById('totalMemory').textContent = fmt(t.total_memory_items);\n    document.getElementById('totalLearnings').textContent = fmt(t.total_learnings);\n    document.getElementById('totalLinks').textContent = fmt(t.total_links);\n    document.getElementById('totalDQ').textContent = fmt(t.total_dq_scores);\n\n    const dbs = data.databases || {};\n\n    // Claude\n    const cl = dbs.claude || {};\n    if (cl.error) {\n      document.getElementById('claudeDot').classList.add('error');\n      document.getElementById('claudeStatus').textContent = 'error';\n    } else {\n      document.getElementById('claudeDot').classList.remove('error');\n      document.getElementById('claudeStatus').textContent = 'connected';\n      document.getElementById('claudeSessions').textContent = fmt(cl.sessions);\n      document.getElementById('claudeActivity').textContent = fmt(cl.activity_events);\n      document.getElementById('claudeTools').textContent = fmt(cl.tool_events);\n      document.getElementById('claudeDQ').textContent = fmt(cl.dq_scores);\n      document.getElementById('claudeHeal').textContent = fmt(cl.self_heal_events);\n      document.getElementById('claudeRouting').textContent = fmt(cl.routing_decisions);\n\n      if (cl.today) {\n        document.getElementById('todayMessages').textContent = fmt(cl.today.messages);\n        document.getElementById('todaySessions').textContent = fmt(cl.today.sessions);\n        document.getElementById('todayTools').textContent = fmt(cl.today.tools);\n      }\n\n      renderDQChart(cl.dq_trend);\n    }\n\n    // Antigravity\n    const ag = dbs.antigravity || {};\n    if (ag.error) {\n      document.getElementById('antigravityDot').classList.add('error');\n      document.getElementById('antigravityStatus').textContent = 'error';\n    } else {\n      document.getElementById('antigravityDot').classList.remove('error');\n      document.getElementById('antigravityStatus').textContent = 'connected';\n      document.getElementById('agFindings').textContent = fmt(ag.findings);\n      document.getElementById('agPapers').textContent = fmt(ag.papers);\n      document.getElementById('agSessions').textContent = fmt(ag.sessions);\n      document.getElementById('agURLs').textContent = fmt(ag.urls);\n      document.getElementById('agDQCount').textContent = fmt(ag.dq_scores);\n      document.getElementById('agAvgDQ').textContent = ag.avg_dq ? ag.avg_dq.toFixed(3) : '--';\n\n      renderBreakdown('agBreakdown', 'Findings by Type', ag.findings_by_type, 'type', 'count', 5);\n    }\n\n    // Supermemory\n    const sm = dbs.supermemory || {};\n    if (sm.error) {\n      document.getElementById('supermemoryDot').classList.add('error');\n      document.getElementById('supermemoryStatus').textContent = 'error';\n    } else {\n      document.getElementById('supermemoryDot').classList.remove('error');\n      document.getElementById('supermemoryStatus').textContent = 'connected';\n      document.getElementById('smItems').textContent = fmt(sm.items);\n      document.getElementById('smLearnings').textContent = fmt(sm.learnings);\n      document.getElementById('smLinks').textContent = fmt(sm.links);\n      document.getElementById('smSessions').textContent = fmt(sm.sessions);\n\n      renderBreakdown('smBreakdown', 'Items by Source', sm.items_by_source, 'source', 'count', 5);\n      renderSessionChart(sm.session_trend);\n    }\n\n    // Activity Feed\n    renderFeed(ag.recent_findings, sm.recent_learnings);\n  }\n\n  // ─── Update from SSE ecosystem pulse (lightweight) ───\n  function updateFromPulse(data) {\n    if (data.claude && !data.claude.error) {\n      document.getElementById('claudeSessions').textContent = fmt(data.claude.sessions);\n      document.getElementById('claudeActivity').textContent = fmt(data.claude.events);\n      document.getElementById('claudeTools').textContent = fmt(data.claude.tools);\n    }\n    if (data.antigravity && !data.antigravity.error) {\n      document.getElementById('agFindings').textContent = fmt(data.antigravity.findings);\n      document.getElementById('agPapers').textContent = fmt(data.antigravity.papers);\n      document.getElementById('agSessions').textContent = fmt(data.antigravity.sessions);\n    }\n    if (data.supermemory && !data.supermemory.error) {\n      document.getElementById('smItems').textContent = fmt(data.supermemory.items);\n      document.getElementById('smLearnings').textContent = fmt(data.supermemory.learnings);\n      document.getElementById('smLinks').textContent = fmt(data.supermemory.links);\n    }\n\n    // Recalculate totals\n    const cs = (data.claude && !data.claude.error) ? data.claude.sessions || 0 : 0;\n    const as_ = (data.antigravity && !data.antigravity.error) ? data.antigravity.sessions || 0 : 0;\n    const ss = (data.supermemory && !data.supermemory.error) ? 0 : 0;  // sessions not in pulse for supermemory\n    // Only update what we can from pulse data\n  }\n\n  // ─── Fetch initial data ───\n  fetch('/api/ecosystem')\n    .then(r => r.json())\n    .then(data => updateDashboard(data))\n    .catch(err => {\n      document.getElementById('loadingState').innerHTML =\n        '<div class=\"error-state\">Failed to load ecosystem data: ' + err.message + '</div>';\n    });\n\n  // ─── SSE Connection ───\n  let retries = 0;\n  const MAX_RETRIES = 50;\n\n  function connectSSE() {\n    const es = new EventSource('/api/stream');\n\n    es.onopen = function() {\n      retries = 0;\n      document.getElementById('sseDot').classList.add('connected');\n      document.getElementById('sseLabel').textContent = 'LIVE';\n    };\n\n    es.addEventListener('ecosystem', function(e) {\n      try {\n        const data = JSON.parse(e.data);\n        updateFromPulse(data);\n      } catch(err) {}\n    });\n\n    es.addEventListener('stats', function(e) {\n      // Update today panel from main stats stream\n      try {\n        const data = JSON.parse(e.data);\n        if (data.today) {\n          document.getElementById('todayMessages').textContent = fmt(data.today.messages);\n          document.getElementById('todaySessions').textContent = fmt(data.today.sessions);\n          document.getElementById('todayTools').textContent = fmt(data.today.tools);\n        }\n      } catch(err) {}\n    });\n\n    es.onerror = function() {\n      document.getElementById('sseDot').classList.remove('connected');\n      document.getElementById('sseLabel').textContent = 'OFFLINE';\n      es.close();\n      if (retries < MAX_RETRIES) {\n        retries++;\n        setTimeout(connectSSE, 3000);\n      }\n    };\n  }\n\n  connectSSE();\n\n  // ─── Periodic full refresh (every 60s) ───\n  setInterval(function() {\n    fetch('/api/ecosystem')\n      .then(r => r.json())\n      .then(data => updateDashboard(data))\n      .catch(() => {});\n  }, 60000);\n\n})();\n</script>\n\n</body>\n</html>\n","numLines":1054,"startLine":1,"totalLines":1054}}}
