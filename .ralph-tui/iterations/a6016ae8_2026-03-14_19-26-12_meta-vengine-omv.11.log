          ecosystem_counter += 1\n   393→                    if ecosystem_counter >= 10:\n   394→                        ecosystem_counter = 0\n   395→                        eco = self._poll_ecosystem()\n   396→                        if self._data_changed(\"ecosystem\", eco):\n   397→                            self.broadcast(\"ecosystem\", eco)\n   398→\n   399→                    # Heartbeat to keep connection alive\n   400→                    self.broadcast(\"heartbeat\", {\"t\": int(time.time())})\n   401→            except Exception:\n   402→                pass\n   403→\n   404→            time.sleep(3)\n   405→\n   406→\n   407→# Global streamer instance\n   408→streamer = DataStreamer()\n   409→\n   410→# ═══════════════════════════════════════════════════════════════\n   411→# LIVE SSE CLIENT JAVASCRIPT (injected into dashboard HTML)\n   412→# ═══════════════════════════════════════════════════════════════\n   413→\n   414→SSE_CLIENT_JS = \"\"\""}]},"parent_tool_use_id":null,"session_id":"cacc1f91-0b46-45d1-9778-ff7a3c602d11","uuid":"c848bb28-42c6-4412-a1cc-e480cba225d3","tool_use_result":{"type":"text","file":{"filePath":"/Users/dicoangelo/.claude/scripts/ccc-api-server.py","content":"        \"\"\"Start the background polling thread.\"\"\"\n        if self.running:\n            return\n        self.running = True\n        t = threading.Thread(target=self._run, daemon=True)\n        t.start()\n\n    def _run(self) -> None:\n        \"\"\"Main polling loop.\"\"\"\n        health_counter = 0\n        ecosystem_counter = 0\n        while self.running:\n            try:\n                with self.lock:\n                    has_clients = len(self.clients) > 0\n\n                if has_clients:\n                    # Always send stats\n                    stats = self._poll_stats()\n                    if self._data_changed(\"stats\", stats):\n                        self.broadcast(\"stats\", stats)\n\n                    # Health + velocity every 15 seconds (every 5th poll)\n                    health_counter += 1\n                    if health_counter >= 5:\n                        health_counter = 0\n                        health = self._poll_health()\n                        if self._data_changed(\"health\", health):\n                            self.broadcast(\"health\", health)\n                        velocity = self._poll_velocity()\n                        if self._data_changed(\"velocity\", velocity):\n                            self.broadcast(\"velocity\", velocity)\n                        new_tables = self._poll_new_tables()\n                        if self._data_changed(\"tables\", new_tables):\n                            self.broadcast(\"tables\", new_tables)\n\n                    # Ecosystem pulse every 30 seconds (every 10th poll)\n                    ecosystem_counter += 1\n                    if ecosystem_counter >= 10:\n                        ecosystem_counter = 0\n                        eco = self._poll_ecosystem()\n                        if self._data_changed(\"ecosystem\", eco):\n                            self.broadcast(\"ecosystem\", eco)\n\n                    # Heartbeat to keep connection alive\n                    self.broadcast(\"heartbeat\", {\"t\": int(time.time())})\n            except Exception:\n                pass\n\n            time.sleep(3)\n\n\n# Global streamer instance\nstreamer = DataStreamer()\n\n# ═══════════════════════════════════════════════════════════════\n# LIVE SSE CLIENT JAVASCRIPT (injected into dashboard HTML)\n# ═══════════════════════════════════════════════════════════════\n\nSSE_CLIENT_JS = \"\"\"","numLines":60,"startLine":355,"totalLines":2046}}}
