{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HomVVuBXH1HA1LoGq4tKrX","type":"tool_result","content":"   390→    def update_from_outcome(self,\n   391→                            model: str,\n   392→                            query_latent: LatentRepresentation,\n   393→                            success: bool,\n   394→                            learning_rate: float = 0.01):\n   395→        \"\"\"\n   396→        Update IRT parameters based on observed outcome.\n   397→        Enables continuous learning from routing feedback.\n   398→        \"\"\"\n   399→        params = self.model_params.get(model)\n   400→        if not params:\n   401→            params = IRTParams(ability=0.5)\n   402→            self.model_params[model] = params\n   403→\n   404→        predicted = self.predict(model, query_latent)\n   405→        actual = 1.0 if success else 0.0\n   406→        error = actual - predicted\n   407→\n   408→        # Update ability parameter\n   409→        params.ability += learning_rate * error * query_latent.discrimination\n   410→        params.ability = max(0.0, min(1.0, params.ability))\n   411→\n   412→        # Update domain-specific ability\n   413→        domain = query_latent.domain_signature\n   414→        if domain not in params.domain_abilities:\n   415→            params.domain_abilities[domain] = params.ability\n   416→        params.domain_abilities[domain] += learning_rate * error * 1.5\n   417→        params.domain_abilities[domain] = max(0.0, min(1.0, params.domain_abilities[domain]))\n   418→\n   419→        self.save_params()\n   420→\n   421→\n   422→# ============================================================\n   423→# PRESSURE FIELD SELECTION\n   424→# ============================================================"}]},"parent_tool_use_id":null,"session_id":"071a4d5f-2d58-4ffd-abdb-361b6aaf2d61","uuid":"92a58b4c-6157-470f-9ba3-8a3c0156099e","tool_use_result":{"type":"text","file":{"filePath":"/Users/dicoangelo/projects/core/meta-vengine/kernel/hsrgs.py","content":"    def update_from_outcome(self,\n                            model: str,\n                            query_latent: LatentRepresentation,\n                            success: bool,\n                            learning_rate: float = 0.01):\n        \"\"\"\n        Update IRT parameters based on observed outcome.\n        Enables continuous learning from routing feedback.\n        \"\"\"\n        params = self.model_params.get(model)\n        if not params:\n            params = IRTParams(ability=0.5)\n            self.model_params[model] = params\n\n        predicted = self.predict(model, query_latent)\n        actual = 1.0 if success else 0.0\n        error = actual - predicted\n\n        # Update ability parameter\n        params.ability += learning_rate * error * query_latent.discrimination\n        params.ability = max(0.0, min(1.0, params.ability))\n\n        # Update domain-specific ability\n        domain = query_latent.domain_signature\n        if domain not in params.domain_abilities:\n            params.domain_abilities[domain] = params.ability\n        params.domain_abilities[domain] += learning_rate * error * 1.5\n        params.domain_abilities[domain] = max(0.0, min(1.0, params.domain_abilities[domain]))\n\n        self.save_params()\n\n\n# ============================================================\n# PRESSURE FIELD SELECTION\n# ============================================================","numLines":35,"startLine":390,"totalLines":979}}}
