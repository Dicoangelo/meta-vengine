{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Ds2wVrN2js7u6AYu5UXDy6","type":"tool_result","content":"     1→#!/usr/bin/env python3\n     2→\"\"\"\n     3→SUPERMAX v2 — Adaptive Agent Count with Difficulty-Aware Spawning + Free-MAD Trajectory Scoring.\n     4→\n     5→US-007: Dynamically selects agent count (1-5) based on graphComplexity\n     6→from the multi-feature graph signal (US-004). Simple queries use 1 agent,\n     7→complex queries get full council evaluation.\n     8→\n     9→US-008: Free-MAD trajectory scoring replaces weighted averaging. Agent\n    10→stability (not agreement speed) determines consensus quality. Sycophancy\n    11→detection via unanimous convergence flagging.\n    12→\n    13→Agent priority order:\n    14→  1. Principal Engineer (technical correctness, waste penalties)\n    15→  2. Security Architect (risk, safety margins, compliance)\n    16→  3. Product Strategist (user value, speed, cost)\n    17→  4. Contrarian (adversarial challenge, from ACE)\n    18→  5. Arbiter (final adjudication, cross-perspective synthesis)\n    19→\n    20→All thresholds stored in config/supermax-v2.json (learnable, not hardcoded).\n    21→\"\"\"\n    22→\n    23→import json\n    24→import sys\n    25→import os\n    26→import time\n    27→from pathlib import Path\n    28→from datetime import datetime\n    29→from dataclasses import dataclass, field\n    30→from typing import List, Optional, Dict, Any\n    31→\n    32→# Resolve paths relative to the meta-vengine root\n    33→_ROOT = Path(__file__).resolve().parent.parent\n    34→_CONFIG_PATH = _ROOT / \"config\" / \"supermax-v2.json\"\n    35→_COSTS_DIR = _ROOT / \"data\"\n    36→\n    37→\n    38→@dataclass\n    39→class AgentSpec:\n    40→    \"\"\"Specification for a SUPERMAX agent to spawn.\"\"\"\n    41→    name: str\n    42→    perspective: str\n    43→    model: str\n    44→    index: int  # priority order (0-based)\n    45→\n    46→\n    47→@dataclass\n    48→class SpawnPlan:\n    49→    \"\"\"Result of PredictiveSpawner.plan() — describes which agents to spawn.\"\"\"\n    50→    graph_complexity: float\n    51→    difficulty_tier: str\n    52→    agent_count: int\n    53→    agents: List[AgentSpec]\n    54→    thresholds_used: Dict[str, Any]\n    55→\n    56→\n    57→def load_config(config_path: Path = None) -> dict:\n    58→    \"\"\"Load SUPERMAX v2 config from JSON. Falls back to defaults if missing.\"\"\"\n    59→    path = config_path or _CONFIG_PATH\n    60→    try:\n    61→        if path.exists():\n    62→            with open(path, \"r\") as f:\n    63→                return json.load(f)\n    64→    except (json.JSONDecodeError, OSError):\n    65→        pass\n    66→    # Emergency fallback — should never be used in production\n    67→    return {\n    68→        \"agentCountThresholds\": {\n    69→            \"trivial\": {\"max\": 0.25, \"agentCount\": 1},\n    70→            \"simple\": {\"max\": 0.45, \"agentCount\": 2},\n    71→            \"moderate\": {\"max\": 0.65, \"agentCount\": 3},\n    72→            \"complex\": {\"max\": 0.85, \"agentCount\": 4},\n    73→            \"expert\": {\"max\": 1.00, \"agentCount\": 5},\n    74→        },\n    75→        \"agentPriority\": [\n    76→            {\"name\": \"PrincipalEngineer\", \"perspective\": \"Technical correctness, waste penalties\", \"model\": \"sonnet\"},\n    77→            {\"name\": \"SecurityArchitect\", \"perspective\": \"Risk, safety margins, compliance\", \"model\": \"sonnet\"},\n    78→            {\"name\": \"ProductStrategist\", \"perspective\": \"User value, speed, cost\", \"model\": \"sonnet\"},\n    79→            {\"name\": \"Contrarian\", \"perspective\": \"Adversarial challenge, assumption stress-testing\", \"model\": \"sonnet\"},\n    80→            {\"name\": \"Arbiter\", \"perspective\": \"Final adjudication, cross-perspective synthesis\", \"model\": \"opus\"},\n    81→        ],\n    82→        \"constraints\": {\"minAgents\": 1, \"maxAgents\": 5, \"defaultAgentCount\": 3},\n    83→    }\n    84→\n    85→\n    86→class PredictiveSpawner:\n    87→    \"\"\"\n    88→    Difficulty-aware agent spawner for SUPERMAX v2.\n    89→\n    90→    Consumes graphComplexity (0.0-1.0) from the multi-feature graph signal\n    91→    (US-004) and selects the appropriate number of council agents.\n    92→\n    93→    Thresholds and agent definitions are loaded from config/supermax-v2.json\n    94→    (learnable — future Optimas LRF).\n    95→    \"\"\"\n    96→\n    97→    def __init__(self, config_path: Path = None):\n    98→        self.config = load_config(config_path)\n    99→        self._thresholds = self._parse_thresholds()\n   100→        self._agents = self._parse_agents()\n   101→        self._constraints = self.config.get(\"constraints\", {})\n   102→\n   103→    def _parse_thresholds(self) -> List[dict]:\n   104→        \"\"\"Parse and sort thresholds by max value ascending.\"\"\"\n   105→        raw = self.config.get(\"agentCountThresholds\", {})\n   106→        tiers = []\n   107→        for tier_name, tier_data in raw.items():\n   108→            tiers.append({\n   109→                \"tier\": tier_name,\n   110→                \"max\": tier_data[\"max\"],\n   111→                \"agentCount\": tier_data[\"agentCount\"],\n   112→            })\n   113→        tiers.sort(key=lambda t: t[\"max\"])\n   114→        return tiers\n   115→\n   116→    def _parse_agents(self) -> List[AgentSpec]:\n   117→        \"\"\"Parse agent priority list from config.\"\"\"\n   118→        raw = self.config.get(\"agentPriority\", [])\n   119→        agents = []\n   120→        for i, entry in enumerate(raw):\n   121→            agents.append(AgentSpec(\n   122→                name=entry[\"name\"],\n   123→                perspective=entry.get(\"perspective\", \"\"),\n   124→                model=entry.get(\"model\", \"sonnet\"),\n   125→                index=i,\n   126→            ))\n   127→        return agents\n   128→\n   129→    def classify_difficulty(self, graph_complexity: float) -> tuple:\n   130→        \"\"\"\n   131→        Classify a graphComplexity score into a difficulty tier and agent count.\n   132→\n   133→        Args:\n   134→            graph_complexity: 0.0-1.0 composite score from computeGraphSignal()\n   135→\n   136→        Returns:\n   137→            (tier_name, agent_count) tuple\n   138→        \"\"\"\n   139→        clamped = max(0.0, min(1.0, graph_complexity))\n   140→\n   141→        for tier in self._thresholds:\n   142→            if clamped < tier[\"max\"] or (clamped == tier[\"max\"] and tier[\"tier\"] == \"expert\"):\n   143→                return tier[\"tier\"], tier[\"agentCount\"]\n   144→\n   145→        # Fallback: if complexity exactly equals 1.0 and no tier matched\n   146→        if self._thresholds:\n   147→            last = self._thresholds[-1]\n   148→            return last[\"tier\"], last[\"agentCount\"]\n   149→\n   150→        # Ultimate fallback\n   151→        default_count = self._constraints.get(\"defaultAgentCount\", 3)\n   152→        return \"unknown\", default_count\n   153→\n   154→    def select_agents(self, count: int) -> List[AgentSpec]:\n   155→        \"\"\"\n   156→        Select agents in priority order up to the given count.\n   157→\n   158→        Priority: PrincipalEngineer > SecurityArchitect > ProductStrategist > Contrarian > Arbiter\n   159→\n   160→        Args:\n   161→            count: Number of agents to select (1-5)\n   162→\n   163→        Returns:\n   164→            List of AgentSpec in priority order\n   165→        \"\"\"\n   166→        min_agents = self._constraints.get(\"minAgents\", 1)\n   167→        max_agents = self._constraints.get(\"maxAgents\", 5)\n   168→        clamped_count = max(min_agents, min(max_agents, count))\n   169→\n   170→        return self._agents[:clamped_count]\n   171→\n   172→    def plan(self, graph_complexity: float) -> SpawnPlan:\n   173→        \"\"\"\n   174→        Create a spawn plan based on graphComplexity.\n   175→\n   176→        This is the main entry point — takes a difficulty score and returns\n   177→        a complete plan for which agents to spawn.\n   178→\n   179→        Args:\n   180→            graph_complexity: 0.0-1.0 from computeGraphSignal() (US-004)\n   181→\n   182→        Returns:\n   183→            SpawnPlan with tier, count, and agent list\n   184→        \"\"\"\n   185→        tier, count = self.classify_difficulty(graph_complexity)\n   186→        agents = self.select_agents(count)\n   187→\n   188→        return SpawnPlan(\n   189→            graph_complexity=graph_complexity,\n   190→            difficulty_tier=tier,\n   191→            agent_count=len(agents),\n   192→            agents=agents,\n   193→            thresholds_used={t[\"tier\"]: t for t in self._thresholds},\n   194→        )\n   195→\n   196→    def plan_with_default(self, graph_complexity: Optional[float] = None) -> SpawnPlan:\n   197→        \"\"\"\n   198→        Plan with graceful degradation when graphComplexity is unavailable.\n   199→\n   200→        Falls back to the default agent count from config when no\n   201→        graph signal is available.\n   202→\n   203→        Args:\n   204→            graph_complexity: 0.0-1.0 or None if unavailable\n   205→\n   206→        Returns:\n   207→            SpawnPlan\n   208→        \"\"\"\n   209→        if graph_complexity is not None:\n   210→            return self.plan(graph_complexity)\n   211→\n   212→        # Fallback: use default agent count\n   213→        default_count = self._constraints.get(\"defaultAgentCount\", 3)\n   214→        agents = self.select_agents(default_count)\n   215→\n   216→        return SpawnPlan(\n   217→            graph_complexity=-1.0,  # sentinel: unavailable\n   218→            difficulty_tier=\"default\",\n   219→            agent_count=len(agents),\n   220→            agents=agents,\n   221→            thresholds_used={t[\"tier\"]: t for t in self._thresholds},\n   222→        )\n   223→\n   224→\n   225→class SupermaxV2:\n   226→    \"\"\"\n   227→    Full SUPERMAX v2 orchestrator combining adaptive spawning (US-007)\n   228→    with Free-MAD trajectory scoring (US-008).\n   229→\n   230→    Usage:\n   231→        v2 = SupermaxV2()\n   232→        plan = v2.plan_agents(graph_complexity=0.7)\n   233→        # ... agents evaluate Round 1 ...\n   234→        peer_context = v2.prepare_peer_context(round1_evals)\n   235→        # ... agents evaluate Round 2 with peer context ...\n   236→        result = v2.synthesize(round1_evals, round2_evals)\n   237→        v2.log(query_hash, plan, result)\n   238→    \"\"\"\n   239→\n   240→    def __init__(self, config_path: Path = None):\n   241→        from coordinator.synthesizer import FreeMadSynthesizer\n   242→        self.spawner = PredictiveSpawner(config_path)\n   243→        self.synthesizer = FreeMadSynthesizer(config_path)\n   244→\n   245→    def plan_agents(self, graph_complexity: float = None) -> SpawnPlan:\n   246→        \"\"\"Plan agent spawning based on graph complexity.\"\"\"\n   247→        return self.spawner.plan_with_default(graph_complexity)\n   248→\n   249→    def prepare_peer_context(self, round1_evals):\n   250→        \"\"\"Anonymize Round 1 evaluations for peer sharing.\"\"\"\n   251→        return self.synthesizer.prepare_peer_context(round1_evals)\n   252→\n   253→    def synthesize(self, round1_evals, round2_evals):\n   254→        \"\"\"Run Free-MAD trajectory synthesis.\"\"\"\n   255→        return self.synthesizer.synthesize(round1_evals, round2_evals)\n   256→\n   257→    def log(self, query_hash: str, plan: SpawnPlan, result=None, cost_estimate: float = 0.0):\n   258→        \"\"\"Log both cost and trajectory data.\"\"\"\n   259→        from coordinator.synthesizer import log_trajectory\n   260→        log_supermax_cost(\n   261→            query_hash=query_hash,\n   262→            agent_count=plan.agent_count,\n   263→            difficulty_tier=plan.difficulty_tier,\n   264→            graph_complexity=plan.graph_complexity,\n   265→            agents_used=[a.name for a in plan.agents],\n   266→            cost_estimate=cost_estimate,\n   267→        )\n   268→        if result is not None:\n   269→            log_trajectory(query_hash, result)\n   270→\n   271→\n   272→def log_supermax_cost(\n   273→    query_hash: str,\n   274→    agent_count: int,\n   275→    difficulty_tier: str,\n   276→    graph_complexity: float,\n   277→    agents_used: List[str],\n   278→    cost_estimate: float = 0.0,\n   279→    log_dir: Path = None,\n   280→):\n   281→    \"\"\"\n   282→    Append cost tracking entry to data/supermax-costs.jsonl.\n   283→\n   284→    Args:\n   285→        query_hash: MD5 hash of the query\n   286→        agent_count: Number of agents spawned\n   287→        difficulty_tier: Classified difficulty tier\n   288→        graph_complexity: The graphComplexity score used\n   289→        agents_used: List of agent names\n   290→        cost_estimate: Estimated USD cost\n   291→        log_dir: Override for the data directory\n   292→    \"\"\"\n   293→    out_dir = log_dir or _COSTS_DIR\n   294→    out_dir.mkdir(parents=True, exist_ok=True)\n   295→    log_path = out_dir / \"supermax-costs.jsonl\"\n   296→\n   297→    entry = {\n   298→        \"ts\": datetime.now(tz=__import__('datetime').timezone.utc).isoformat(),\n   299→        \"query_hash\": query_hash,\n   300→        \"agent_count\": agent_count,\n   301→        \"difficulty_tier\": difficulty_tier,\n   302→        \"graph_complexity\": graph_complexity,\n   303→        \"agents_used\": agents_used,\n   304→        \"cost_estimate\": cost_estimate,\n   305→    }\n   306→\n   307→    with open(log_path, \"a\") as f:\n   308→        f.write(json.dumps(entry) + \"\\n\")\n   309→\n   310→\n   311→# ─────────────────────────────────────────────────────────────────────────────\n   312→# CLI interface\n   313→# ─────────────────────────────────────────────────────────────────────────────\n   314→\n   315→def main():\n   316→    \"\"\"CLI entry point for SUPERMAX v2.\"\"\"\n   317→    import argparse\n   318→\n   319→    parser = argparse.ArgumentParser(\n   320→        description=\"SUPERMAX v2 — Adaptive Agent Count\",\n   321→        formatter_class=argparse.RawDescriptionHelpFormatter,\n   322→        epilog=\"\"\"\n   323→Examples:\n   324→  python3 coordinator/supermax.py plan 0.15    # trivial → 1 agent\n   325→  python3 coordinator/supermax.py plan 0.50    # moderate → 3 agents\n   326→  python3 coordinator/supermax.py plan 0.90    # expert → 5 agents\n   327→  python3 coordinator/supermax.py classify 0.30  # → simple, 2 agents\n   328→        \"\"\",\n   329→    )\n   330→\n   331→    parser.add_argument(\"command\", choices=[\"plan\", \"classify\", \"config\"])\n   332→    parser.add_argument(\"complexity\", nargs=\"?\", type=float, help=\"graphComplexity (0.0-1.0)\")\n   333→\n   334→    args = parser.parse_args()\n   335→\n   336→    spawner = PredictiveSpawner()\n   337→\n   338→    if args.command == \"config\":\n   339→        print(json.dumps(spawner.config, indent=2))\n   340→\n   341→    elif args.command == \"classify\":\n   342→        if args.complexity is None:\n   343→            parser.error(\"classify requires a complexity value\")\n   344→        tier, count = spawner.classify_difficulty(args.complexity)\n   345→        print(f\"Complexity: {args.complexity}\")\n   346→        print(f\"Tier: {tier}\")\n   347→        print(f\"Agent count: {count}\")\n   348→\n   349→    elif args.command == \"plan\":\n   350→        if args.complexity is None:\n   351→            parser.error(\"plan requires a complexity value\")\n   352→        plan = spawner.plan(args.complexity)\n   353→        print(f\"Complexity: {plan.graph_complexity}\")\n   354→        print(f\"Tier: {plan.difficulty_tier}\")\n   355→        print(f\"Agent count: {plan.agent_count}\")\n   356→        print(f\"Agents:\")\n   357→        for a in plan.agents:\n   358→            print(f\"  {a.index + 1}. {a.name} ({a.model}) — {a.perspective}\")\n   359→\n   360→\n   361→if __name__ == \"__main__\":\n   362→    main()\n   363→"}]},"parent_tool_use_id":null,"session_id":"071a4d5f-2d58-4ffd-abdb-361b6aaf2d61","uuid":"0b03080b-c26b-4c85-8c18-699533354632","tool_use_result":{"type":"text","file":{"filePath":"/Users/dicoangelo/projects/core/meta-vengine/coordinator/supermax.py","content":"#!/usr/bin/env python3\n\"\"\"\nSUPERMAX v2 — Adaptive Agent Count with Difficulty-Aware Spawning + Free-MAD Trajectory Scoring.\n\nUS-007: Dynamically selects agent count (1-5) based on graphComplexity\nfrom the multi-feature graph signal (US-004). Simple queries use 1 agent,\ncomplex queries get full council evaluation.\n\nUS-008: Free-MAD trajectory scoring replaces weighted averaging. Agent\nstability (not agreement speed) determines consensus quality. Sycophancy\ndetection via unanimous convergence flagging.\n\nAgent priority order:\n  1. Principal Engineer (technical correctness, waste penalties)\n  2. Security Architect (risk, safety margins, compliance)\n  3. Product Strategist (user value, speed, cost)\n  4. Contrarian (adversarial challenge, from ACE)\n  5. Arbiter (final adjudication, cross-perspective synthesis)\n\nAll thresholds stored in config/supermax-v2.json (learnable, not hardcoded).\n\"\"\"\n\nimport json\nimport sys\nimport os\nimport time\nfrom pathlib import Path\nfrom datetime import datetime\nfrom dataclasses import dataclass, field\nfrom typing import List, Optional, Dict, Any\n\n# Resolve paths relative to the meta-vengine root\n_ROOT = Path(__file__).resolve().parent.parent\n_CONFIG_PATH = _ROOT / \"config\" / \"supermax-v2.json\"\n_COSTS_DIR = _ROOT / \"data\"\n\n\n@dataclass\nclass AgentSpec:\n    \"\"\"Specification for a SUPERMAX agent to spawn.\"\"\"\n    name: str\n    perspective: str\n    model: str\n    index: int  # priority order (0-based)\n\n\n@dataclass\nclass SpawnPlan:\n    \"\"\"Result of PredictiveSpawner.plan() — describes which agents to spawn.\"\"\"\n    graph_complexity: float\n    difficulty_tier: str\n    agent_count: int\n    agents: List[AgentSpec]\n    thresholds_used: Dict[str, Any]\n\n\ndef load_config(config_path: Path = None) -> dict:\n    \"\"\"Load SUPERMAX v2 config from JSON. Falls back to defaults if missing.\"\"\"\n    path = config_path or _CONFIG_PATH\n    try:\n        if path.exists():\n            with open(path, \"r\") as f:\n                return json.load(f)\n    except (json.JSONDecodeError, OSError):\n        pass\n    # Emergency fallback — should never be used in production\n    return {\n        \"agentCountThresholds\": {\n            \"trivial\": {\"max\": 0.25, \"agentCount\": 1},\n            \"simple\": {\"max\": 0.45, \"agentCount\": 2},\n            \"moderate\": {\"max\": 0.65, \"agentCount\": 3},\n            \"complex\": {\"max\": 0.85, \"agentCount\": 4},\n            \"expert\": {\"max\": 1.00, \"agentCount\": 5},\n        },\n        \"agentPriority\": [\n            {\"name\": \"PrincipalEngineer\", \"perspective\": \"Technical correctness, waste penalties\", \"model\": \"sonnet\"},\n            {\"name\": \"SecurityArchitect\", \"perspective\": \"Risk, safety margins, compliance\", \"model\": \"sonnet\"},\n            {\"name\": \"ProductStrategist\", \"perspective\": \"User value, speed, cost\", \"model\": \"sonnet\"},\n            {\"name\": \"Contrarian\", \"perspective\": \"Adversarial challenge, assumption stress-testing\", \"model\": \"sonnet\"},\n            {\"name\": \"Arbiter\", \"perspective\": \"Final adjudication, cross-perspective synthesis\", \"model\": \"opus\"},\n        ],\n        \"constraints\": {\"minAgents\": 1, \"maxAgents\": 5, \"defaultAgentCount\": 3},\n    }\n\n\nclass PredictiveSpawner:\n    \"\"\"\n    Difficulty-aware agent spawner for SUPERMAX v2.\n\n    Consumes graphComplexity (0.0-1.0) from the multi-feature graph signal\n    (US-004) and selects the appropriate number of council agents.\n\n    Thresholds and agent definitions are loaded from config/supermax-v2.json\n    (learnable — future Optimas LRF).\n    \"\"\"\n\n    def __init__(self, config_path: Path = None):\n        self.config = load_config(config_path)\n        self._thresholds = self._parse_thresholds()\n        self._agents = self._parse_agents()\n        self._constraints = self.config.get(\"constraints\", {})\n\n    def _parse_thresholds(self) -> List[dict]:\n        \"\"\"Parse and sort thresholds by max value ascending.\"\"\"\n        raw = self.config.get(\"agentCountThresholds\", {})\n        tiers = []\n        for tier_name, tier_data in raw.items():\n            tiers.append({\n                \"tier\": tier_name,\n                \"max\": tier_data[\"max\"],\n                \"agentCount\": tier_data[\"agentCount\"],\n            })\n        tiers.sort(key=lambda t: t[\"max\"])\n        return tiers\n\n    def _parse_agents(self) -> List[AgentSpec]:\n        \"\"\"Parse agent priority list from config.\"\"\"\n        raw = self.config.get(\"agentPriority\", [])\n        agents = []\n        for i, entry in enumerate(raw):\n            agents.append(AgentSpec(\n                name=entry[\"name\"],\n                perspective=entry.get(\"perspective\", \"\"),\n                model=entry.get(\"model\", \"sonnet\"),\n                index=i,\n            ))\n        return agents\n\n    def classify_difficulty(self, graph_complexity: float) -> tuple:\n        \"\"\"\n        Classify a graphComplexity score into a difficulty tier and agent count.\n\n        Args:\n            graph_complexity: 0.0-1.0 composite score from computeGraphSignal()\n\n        Returns:\n            (tier_name, agent_count) tuple\n        \"\"\"\n        clamped = max(0.0, min(1.0, graph_complexity))\n\n        for tier in self._thresholds:\n            if clamped < tier[\"max\"] or (clamped == tier[\"max\"] and tier[\"tier\"] == \"expert\"):\n                return tier[\"tier\"], tier[\"agentCount\"]\n\n        # Fallback: if complexity exactly equals 1.0 and no tier matched\n        if self._thresholds:\n            last = self._thresholds[-1]\n            return last[\"tier\"], last[\"agentCount\"]\n\n        # Ultimate fallback\n        default_count = self._constraints.get(\"defaultAgentCount\", 3)\n        return \"unknown\", default_count\n\n    def select_agents(self, count: int) -> List[AgentSpec]:\n        \"\"\"\n        Select agents in priority order up to the given count.\n\n        Priority: PrincipalEngineer > SecurityArchitect > ProductStrategist > Contrarian > Arbiter\n\n        Args:\n            count: Number of agents to select (1-5)\n\n        Returns:\n            List of AgentSpec in priority order\n        \"\"\"\n        min_agents = self._constraints.get(\"minAgents\", 1)\n        max_agents = self._constraints.get(\"maxAgents\", 5)\n        clamped_count = max(min_agents, min(max_agents, count))\n\n        return self._agents[:clamped_count]\n\n    def plan(self, graph_complexity: float) -> SpawnPlan:\n        \"\"\"\n        Create a spawn plan based on graphComplexity.\n\n        This is the main entry point — takes a difficulty score and returns\n        a complete plan for which agents to spawn.\n\n        Args:\n            graph_complexity: 0.0-1.0 from computeGraphSignal() (US-004)\n\n        Returns:\n            SpawnPlan with tier, count, and agent list\n        \"\"\"\n        tier, count = self.classify_difficulty(graph_complexity)\n        agents = self.select_agents(count)\n\n        return SpawnPlan(\n            graph_complexity=graph_complexity,\n            difficulty_tier=tier,\n            agent_count=len(agents),\n            agents=agents,\n            thresholds_used={t[\"tier\"]: t for t in self._thresholds},\n        )\n\n    def plan_with_default(self, graph_complexity: Optional[float] = None) -> SpawnPlan:\n        \"\"\"\n        Plan with graceful degradation when graphComplexity is unavailable.\n\n        Falls back to the default agent count from config when no\n        graph signal is available.\n\n        Args:\n            graph_complexity: 0.0-1.0 or None if unavailable\n\n        Returns:\n            SpawnPlan\n        \"\"\"\n        if graph_complexity is not None:\n            return self.plan(graph_complexity)\n\n        # Fallback: use default agent count\n        default_count = self._constraints.get(\"defaultAgentCount\", 3)\n        agents = self.select_agents(default_count)\n\n        return SpawnPlan(\n            graph_complexity=-1.0,  # sentinel: unavailable\n            difficulty_tier=\"default\",\n            agent_count=len(agents),\n            agents=agents,\n            thresholds_used={t[\"tier\"]: t for t in self._thresholds},\n        )\n\n\nclass SupermaxV2:\n    \"\"\"\n    Full SUPERMAX v2 orchestrator combining adaptive spawning (US-007)\n    with Free-MAD trajectory scoring (US-008).\n\n    Usage:\n        v2 = SupermaxV2()\n        plan = v2.plan_agents(graph_complexity=0.7)\n        # ... agents evaluate Round 1 ...\n        peer_context = v2.prepare_peer_context(round1_evals)\n        # ... agents evaluate Round 2 with peer context ...\n        result = v2.synthesize(round1_evals, round2_evals)\n        v2.log(query_hash, plan, result)\n    \"\"\"\n\n    def __init__(self, config_path: Path = None):\n        from coordinator.synthesizer import FreeMadSynthesizer\n        self.spawner = PredictiveSpawner(config_path)\n        self.synthesizer = FreeMadSynthesizer(config_path)\n\n    def plan_agents(self, graph_complexity: float = None) -> SpawnPlan:\n        \"\"\"Plan agent spawning based on graph complexity.\"\"\"\n        return self.spawner.plan_with_default(graph_complexity)\n\n    def prepare_peer_context(self, round1_evals):\n        \"\"\"Anonymize Round 1 evaluations for peer sharing.\"\"\"\n        return self.synthesizer.prepare_peer_context(round1_evals)\n\n    def synthesize(self, round1_evals, round2_evals):\n        \"\"\"Run Free-MAD trajectory synthesis.\"\"\"\n        return self.synthesizer.synthesize(round1_evals, round2_evals)\n\n    def log(self, query_hash: str, plan: SpawnPlan, result=None, cost_estimate: float = 0.0):\n        \"\"\"Log both cost and trajectory data.\"\"\"\n        from coordinator.synthesizer import log_trajectory\n        log_supermax_cost(\n            query_hash=query_hash,\n            agent_count=plan.agent_count,\n            difficulty_tier=plan.difficulty_tier,\n            graph_complexity=plan.graph_complexity,\n            agents_used=[a.name for a in plan.agents],\n            cost_estimate=cost_estimate,\n        )\n        if result is not None:\n            log_trajectory(query_hash, result)\n\n\ndef log_supermax_cost(\n    query_hash: str,\n    agent_count: int,\n    difficulty_tier: str,\n    graph_complexity: float,\n    agents_used: List[str],\n    cost_estimate: float = 0.0,\n    log_dir: Path = None,\n):\n    \"\"\"\n    Append cost tracking entry to data/supermax-costs.jsonl.\n\n    Args:\n        query_hash: MD5 hash of the query\n        agent_count: Number of agents spawned\n        difficulty_tier: Classified difficulty tier\n        graph_complexity: The graphComplexity score used\n        agents_used: List of agent names\n        cost_estimate: Estimated USD cost\n        log_dir: Override for the data directory\n    \"\"\"\n    out_dir = log_dir or _COSTS_DIR\n    out_dir.mkdir(parents=True, exist_ok=True)\n    log_path = out_dir / \"supermax-costs.jsonl\"\n\n    entry = {\n        \"ts\": datetime.now(tz=__import__('datetime').timezone.utc).isoformat(),\n        \"query_hash\": query_hash,\n        \"agent_count\": agent_count,\n        \"difficulty_tier\": difficulty_tier,\n        \"graph_complexity\": graph_complexity,\n        \"agents_used\": agents_used,\n        \"cost_estimate\": cost_estimate,\n    }\n\n    with open(log_path, \"a\") as f:\n        f.write(json.dumps(entry) + \"\\n\")\n\n\n# ─────────────────────────────────────────────────────────────────────────────\n# CLI interface\n# ─────────────────────────────────────────────────────────────────────────────\n\ndef main():\n    \"\"\"CLI entry point for SUPERMAX v2.\"\"\"\n    import argparse\n\n    parser = argparse.ArgumentParser(\n        description=\"SUPERMAX v2 — Adaptive Agent Count\",\n        formatter_class=argparse.RawDescriptionHelpFormatter,\n        epilog=\"\"\"\nExamples:\n  python3 coordinator/supermax.py plan 0.15    # trivial → 1 agent\n  python3 coordinator/supermax.py plan 0.50    # moderate → 3 agents\n  python3 coordinator/supermax.py plan 0.90    # expert → 5 agents\n  python3 coordinator/supermax.py classify 0.30  # → simple, 2 agents\n        \"\"\",\n    )\n\n    parser.add_argument(\"command\", choices=[\"plan\", \"classify\", \"config\"])\n    parser.add_argument(\"complexity\", nargs=\"?\", type=float, help=\"graphComplexity (0.0-1.0)\")\n\n    args = parser.parse_args()\n\n    spawner = PredictiveSpawner()\n\n    if args.command == \"config\":\n        print(json.dumps(spawner.config, indent=2))\n\n    elif args.command == \"classify\":\n        if args.complexity is None:\n            parser.error(\"classify requires a complexity value\")\n        tier, count = spawner.classify_difficulty(args.complexity)\n        print(f\"Complexity: {args.complexity}\")\n        print(f\"Tier: {tier}\")\n        print(f\"Agent count: {count}\")\n\n    elif args.command == \"plan\":\n        if args.complexity is None:\n            parser.error(\"plan requires a complexity value\")\n        plan = spawner.plan(args.complexity)\n        print(f\"Complexity: {plan.graph_complexity}\")\n        print(f\"Tier: {plan.difficulty_tier}\")\n        print(f\"Agent count: {plan.agent_count}\")\n        print(f\"Agents:\")\n        for a in plan.agents:\n            print(f\"  {a.index + 1}. {a.name} ({a.model}) — {a.perspective}\")\n\n\nif __name__ == \"__main__\":\n    main()\n","numLines":363,"startLine":1,"totalLines":363}}}
