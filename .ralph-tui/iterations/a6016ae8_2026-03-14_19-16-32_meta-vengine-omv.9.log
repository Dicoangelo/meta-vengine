{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AXzsfn4xhUEXbhPWSCt6jA","type":"tool_result","content":"     1→#!/usr/bin/env python3\n     2→\"\"\"\n     3→Free-MAD Trajectory Scoring Synthesizer for SUPERMAX v2.\n     4→\n     5→US-008: Replaces DisagreementAwareSynthesizer weighted averaging with\n     6→trajectory stability scoring. Based on Free-MAD (arXiv:2509.11035).\n     7→\n     8→Protocol:\n     9→  1. Each agent evaluates independently (Round 1)\n    10→  2. Anonymized peer reasoning shared (agent labels stripped — anti-sycophancy)\n    11→  3. Each agent re-evaluates (Round 2)\n    12→  4. Delta = trajectory. Stable agents → higher weight. Unstable → lower weight.\n    13→  5. Unanimous convergence → flag sycophancy → trigger Contrarian.\n    14→\"\"\"\n    15→\n    16→import json\n    17→import math\n    18→import os\n    19→import sys\n    20→from pathlib import Path\n    21→from datetime import datetime, timezone\n    22→from dataclasses import dataclass, field\n    23→from typing import List, Optional, Dict, Any, Tuple\n    24→\n    25→# Resolve paths relative to the meta-vengine root\n    26→_ROOT = Path(__file__).resolve().parent.parent\n    27→_CONFIG_PATH = _ROOT / \"config\" / \"supermax-v2.json\"\n    28→_TRAJECTORIES_DIR = _ROOT / \"data\"\n    29→\n    30→\n    31→@dataclass\n    32→class DQEvaluation:\n    33→    \"\"\"A single DQ evaluation from one agent.\"\"\"\n    34→    agent_name: str\n    35→    validity: float      # 0.0-1.0\n    36→    specificity: float   # 0.0-1.0\n    37→    correctness: float   # 0.0-1.0\n    38→    reasoning: str = \"\"\n    39→    composite_dq: float = 0.0\n    40→\n    41→    def __post_init__(self):\n    42→        self.composite_dq = (\n    43→            self.validity * 0.4 +\n    44→            self.specificity * 0.3 +\n    45→            self.correctness * 0.3\n    46→        )\n    47→\n    48→    def dimensions(self) -> Dict[str, float]:\n    49→        return {\n    50→            \"validity\": self.validity,\n    51→            \"specificity\": self.specificity,\n    52→            \"correctness\": self.correctness,\n    53→        }\n    54→\n    55→\n    56→@dataclass\n    57→class AgentTrajectory:\n    58→    \"\"\"Trajectory data for one agent across Round 1 and Round 2.\"\"\"\n    59→    agent_name: str\n    60→    round1: DQEvaluation\n    61→    round2: DQEvaluation\n    62→    delta_validity: float = 0.0\n    63→    delta_specificity: float = 0.0\n    64→    delta_correctness: float = 0.0\n    65→    delta_composite: float = 0.0\n    66→    stability_score: float = 0.0  # 0.0 (unstable) to 1.0 (perfectly stable)\n    67→    trajectory_weight: float = 0.0  # weight in final consensus\n    68→\n    69→    def __post_init__(self):\n    70→        self.delta_validity = abs(self.round2.validity - self.round1.validity)\n    71→        self.delta_specificity = abs(self.round2.specificity - self.round1.specificity)\n    72→        self.delta_correctness = abs(self.round2.correctness - self.round1.correctness)\n    73→        self.delta_composite = abs(self.round2.composite_dq - self.round1.composite_dq)\n    74→\n    75→    @property\n    76→    def max_dimension_delta(self) -> float:\n    77→        return max(self.delta_validity, self.delta_specificity, self.delta_correctness)\n    78→\n    79→\n    80→@dataclass\n    81→class SynthesisResult:\n    82→    \"\"\"Final consensus result from Free-MAD trajectory scoring.\"\"\"\n    83→    consensus_dq: float\n    84→    consensus_validity: float\n    85→    consensus_specificity: float\n    86→    consensus_correctness: float\n    87→    trajectories: List[AgentTrajectory]\n    88→    sycophancy_flagged: bool\n    89→    contrarian_triggered: bool\n    90→    disagreement_dimensions: List[str]  # which dimensions diverged > threshold\n    91→    method: str = \"free_mad_trajectory\"\n    92→\n    93→\n    94→def load_free_mad_config(config_path: Path = None) -> dict:\n    95→    \"\"\"Load Free-MAD specific config from supermax-v2.json.\"\"\"\n    96→    path = config_path or _CONFIG_PATH\n    97→    try:\n    98→        if path.exists():\n    99→            with open(path, \"r\") as f:\n   100→                cfg = json.load(f)\n   101→                return cfg.get(\"freeMad\", _default_free_mad_config())\n   102→    except (json.JSONDecodeError, OSError):\n   103→        pass\n   104→    return _default_free_mad_config()\n   105→\n   106→\n   107→def _default_free_mad_config() -> dict:\n   108→    \"\"\"Emergency fallback config for Free-MAD.\"\"\"\n   109→    return {\n   110→        \"stabilityDecayRate\": 5.0,\n   111→        \"sycophancyConvergenceThreshold\": 0.05,\n   112→        \"disagreementEscalationThreshold\": 0.15,\n   113→        \"minStabilityWeight\": 0.1,\n   114→        \"maxStabilityWeight\": 1.0,\n   115→    }\n   116→\n   117→\n   118→def anonymize_reasoning(evaluations: List[DQEvaluation]) -> List[Dict[str, Any]]:\n   119→    \"\"\"\n   120→    Strip agent labels from evaluations for anti-sycophancy peer sharing.\n   121→\n   122→    Returns anonymized reasoning blocks with only scores and reasoning text.\n   123→    Agent names are replaced with opaque identifiers (Evaluator A, B, C...).\n   124→    \"\"\"\n   125→    anonymized = []\n   126→    for i, ev in enumerate(evaluations):\n   127→        label = chr(65 + i)  # A, B, C, ...\n   128→        anonymized.append({\n   129→            \"evaluator\": f\"Evaluator {label}\",\n   130→            \"scores\": {\n   131→                \"validity\": ev.validity,\n   132→                \"specificity\": ev.specificity,\n   133→                \"correctness\": ev.correctness,\n   134→                \"composite_dq\": ev.composite_dq,\n   135→            },\n   136→            \"reasoning\": ev.reasoning,\n   137→        })\n   138→    return anonymized\n   139→\n   140→\n   141→def compute_stability_score(trajectory: AgentTrajectory, decay_rate: float = 5.0) -> float:\n   142→    \"\"\"\n   143→    Compute stability score from trajectory delta using exponential decay.\n   144→\n   145→    stability = exp(-decay_rate * max_dimension_delta)\n   146→\n   147→    Small delta → stability ≈ 1.0 (agent held position)\n   148→    Large delta → stability → 0.0 (agent capitulated)\n   149→\n   150→    Args:\n   151→        trajectory: The agent's trajectory across rounds\n   152→        decay_rate: How aggressively to penalize instability (default 5.0)\n   153→\n   154→    Returns:\n   155→        Stability score 0.0-1.0\n   156→    \"\"\"\n   157→    return math.exp(-decay_rate * trajectory.max_dimension_delta)\n   158→\n   159→\n   160→def compute_trajectory_weights(\n   161→    trajectories: List[AgentTrajectory],\n   162→    config: dict = None,\n   163→) -> List[AgentTrajectory]:\n   164→    \"\"\"\n   165→    Compute trajectory-based weights for all agents.\n   166→\n   167→    Stable agents get higher weight. Weights are normalized to sum to 1.0.\n   168→    Minimum weight prevents any agent from being completely silenced.\n   169→\n   170→    Args:\n   171→        trajectories: List of agent trajectories\n   172→        config: Free-MAD config dict\n   173→\n   174→    Returns:\n   175→        Same trajectories with stability_score and trajectory_weight populated\n   176→    \"\"\"\n   177→    cfg = config or _default_free_mad_config()\n   178→    decay_rate = cfg.get(\"stabilityDecayRate\", 5.0)\n   179→    min_weight = cfg.get(\"minStabilityWeight\", 0.1)\n   180→    max_weight = cfg.get(\"maxStabilityWeight\", 1.0)\n   181→\n   182→    # Compute raw stability scores\n   183→    for t in trajectories:\n   184→        t.stability_score = compute_stability_score(t, decay_rate)\n   185→\n   186→    # Clamp and normalize\n   187→    raw_weights = [max(min_weight, min(max_weight, t.stability_score)) for t in trajectories]\n   188→    total = sum(raw_weights)\n   189→\n   190→    if total > 0:\n   191→        for i, t in enumerate(trajectories):\n   192→            t.trajectory_weight = raw_weights[i] / total\n   193→    else:\n   194→        # Uniform fallback\n   195→        uniform = 1.0 / len(trajectories) if trajectories else 0.0\n   196→        for t in trajectories:\n   197→            t.trajectory_weight = uniform\n   198→\n   199→    return trajectories\n   200→\n   201→\n   202→def detect_sycophancy(\n   203→    trajectories: List[AgentTrajectory],\n   204→    convergence_threshold: float = 0.05,\n   205→) -> bool:\n   206→    \"\"\"\n   207→    Detect unanimous convergence (potential sycophancy).\n   208→\n   209→    If ALL agents shifted toward each other (all deltas point toward the\n   210→    group mean and are below threshold after convergence), flag as sycophancy.\n   211→\n   212→    Args:\n   213→        trajectories: List of agent trajectories after Round 2\n   214→        convergence_threshold: Max spread in Round 2 scores to flag convergence\n   215→\n   216→    Returns:\n   217→        True if sycophancy pattern detected\n   218→    \"\"\"\n   219→    if len(trajectories) < 2:\n   220→        return False\n   221→\n   222→    # Check if all agents moved (none held position perfectly)\n   223→    all_moved = all(t.delta_composite > 0.01 for t in trajectories)\n   224→    if not all_moved:\n   225→        return False\n   226→\n   227→    # Check if Round 2 scores converged to a tight cluster\n   228→    r2_composites = [t.round2.composite_dq for t in trajectories]\n   229→    r2_spread = max(r2_composites) - min(r2_composites)\n   230→\n   231→    # Check Round 1 had meaningful disagreement\n   232→    r1_composites = [t.round1.composite_dq for t in trajectories]\n   233→    r1_spread = max(r1_composites) - min(r1_composites)\n   234→\n   235→    # Sycophancy: started with disagreement, ended with tight convergence, all moved\n   236→    return r1_spread > convergence_threshold and r2_spread <= convergence_threshold\n   237→\n   238→\n   239→def find_disagreement_dimensions(\n   240→    trajectories: List[AgentTrajectory],\n   241→    threshold: float = 0.15,\n   242→) -> List[str]:\n   243→    \"\"\"\n   244→    Find DQ dimensions where agent trajectories diverge beyond threshold.\n   245→\n   246→    Used for disagreement escalation (US-009).\n   247→\n   248→    Args:\n   249→        trajectories: List of agent trajectories\n   250→        threshold: Divergence threshold per dimension\n   251→\n   252→    Returns:\n   253→        List of dimension names that diverged\n   254→    \"\"\"\n   255→    if len(trajectories) < 2:\n   256→        return []\n   257→\n   258→    divergent = []\n   259→    for dim in [\"validity\", \"specificity\", \"correctness\"]:\n   260→        # Check spread of Round 2 scores on this dimension\n   261→        r2_scores = [getattr(t.round2, dim) for t in trajectories]\n   262→        spread = max(r2_scores) - min(r2_scores)\n   263→        if spread > threshold:\n   264→            divergent.append(dim)\n   265→\n   266→    return divergent\n   267→\n   268→\n   269→def synthesize_consensus(\n   270→    trajectories: List[AgentTrajectory],\n   271→) -> Dict[str, float]:\n   272→    \"\"\"\n   273→    Compute weighted consensus from trajectory-weighted agents.\n   274→\n   275→    Uses Round 2 scores weighted by trajectory stability.\n   276→\n   277→    Args:\n   278→        trajectories: Trajectories with trajectory_weight populated\n   279→\n   280→    Returns:\n   281→        Dict with consensus scores per dimension + composite\n   282→    \"\"\"\n   283→    consensus_v = 0.0\n   284→    consensus_s = 0.0\n   285→    consensus_c = 0.0\n   286→\n   287→    for t in trajectories:\n   288→        consensus_v += t.round2.validity * t.trajectory_weight\n   289→        consensus_s += t.round2.specificity * t.trajectory_weight\n   290→        consensus_c += t.round2.correctness * t.trajectory_weight\n   291→\n   292→    composite = consensus_v * 0.4 + consensus_s * 0.3 + consensus_c * 0.3\n   293→\n   294→    return {\n   295→        \"validity\": consensus_v,\n   296→        \"specificity\": consensus_s,\n   297→        \"correctness\": consensus_c,\n   298→        \"composite_dq\": composite,\n   299→    }\n   300→\n   301→\n   302→class FreeMadSynthesizer:\n   303→    \"\"\"\n   304→    Free-MAD Trajectory Scoring Synthesizer.\n   305→\n   306→    Replaces DisagreementAwareSynthesizer with trajectory stability scoring.\n   307→    Protocol:\n   308→      1. Receive Round 1 evaluations from agents\n   309→      2. Anonymize and share peer reasoning\n   310→      3. Receive Round 2 evaluations\n   311→      4. Compute trajectories, stability, weights\n   312→      5. Detect sycophancy / disagreement\n   313→      6. Produce weighted consensus\n   314→    \"\"\"\n   315→\n   316→    def __init__(self, config_path: Path = None):\n   317→        self.config = load_free_mad_config(config_path)\n   318→        self._decay_rate = self.config.get(\"stabilityDecayRate\", 5.0)\n   319→        self._sycophancy_threshold = self.config.get(\"sycophancyConvergenceThreshold\", 0.05)\n   320→        self._escalation_threshold = self.config.get(\"disagreementEscalationThreshold\", 0.15)\n   321→\n   322→    def prepare_peer_context(self, round1_evals: List[DQEvaluation]) -> List[Dict[str, Any]]:\n   323→        \"\"\"\n   324→        Prepare anonymized peer reasoning for Round 2.\n   325→\n   326→        Strips agent labels (anti-sycophancy per CONSENSAGENT ACL 2025).\n   327→\n   328→        Args:\n   329→            round1_evals: Round 1 evaluations from all agents\n   330→\n   331→        Returns:\n   332→            Anonymized reasoning blocks for peer exposure\n   333→        \"\"\"\n   334→        return anonymize_reasoning(round1_evals)\n   335→\n   336→    def score_trajectories(\n   337→        self,\n   338→        round1_evals: List[DQEvaluation],\n   339→        round2_evals: List[DQEvaluation],\n   340→    ) -> List[AgentTrajectory]:\n   341→        \"\"\"\n   342→        Compute trajectories from Round 1 → Round 2 evaluations.\n   343→\n   344→        Args:\n   345→            round1_evals: Initial independent evaluations\n   346→            round2_evals: Post-peer-exposure evaluations\n   347→\n   348→        Returns:\n   349→            List of AgentTrajectory with stability and weights computed\n   350→        \"\"\"\n   351→        if len(round1_evals) != len(round2_evals):\n   352→            raise ValueError(\n   353→                f\"Round 1 ({len(round1_evals)}) and Round 2 ({len(round2_evals)}) \"\n   354→                \"evaluation counts must match\"\n   355→            )\n   356→\n   357→        trajectories = []\n   358→        for r1, r2 in zip(round1_evals, round2_evals):\n   359→            if r1.agent_name != r2.agent_name:\n   360→                raise ValueError(\n   361→                    f\"Agent mismatch: Round 1 '{r1.agent_name}' vs Round 2 '{r2.agent_name}'\"\n   362→                )\n   363→            trajectories.append(AgentTrajectory(\n   364→                agent_name=r1.agent_name,\n   365→                round1=r1,\n   366→                round2=r2,\n   367→            ))\n   368→\n   369→        # Compute stability scores and weights\n   370→        trajectories = compute_trajectory_weights(trajectories, self.config)\n   371→\n   372→        return trajectories\n   373→\n   374→    def synthesize(\n   375→        self,\n   376→        round1_evals: List[DQEvaluation],\n   377→        round2_evals: List[DQEvaluation],\n   378→    ) -> SynthesisResult:\n   379→        \"\"\"\n   380→        Full Free-MAD synthesis: trajectories → sycophancy check → consensus.\n   381→\n   382→        This is the main entry point for SUPERMAX v2 consensus.\n   383→\n   384→        Args:\n   385→            round1_evals: Independent evaluations (Round 1)\n   386→            round2_evals: Post-peer-exposure evaluations (Round 2)\n   387→\n   388→        Returns:\n   389→            SynthesisResult with consensus scores, trajectories, and flags\n   390→        \"\"\"\n   391→        trajectories = self.score_trajectories(round1_evals, round2_evals)\n   392→\n   393→        # Detect sycophancy\n   394→        sycophancy_flagged = detect_sycophancy(\n   395→            trajectories, self._sycophancy_threshold\n   396→        )\n   397→\n   398→        # Find disagreement dimensions (for US-009 escalation)\n   399→        disagreement_dims = find_disagreement_dimensions(\n   400→            trajectories, self._escalation_threshold\n   401→        )\n   402→\n   403→        # Determine if Contrarian should be triggered\n   404→        contrarian_triggered = sycophancy_flagged\n   405→\n   406→        # Compute weighted consensus\n   407→        consensus = synthesize_consensus(trajectories)\n   408→\n   409→        return SynthesisResult(\n   410→            consensus_dq=consensus[\"composite_dq\"],\n   411→            consensus_validity=consensus[\"validity\"],\n   412→            consensus_specificity=consensus[\"specificity\"],\n   413→            consensus_correctness=consensus[\"correctness\"],\n   414→            trajectories=trajectories,\n   415→            sycophancy_flagged=sycophancy_flagged,\n   416→            contrarian_triggered=contrarian_triggered,\n   417→            disagreement_dimensions=disagreement_dims,\n   418→        )\n   419→\n   420→\n   421→def log_trajectory(\n   422→    query_hash: str,\n   423→    result: SynthesisResult,\n   424→    log_dir: Path = None,\n   425→):\n   426→    \"\"\"\n   427→    Append trajectory data per query to data/supermax-trajectories.jsonl.\n   428→\n   429→    Args:\n   430→        query_hash: MD5 hash of the query\n   431→        result: SynthesisResult from synthesize()\n   432→        log_dir: Override for the data directory\n   433→    \"\"\"\n   434→    out_dir = log_dir or _TRAJECTORIES_DIR\n   435→    out_dir.mkdir(parents=True, exist_ok=True)\n   436→    log_path = out_dir / \"supermax-trajectories.jsonl\"\n   437→\n   438→    trajectory_data = []\n   439→    for t in result.trajectories:\n   440→        trajectory_data.append({\n   441→            \"agent\": t.agent_name,\n   442→            \"round1_dq\": t.round1.composite_dq,\n   443→            \"round2_dq\": t.round2.composite_dq,\n   444→            \"delta_validity\": round(t.delta_validity, 4),\n   445→            \"delta_specificity\": round(t.delta_specificity, 4),\n   446→            \"delta_correctness\": round(t.delta_correctness, 4),\n   447→            \"delta_composite\": round(t.delta_composite, 4),\n   448→            \"stability_score\": round(t.stability_score, 4),\n   449→            \"trajectory_weight\": round(t.trajectory_weight, 4),\n   450→        })\n   451→\n   452→    entry = {\n   453→        \"ts\": datetime.now(tz=timezone.utc).isoformat(),\n   454→        \"query_hash\": query_hash,\n   455→        \"consensus_dq\": round(result.consensus_dq, 4),\n   456→        \"sycophancy_flagged\": result.sycophancy_flagged,\n   457→        \"contrarian_triggered\": result.contrarian_triggered,\n   458→        \"disagreement_dimensions\": result.disagreement_dimensions,\n   459→        \"agent_count\": len(result.trajectories),\n   460→        \"trajectories\": trajectory_data,\n   461→        \"method\": result.method,\n   462→    }\n   463→\n   464→    with open(log_path, \"a\") as f:\n   465→        f.write(json.dumps(entry) + \"\\n\")\n   466→\n   467→\n   468→# ─────────────────────────────────────────────────────────────────────────────\n   469→# CLI interface\n   470→# ─────────────────────────────────────────────────────────────────────────────\n   471→\n   472→def main():\n   473→    \"\"\"CLI entry point for Free-MAD Synthesizer.\"\"\"\n   474→    import argparse\n   475→\n   476→    parser = argparse.ArgumentParser(\n   477→        description=\"Free-MAD Trajectory Scoring Synthesizer\",\n   478→        formatter_class=argparse.RawDescriptionHelpFormatter,\n   479→        epilog=\"\"\"\n   480→Examples:\n   481→  python3 coordinator/synthesizer.py config     # Show Free-MAD config\n   482→  python3 coordinator/synthesizer.py demo       # Run demo synthesis\n   483→        \"\"\",\n   484→    )\n   485→\n   486→    parser.add_argument(\"command\", choices=[\"config\", \"demo\"])\n   487→    args = parser.parse_args()\n   488→\n   489→    synth = FreeMadSynthesizer()\n   490→\n   491→    if args.command == \"config\":\n   492→        print(json.dumps(synth.config, indent=2))\n   493→\n   494→    elif args.command == \"demo\":\n   495→        # Demo: 3 agents, one stable, one unstable, one moderate\n   496→        r1 = [\n   497→            DQEvaluation(\"PrincipalEngineer\", 0.8, 0.7, 0.9, \"Technically sound\"),\n   498→            DQEvaluation(\"SecurityArchitect\", 0.6, 0.8, 0.7, \"Some risk concerns\"),\n   499→            DQEvaluation(\"ProductStrategist\", 0.9, 0.6, 0.8, \"Good user value\"),\n   500→        ]\n   501→        # After peer exposure: Engineer holds, Architect shifts, Strategist moderate shift\n   502→        r2 = [\n   503→            DQEvaluation(\"PrincipalEngineer\", 0.8, 0.72, 0.88, \"Held position after review\"),\n   504→            DQEvaluation(\"SecurityArchitect\", 0.78, 0.75, 0.82, \"Shifted toward peers\"),\n   505→            DQEvaluation(\"ProductStrategist\", 0.85, 0.65, 0.8, \"Minor adjustment\"),\n   506→        ]\n   507→\n   508→        result = synth.synthesize(r1, r2)\n   509→        print(f\"Consensus DQ: {result.consensus_dq:.4f}\")\n   510→        print(f\"Sycophancy flagged: {result.sycophancy_flagged}\")\n   511→        print(f\"Disagreement dims: {result.disagreement_dimensions}\")\n   512→        print(f\"\\nTrajectories:\")\n   513→        for t in result.trajectories:\n   514→            print(f\"  {t.agent_name}: stability={t.stability_score:.4f} weight={t.trajectory_weight:.4f} Δ={t.delta_composite:.4f}\")\n   515→\n   516→\n   517→if __name__ == \"__main__\":\n   518→    main()\n   519→"}]},"parent_tool_use_id":null,"session_id":"071a4d5f-2d58-4ffd-abdb-361b6aaf2d61","uuid":"65d3f593-0c33-4a21-908e-4bc3104b2778","tool_use_result":{"type":"text","file":{"filePath":"/Users/dicoangelo/projects/core/meta-vengine/coordinator/synthesizer.py","content":"#!/usr/bin/env python3\n\"\"\"\nFree-MAD Trajectory Scoring Synthesizer for SUPERMAX v2.\n\nUS-008: Replaces DisagreementAwareSynthesizer weighted averaging with\ntrajectory stability scoring. Based on Free-MAD (arXiv:2509.11035).\n\nProtocol:\n  1. Each agent evaluates independently (Round 1)\n  2. Anonymized peer reasoning shared (agent labels stripped — anti-sycophancy)\n  3. Each agent re-evaluates (Round 2)\n  4. Delta = trajectory. Stable agents → higher weight. Unstable → lower weight.\n  5. Unanimous convergence → flag sycophancy → trigger Contrarian.\n\"\"\"\n\nimport json\nimport math\nimport os\nimport sys\nfrom pathlib import Path\nfrom datetime import datetime, timezone\nfrom dataclasses import dataclass, field\nfrom typing import List, Optional, Dict, Any, Tuple\n\n# Resolve paths relative to the meta-vengine root\n_ROOT = Path(__file__).resolve().parent.parent\n_CONFIG_PATH = _ROOT / \"config\" / \"supermax-v2.json\"\n_TRAJECTORIES_DIR = _ROOT / \"data\"\n\n\n@dataclass\nclass DQEvaluation:\n    \"\"\"A single DQ evaluation from one agent.\"\"\"\n    agent_name: str\n    validity: float      # 0.0-1.0\n    specificity: float   # 0.0-1.0\n    correctness: float   # 0.0-1.0\n    reasoning: str = \"\"\n    composite_dq: float = 0.0\n\n    def __post_init__(self):\n        self.composite_dq = (\n            self.validity * 0.4 +\n            self.specificity * 0.3 +\n            self.correctness * 0.3\n        )\n\n    def dimensions(self) -> Dict[str, float]:\n        return {\n            \"validity\": self.validity,\n            \"specificity\": self.specificity,\n            \"correctness\": self.correctness,\n        }\n\n\n@dataclass\nclass AgentTrajectory:\n    \"\"\"Trajectory data for one agent across Round 1 and Round 2.\"\"\"\n    agent_name: str\n    round1: DQEvaluation\n    round2: DQEvaluation\n    delta_validity: float = 0.0\n    delta_specificity: float = 0.0\n    delta_correctness: float = 0.0\n    delta_composite: float = 0.0\n    stability_score: float = 0.0  # 0.0 (unstable) to 1.0 (perfectly stable)\n    trajectory_weight: float = 0.0  # weight in final consensus\n\n    def __post_init__(self):\n        self.delta_validity = abs(self.round2.validity - self.round1.validity)\n        self.delta_specificity = abs(self.round2.specificity - self.round1.specificity)\n        self.delta_correctness = abs(self.round2.correctness - self.round1.correctness)\n        self.delta_composite = abs(self.round2.composite_dq - self.round1.composite_dq)\n\n    @property\n    def max_dimension_delta(self) -> float:\n        return max(self.delta_validity, self.delta_specificity, self.delta_correctness)\n\n\n@dataclass\nclass SynthesisResult:\n    \"\"\"Final consensus result from Free-MAD trajectory scoring.\"\"\"\n    consensus_dq: float\n    consensus_validity: float\n    consensus_specificity: float\n    consensus_correctness: float\n    trajectories: List[AgentTrajectory]\n    sycophancy_flagged: bool\n    contrarian_triggered: bool\n    disagreement_dimensions: List[str]  # which dimensions diverged > threshold\n    method: str = \"free_mad_trajectory\"\n\n\ndef load_free_mad_config(config_path: Path = None) -> dict:\n    \"\"\"Load Free-MAD specific config from supermax-v2.json.\"\"\"\n    path = config_path or _CONFIG_PATH\n    try:\n        if path.exists():\n            with open(path, \"r\") as f:\n                cfg = json.load(f)\n                return cfg.get(\"freeMad\", _default_free_mad_config())\n    except (json.JSONDecodeError, OSError):\n        pass\n    return _default_free_mad_config()\n\n\ndef _default_free_mad_config() -> dict:\n    \"\"\"Emergency fallback config for Free-MAD.\"\"\"\n    return {\n        \"stabilityDecayRate\": 5.0,\n        \"sycophancyConvergenceThreshold\": 0.05,\n        \"disagreementEscalationThreshold\": 0.15,\n        \"minStabilityWeight\": 0.1,\n        \"maxStabilityWeight\": 1.0,\n    }\n\n\ndef anonymize_reasoning(evaluations: List[DQEvaluation]) -> List[Dict[str, Any]]:\n    \"\"\"\n    Strip agent labels from evaluations for anti-sycophancy peer sharing.\n\n    Returns anonymized reasoning blocks with only scores and reasoning text.\n    Agent names are replaced with opaque identifiers (Evaluator A, B, C...).\n    \"\"\"\n    anonymized = []\n    for i, ev in enumerate(evaluations):\n        label = chr(65 + i)  # A, B, C, ...\n        anonymized.append({\n            \"evaluator\": f\"Evaluator {label}\",\n            \"scores\": {\n                \"validity\": ev.validity,\n                \"specificity\": ev.specificity,\n                \"correctness\": ev.correctness,\n                \"composite_dq\": ev.composite_dq,\n            },\n            \"reasoning\": ev.reasoning,\n        })\n    return anonymized\n\n\ndef compute_stability_score(trajectory: AgentTrajectory, decay_rate: float = 5.0) -> float:\n    \"\"\"\n    Compute stability score from trajectory delta using exponential decay.\n\n    stability = exp(-decay_rate * max_dimension_delta)\n\n    Small delta → stability ≈ 1.0 (agent held position)\n    Large delta → stability → 0.0 (agent capitulated)\n\n    Args:\n        trajectory: The agent's trajectory across rounds\n        decay_rate: How aggressively to penalize instability (default 5.0)\n\n    Returns:\n        Stability score 0.0-1.0\n    \"\"\"\n    return math.exp(-decay_rate * trajectory.max_dimension_delta)\n\n\ndef compute_trajectory_weights(\n    trajectories: List[AgentTrajectory],\n    config: dict = None,\n) -> List[AgentTrajectory]:\n    \"\"\"\n    Compute trajectory-based weights for all agents.\n\n    Stable agents get higher weight. Weights are normalized to sum to 1.0.\n    Minimum weight prevents any agent from being completely silenced.\n\n    Args:\n        trajectories: List of agent trajectories\n        config: Free-MAD config dict\n\n    Returns:\n        Same trajectories with stability_score and trajectory_weight populated\n    \"\"\"\n    cfg = config or _default_free_mad_config()\n    decay_rate = cfg.get(\"stabilityDecayRate\", 5.0)\n    min_weight = cfg.get(\"minStabilityWeight\", 0.1)\n    max_weight = cfg.get(\"maxStabilityWeight\", 1.0)\n\n    # Compute raw stability scores\n    for t in trajectories:\n        t.stability_score = compute_stability_score(t, decay_rate)\n\n    # Clamp and normalize\n    raw_weights = [max(min_weight, min(max_weight, t.stability_score)) for t in trajectories]\n    total = sum(raw_weights)\n\n    if total > 0:\n        for i, t in enumerate(trajectories):\n            t.trajectory_weight = raw_weights[i] / total\n    else:\n        # Uniform fallback\n        uniform = 1.0 / len(trajectories) if trajectories else 0.0\n        for t in trajectories:\n            t.trajectory_weight = uniform\n\n    return trajectories\n\n\ndef detect_sycophancy(\n    trajectories: List[AgentTrajectory],\n    convergence_threshold: float = 0.05,\n) -> bool:\n    \"\"\"\n    Detect unanimous convergence (potential sycophancy).\n\n    If ALL agents shifted toward each other (all deltas point toward the\n    group mean and are below threshold after convergence), flag as sycophancy.\n\n    Args:\n        trajectories: List of agent trajectories after Round 2\n        convergence_threshold: Max spread in Round 2 scores to flag convergence\n\n    Returns:\n        True if sycophancy pattern detected\n    \"\"\"\n    if len(trajectories) < 2:\n        return False\n\n    # Check if all agents moved (none held position perfectly)\n    all_moved = all(t.delta_composite > 0.01 for t in trajectories)\n    if not all_moved:\n        return False\n\n    # Check if Round 2 scores converged to a tight cluster\n    r2_composites = [t.round2.composite_dq for t in trajectories]\n    r2_spread = max(r2_composites) - min(r2_composites)\n\n    # Check Round 1 had meaningful disagreement\n    r1_composites = [t.round1.composite_dq for t in trajectories]\n    r1_spread = max(r1_composites) - min(r1_composites)\n\n    # Sycophancy: started with disagreement, ended with tight convergence, all moved\n    return r1_spread > convergence_threshold and r2_spread <= convergence_threshold\n\n\ndef find_disagreement_dimensions(\n    trajectories: List[AgentTrajectory],\n    threshold: float = 0.15,\n) -> List[str]:\n    \"\"\"\n    Find DQ dimensions where agent trajectories diverge beyond threshold.\n\n    Used for disagreement escalation (US-009).\n\n    Args:\n        trajectories: List of agent trajectories\n        threshold: Divergence threshold per dimension\n\n    Returns:\n        List of dimension names that diverged\n    \"\"\"\n    if len(trajectories) < 2:\n        return []\n\n    divergent = []\n    for dim in [\"validity\", \"specificity\", \"correctness\"]:\n        # Check spread of Round 2 scores on this dimension\n        r2_scores = [getattr(t.round2, dim) for t in trajectories]\n        spread = max(r2_scores) - min(r2_scores)\n        if spread > threshold:\n            divergent.append(dim)\n\n    return divergent\n\n\ndef synthesize_consensus(\n    trajectories: List[AgentTrajectory],\n) -> Dict[str, float]:\n    \"\"\"\n    Compute weighted consensus from trajectory-weighted agents.\n\n    Uses Round 2 scores weighted by trajectory stability.\n\n    Args:\n        trajectories: Trajectories with trajectory_weight populated\n\n    Returns:\n        Dict with consensus scores per dimension + composite\n    \"\"\"\n    consensus_v = 0.0\n    consensus_s = 0.0\n    consensus_c = 0.0\n\n    for t in trajectories:\n        consensus_v += t.round2.validity * t.trajectory_weight\n        consensus_s += t.round2.specificity * t.trajectory_weight\n        consensus_c += t.round2.correctness * t.trajectory_weight\n\n    composite = consensus_v * 0.4 + consensus_s * 0.3 + consensus_c * 0.3\n\n    return {\n        \"validity\": consensus_v,\n        \"specificity\": consensus_s,\n        \"correctness\": consensus_c,\n        \"composite_dq\": composite,\n    }\n\n\nclass FreeMadSynthesizer:\n    \"\"\"\n    Free-MAD Trajectory Scoring Synthesizer.\n\n    Replaces DisagreementAwareSynthesizer with trajectory stability scoring.\n    Protocol:\n      1. Receive Round 1 evaluations from agents\n      2. Anonymize and share peer reasoning\n      3. Receive Round 2 evaluations\n      4. Compute trajectories, stability, weights\n      5. Detect sycophancy / disagreement\n      6. Produce weighted consensus\n    \"\"\"\n\n    def __init__(self, config_path: Path = None):\n        self.config = load_free_mad_config(config_path)\n        self._decay_rate = self.config.get(\"stabilityDecayRate\", 5.0)\n        self._sycophancy_threshold = self.config.get(\"sycophancyConvergenceThreshold\", 0.05)\n        self._escalation_threshold = self.config.get(\"disagreementEscalationThreshold\", 0.15)\n\n    def prepare_peer_context(self, round1_evals: List[DQEvaluation]) -> List[Dict[str, Any]]:\n        \"\"\"\n        Prepare anonymized peer reasoning for Round 2.\n\n        Strips agent labels (anti-sycophancy per CONSENSAGENT ACL 2025).\n\n        Args:\n            round1_evals: Round 1 evaluations from all agents\n\n        Returns:\n            Anonymized reasoning blocks for peer exposure\n        \"\"\"\n        return anonymize_reasoning(round1_evals)\n\n    def score_trajectories(\n        self,\n        round1_evals: List[DQEvaluation],\n        round2_evals: List[DQEvaluation],\n    ) -> List[AgentTrajectory]:\n        \"\"\"\n        Compute trajectories from Round 1 → Round 2 evaluations.\n\n        Args:\n            round1_evals: Initial independent evaluations\n            round2_evals: Post-peer-exposure evaluations\n\n        Returns:\n            List of AgentTrajectory with stability and weights computed\n        \"\"\"\n        if len(round1_evals) != len(round2_evals):\n            raise ValueError(\n                f\"Round 1 ({len(round1_evals)}) and Round 2 ({len(round2_evals)}) \"\n                \"evaluation counts must match\"\n            )\n\n        trajectories = []\n        for r1, r2 in zip(round1_evals, round2_evals):\n            if r1.agent_name != r2.agent_name:\n                raise ValueError(\n                    f\"Agent mismatch: Round 1 '{r1.agent_name}' vs Round 2 '{r2.agent_name}'\"\n                )\n            trajectories.append(AgentTrajectory(\n                agent_name=r1.agent_name,\n                round1=r1,\n                round2=r2,\n            ))\n\n        # Compute stability scores and weights\n        trajectories = compute_trajectory_weights(trajectories, self.config)\n\n        return trajectories\n\n    def synthesize(\n        self,\n        round1_evals: List[DQEvaluation],\n        round2_evals: List[DQEvaluation],\n    ) -> SynthesisResult:\n        \"\"\"\n        Full Free-MAD synthesis: trajectories → sycophancy check → consensus.\n\n        This is the main entry point for SUPERMAX v2 consensus.\n\n        Args:\n            round1_evals: Independent evaluations (Round 1)\n            round2_evals: Post-peer-exposure evaluations (Round 2)\n\n        Returns:\n            SynthesisResult with consensus scores, trajectories, and flags\n        \"\"\"\n        trajectories = self.score_trajectories(round1_evals, round2_evals)\n\n        # Detect sycophancy\n        sycophancy_flagged = detect_sycophancy(\n            trajectories, self._sycophancy_threshold\n        )\n\n        # Find disagreement dimensions (for US-009 escalation)\n        disagreement_dims = find_disagreement_dimensions(\n            trajectories, self._escalation_threshold\n        )\n\n        # Determine if Contrarian should be triggered\n        contrarian_triggered = sycophancy_flagged\n\n        # Compute weighted consensus\n        consensus = synthesize_consensus(trajectories)\n\n        return SynthesisResult(\n            consensus_dq=consensus[\"composite_dq\"],\n            consensus_validity=consensus[\"validity\"],\n            consensus_specificity=consensus[\"specificity\"],\n            consensus_correctness=consensus[\"correctness\"],\n            trajectories=trajectories,\n            sycophancy_flagged=sycophancy_flagged,\n            contrarian_triggered=contrarian_triggered,\n            disagreement_dimensions=disagreement_dims,\n        )\n\n\ndef log_trajectory(\n    query_hash: str,\n    result: SynthesisResult,\n    log_dir: Path = None,\n):\n    \"\"\"\n    Append trajectory data per query to data/supermax-trajectories.jsonl.\n\n    Args:\n        query_hash: MD5 hash of the query\n        result: SynthesisResult from synthesize()\n        log_dir: Override for the data directory\n    \"\"\"\n    out_dir = log_dir or _TRAJECTORIES_DIR\n    out_dir.mkdir(parents=True, exist_ok=True)\n    log_path = out_dir / \"supermax-trajectories.jsonl\"\n\n    trajectory_data = []\n    for t in result.trajectories:\n        trajectory_data.append({\n            \"agent\": t.agent_name,\n            \"round1_dq\": t.round1.composite_dq,\n            \"round2_dq\": t.round2.composite_dq,\n            \"delta_validity\": round(t.delta_validity, 4),\n            \"delta_specificity\": round(t.delta_specificity, 4),\n            \"delta_correctness\": round(t.delta_correctness, 4),\n            \"delta_composite\": round(t.delta_composite, 4),\n            \"stability_score\": round(t.stability_score, 4),\n            \"trajectory_weight\": round(t.trajectory_weight, 4),\n        })\n\n    entry = {\n        \"ts\": datetime.now(tz=timezone.utc).isoformat(),\n        \"query_hash\": query_hash,\n        \"consensus_dq\": round(result.consensus_dq, 4),\n        \"sycophancy_flagged\": result.sycophancy_flagged,\n        \"contrarian_triggered\": result.contrarian_triggered,\n        \"disagreement_dimensions\": result.disagreement_dimensions,\n        \"agent_count\": len(result.trajectories),\n        \"trajectories\": trajectory_data,\n        \"method\": result.method,\n    }\n\n    with open(log_path, \"a\") as f:\n        f.write(json.dumps(entry) + \"\\n\")\n\n\n# ─────────────────────────────────────────────────────────────────────────────\n# CLI interface\n# ─────────────────────────────────────────────────────────────────────────────\n\ndef main():\n    \"\"\"CLI entry point for Free-MAD Synthesizer.\"\"\"\n    import argparse\n\n    parser = argparse.ArgumentParser(\n        description=\"Free-MAD Trajectory Scoring Synthesizer\",\n        formatter_class=argparse.RawDescriptionHelpFormatter,\n        epilog=\"\"\"\nExamples:\n  python3 coordinator/synthesizer.py config     # Show Free-MAD config\n  python3 coordinator/synthesizer.py demo       # Run demo synthesis\n        \"\"\",\n    )\n\n    parser.add_argument(\"command\", choices=[\"config\", \"demo\"])\n    args = parser.parse_args()\n\n    synth = FreeMadSynthesizer()\n\n    if args.command == \"config\":\n        print(json.dumps(synth.config, indent=2))\n\n    elif args.command == \"demo\":\n        # Demo: 3 agents, one stable, one unstable, one moderate\n        r1 = [\n            DQEvaluation(\"PrincipalEngineer\", 0.8, 0.7, 0.9, \"Technically sound\"),\n            DQEvaluation(\"SecurityArchitect\", 0.6, 0.8, 0.7, \"Some risk concerns\"),\n            DQEvaluation(\"ProductStrategist\", 0.9, 0.6, 0.8, \"Good user value\"),\n        ]\n        # After peer exposure: Engineer holds, Architect shifts, Strategist moderate shift\n        r2 = [\n            DQEvaluation(\"PrincipalEngineer\", 0.8, 0.72, 0.88, \"Held position after review\"),\n            DQEvaluation(\"SecurityArchitect\", 0.78, 0.75, 0.82, \"Shifted toward peers\"),\n            DQEvaluation(\"ProductStrategist\", 0.85, 0.65, 0.8, \"Minor adjustment\"),\n        ]\n\n        result = synth.synthesize(r1, r2)\n        print(f\"Consensus DQ: {result.consensus_dq:.4f}\")\n        print(f\"Sycophancy flagged: {result.sycophancy_flagged}\")\n        print(f\"Disagreement dims: {result.disagreement_dimensions}\")\n        print(f\"\\nTrajectories:\")\n        for t in result.trajectories:\n            print(f\"  {t.agent_name}: stability={t.stability_score:.4f} weight={t.trajectory_weight:.4f} Δ={t.delta_composite:.4f}\")\n\n\nif __name__ == \"__main__\":\n    main()\n","numLines":519,"startLine":1,"totalLines":519}}}
