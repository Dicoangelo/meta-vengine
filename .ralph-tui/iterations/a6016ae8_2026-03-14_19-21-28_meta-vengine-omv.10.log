{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01M82o3zrKe4wqWysHrR44uw","type":"tool_result","content":"     1→#!/usr/bin/env python3\n     2→\"\"\"\n     3→US-005: Behavioral Outcome Signal — Composite Score Extractor\n     4→\n     5→Computes composite behavioral outcome scores per session from non-circular\n     6→telemetry signals. Replaces unreliable ACE self-assessment with ground truth\n     7→derived from actual user behavior.\n     8→\n     9→Composite score components (weights from PRD):\n    10→  - Session completion (not abandoned): 0.30\n    11→  - Tool success rate: 0.25\n    12→  - Efficiency ratio (messages / DQ complexity): 0.20\n    13→  - No model override by user: 0.15\n    14→  - No follow-up session on same topic within 24h: 0.10\n    15→\n    16→Reads from: claude.db (sessions, tool_events, activity_events, command_events)\n    17→Outputs to: data/behavioral-outcomes.jsonl (append-only)\n    18→\"\"\"\n    19→\n    20→import json\n    21→import os\n    22→import sqlite3\n    23→import sys\n    24→from datetime import datetime, timedelta, timezone\n    25→from pathlib import Path\n    26→\n    27→# Default paths\n    28→CLAUDE_DB_PATH = os.path.expanduser(\"~/.claude/data/claude.db\")\n    29→OUTPUT_DIR = Path(__file__).parent.parent / \"data\"\n    30→OUTPUT_FILE = OUTPUT_DIR / \"behavioral-outcomes.jsonl\"\n    31→\n    32→# Component weights (from PRD — designed as future Optimas LRF)\n    33→WEIGHTS = {\n    34→    \"completion\": 0.30,\n    35→    \"tool_success\": 0.25,\n    36→    \"efficiency\": 0.20,\n    37→    \"no_override\": 0.15,\n    38→    \"no_followup\": 0.10,\n    39→}\n    40→\n    41→\n    42→def get_db_connection(db_path=None):\n    43→    \"\"\"Open read-only connection to claude.db.\"\"\"\n    44→    path = db_path or CLAUDE_DB_PATH\n    45→    if not os.path.exists(path):\n    46→        raise FileNotFoundError(f\"claude.db not found at {path}\")\n    47→    conn = sqlite3.connect(f\"file:{path}?mode=ro\", uri=True)\n    48→    conn.row_factory = sqlite3.Row\n    49→    return conn\n    50→\n    51→\n    52→def compute_completion_score(session):\n    53→    \"\"\"Score 1: Session completion (not abandoned). Weight: 0.30.\n    54→\n    55→    Mapping:\n    56→      success/completed → 1.0\n    57→      partial/quick → 0.5\n    58→      abandoned → 0.0\n    59→    \"\"\"\n    60→    outcome = (session[\"outcome\"] or \"\").lower()\n    61→    if outcome in (\"success\", \"completed\"):\n    62→        return 1.0\n    63→    elif outcome in (\"partial\", \"quick\"):\n    64→        return 0.5\n    65→    else:  # abandoned or unknown\n    66→        return 0.0\n    67→\n    68→\n    69→def compute_tool_success_rate(conn, session):\n    70→    \"\"\"Score 2: Tool success rate from tool_events. Weight: 0.25.\n    71→\n    72→    Since tool_events has no session_id, we correlate by timestamp range\n    73→    matching the session's started_at/ended_at window.\n    74→    Returns success_count / total_count, or 0.5 if no tool events found.\n    75→    \"\"\"\n    76→    started = session[\"started_at\"]\n    77→    ended = session[\"ended_at\"]\n    78→    if not started or not ended:\n    79→        return 0.5  # No time range, neutral score\n    80→\n    81→    # Convert ISO timestamps to unix timestamps for tool_events comparison\n    82→    try:\n    83→        start_ts = int(datetime.fromisoformat(started.replace(\"Z\", \"+00:00\")).timestamp())\n    84→        end_ts = int(datetime.fromisoformat(ended.replace(\"Z\", \"+00:00\")).timestamp())\n    85→    except (ValueError, AttributeError):\n    86→        return 0.5\n    87→\n    88→    cursor = conn.execute(\n    89→        \"SELECT success, COUNT(*) as cnt FROM tool_events \"\n    90→        \"WHERE timestamp >= ? AND timestamp <= ? \"\n    91→        \"GROUP BY success\",\n    92→        (start_ts, end_ts),\n    93→    )\n    94→    rows = cursor.fetchall()\n    95→    if not rows:\n    96→        return 0.5  # No tool events in window, neutral\n    97→\n    98→    total = sum(r[\"cnt\"] for r in rows)\n    99→    success = sum(r[\"cnt\"] for r in rows if r[\"success\"] == 1)\n   100→    return success / total if total > 0 else 0.5\n   101→\n   102→\n   103→def compute_efficiency_ratio(session):\n   104→    \"\"\"Score 3: Efficiency ratio (messages relative to complexity). Weight: 0.20.\n   105→\n   106→    Lower message count per unit complexity = more efficient.\n   107→    Score = 1.0 - clamp(messages / (complexity * expected_messages), 0, 1)\n   108→\n   109→    Expected messages per complexity unit (heuristic):\n   110→      complexity 0.0 → ~10 messages expected\n   111→      complexity 1.0 → ~200 messages expected\n   112→    \"\"\"\n   113→    messages = session[\"message_count\"] or 0\n   114→    complexity = session[\"complexity\"]\n   115→\n   116→    if complexity is None or complexity <= 0:\n   117→        # No complexity data — use message count heuristic\n   118→        # Under 50 messages = efficient, over 200 = inefficient\n   119→        if messages <= 0:\n   120→            return 0.5\n   121→        ratio = min(messages / 100.0, 1.0)\n   122→        return 1.0 - ratio\n   123→\n   124→    # Scale expected messages by complexity\n   125→    expected = 10 + (complexity * 190)  # 10 at c=0, 200 at c=1\n   126→    ratio = messages / expected\n   127→    # ratio < 1 means more efficient than expected\n   128→    return max(0.0, min(1.0, 1.0 - (ratio - 1.0) * 0.5))\n   129→\n   130→\n   131→def compute_no_override_score(conn, session):\n   132→    \"\"\"Score 4: No model override by user. Weight: 0.15.\n   133→\n   134→    Check command_events for model switch commands during the session window.\n   135→    If user manually switched models, score = 0.0 (they weren't happy with routing).\n   136→    If no override, score = 1.0.\n   137→    \"\"\"\n   138→    started = session[\"started_at\"]\n   139→    ended = session[\"ended_at\"]\n   140→    if not started or not ended:\n   141→        return 1.0  # Can't check, assume no override\n   142→\n   143→    try:\n   144→        start_ts = int(datetime.fromisoformat(started.replace(\"Z\", \"+00:00\")).timestamp())\n   145→        end_ts = int(datetime.fromisoformat(ended.replace(\"Z\", \"+00:00\")).timestamp())\n   146→    except (ValueError, AttributeError):\n   147→        return 1.0\n   148→\n   149→    # Look for model-switching commands\n   150→    cursor = conn.execute(\n   151→        \"SELECT COUNT(*) as cnt FROM command_events \"\n   152→        \"WHERE timestamp >= ? AND timestamp <= ? \"\n   153→        \"AND (command LIKE '%model%' OR command LIKE '%switch%' \"\n   154→        \"OR command LIKE '%opus%' OR command LIKE '%sonnet%' OR command LIKE '%haiku%')\",\n   155→        (start_ts, end_ts),\n   156→    )\n   157→    row = cursor.fetchone()\n   158→    return 0.0 if (row and row[\"cnt\"] > 0) else 1.0\n   159→\n   160→\n   161→def compute_no_followup_score(conn, session):\n   162→    \"\"\"Score 5: No follow-up session on same topic within 24h. Weight: 0.10.\n   163→\n   164→    If no session with the same project_path starts within 24 hours after\n   165→    this session ends, score = 1.0 (task was resolved).\n   166→    If there is a follow-up, score = 0.0 (user had to come back).\n   167→    \"\"\"\n   168→    ended = session[\"ended_at\"]\n   169→    project = session[\"project_path\"]\n   170→\n   171→    if not ended or not project:\n   172→        return 0.5  # Can't determine, neutral\n   173→\n   174→    try:\n   175→        end_dt = datetime.fromisoformat(ended.replace(\"Z\", \"+00:00\"))\n   176→        window_end = end_dt + timedelta(hours=24)\n   177→    except (ValueError, AttributeError):\n   178→        return 0.5\n   179→\n   180→    cursor = conn.execute(\n   181→        \"SELECT COUNT(*) as cnt FROM sessions \"\n   182→        \"WHERE project_path = ? AND started_at > ? AND started_at < ? \"\n   183→        \"AND id != ?\",\n   184→        (project, ended, window_end.isoformat(), session[\"id\"]),\n   185→    )\n   186→    row = cursor.fetchone()\n   187→    return 0.0 if (row and row[\"cnt\"] > 0) else 1.0\n   188→\n   189→\n   190→def compute_behavioral_score(conn, session):\n   191→    \"\"\"Compute composite behavioral outcome score for a single session.\n   192→\n   193→    Returns dict with component scores and weighted composite.\n   194→    \"\"\"\n   195→    components = {\n   196→        \"completion\": compute_completion_score(session),\n   197→        \"tool_success\": compute_tool_success_rate(conn, session),\n   198→        \"efficiency\": compute_efficiency_ratio(session),\n   199→        \"no_override\": compute_no_override_score(conn, session),\n   200→        \"no_followup\": compute_no_followup_score(conn, session),\n   201→    }\n   202→\n   203→    # Weighted composite\n   204→    composite = sum(components[k] * WEIGHTS[k] for k in WEIGHTS)\n   205→    composite = max(0.0, min(1.0, composite))\n   206→\n   207→    return {\n   208→        \"session_id\": session[\"id\"],\n   209→        \"started_at\": session[\"started_at\"],\n   210→        \"project_path\": session[\"project_path\"],\n   211→        \"model\": session[\"model\"],\n   212→        \"outcome\": session[\"outcome\"],\n   213→        \"message_count\": session[\"message_count\"],\n   214→        \"components\": components,\n   215→        \"weights\": WEIGHTS,\n   216→        \"behavioral_score\": round(composite, 4),\n   217→        \"ace_quality_score\": session[\"quality_score\"],  # Preserved as weak signal\n   218→        \"computed_at\": datetime.now(timezone.utc).isoformat(),\n   219→    }\n   220→\n   221→\n   222→def load_processed_ids(output_path):\n   223→    \"\"\"Load set of already-processed session IDs from output JSONL.\"\"\"\n   224→    processed = set()\n   225→    if not output_path.exists():\n   226→        return processed\n   227→    with open(output_path, \"r\") as f:\n   228→        for line in f:\n   229→            line = line.strip()\n   230→            if not line:\n   231→                continue\n   232→            try:\n   233→                record = json.loads(line)\n   234→                processed.add(record.get(\"session_id\"))\n   235→            except json.JSONDecodeError:\n   236→                continue\n   237→    return processed\n   238→\n   239→\n   240→def process_sessions(db_path=None, output_path=None, backfill=False, limit=None):\n   241→    \"\"\"Process sessions and output behavioral scores.\n   242→\n   243→    Args:\n   244→        db_path: Path to claude.db (default: ~/.claude/data/claude.db)\n   245→        output_path: Path to output JSONL (default: data/behavioral-outcomes.jsonl)\n   246→        backfill: If True, process all historical sessions\n   247→        limit: Max sessions to process (None = all)\n   248→\n   249→    Returns:\n   250→        dict with processing stats\n   251→    \"\"\"\n   252→    out = output_path or OUTPUT_FILE\n   253→    out.parent.mkdir(parents=True, exist_ok=True)\n   254→\n   255→    conn = get_db_connection(db_path)\n   256→    processed_ids = load_processed_ids(out)\n   257→\n   258→    # Query sessions\n   259→    query = \"SELECT * FROM sessions ORDER BY started_at ASC\"\n   260→    if limit:\n   261→        query += f\" LIMIT {int(limit)}\"\n   262→\n   263→    cursor = conn.execute(query)\n   264→    sessions = cursor.fetchall()\n   265→\n   266→    stats = {\"total\": len(sessions), \"processed\": 0, \"skipped\": 0, \"errors\": 0}\n   267→\n   268→    with open(out, \"a\") as f:\n   269→        for session in sessions:\n   270→            sid = session[\"id\"]\n   271→            if sid in processed_ids:\n   272→                stats[\"skipped\"] += 1\n   273→                continue\n   274→\n   275→            try:\n   276→                result = compute_behavioral_score(conn, session)\n   277→                f.write(json.dumps(result) + \"\\n\")\n   278→                stats[\"processed\"] += 1\n   279→            except Exception as e:\n   280→                stats[\"errors\"] += 1\n   281→                if not backfill:  # In backfill mode, silently skip errors\n   282→                    print(f\"Error processing {sid}: {e}\", file=sys.stderr)\n   283→\n   284→    conn.close()\n   285→    return stats\n   286→\n   287→\n   288→def main():\n   289→    \"\"\"CLI entry point.\"\"\"\n   290→    import argparse\n   291→\n   292→    parser = argparse.ArgumentParser(\n   293→        description=\"Compute behavioral outcome scores from session telemetry\"\n   294→    )\n   295→    parser.add_argument(\n   296→        \"--backfill\",\n   297→        action=\"store_true\",\n   298→        help=\"Process all historical sessions\",\n   299→    )\n   300→    parser.add_argument(\n   301→        \"--db\",\n   302→        default=None,\n   303→        help=f\"Path to claude.db (default: {CLAUDE_DB_PATH})\",\n   304→    )\n   305→    parser.add_argument(\n   306→        \"--output\",\n   307→        default=None,\n   308→        help=f\"Output JSONL path (default: {OUTPUT_FILE})\",\n   309→    )\n   310→    parser.add_argument(\n   311→        \"--limit\",\n   312→        type=int,\n   313→        default=None,\n   314→        help=\"Max sessions to process\",\n   315→    )\n   316→    parser.add_argument(\n   317→        \"--stats\",\n   318→        action=\"store_true\",\n   319→        help=\"Show stats from existing output file\",\n   320→    )\n   321→\n   322→    args = parser.parse_args()\n   323→\n   324→    if args.stats:\n   325→        out = Path(args.output) if args.output else OUTPUT_FILE\n   326→        if not out.exists():\n   327→            print(\"No behavioral outcomes file found.\")\n   328→            return\n   329→        count = 0\n   330→        total_score = 0.0\n   331→        with open(out) as f:\n   332→            for line in f:\n   333→                if line.strip():\n   334→                    try:\n   335→                        r = json.loads(line)\n   336→                        count += 1\n   337→                        total_score += r.get(\"behavioral_score\", 0)\n   338→                    except json.JSONDecodeError:\n   339→                        pass\n   340→        avg = total_score / count if count > 0 else 0\n   341→        print(f\"Sessions scored: {count}\")\n   342→        print(f\"Average behavioral score: {avg:.4f}\")\n   343→        return\n   344→\n   345→    output_path = Path(args.output) if args.output else None\n   346→    stats = process_sessions(\n   347→        db_path=args.db,\n   348→        output_path=output_path,\n   349→        backfill=args.backfill,\n   350→        limit=args.limit,\n   351→    )\n   352→\n   353→    print(f\"Behavioral Outcome Scoring Complete\")\n   354→    print(f\"  Total sessions: {stats['total']}\")\n   355→    print(f\"  Processed: {stats['processed']}\")\n   356→    print(f\"  Skipped (already done): {stats['skipped']}\")\n   357→    print(f\"  Errors: {stats['errors']}\")\n   358→\n   359→\n   360→if __name__ == \"__main__\":\n   361→    main()\n   362→"}]},"parent_tool_use_id":null,"session_id":"dcbaa877-8e8f-4b22-8545-f03330fdd7b1","uuid":"292532c1-8616-4b9f-a96c-1ebaadd40593","tool_use_result":{"type":"text","file":{"filePath":"/Users/dicoangelo/projects/core/meta-vengine/kernel/behavioral-outcome.py","content":"#!/usr/bin/env python3\n\"\"\"\nUS-005: Behavioral Outcome Signal — Composite Score Extractor\n\nComputes composite behavioral outcome scores per session from non-circular\ntelemetry signals. Replaces unreliable ACE self-assessment with ground truth\nderived from actual user behavior.\n\nComposite score components (weights from PRD):\n  - Session completion (not abandoned): 0.30\n  - Tool success rate: 0.25\n  - Efficiency ratio (messages / DQ complexity): 0.20\n  - No model override by user: 0.15\n  - No follow-up session on same topic within 24h: 0.10\n\nReads from: claude.db (sessions, tool_events, activity_events, command_events)\nOutputs to: data/behavioral-outcomes.jsonl (append-only)\n\"\"\"\n\nimport json\nimport os\nimport sqlite3\nimport sys\nfrom datetime import datetime, timedelta, timezone\nfrom pathlib import Path\n\n# Default paths\nCLAUDE_DB_PATH = os.path.expanduser(\"~/.claude/data/claude.db\")\nOUTPUT_DIR = Path(__file__).parent.parent / \"data\"\nOUTPUT_FILE = OUTPUT_DIR / \"behavioral-outcomes.jsonl\"\n\n# Component weights (from PRD — designed as future Optimas LRF)\nWEIGHTS = {\n    \"completion\": 0.30,\n    \"tool_success\": 0.25,\n    \"efficiency\": 0.20,\n    \"no_override\": 0.15,\n    \"no_followup\": 0.10,\n}\n\n\ndef get_db_connection(db_path=None):\n    \"\"\"Open read-only connection to claude.db.\"\"\"\n    path = db_path or CLAUDE_DB_PATH\n    if not os.path.exists(path):\n        raise FileNotFoundError(f\"claude.db not found at {path}\")\n    conn = sqlite3.connect(f\"file:{path}?mode=ro\", uri=True)\n    conn.row_factory = sqlite3.Row\n    return conn\n\n\ndef compute_completion_score(session):\n    \"\"\"Score 1: Session completion (not abandoned). Weight: 0.30.\n\n    Mapping:\n      success/completed → 1.0\n      partial/quick → 0.5\n      abandoned → 0.0\n    \"\"\"\n    outcome = (session[\"outcome\"] or \"\").lower()\n    if outcome in (\"success\", \"completed\"):\n        return 1.0\n    elif outcome in (\"partial\", \"quick\"):\n        return 0.5\n    else:  # abandoned or unknown\n        return 0.0\n\n\ndef compute_tool_success_rate(conn, session):\n    \"\"\"Score 2: Tool success rate from tool_events. Weight: 0.25.\n\n    Since tool_events has no session_id, we correlate by timestamp range\n    matching the session's started_at/ended_at window.\n    Returns success_count / total_count, or 0.5 if no tool events found.\n    \"\"\"\n    started = session[\"started_at\"]\n    ended = session[\"ended_at\"]\n    if not started or not ended:\n        return 0.5  # No time range, neutral score\n\n    # Convert ISO timestamps to unix timestamps for tool_events comparison\n    try:\n        start_ts = int(datetime.fromisoformat(started.replace(\"Z\", \"+00:00\")).timestamp())\n        end_ts = int(datetime.fromisoformat(ended.replace(\"Z\", \"+00:00\")).timestamp())\n    except (ValueError, AttributeError):\n        return 0.5\n\n    cursor = conn.execute(\n        \"SELECT success, COUNT(*) as cnt FROM tool_events \"\n        \"WHERE timestamp >= ? AND timestamp <= ? \"\n        \"GROUP BY success\",\n        (start_ts, end_ts),\n    )\n    rows = cursor.fetchall()\n    if not rows:\n        return 0.5  # No tool events in window, neutral\n\n    total = sum(r[\"cnt\"] for r in rows)\n    success = sum(r[\"cnt\"] for r in rows if r[\"success\"] == 1)\n    return success / total if total > 0 else 0.5\n\n\ndef compute_efficiency_ratio(session):\n    \"\"\"Score 3: Efficiency ratio (messages relative to complexity). Weight: 0.20.\n\n    Lower message count per unit complexity = more efficient.\n    Score = 1.0 - clamp(messages / (complexity * expected_messages), 0, 1)\n\n    Expected messages per complexity unit (heuristic):\n      complexity 0.0 → ~10 messages expected\n      complexity 1.0 → ~200 messages expected\n    \"\"\"\n    messages = session[\"message_count\"] or 0\n    complexity = session[\"complexity\"]\n\n    if complexity is None or complexity <= 0:\n        # No complexity data — use message count heuristic\n        # Under 50 messages = efficient, over 200 = inefficient\n        if messages <= 0:\n            return 0.5\n        ratio = min(messages / 100.0, 1.0)\n        return 1.0 - ratio\n\n    # Scale expected messages by complexity\n    expected = 10 + (complexity * 190)  # 10 at c=0, 200 at c=1\n    ratio = messages / expected\n    # ratio < 1 means more efficient than expected\n    return max(0.0, min(1.0, 1.0 - (ratio - 1.0) * 0.5))\n\n\ndef compute_no_override_score(conn, session):\n    \"\"\"Score 4: No model override by user. Weight: 0.15.\n\n    Check command_events for model switch commands during the session window.\n    If user manually switched models, score = 0.0 (they weren't happy with routing).\n    If no override, score = 1.0.\n    \"\"\"\n    started = session[\"started_at\"]\n    ended = session[\"ended_at\"]\n    if not started or not ended:\n        return 1.0  # Can't check, assume no override\n\n    try:\n        start_ts = int(datetime.fromisoformat(started.replace(\"Z\", \"+00:00\")).timestamp())\n        end_ts = int(datetime.fromisoformat(ended.replace(\"Z\", \"+00:00\")).timestamp())\n    except (ValueError, AttributeError):\n        return 1.0\n\n    # Look for model-switching commands\n    cursor = conn.execute(\n        \"SELECT COUNT(*) as cnt FROM command_events \"\n        \"WHERE timestamp >= ? AND timestamp <= ? \"\n        \"AND (command LIKE '%model%' OR command LIKE '%switch%' \"\n        \"OR command LIKE '%opus%' OR command LIKE '%sonnet%' OR command LIKE '%haiku%')\",\n        (start_ts, end_ts),\n    )\n    row = cursor.fetchone()\n    return 0.0 if (row and row[\"cnt\"] > 0) else 1.0\n\n\ndef compute_no_followup_score(conn, session):\n    \"\"\"Score 5: No follow-up session on same topic within 24h. Weight: 0.10.\n\n    If no session with the same project_path starts within 24 hours after\n    this session ends, score = 1.0 (task was resolved).\n    If there is a follow-up, score = 0.0 (user had to come back).\n    \"\"\"\n    ended = session[\"ended_at\"]\n    project = session[\"project_path\"]\n\n    if not ended or not project:\n        return 0.5  # Can't determine, neutral\n\n    try:\n        end_dt = datetime.fromisoformat(ended.replace(\"Z\", \"+00:00\"))\n        window_end = end_dt + timedelta(hours=24)\n    except (ValueError, AttributeError):\n        return 0.5\n\n    cursor = conn.execute(\n        \"SELECT COUNT(*) as cnt FROM sessions \"\n        \"WHERE project_path = ? AND started_at > ? AND started_at < ? \"\n        \"AND id != ?\",\n        (project, ended, window_end.isoformat(), session[\"id\"]),\n    )\n    row = cursor.fetchone()\n    return 0.0 if (row and row[\"cnt\"] > 0) else 1.0\n\n\ndef compute_behavioral_score(conn, session):\n    \"\"\"Compute composite behavioral outcome score for a single session.\n\n    Returns dict with component scores and weighted composite.\n    \"\"\"\n    components = {\n        \"completion\": compute_completion_score(session),\n        \"tool_success\": compute_tool_success_rate(conn, session),\n        \"efficiency\": compute_efficiency_ratio(session),\n        \"no_override\": compute_no_override_score(conn, session),\n        \"no_followup\": compute_no_followup_score(conn, session),\n    }\n\n    # Weighted composite\n    composite = sum(components[k] * WEIGHTS[k] for k in WEIGHTS)\n    composite = max(0.0, min(1.0, composite))\n\n    return {\n        \"session_id\": session[\"id\"],\n        \"started_at\": session[\"started_at\"],\n        \"project_path\": session[\"project_path\"],\n        \"model\": session[\"model\"],\n        \"outcome\": session[\"outcome\"],\n        \"message_count\": session[\"message_count\"],\n        \"components\": components,\n        \"weights\": WEIGHTS,\n        \"behavioral_score\": round(composite, 4),\n        \"ace_quality_score\": session[\"quality_score\"],  # Preserved as weak signal\n        \"computed_at\": datetime.now(timezone.utc).isoformat(),\n    }\n\n\ndef load_processed_ids(output_path):\n    \"\"\"Load set of already-processed session IDs from output JSONL.\"\"\"\n    processed = set()\n    if not output_path.exists():\n        return processed\n    with open(output_path, \"r\") as f:\n        for line in f:\n            line = line.strip()\n            if not line:\n                continue\n            try:\n                record = json.loads(line)\n                processed.add(record.get(\"session_id\"))\n            except json.JSONDecodeError:\n                continue\n    return processed\n\n\ndef process_sessions(db_path=None, output_path=None, backfill=False, limit=None):\n    \"\"\"Process sessions and output behavioral scores.\n\n    Args:\n        db_path: Path to claude.db (default: ~/.claude/data/claude.db)\n        output_path: Path to output JSONL (default: data/behavioral-outcomes.jsonl)\n        backfill: If True, process all historical sessions\n        limit: Max sessions to process (None = all)\n\n    Returns:\n        dict with processing stats\n    \"\"\"\n    out = output_path or OUTPUT_FILE\n    out.parent.mkdir(parents=True, exist_ok=True)\n\n    conn = get_db_connection(db_path)\n    processed_ids = load_processed_ids(out)\n\n    # Query sessions\n    query = \"SELECT * FROM sessions ORDER BY started_at ASC\"\n    if limit:\n        query += f\" LIMIT {int(limit)}\"\n\n    cursor = conn.execute(query)\n    sessions = cursor.fetchall()\n\n    stats = {\"total\": len(sessions), \"processed\": 0, \"skipped\": 0, \"errors\": 0}\n\n    with open(out, \"a\") as f:\n        for session in sessions:\n            sid = session[\"id\"]\n            if sid in processed_ids:\n                stats[\"skipped\"] += 1\n                continue\n\n            try:\n                result = compute_behavioral_score(conn, session)\n                f.write(json.dumps(result) + \"\\n\")\n                stats[\"processed\"] += 1\n            except Exception as e:\n                stats[\"errors\"] += 1\n                if not backfill:  # In backfill mode, silently skip errors\n                    print(f\"Error processing {sid}: {e}\", file=sys.stderr)\n\n    conn.close()\n    return stats\n\n\ndef main():\n    \"\"\"CLI entry point.\"\"\"\n    import argparse\n\n    parser = argparse.ArgumentParser(\n        description=\"Compute behavioral outcome scores from session telemetry\"\n    )\n    parser.add_argument(\n        \"--backfill\",\n        action=\"store_true\",\n        help=\"Process all historical sessions\",\n    )\n    parser.add_argument(\n        \"--db\",\n        default=None,\n        help=f\"Path to claude.db (default: {CLAUDE_DB_PATH})\",\n    )\n    parser.add_argument(\n        \"--output\",\n        default=None,\n        help=f\"Output JSONL path (default: {OUTPUT_FILE})\",\n    )\n    parser.add_argument(\n        \"--limit\",\n        type=int,\n        default=None,\n        help=\"Max sessions to process\",\n    )\n    parser.add_argument(\n        \"--stats\",\n        action=\"store_true\",\n        help=\"Show stats from existing output file\",\n    )\n\n    args = parser.parse_args()\n\n    if args.stats:\n        out = Path(args.output) if args.output else OUTPUT_FILE\n        if not out.exists():\n            print(\"No behavioral outcomes file found.\")\n            return\n        count = 0\n        total_score = 0.0\n        with open(out) as f:\n            for line in f:\n                if line.strip():\n                    try:\n                        r = json.loads(line)\n                        count += 1\n                        total_score += r.get(\"behavioral_score\", 0)\n                    except json.JSONDecodeError:\n                        pass\n        avg = total_score / count if count > 0 else 0\n        print(f\"Sessions scored: {count}\")\n        print(f\"Average behavioral score: {avg:.4f}\")\n        return\n\n    output_path = Path(args.output) if args.output else None\n    stats = process_sessions(\n        db_path=args.db,\n        output_path=output_path,\n        backfill=args.backfill,\n        limit=args.limit,\n    )\n\n    print(f\"Behavioral Outcome Scoring Complete\")\n    print(f\"  Total sessions: {stats['total']}\")\n    print(f\"  Processed: {stats['processed']}\")\n    print(f\"  Skipped (already done): {stats['skipped']}\")\n    print(f\"  Errors: {stats['errors']}\")\n\n\nif __name__ == \"__main__\":\n    main()\n","numLines":362,"startLine":1,"totalLines":362}}}
