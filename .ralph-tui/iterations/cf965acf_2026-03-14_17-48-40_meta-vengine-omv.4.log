{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XmwwjwYaHj9f7Zvsw14fWH","type":"tool_result","content":"     1→#!/usr/bin/env node\n     2→/**\n     3→ * Complexity Analyzer - Astraea-inspired query complexity estimation\n     4→ *\n     5→ * Based on: \"Astraea: A State-Aware Scheduling Engine for LLM-Powered Agents\"\n     6→ * arXiv: https://arxiv.org/abs/2512.14142\n     7→ *\n     8→ * Estimates query complexity to inform model routing decisions.\n     9→ */\n    10→\n    11→const fs = require('fs');\n    12→const path = require('path');\n    13→\n    14→// ═══════════════════════════════════════════════════════════════════════════\n    15→// COMPLEXITY SIGNALS\n    16→// ═══════════════════════════════════════════════════════════════════════════\n    17→\n    18→const SIGNALS = {\n    19→  // Semantic keywords that indicate complexity\n    20→  code: ['function', 'class', 'async', 'import', 'export', 'const', 'let', 'var',\n    21→         'interface', 'type', 'enum', 'module', 'require', 'def ', 'return'],\n    22→\n    23→  architecture: ['design', 'architecture', 'system', 'refactor', 'restructure',\n    24→                 'pattern', 'microservice', 'distributed', 'scalable', 'optimize'],\n    25→\n    26→  debug: ['error', 'fix', 'bug', 'debug', 'why', 'not working', 'broken',\n    27→          'crash', 'exception', 'failed', 'issue', 'problem'],\n    28→\n    29→  multiFile: ['across', 'all files', 'every', 'multiple', 'entire codebase',\n    30→              'project-wide', 'refactor all', 'update all'],\n    31→\n    32→  analysis: ['analyze', 'review', 'audit', 'compare', 'evaluate', 'assess',\n    33→             'investigate', 'research', 'study', 'understand'],\n    34→\n    35→  creation: ['create', 'build', 'implement', 'develop', 'write', 'generate',\n    36→             'make', 'add', 'new feature', 'from scratch'],\n    37→\n    38→  simple: ['what is', 'how to', 'explain', 'show me', 'list', 'print',\n    39→           'hello', 'thanks', 'yes', 'no', 'ok']\n    40→};\n    41→\n    42→// Complexity weights for each signal category\n    43→const WEIGHTS = {\n    44→  code: 0.15,\n    45→  architecture: 0.25,\n    46→  debug: 0.10,\n    47→  multiFile: 0.20,\n    48→  analysis: 0.15,\n    49→  creation: 0.10,\n    50→  simple: -0.15  // Negative weight reduces complexity\n    51→};\n    52→\n    53→// Token-based complexity thresholds (from Astraea paper)\n    54→const TOKEN_THRESHOLDS = {\n    55→  simple: { max: 20, score: 0.10 },\n    56→  moderate: { max: 100, score: 0.30 },\n    57→  complex: { max: 500, score: 0.60 },\n    58→  expert: { max: Infinity, score: 0.90 }\n    59→};\n    60→\n    61→// ═══════════════════════════════════════════════════════════════════════════\n    62→// ANALYSIS FUNCTIONS\n    63→// ═══════════════════════════════════════════════════════════════════════════\n    64→\n    65→/**\n    66→ * Simple tokenizer - splits on whitespace and punctuation\n    67→ */\n    68→function tokenize(text) {\n    69→  return text.toLowerCase()\n    70→    .replace(/[^\\w\\s]/g, ' ')\n    71→    .split(/\\s+/)\n    72→    .filter(t => t.length > 0);\n    73→}\n    74→\n    75→/**\n    76→ * Estimate tokens (rough approximation: ~4 chars per token)\n    77→ */\n    78→function estimateTokens(text) {\n    79→  return Math.ceil(text.length / 4);\n    80→}\n    81→\n    82→/**\n    83→ * Check if query contains keywords from a signal category\n    84→ */\n    85→function hasSignals(query, category) {\n    86→  const lowerQuery = query.toLowerCase();\n    87→  return SIGNALS[category].some(keyword => lowerQuery.includes(keyword));\n    88→}\n    89→\n    90→/**\n    91→ * Count matching signals for a category\n    92→ */\n    93→function countSignals(query, category) {\n    94→  const lowerQuery = query.toLowerCase();\n    95→  return SIGNALS[category].filter(keyword => lowerQuery.includes(keyword)).length;\n    96→}\n    97→\n    98→/**\n    99→ * Detect if query requires project context\n   100→ */\n   101→function requiresProjectContext(query) {\n   102→  const patterns = [\n   103→    /\\b(this|our|my|the)\\s+\\w+\\s+(file|code|project|app|component)/i,\n   104→    /\\bin\\s+(this|the)\\s+(codebase|repo|project)/i,\n   105→    /\\bcurrent\\s+(file|directory|project)/i\n   106→  ];\n   107→  return patterns.some(p => p.test(query));\n   108→}\n   109→\n   110→/**\n   111→ * Detect if query is conversational/simple\n   112→ */\n   113→function isConversational(query) {\n   114→  const patterns = [\n   115→    /^(hi|hello|hey|thanks|thank you|ok|okay|yes|no|sure)/i,\n   116→    /^what (is|are) \\w+\\??$/i,\n   117→    /^(how|can|could) (do|can) (i|you)/i\n   118→  ];\n   119→  return patterns.some(p => p.test(query)) && query.length < 50;\n   120→}\n   121→\n   122→/**\n   123→ * Load historical complexity data for similar queries\n   124→ */\n   125→function loadHistory() {\n   126→  const historyPath = path.join(process.env.HOME, '.claude/kernel/dq-scores.jsonl');\n   127→  if (!fs.existsSync(historyPath)) return [];\n   128→\n   129→  try {\n   130→    const lines = fs.readFileSync(historyPath, 'utf8').split('\\n').filter(l => l.trim());\n   131→    return lines.slice(-100).map(l => JSON.parse(l)); // Last 100 entries\n   132→  } catch (e) {\n   133→    return [];\n   134→  }\n   135→}\n   136→\n   137→/**\n   138→ * Find similar historical queries and their complexity\n   139→ */\n   140→function getHistoricalComplexity(query, history) {\n   141→  if (history.length === 0) return null;\n   142→\n   143→  const tokens = new Set(tokenize(query));\n   144→  let bestMatch = null;\n   145→  let bestScore = 0;\n   146→\n   147→  for (const entry of history) {\n   148→    if (!entry.query) continue;\n   149→    const historyTokens = new Set(tokenize(entry.query));\n   150→\n   151→    // Jaccard similarity\n   152→    const intersection = [...tokens].filter(t => historyTokens.has(t)).length;\n   153→    const union = new Set([...tokens, ...historyTokens]).size;\n   154→    const similarity = intersection / union;\n   155→\n   156→    if (similarity > bestScore && similarity > 0.3) {\n   157→      bestScore = similarity;\n   158→      bestMatch = entry;\n   159→    }\n   160→  }\n   161→\n   162→  return bestMatch ? { complexity: bestMatch.complexity, confidence: bestScore } : null;\n   163→}\n   164→\n   165→// ═══════════════════════════════════════════════════════════════════════════\n   166→// MAIN COMPLEXITY ESTIMATION\n   167→// ═══════════════════════════════════════════════════════════════════════════\n   168→\n   169→/**\n   170→ * Estimate complexity of a query\n   171→ * Returns: { score: 0-1, signals: object, model: string, reasoning: string }\n   172→ */\n   173→function estimateComplexity(query) {\n   174→  const tokens = estimateTokens(query);\n   175→  const history = loadHistory();\n   176→\n   177→  // Start with token-based score\n   178→  let score = 0;\n   179→  const reasoning = [];\n   180→\n   181→  // Token length scoring\n   182→  if (tokens <= TOKEN_THRESHOLDS.simple.max) {\n   183→    score += TOKEN_THRESHOLDS.simple.score;\n   184→    reasoning.push(`Short query (${tokens} tokens)`);\n   185→  } else if (tokens <= TOKEN_THRESHOLDS.moderate.max) {\n   186→    score += TOKEN_THRESHOLDS.moderate.score;\n   187→    reasoning.push(`Medium query (${tokens} tokens)`);\n   188→  } else if (tokens <= TOKEN_THRESHOLDS.complex.max) {\n   189→    score += TOKEN_THRESHOLDS.complex.score;\n   190→    reasoning.push(`Long query (${tokens} tokens)`);\n   191→  } else {\n   192→    score += TOKEN_THRESHOLDS.expert.score;\n   193→    reasoning.push(`Very long query (${tokens} tokens)`);\n   194→  }\n   195→\n   196→  // Signal-based scoring\n   197→  const signalScores = {};\n   198→  for (const [category, weight] of Object.entries(WEIGHTS)) {\n   199→    if (hasSignals(query, category)) {\n   200→      const count = countSignals(query, category);\n   201→      const categoryScore = weight * Math.min(count, 3); // Cap at 3 matches\n   202→      signalScores[category] = { count, score: categoryScore };\n   203→      score += categoryScore;\n   204→\n   205→      if (weight > 0) {\n   206→        reasoning.push(`${category}: ${count} signal(s)`);\n   207→      }\n   208→    }\n   209→  }\n   210→\n   211→  // Context requirements\n   212→  if (requiresProjectContext(query)) {\n   213→    score += 0.15;\n   214→    reasoning.push('Requires project context');\n   215→  }\n   216→\n   217→  // Conversational reduction\n   218→  if (isConversational(query)) {\n   219→    score -= 0.20;\n   220→    reasoning.push('Conversational/simple');\n   221→  }\n   222→\n   223→  // Historical adjustment\n   224→  const historical = getHistoricalComplexity(query, history);\n   225→  if (historical && historical.confidence > 0.5) {\n   226→    const adjustment = (historical.complexity - score) * 0.3;\n   227→    score += adjustment;\n   228→    reasoning.push(`Historical: ${historical.complexity.toFixed(2)} (conf: ${historical.confidence.toFixed(2)})`);\n   229→  }\n   230→\n   231→  // Clamp to 0-1\n   232→  score = Math.max(0, Math.min(1, score));\n   233→\n   234→  // Determine recommended model\n   235→  let model;\n   236→  if (score < 0.25) model = 'haiku';\n   237→  else if (score < 0.60) model = 'sonnet';\n   238→  else model = 'opus';\n   239→\n   240→  return {\n   241→    score: parseFloat(score.toFixed(3)),\n   242→    tokens,\n   243→    signals: signalScores,\n   244→    model,\n   245→    reasoning: reasoning.join('; ')\n   246→  };\n   247→}\n   248→\n   249→// ═══════════════════════════════════════════════════════════════════════════\n   250→// CLI INTERFACE\n   251→// ═══════════════════════════════════════════════════════════════════════════\n   252→\n   253→if (require.main === module) {\n   254→  const args = process.argv.slice(2);\n   255→\n   256→  if (args.length === 0) {\n   257→    // Read from stdin\n   258→    let input = '';\n   259→    process.stdin.setEncoding('utf8');\n   260→    process.stdin.on('data', chunk => input += chunk);\n   261→    process.stdin.on('end', () => {\n   262→      const result = estimateComplexity(input.trim());\n   263→      console.log(JSON.stringify(result, null, 2));\n   264→    });\n   265→  } else if (args[0] === '--score-only') {\n   266→    // Just output the score\n   267→    const query = args.slice(1).join(' ');\n   268→    const result = estimateComplexity(query);\n   269→    console.log(result.score);\n   270→  } else if (args[0] === '--model-only') {\n   271→    // Just output the model\n   272→    const query = args.slice(1).join(' ');\n   273→    const result = estimateComplexity(query);\n   274→    console.log(result.model);\n   275→  } else {\n   276→    // Query as arguments\n   277→    const query = args.join(' ');\n   278→    const result = estimateComplexity(query);\n   279→    console.log(JSON.stringify(result, null, 2));\n   280→  }\n   281→}\n   282→\n   283→module.exports = { estimateComplexity, tokenize, estimateTokens };\n   284→"}]},"parent_tool_use_id":null,"session_id":"e0d71b02-fe91-48e7-9011-d4777d961b4b","uuid":"b0117471-e2b2-4e80-a7dd-0ac2233f8b37","tool_use_result":{"type":"text","file":{"filePath":"/Users/dicoangelo/projects/core/meta-vengine/kernel/complexity-analyzer.js","content":"#!/usr/bin/env node\n/**\n * Complexity Analyzer - Astraea-inspired query complexity estimation\n *\n * Based on: \"Astraea: A State-Aware Scheduling Engine for LLM-Powered Agents\"\n * arXiv: https://arxiv.org/abs/2512.14142\n *\n * Estimates query complexity to inform model routing decisions.\n */\n\nconst fs = require('fs');\nconst path = require('path');\n\n// ═══════════════════════════════════════════════════════════════════════════\n// COMPLEXITY SIGNALS\n// ═══════════════════════════════════════════════════════════════════════════\n\nconst SIGNALS = {\n  // Semantic keywords that indicate complexity\n  code: ['function', 'class', 'async', 'import', 'export', 'const', 'let', 'var',\n         'interface', 'type', 'enum', 'module', 'require', 'def ', 'return'],\n\n  architecture: ['design', 'architecture', 'system', 'refactor', 'restructure',\n                 'pattern', 'microservice', 'distributed', 'scalable', 'optimize'],\n\n  debug: ['error', 'fix', 'bug', 'debug', 'why', 'not working', 'broken',\n          'crash', 'exception', 'failed', 'issue', 'problem'],\n\n  multiFile: ['across', 'all files', 'every', 'multiple', 'entire codebase',\n              'project-wide', 'refactor all', 'update all'],\n\n  analysis: ['analyze', 'review', 'audit', 'compare', 'evaluate', 'assess',\n             'investigate', 'research', 'study', 'understand'],\n\n  creation: ['create', 'build', 'implement', 'develop', 'write', 'generate',\n             'make', 'add', 'new feature', 'from scratch'],\n\n  simple: ['what is', 'how to', 'explain', 'show me', 'list', 'print',\n           'hello', 'thanks', 'yes', 'no', 'ok']\n};\n\n// Complexity weights for each signal category\nconst WEIGHTS = {\n  code: 0.15,\n  architecture: 0.25,\n  debug: 0.10,\n  multiFile: 0.20,\n  analysis: 0.15,\n  creation: 0.10,\n  simple: -0.15  // Negative weight reduces complexity\n};\n\n// Token-based complexity thresholds (from Astraea paper)\nconst TOKEN_THRESHOLDS = {\n  simple: { max: 20, score: 0.10 },\n  moderate: { max: 100, score: 0.30 },\n  complex: { max: 500, score: 0.60 },\n  expert: { max: Infinity, score: 0.90 }\n};\n\n// ═══════════════════════════════════════════════════════════════════════════\n// ANALYSIS FUNCTIONS\n// ═══════════════════════════════════════════════════════════════════════════\n\n/**\n * Simple tokenizer - splits on whitespace and punctuation\n */\nfunction tokenize(text) {\n  return text.toLowerCase()\n    .replace(/[^\\w\\s]/g, ' ')\n    .split(/\\s+/)\n    .filter(t => t.length > 0);\n}\n\n/**\n * Estimate tokens (rough approximation: ~4 chars per token)\n */\nfunction estimateTokens(text) {\n  return Math.ceil(text.length / 4);\n}\n\n/**\n * Check if query contains keywords from a signal category\n */\nfunction hasSignals(query, category) {\n  const lowerQuery = query.toLowerCase();\n  return SIGNALS[category].some(keyword => lowerQuery.includes(keyword));\n}\n\n/**\n * Count matching signals for a category\n */\nfunction countSignals(query, category) {\n  const lowerQuery = query.toLowerCase();\n  return SIGNALS[category].filter(keyword => lowerQuery.includes(keyword)).length;\n}\n\n/**\n * Detect if query requires project context\n */\nfunction requiresProjectContext(query) {\n  const patterns = [\n    /\\b(this|our|my|the)\\s+\\w+\\s+(file|code|project|app|component)/i,\n    /\\bin\\s+(this|the)\\s+(codebase|repo|project)/i,\n    /\\bcurrent\\s+(file|directory|project)/i\n  ];\n  return patterns.some(p => p.test(query));\n}\n\n/**\n * Detect if query is conversational/simple\n */\nfunction isConversational(query) {\n  const patterns = [\n    /^(hi|hello|hey|thanks|thank you|ok|okay|yes|no|sure)/i,\n    /^what (is|are) \\w+\\??$/i,\n    /^(how|can|could) (do|can) (i|you)/i\n  ];\n  return patterns.some(p => p.test(query)) && query.length < 50;\n}\n\n/**\n * Load historical complexity data for similar queries\n */\nfunction loadHistory() {\n  const historyPath = path.join(process.env.HOME, '.claude/kernel/dq-scores.jsonl');\n  if (!fs.existsSync(historyPath)) return [];\n\n  try {\n    const lines = fs.readFileSync(historyPath, 'utf8').split('\\n').filter(l => l.trim());\n    return lines.slice(-100).map(l => JSON.parse(l)); // Last 100 entries\n  } catch (e) {\n    return [];\n  }\n}\n\n/**\n * Find similar historical queries and their complexity\n */\nfunction getHistoricalComplexity(query, history) {\n  if (history.length === 0) return null;\n\n  const tokens = new Set(tokenize(query));\n  let bestMatch = null;\n  let bestScore = 0;\n\n  for (const entry of history) {\n    if (!entry.query) continue;\n    const historyTokens = new Set(tokenize(entry.query));\n\n    // Jaccard similarity\n    const intersection = [...tokens].filter(t => historyTokens.has(t)).length;\n    const union = new Set([...tokens, ...historyTokens]).size;\n    const similarity = intersection / union;\n\n    if (similarity > bestScore && similarity > 0.3) {\n      bestScore = similarity;\n      bestMatch = entry;\n    }\n  }\n\n  return bestMatch ? { complexity: bestMatch.complexity, confidence: bestScore } : null;\n}\n\n// ═══════════════════════════════════════════════════════════════════════════\n// MAIN COMPLEXITY ESTIMATION\n// ═══════════════════════════════════════════════════════════════════════════\n\n/**\n * Estimate complexity of a query\n * Returns: { score: 0-1, signals: object, model: string, reasoning: string }\n */\nfunction estimateComplexity(query) {\n  const tokens = estimateTokens(query);\n  const history = loadHistory();\n\n  // Start with token-based score\n  let score = 0;\n  const reasoning = [];\n\n  // Token length scoring\n  if (tokens <= TOKEN_THRESHOLDS.simple.max) {\n    score += TOKEN_THRESHOLDS.simple.score;\n    reasoning.push(`Short query (${tokens} tokens)`);\n  } else if (tokens <= TOKEN_THRESHOLDS.moderate.max) {\n    score += TOKEN_THRESHOLDS.moderate.score;\n    reasoning.push(`Medium query (${tokens} tokens)`);\n  } else if (tokens <= TOKEN_THRESHOLDS.complex.max) {\n    score += TOKEN_THRESHOLDS.complex.score;\n    reasoning.push(`Long query (${tokens} tokens)`);\n  } else {\n    score += TOKEN_THRESHOLDS.expert.score;\n    reasoning.push(`Very long query (${tokens} tokens)`);\n  }\n\n  // Signal-based scoring\n  const signalScores = {};\n  for (const [category, weight] of Object.entries(WEIGHTS)) {\n    if (hasSignals(query, category)) {\n      const count = countSignals(query, category);\n      const categoryScore = weight * Math.min(count, 3); // Cap at 3 matches\n      signalScores[category] = { count, score: categoryScore };\n      score += categoryScore;\n\n      if (weight > 0) {\n        reasoning.push(`${category}: ${count} signal(s)`);\n      }\n    }\n  }\n\n  // Context requirements\n  if (requiresProjectContext(query)) {\n    score += 0.15;\n    reasoning.push('Requires project context');\n  }\n\n  // Conversational reduction\n  if (isConversational(query)) {\n    score -= 0.20;\n    reasoning.push('Conversational/simple');\n  }\n\n  // Historical adjustment\n  const historical = getHistoricalComplexity(query, history);\n  if (historical && historical.confidence > 0.5) {\n    const adjustment = (historical.complexity - score) * 0.3;\n    score += adjustment;\n    reasoning.push(`Historical: ${historical.complexity.toFixed(2)} (conf: ${historical.confidence.toFixed(2)})`);\n  }\n\n  // Clamp to 0-1\n  score = Math.max(0, Math.min(1, score));\n\n  // Determine recommended model\n  let model;\n  if (score < 0.25) model = 'haiku';\n  else if (score < 0.60) model = 'sonnet';\n  else model = 'opus';\n\n  return {\n    score: parseFloat(score.toFixed(3)),\n    tokens,\n    signals: signalScores,\n    model,\n    reasoning: reasoning.join('; ')\n  };\n}\n\n// ═══════════════════════════════════════════════════════════════════════════\n// CLI INTERFACE\n// ═══════════════════════════════════════════════════════════════════════════\n\nif (require.main === module) {\n  const args = process.argv.slice(2);\n\n  if (args.length === 0) {\n    // Read from stdin\n    let input = '';\n    process.stdin.setEncoding('utf8');\n    process.stdin.on('data', chunk => input += chunk);\n    process.stdin.on('end', () => {\n      const result = estimateComplexity(input.trim());\n      console.log(JSON.stringify(result, null, 2));\n    });\n  } else if (args[0] === '--score-only') {\n    // Just output the score\n    const query = args.slice(1).join(' ');\n    const result = estimateComplexity(query);\n    console.log(result.score);\n  } else if (args[0] === '--model-only') {\n    // Just output the model\n    const query = args.slice(1).join(' ');\n    const result = estimateComplexity(query);\n    console.log(result.model);\n  } else {\n    // Query as arguments\n    const query = args.join(' ');\n    const result = estimateComplexity(query);\n    console.log(JSON.stringify(result, null, 2));\n  }\n}\n\nmodule.exports = { estimateComplexity, tokenize, estimateTokens };\n","numLines":284,"startLine":1,"totalLines":284}}}
