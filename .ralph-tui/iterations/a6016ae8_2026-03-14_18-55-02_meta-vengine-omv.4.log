{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BwnAuyJfL917mVkK96tQuP","type":"tool_result","content":"     1→#!/usr/bin/env node\n     2→/**\n     3→ * Decision Quality (DQ) Scorer - ACE Framework Implementation\n     4→ *\n     5→ * Based on: OS-App Adaptive Convergence Engine (ACE) DQ Framework\n     6→ * Measures: validity (0.4) + specificity (0.3) + correctness (0.3)\n     7→ *\n     8→ * Scores routing decisions and learns from history.\n     9→ */\n    10→\n    11→const fs = require('fs');\n    12→const path = require('path');\n    13→const crypto = require('crypto');\n    14→const { execSync } = require('child_process');\n    15→const { estimateComplexity } = require('./complexity-analyzer');\n    16→const { PRICING } = require(path.join(process.env.HOME, '.claude/config/pricing.js'));\n    17→\n    18→// ═══════════════════════════════════════════════════════════════════════════\n    19→// BASELINES LOADING\n    20→// ═══════════════════════════════════════════════════════════════════════════\n    21→\n    22→const BASELINES_PATH = path.join(process.env.HOME, '.claude/kernel/baselines.json');\n    23→\n    24→function loadBaselines() {\n    25→  if (!fs.existsSync(BASELINES_PATH)) {\n    26→    return null;  // Use hardcoded defaults\n    27→  }\n    28→\n    29→  try {\n    30→    const data = fs.readFileSync(BASELINES_PATH, 'utf8');\n    31→    return JSON.parse(data);\n    32→  } catch (e) {\n    33→    console.error('Error loading baselines:', e.message);\n    34→    return null;\n    35→  }\n    36→}\n    37→\n    38→const BASELINES = loadBaselines();\n    39→\n    40→// ═══════════════════════════════════════════════════════════════════════════\n    41→// DQ WEIGHTS (from ACE Framework + Cognitive OS adjustments)\n    42→// ═══════════════════════════════════════════════════════════════════════════\n    43→\n    44→const COGNITIVE_DQ_WEIGHTS_PATH = path.join(process.env.HOME, '.claude/kernel/cognitive-os/cognitive-dq-weights.json');\n    45→const EXPERTISE_ROUTING_STATE_PATH = path.join(process.env.HOME, '.claude/kernel/expertise-routing-state.json');\n    46→\n    47→function loadCognitiveDQWeights() {\n    48→  // Try to load cognitive-aware weights from Cognitive OS\n    49→  if (fs.existsSync(COGNITIVE_DQ_WEIGHTS_PATH)) {\n    50→    try {\n    51→      const data = JSON.parse(fs.readFileSync(COGNITIVE_DQ_WEIGHTS_PATH, 'utf8'));\n    52→      const fileAge = Date.now() - new Date(data.timestamp).getTime();\n    53→      // Only use if less than 30 minutes old\n    54→      if (fileAge < 30 * 60 * 1000 && data.dq_weights) {\n    55→        return {\n    56→          weights: data.dq_weights,\n    57→          complexityModifier: data.complexity_threshold_modifier || 1.0,\n    58→          cognitiveMode: data.cognitive_mode,\n    59→          reasoning: data.reasoning\n    60→        };\n    61→      }\n    62→    } catch (e) {\n    63→      // Fall through to defaults\n    64→    }\n    65→  }\n    66→  return null;\n    67→}\n    68→\n    69→const COGNITIVE_WEIGHTS = loadCognitiveDQWeights();\n    70→\n    71→const DQ_WEIGHTS = COGNITIVE_WEIGHTS?.weights || BASELINES?.dq_weights || {\n    72→  validity: 0.4,      // Does the routing make logical sense?\n    73→  specificity: 0.3,   // How precise is the model selection?\n    74→  correctness: 0.3    // Historical accuracy of similar queries\n    75→};\n    76→\n    77→// Complexity threshold modifier from Cognitive OS (affects model selection boundaries)\n    78→const COMPLEXITY_MODIFIER = COGNITIVE_WEIGHTS?.complexityModifier || 1.0;\n    79→\n    80→// ═══════════════════════════════════════════════════════════════════════════\n    81→// EXPERTISE ROUTING\n    82→// ═══════════════════════════════════════════════════════════════════════════\n    83→\n    84→function loadExpertiseState() {\n    85→  if (fs.existsSync(EXPERTISE_ROUTING_STATE_PATH)) {\n    86→    try {\n    87→      const data = JSON.parse(fs.readFileSync(EXPERTISE_ROUTING_STATE_PATH, 'utf8'));\n    88→      const fileAge = Date.now() - new Date(data.timestamp).getTime();\n    89→      // Use if less than 1 hour old\n    90→      if (fileAge < 60 * 60 * 1000) {\n    91→        return data;\n    92→      }\n    93→    } catch (e) {}\n    94→  }\n    95→  return null;\n    96→}\n    97→\n    98→const EXPERTISE_STATE = loadExpertiseState();\n    99→\n   100→/**\n   101→ * Detect domain of query and check expertise level\n   102→ */\n   103→function getExpertiseAdjustment(query) {\n   104→  if (!EXPERTISE_STATE) return null;\n   105→\n   106→  const highExpertise = EXPERTISE_STATE.high_expertise_domains || [];\n   107→  const lowExpertise = EXPERTISE_STATE.low_expertise_domains || [];\n   108→  const queryLower = query.toLowerCase();\n   109→\n   110→  // Check if query matches high expertise domains\n   111→  for (const domain of highExpertise) {\n   112→    if (queryLower.includes(domain) ||\n   113→        (domain === 'react' && (queryLower.includes('component') || queryLower.includes('hook'))) ||\n   114→        (domain === 'typescript' && queryLower.includes('type')) ||\n   115→        (domain === 'python' && queryLower.includes('.py'))) {\n   116→      return { domain, adjustment: 'downgrade', expertise: 'high' };\n   117→    }\n   118→  }\n   119→\n   120→  // Check if query matches low expertise domains\n   121→  for (const domain of lowExpertise) {\n   122→    if (queryLower.includes(domain)) {\n   123→      return { domain, adjustment: 'upgrade', expertise: 'low' };\n   124→    }\n   125→  }\n   126→\n   127→  return null;\n   128→}\n   129→\n   130→// Actionable threshold\n   131→const DQ_THRESHOLD = BASELINES?.dq_thresholds?.actionable || 0.5;\n   132→\n   133→// Model capabilities (for validity assessment)\n   134→// Load from baselines if available, otherwise use hardcoded\n   135→const MODEL_CAPABILITIES = BASELINES?.complexity_thresholds ? {\n   136→  haiku: {\n   137→    strengths: ['quick answers', 'simple tasks', 'formatting', 'short responses'],\n   138→    weaknesses: ['complex reasoning', 'long context', 'code generation', 'architecture'],\n   139→    maxComplexity: BASELINES.complexity_thresholds.haiku.range[1],\n   140→    costPerMToken: BASELINES.cost_per_mtok?.haiku || { input: 0.25, output: 1.25 }\n   141→  },\n   142→  sonnet: {\n   143→    strengths: ['code generation', 'analysis', 'moderate reasoning', 'balanced tasks'],\n   144→    weaknesses: ['expert-level problems', 'novel architecture', 'research synthesis'],\n   145→    maxComplexity: BASELINES.complexity_thresholds.sonnet.range[1],\n   146→    costPerMToken: BASELINES.cost_per_mtok?.sonnet || { input: 3, output: 15 }\n   147→  },\n   148→  opus: {\n   149→    strengths: ['complex reasoning', 'novel problems', 'architecture', 'research', 'expert tasks'],\n   150→    weaknesses: ['cost', 'latency for simple tasks'],\n   151→    maxComplexity: BASELINES.complexity_thresholds.opus.range[1],\n   152→    costPerMToken: BASELINES.cost_per_mtok?.opus || { input: 5, output: 25 }\n   153→  }\n   154→} : {\n   155→  // Fallback values from centralized pricing config\n   156→  haiku: {\n   157→    strengths: ['quick answers', 'simple tasks', 'formatting', 'short responses'],\n   158→    weaknesses: ['complex reasoning', 'long context', 'code generation', 'architecture'],\n   159→    maxComplexity: 0.30,\n   160→    costPerMToken: { input: PRICING.haiku.input, output: PRICING.haiku.output }\n   161→  },\n   162→  sonnet: {\n   163→    strengths: ['code generation', 'analysis', 'moderate reasoning', 'balanced tasks'],\n   164→    weaknesses: ['expert-level problems', 'novel architecture', 'research synthesis'],\n   165→    maxComplexity: 0.70,\n   166→    costPerMToken: { input: PRICING.sonnet.input, output: PRICING.sonnet.output }\n   167→  },\n   168→  opus: {\n   169→    strengths: ['complex reasoning', 'novel problems', 'architecture', 'research', 'expert tasks'],\n   170→    weaknesses: ['cost', 'latency for simple tasks'],\n   171→    maxComplexity: 1.0,\n   172→    costPerMToken: { input: PRICING.opus.input, output: PRICING.opus.output }\n   173→  }\n   174→};\n   175→\n   176→// Adaptive thresholds (from ACE)\n   177→const ADAPTIVE_THRESHOLDS = {\n   178→  simple:   { complexity: [0, 0.25],   model: 'haiku',  rounds: 3,  gap: 2 },\n   179→  moderate: { complexity: [0.25, 0.50], model: 'sonnet', rounds: 7,  gap: 3 },\n   180→  complex:  { complexity: [0.50, 0.75], model: 'sonnet', rounds: 12, gap: 4 },\n   181→  expert:   { complexity: [0.75, 1.0],  model: 'opus',   rounds: 15, gap: 5 }\n   182→};\n   183→\n   184→// ═══════════════════════════════════════════════════════════════════════════\n   185→// HISTORY MANAGEMENT\n   186→// ═══════════════════════════════════════════════════════════════════════════\n   187→\n   188→const HISTORY_PATH = path.join(process.env.HOME, '.claude/kernel/dq-scores.jsonl');\n   189→\n   190→function loadHistory() {\n   191→  if (!fs.existsSync(HISTORY_PATH)) return [];\n   192→\n   193→  try {\n   194→    const lines = fs.readFileSync(HISTORY_PATH, 'utf8').split('\\n').filter(l => l.trim());\n   195→    return lines.map(l => JSON.parse(l));\n   196→  } catch (e) {\n   197→    return [];\n   198→  }\n   199→}\n   200→\n   201→function saveDecision(decision) {\n   202→  const line = JSON.stringify(decision) + '\\n';\n   203→  fs.appendFileSync(HISTORY_PATH, line);\n   204→}\n   205→\n   206→/**\n   207→ * Apply cognitive complexity modifier to adjust thresholds\n   208→ */\n   209→function applyCognitiveModifier(complexity) {\n   210→  // If modifier > 1, we can handle more complexity (raise thresholds effectively)\n   211→  // If modifier < 1, we should use simpler models (lower thresholds effectively)\n   212→  return complexity / COMPLEXITY_MODIFIER;\n   213→}\n   214→\n   215→// ═══════════════════════════════════════════════════════════════════════════\n   216→// DISTRIBUTIONAL FEATURES (US-001: Multi-Feature Graph Signal)\n   217→// ═══════════════════════════════════════════════════════════════════════════\n   218→\n   219→/**\n   220→ * Compute distributional features from supermemory retrieval score distributions.\n   221→ * Used by the multi-feature graph signal (US-004) to replace single skewness metric.\n   222→ *\n   223→ * @param {number[]} scores - Raw retrieval scores from supermemory\n   224→ * @returns {{entropy: number, gini: number, skewness: number, sampleSize: number} | null}\n   225→ *          Returns null when scores.length < 5 (minimum sample threshold per Security Architect)\n   226→ */\n   227→function computeDistributionalFeatures(scores) {\n   228→  if (!Array.isArray(scores) || scores.length < 5) {\n   229→    return null;\n   230→  }\n   231→\n   232→  const n = scores.length;\n   233→\n   234→  // Normalize scores to a probability distribution (sum to 1)\n   235→  const sum = scores.reduce((a, b) => a + b, 0);\n   236→  if (sum === 0) {\n   237→    return { entropy: 0, gini: 1 / n, skewness: 0, sampleSize: n };\n   238→  }\n   239→  const probs = scores.map(s => s / sum);\n   240→\n   241→  // Shannon entropy: -Σ(p * log(p)), skip p=0 terms\n   242→  const entropy = -probs.reduce((acc, p) => {\n   243→    if (p > 0) acc += p * Math.log(p);\n   244→    return acc;\n   245→  }, 0);\n   246→\n   247→  // Gini impurity: 1 - Σ(p_i²)\n   248→  const gini = 1 - probs.reduce((acc, p) => acc + p * p, 0);\n   249→\n   250→  // Skewness (Fisher-Pearson, sample-adjusted)\n   251→  const mean = scores.reduce((a, b) => a + b, 0) / n;\n   252→  const variance = scores.reduce((acc, s) => acc + (s - mean) ** 2, 0) / n;\n   253→  const stdDev = Math.sqrt(variance);\n   254→  let skewness = 0;\n   255→  if (stdDev > 0 && n >= 3) {\n   256→    const m3 = scores.reduce((acc, s) => acc + ((s - mean) / stdDev) ** 3, 0) / n;\n   257→    // Apply sample adjustment factor\n   258→    skewness = (Math.sqrt(n * (n - 1)) / (n - 2)) * m3;\n   259→  }\n   260→\n   261→  return {\n   262→    entropy: parseFloat(entropy.toFixed(6)),\n   263→    gini: parseFloat(gini.toFixed(6)),\n   264→    skewness: parseFloat(skewness.toFixed(6)),\n   265→    sampleSize: n\n   266→  };\n   267→}\n   268→\n   269→// ═══════════════════════════════════════════════════════════════════════════\n   270→// IRT DIFFICULTY BRIDGE (US-003: Multi-Feature Graph Signal — IRT Integration)\n   271→// ═══════════════════════════════════════════════════════════════════════════\n   272→\n   273→const IRT_BRIDGE_PATH = path.join(process.env.HOME, '.claude/kernel/hsrgs/irt-bridge.json');\n   274→\n   275→/**\n   276→ * Load IRT difficulty data from the HSRGS bridge file (Python → Node.js).\n   277→ * Returns the bridge data if fresh (< 60 seconds old), null otherwise.\n   278→ *\n   279→ * @param {string} [queryHash] - Optional query hash to match against bridge data\n   280→ * @returns {{difficulty: number, discrimination: number, domain_signature: string,\n   281→ *            irt_predictions: Object, selected_model: string, timestamp: number} | null}\n   282→ */\n   283→function loadIRTBridge(queryHash) {\n   284→  try {\n   285→    if (!fs.existsSync(IRT_BRIDGE_PATH)) return null;\n   286→\n   287→    const data = JSON.parse(fs.readFileSync(IRT_BRIDGE_PATH, 'utf8'));\n   288→\n   289→    // Staleness check: bridge data must be < 60 seconds old\n   290→    const ageMs = Date.now() - data.timestamp;\n   291→    if (ageMs > 60000) return null;\n   292→\n   293→    // If queryHash provided, verify it matches\n   294→    if (queryHash && data.query_hash !== queryHash) return null;\n   295→\n   296→    // Validate required fields\n   297→    if (typeof data.difficulty !== 'number') return null;\n   298→\n   299→    return data;\n   300→  } catch (e) {\n   301→    return null;\n   302→  }\n   303→}\n   304→\n   305→/**\n   306→ * Compute IRT difficulty modifier for routing.\n   307→ * High IRT difficulty (> 0.7) biases toward Opus (positive modifier).\n   308→ * Low IRT difficulty (< 0.3) biases toward Haiku (negative modifier).\n   309→ * Mid-range: no effect.\n   310→ *\n   311→ * @param {number} irtDifficulty - IRT difficulty from HSRGS (0.0-1.0)\n   312→ * @returns {number} Modifier to apply to complexity score (-0.15 to +0.15)\n   313→ */\n   314→function computeIRTModifier(irtDifficulty) {\n   315→  if (typeof irtDifficulty !== 'number' || isNaN(irtDifficulty)) return 0.0;\n   316→\n   317→  // Clamp to valid range\n   318→  const d = Math.max(0.0, Math.min(1.0, irtDifficulty));\n   319→\n   320→  if (d > 0.7) {\n   321→    // High difficulty: bias toward more capable model (Opus)\n   322→    // Scale: 0.7 → 0.0, 1.0 → +0.15\n   323→    return parseFloat(((d - 0.7) / 0.3 * 0.15).toFixed(4));\n   324→  } else if (d < 0.3) {\n   325→    // Low difficulty: bias toward cheaper model (Haiku)\n   326→    // Scale: 0.3 → 0.0, 0.0 → -0.15\n   327→    return parseFloat(((d - 0.3) / 0.3 * 0.15).toFixed(4));\n   328→  }\n   329→\n   330→  // Mid-range: no modification\n   331→  return 0.0;\n   332→}\n   333→\n   334→// ═══════════════════════════════════════════════════════════════════════════\n   335→// SUBGRAPH DENSITY (US-002: Multi-Feature Graph Signal)\n   336→// ═══════════════════════════════════════════════════════════════════════════\n   337→\n   338→const SUPERMEMORY_DB_PATH = path.join(process.env.HOME, '.claude/memory/supermemory.db');\n   339→\n   340→/**\n   341→ * Query supermemory.db via sqlite3 CLI (zero-dependency, no native modules).\n   342→ * Uses UNION for indexed lookups on both from_id and to_id.\n   343→ *\n   344→ * @param {string} sql - SQL query to execute\n   345→ * @returns {string} Raw output from sqlite3\n   346→ */\n   347→function querySuperMemory(sql) {\n   348→  try {\n   349→    return execSync(\n   350→      `sqlite3 \"${SUPERMEMORY_DB_PATH}\" \"${sql.replace(/\"/g, '\\\\\"')}\"`,\n   351→      { encoding: 'utf8', timeout: 5000 }\n   352→    ).trim();\n   353→  } catch (e) {\n   354→    return '';\n   355→  }\n   356→}\n   357→\n   358→/**\n   359→ * Compute subgraph density for a set of retrieved knowledge nodes.\n   360→ * Sparse subgraphs (density < 0.1) cause ~30% of KG-RAG errors (GraphRouter ICLR 2025).\n   361→ *\n   362→ * @param {string[]} retrievedNodes - Array of node IDs from supermemory retrieval\n   363→ * @param {string} [queryTopic] - Optional topic string for coverage rate estimation via FTS\n   364→ * @returns {{density: number, nodeCount: number, edgeCount: number, coverageRate: number} | null}\n   365→ *          Returns null when retrievedNodes.length < 2 (need at least 2 nodes for density)\n   366→ */\n   367→function computeSubgraphDensity(retrievedNodes, queryTopic) {\n   368→  if (!Array.isArray(retrievedNodes) || retrievedNodes.length < 2) {\n   369→    return null;\n   370→  }\n   371→\n   372→  // Deduplicate nodes\n   373→  const nodes = [...new Set(retrievedNodes)];\n   374→  const nodeCount = nodes.length;\n   375→\n   376→  if (nodeCount < 2) {\n   377→    return null;\n   378→  }\n   379→\n   380→  // Maximum possible edges in an undirected graph: n*(n-1)/2\n   381→  const maxEdges = (nodeCount * (nodeCount - 1)) / 2;\n   382→\n   383→  // Query actual edges among retrieved nodes using indexed UNION approach\n   384→  // Build IN clause for the node set\n   385→  const inClause = nodes.map(n => `'${n.replace(/'/g, \"''\")}'`).join(',');\n   386→\n   387→  // Count edges where BOTH endpoints are in the retrieved set\n   388→  // UNION approach uses indexes on both from_id and to_id efficiently\n   389→  const edgeSql = `SELECT COUNT(*) FROM (\n   390→    SELECT DISTINCT from_id, to_id FROM (\n   391→      SELECT from_id, to_id FROM memory_links WHERE from_id IN (${inClause}) AND to_id IN (${inClause})\n   392→      UNION\n   393→      SELECT from_id, to_id FROM memory_links WHERE to_id IN (${inClause}) AND from_id IN (${inClause})\n   394→    )\n   395→  )`;\n   396→\n   397→  const edgeResult = querySuperMemory(edgeSql);\n   398→  const edgeCount = parseInt(edgeResult, 10) || 0;\n   399→\n   400→  // Density = actual edges / possible edges\n   401→  const density = maxEdges > 0 ? edgeCount / maxEdges : 0;\n   402→\n   403→  // Coverage rate: retrieved nodes / estimated relevant nodes\n   404→  // Use FTS match count from memory_items as the estimate of relevant nodes\n   405→  let coverageRate = 1.0; // Default: assume full coverage if no topic\n   406→  if (queryTopic && queryTopic.trim()) {\n   407→    const safeTopic = queryTopic.replace(/\"/g, '').replace(/'/g, \"''\").replace(/[^\\w\\s-]/g, '');\n   408→    if (safeTopic.trim()) {\n   409→      const ftsSql = `SELECT COUNT(*) FROM memory_fts WHERE memory_fts MATCH '${safeTopic}'`;\n   410→      const ftsResult = querySuperMemory(ftsSql);\n   411→      const relevantCount = parseInt(ftsResult, 10) || 0;\n   412→      if (relevantCount > 0) {\n   413→        coverageRate = Math.min(1.0, nodeCount / relevantCount);\n   414→      }\n   415→    }\n   416→  }\n   417→\n   418→  return {\n   419→    density: parseFloat(density.toFixed(6)),\n   420→    nodeCount,\n   421→    edgeCount,\n   422→    coverageRate: parseFloat(coverageRate.toFixed(6))\n   423→  };\n   424→}\n   425→\n   426→/**\n   427→ * Compute subgraph density from pre-fetched graph links (no DB access needed).\n   428→ * Used for testing and when links are already loaded.\n   429→ *\n   430→ * @param {string[]} retrievedNodes - Array of node IDs\n   431→ * @param {{from_id: string, to_id: string}[]} graphLinks - Pre-fetched edge list\n   432→ * @returns {{density: number, nodeCount: number, edgeCount: number, coverageRate: number} | null}\n   433→ */\n   434→function computeSubgraphDensityFromLinks(retrievedNodes, graphLinks) {\n   435→  if (!Array.isArray(retrievedNodes) || retrievedNodes.length < 2) {\n   436→    return null;\n   437→  }\n   438→  if (!Array.isArray(graphLinks)) {\n   439→    return null;\n   440→  }\n   441→\n   442→  const nodeSet = new Set(retrievedNodes);\n   443→  const nodeCount = nodeSet.size;\n   444→\n   445→  if (nodeCount < 2) {\n   446→    return null;\n   447→  }\n   448→\n   449→  const maxEdges = (nodeCount * (nodeCount - 1)) / 2;\n   450→\n   451→  // Count unique edges where both endpoints are in the node set\n   452→  const edgeSet = new Set();\n   453→  for (const link of graphLinks) {\n   454→    if (nodeSet.has(link.from_id) && nodeSet.has(link.to_id) && link.from_id !== link.to_id) {\n   455→      // Normalize edge direction for undirected counting\n   456→      const edgeKey = [link.from_id, link.to_id].sort().join('::');\n   457→      edgeSet.add(edgeKey);\n   458→    }\n   459→  }\n   460→\n   461→  const edgeCount = edgeSet.size;\n   462→  const density = maxEdges > 0 ? edgeCount / maxEdges : 0;\n   463→\n   464→  return {\n   465→    density: parseFloat(density.toFixed(6)),\n   466→    nodeCount,\n   467→    edgeCount,\n   468→    coverageRate: 1.0 // No topic available for in-memory computation\n   469→  };\n   470→}\n   471→\n   472→// ═══════════════════════════════════════════════════════════════════════════\n   473→// MULTI-FEATURE GRAPH SIGNAL (US-004: Signal Composition)\n   474→// ═══════════════════════════════════════════════════════════════════════════\n   475→\n   476→const GRAPH_SIGNAL_WEIGHTS_PATH = path.join(__dirname, '..', 'config', 'graph-signal-weights.json');\n   477→\n   478→/**\n   479→ * Load graph signal weights from config file (the ONLY authority).\n   480→ * Designed as a future Optimas Local Reward Function (learnable).\n   481→ *\n   482→ * @returns {{entropy: number, gini: number, subgraphDensity: number, irtDifficulty: number}}\n   483→ */\n   484→function loadGraphSignalWeights() {\n   485→  try {\n   486→    if (fs.existsSync(GRAPH_SIGNAL_WEIGHTS_PATH)) {\n   487→      const config = JSON.parse(fs.readFileSync(GRAPH_SIGNAL_WEIGHTS_PATH, 'utf8'));\n   488→      if (config.weights) return config.weights;\n   489→    }\n   490→  } catch (e) {\n   491→    // Fall through to defaults\n   492→  }\n   493→  // Emergency fallback only — should never be used in production\n   494→  return { entropy: 0.30, gini: 0.25, subgraphDensity: 0.25, irtDifficulty: 0.20 };\n   495→}\n   496→\n   497→/**\n   498→ * Compose entropy, Gini, subgraph density, and IRT difficulty into a single\n   499→ * graphComplexity score (0.0-1.0). Replaces keyword-based complexity for routing.\n   500→ *\n   501→ * Higher graphComplexity means the query is harder (sparse knowledge, concentrated\n   502→ * retrieval scores, high IRT difficulty) and should route to more capable models.\n   503→ *\n   504→ * Feature normalization:\n   505→ * - entropy: inverted (high entropy = well-distributed knowledge = EASIER)\n   506→ *   normalized to [0,1] via 1 - entropy/maxEntropy\n   507→ * - gini: inverted (high Gini = diverse distribution = EASIER)\n   508→ *   normalized to [0,1] via 1 - gini\n   509→ * - subgraphDensity: inverted (dense subgraph = well-connected knowledge = EASIER)\n   510→ *   normalized to [0,1] via 1 - density\n   511→ * - irtDifficulty: direct (high difficulty = HARDER), already [0,1]\n   512→ *\n   513→ * @param {Object} params\n   514→ * @param {Object|null} params.distributional - Output of computeDistributionalFeatures()\n   515→ * @param {Object|null} params.subgraph - Output of computeSubgraphDensity()\n   516→ * @param {number|null} params.irtDifficulty - IRT difficulty from HSRGS bridge (0.0-1.0)\n   517→ * @returns {{graphComplexity: number, features: Object, weights: Object, featureCount: number} | null}\n   518→ *          Returns null if no features are available\n   519→ */\n   520→function computeGraphSignal({ distributional, subgraph, irtDifficulty }) {\n   521→  const weights = loadGraphSignalWeights();\n   522→  const features = {};\n   523→  let totalWeight = 0;\n   524→  let weightedSum = 0;\n   525→\n   526→  // Entropy: invert so high entropy (easy) → low complexity\n   527→  if (distributional && typeof distributional.entropy === 'number') {\n   528→    // Max entropy for n items = ln(n). Use sampleSize for normalization.\n   529→    const maxEntropy = Math.log(distributional.sampleSize);\n   530→    const normalizedEntropy = maxEntropy > 0 ? distributional.entropy / maxEntropy : 0;\n   531→    const complexityFromEntropy = 1 - normalizedEntropy; // invert: low entropy = high complexity\n   532→    features.entropy = parseFloat(complexityFromEntropy.toFixed(6));\n   533→    weightedSum += features.entropy * weights.entropy;\n   534→    totalWeight += weights.entropy;\n   535→  }\n   536→\n   537→  // Gini: invert so high Gini (diverse) → low complexity\n   538→  if (distributional && typeof distributional.gini === 'number') {\n   539→    const complexityFromGini = 1 - distributional.gini; // invert: low diversity = high complexity\n   540→    features.gini = parseFloat(complexityFromGini.toFixed(6));\n   541→    weightedSum += features.gini * weights.gini;\n   542→    totalWeight += weights.gini;\n   543→  }\n   544→\n   545→  // Subgraph density: invert so dense graph → low complexity\n   546→  if (subgraph && typeof subgraph.density === 'number') {\n   547→    const complexityFromDensity = 1 - subgraph.density; // invert: sparse = high complexity\n   548→    features.subgraphDensity = parseFloat(complexityFromDensity.toFixed(6));\n   549→    weightedSum += features.subgraphDensity * weights.subgraphDensity;\n   550→    totalWeight += weights.subgraphDensity;\n   551→  }\n   552→\n   553→  // IRT difficulty: direct mapping (already 0-1, high = hard)\n   554→  if (typeof irtDifficulty === 'number' && !isNaN(irtDifficulty)) {\n   555→    const clampedIRT = Math.max(0, Math.min(1, irtDifficulty));\n   556→    features.irtDifficulty = parseFloat(clampedIRT.toFixed(6));\n   557→    weightedSum += features.irtDifficulty * weights.irtDifficulty;\n   558→    totalWeight += weights.irtDifficulty;\n   559→  }\n   560→\n   561→  const featureCount = Object.keys(features).length;\n   562→  if (featureCount === 0) return null;\n   563→\n   564→  // Normalize by actual weight used (handles partial feature availability)\n   565→  const graphComplexity = totalWeight > 0 ? weightedSum / totalWeight : 0;\n   566→\n   567→  return {\n   568→    graphComplexity: parseFloat(Math.max(0, Math.min(1, graphComplexity)).toFixed(6)),\n   569→    features,\n   570→    weights,\n   571→    featureCount\n   572→  };\n   573→}\n   574→\n   575→// ═══════════════════════════════════════════════════════════════════════════\n   576→// DQ SCORING FUNCTIONS\n   577→// ═══════════════════════════════════════════════════════════════════════════\n   578→\n   579→/**\n   580→ * Assess validity: Does the model selection make logical sense?\n   581→ */\n   582→function assessValidity(complexity, model) {\n   583→  const modelCaps = MODEL_CAPABILITIES[model];\n   584→  if (!modelCaps) return 0;\n   585→\n   586→  // Perfect validity: complexity within model's range\n   587→  if (complexity <= modelCaps.maxComplexity) {\n   588→    // Penalize over-provisioning (using opus for simple tasks)\n   589→    const overProvision = modelCaps.maxComplexity - complexity;\n   590→    if (model === 'opus' && complexity < 0.5) {\n   591→      return 0.6; // Wasteful but valid\n   592→    }\n   593→    if (model === 'sonnet' && complexity < 0.2) {\n   594→      return 0.7; // Slightly wasteful\n   595→    }\n   596→    return 1.0 - (overProvision * 0.2); // Small penalty for over-provisioning\n   597→  }\n   598→\n   599→  // Under-provisioning is worse\n   600→  const underProvision = complexity - modelCaps.maxComplexity;\n   601→  return Math.max(0, 1.0 - (underProvision * 2)); // Heavy penalty\n   602→}\n   603→\n   604→/**\n   605→ * Assess specificity: How precise is the model selection?\n   606→ */\n   607→function assessSpecificity(query, complexity, model) {\n   608→  // Check if model matches the ideal for this complexity\n   609→  let idealModel;\n   610→  for (const [level, config] of Object.entries(ADAPTIVE_THRESHOLDS)) {\n   611→    if (complexity >= config.complexity[0] && complexity < config.complexity[1]) {\n   612→      idealModel = config.model;\n   613→      break;\n   614→    }\n   615→  }\n   616→  if (!idealModel) idealModel = 'opus';\n   617→\n   618→  if (model === idealModel) return 1.0;\n   619→\n   620→  // Adjacent model is acceptable\n   621→  const models = ['haiku', 'sonnet', 'opus'];\n   622→  const idealIdx = models.indexOf(idealModel);\n   623→  const actualIdx = models.indexOf(model);\n   624→  const distance = Math.abs(idealIdx - actualIdx);\n   625→\n   626→  return Math.max(0, 1.0 - (distance * 0.4));\n   627→}\n   628→\n   629→/**\n   630→ * Assess correctness: Historical accuracy for similar queries\n   631→ */\n   632→function assessCorrectness(query, model, history) {\n   633→  if (history.length === 0) return 0.5; // No history, neutral\n   634→\n   635→  // Find similar queries\n   636→  const queryTokens = new Set(query.toLowerCase().split(/\\s+/));\n   637→  const similar = history.filter(h => {\n   638→    if (!h.query) return false;\n   639→    const histTokens = new Set(h.query.toLowerCase().split(/\\s+/));\n   640→    const intersection = [...queryTokens].filter(t => histTokens.has(t)).length;\n   641→    return intersection / Math.max(queryTokens.size, histTokens.size) > 0.3;\n   642→  });\n   643→\n   644→  if (similar.length === 0) return 0.5;\n   645→\n   646→  // Check success rate for this model on similar queries\n   647→  const modelMatches = similar.filter(s => s.model === model);\n   648→  if (modelMatches.length === 0) return 0.5;\n   649→\n   650→  // If we have feedback, use it\n   651→  const withFeedback = modelMatches.filter(m => m.success !== undefined);\n   652→  if (withFeedback.length > 0) {\n   653→    const successRate = withFeedback.filter(m => m.success).length / withFeedback.length;\n   654→    return successRate;\n   655→  }\n   656→\n   657→  // Otherwise, assume DQ score is a proxy for success\n   658→  const avgDQ = modelMatches.reduce((sum, m) => sum + (m.dqScore || 0.5), 0) / modelMatches.length;\n   659→  return avgDQ;\n   660→}\n   661→\n   662→/**\n   663→ * Calculate composite DQ score\n   664→ */\n   665→function calculateDQ(query, complexity, model, history = []) {\n   666→  const validity = assessValidity(complexity, model);\n   667→  const specificity = assessSpecificity(query, complexity, model);\n   668→  const correctness = assessCorrectness(query, model, history);\n   669→\n   670→  const score = (validity * DQ_WEIGHTS.validity) +\n   671→                (specificity * DQ_WEIGHTS.specificity) +\n   672→                (correctness * DQ_WEIGHTS.correctness);\n   673→\n   674→  return {\n   675→    score: parseFloat(score.toFixed(3)),\n   676→    components: {\n   677→      validity: parseFloat(validity.toFixed(3)),\n   678→      specificity: parseFloat(specificity.toFixed(3)),\n   679→      correctness: parseFloat(correctness.toFixed(3))\n   680→    },\n   681→    actionable: score >= DQ_THRESHOLD\n   682→  };\n   683→}\n   684→\n   685→// ═══════════════════════════════════════════════════════════════════════════\n   686→// ROUTING DECISION\n   687→// ═══════════════════════════════════════════════════════════════════════════\n   688→\n   689→/**\n   690→ * Make a routing decision with DQ scoring\n   691→ */\n   692→function route(query) {\n   693→  const history = loadHistory();\n   694→  const complexity = estimateComplexity(query);\n   695→\n   696→  // Apply cognitive modifier to complexity for threshold comparisons\n   697→  const adjustedComplexity = applyCognitiveModifier(complexity.score);\n   698→\n   699→  // Apply IRT difficulty modifier (US-003: cross-runtime bridge from HSRGS)\n   700→  const queryHash = crypto.createHash('md5').update(query).digest('hex');\n   701→  const irtBridge = loadIRTBridge(queryHash);\n   702→  const irtDifficulty = irtBridge ? irtBridge.difficulty : null;\n   703→  const IRT_MOD = computeIRTModifier(irtDifficulty);\n   704→  const irtAdjustedComplexity = Math.max(0, Math.min(1, adjustedComplexity + IRT_MOD));\n   705→\n   706→  // US-004: Compute multi-feature graph signal\n   707→  // Attempt to gather distributional features and subgraph density\n   708→  // These may be null if no retrieval scores / nodes are available for this query\n   709→  const graphSignal = computeGraphSignal({\n   710→    distributional: null, // Populated by caller or retrieval pipeline when available\n   711→    subgraph: null,       // Populated by caller or retrieval pipeline when available\n   712→    irtDifficulty: irtDifficulty\n   713→  });\n   714→\n   715→  // A/B test: determine which complexity signal to use for routing\n   716→  // Odd session timestamps use graph signal, even use keyword (deterministic)\n   717→  const sessionId = Math.floor(Date.now() / 1000);\n   718→  const useGraphSignal = graphSignal && graphSignal.featureCount >= 2 && (sessionId % 2 === 1);\n   719→  const routingComplexity = useGraphSignal ? graphSignal.graphComplexity : irtAdjustedComplexity;\n   720→\n   721→  // Try each model and pick best DQ\n   722→  const candidates = ['haiku', 'sonnet', 'opus'].map(model => {\n   723→    // Use the selected complexity signal for DQ calculation\n   724→    const dq = calculateDQ(query, routingComplexity, model, history);\n   725→    return { model, dq, complexity: complexity.score, adjustedComplexity: routingComplexity };\n   726→  });\n   727→\n   728→  // Sort by DQ score (highest first), then by cost (lowest first for ties)\n   729→  candidates.sort((a, b) => {\n   730→    if (Math.abs(a.dq.score - b.dq.score) > 0.05) {\n   731→      return b.dq.score - a.dq.score;\n   732→    }\n   733→    // If DQ scores are similar, prefer cheaper model\n   734→    const costOrder = { haiku: 0, sonnet: 1, opus: 2 };\n   735→    return costOrder[a.model] - costOrder[b.model];\n   736→  });\n   737→\n   738→  let best = candidates[0];\n   739→\n   740→  // Apply expertise-based adjustment\n   741→  const expertiseAdj = getExpertiseAdjustment(query);\n   742→  let expertiseOverride = null;\n   743→\n   744→  if (expertiseAdj) {\n   745→    const models = ['haiku', 'sonnet', 'opus'];\n   746→    const currentIdx = models.indexOf(best.model);\n   747→\n   748→    if (expertiseAdj.adjustment === 'downgrade' && currentIdx > 0) {\n   749→      // High expertise - can use cheaper model\n   750→      const newModel = models[currentIdx - 1];\n   751→      expertiseOverride = {\n   752→        original: best.model,\n   753→        adjusted: newModel,\n   754→        domain: expertiseAdj.domain,\n   755→        reason: `High expertise in ${expertiseAdj.domain}`\n   756→      };\n   757→      // Find the candidate for the new model\n   758→      const newCandidate = candidates.find(c => c.model === newModel);\n   759→      if (newCandidate) {\n   760→        best = newCandidate;\n   761→      }\n   762→    } else if (expertiseAdj.adjustment === 'upgrade' && currentIdx < models.length - 1) {\n   763→      // Low expertise - need more capable model\n   764→      const newModel = models[currentIdx + 1];\n   765→      expertiseOverride = {\n   766→        original: best.model,\n   767→        adjusted: newModel,\n   768→        domain: expertiseAdj.domain,\n   769→        reason: `Low expertise in ${expertiseAdj.domain}`\n   770→      };\n   771→      const newCandidate = candidates.find(c => c.model === newModel);\n   772→      if (newCandidate) {\n   773→        best = newCandidate;\n   774→      }\n   775→    }\n   776→  }\n   777→\n   778→  // Estimate cost for this routing decision\n   779→  function estimateCost(model, queryText) {\n   780→    const modelCaps = MODEL_CAPABILITIES[model];\n   781→    if (!modelCaps) return 0;\n   782→\n   783→    // Rough estimate: query ~100 tokens, response ~500 tokens\n   784→    const estInputTokens = Math.max(100, queryText.length / 4);\n   785→    const estOutputTokens = 500;\n   786→\n   787→    const cost = (estInputTokens * modelCaps.costPerMToken.input / 1_000_000 +\n   788→                  estOutputTokens * modelCaps.costPerMToken.output / 1_000_000);\n   789→\n   790→    return cost;\n   791→  }\n   792→\n   793→  // Log the decision with enhanced metadata\n   794→  const decision = {\n   795→    ts: Math.floor(Date.now() / 1000),  // Unix seconds (not ms)\n   796→    query_hash: crypto.createHash('md5').update(query).digest('hex'),\n   797→    query: query.slice(0, 200), // Truncate for storage\n   798→    query_preview: query.slice(0, 50),\n   799→    complexity: complexity.score,\n   800→    adjusted_complexity: irtAdjustedComplexity,\n   801→    complexity_reasoning: complexity.reasoning,\n   802→    irt: irtBridge ? {\n   803→      difficulty: irtDifficulty,\n   804→      modifier: IRT_MOD,\n   805→      source: 'hsrgs-bridge'\n   806→    } : null,\n   807→    graphSignal: graphSignal || null,\n   808→    ab_test: {\n   809→      keyword_complexity: irtAdjustedComplexity,\n   810→      graph_complexity: graphSignal ? graphSignal.graphComplexity : null,\n   811→      signal_used: useGraphSignal ? 'graph' : 'keyword',\n   812→      session_id: sessionId\n   813→    },\n   814→    model: best.model,\n   815→    dqScore: best.dq.score,\n   816→    dqComponents: best.dq.components,\n   817→    reasoning: complexity.reasoning,\n   818→    alternatives: candidates.slice(1).map(c => ({ model: c.model, dq: c.dq.score })),\n   819→    cost_estimate: estimateCost(best.model, query),\n   820→    baseline_version: BASELINES ? BASELINES.version : 'hardcoded',\n   821→    cognitive: COGNITIVE_WEIGHTS ? {\n   822→      mode: COGNITIVE_WEIGHTS.cognitiveMode,\n   823→      modifier: COMPLEXITY_MODIFIER,\n   824→      weights_applied: true\n   825→    } : null,\n   826→    expertise: expertiseOverride\n   827→  };\n   828→\n   829→  saveDecision(decision);\n   830→\n   831→  return {\n   832→    model: best.model,\n   833→    complexity: complexity.score,\n   834→    dq: best.dq,\n   835→    reasoning: complexity.reasoning,\n   836→    cost_estimate: decision.cost_estimate,\n   837→    baseline_version: decision.baseline_version,\n   838→    cognitive: decision.cognitive,\n   839→    expertise: decision.expertise\n   840→  };\n   841→}\n   842→\n   843→/**\n   844→ * Record feedback on a routing decision\n   845→ */\n   846→function recordFeedback(queryPrefix, success) {\n   847→  const history = loadHistory();\n   848→\n   849→  // Find most recent matching query\n   850→  for (let i = history.length - 1; i >= 0; i--) {\n   851→    if (history[i].query && history[i].query.startsWith(queryPrefix)) {\n   852→      history[i].success = success;\n   853→      history[i].feedbackTs = Date.now();\n   854→\n   855→      // Rewrite history file\n   856→      const content = history.map(h => JSON.stringify(h)).join('\\n') + '\\n';\n   857→      fs.writeFileSync(HISTORY_PATH, content);\n   858→      return true;\n   859→    }\n   860→  }\n   861→  return false;\n   862→}\n   863→\n   864→/**\n   865→ * Get statistics on routing decisions\n   866→ */\n   867→function getStats() {\n   868→  const history = loadHistory();\n   869→  const last24h = history.filter(h => h.ts > Date.now() - 86400000);\n   870→  const last7d = history.filter(h => h.ts > Date.now() - 604800000);\n   871→\n   872→  const modelCounts = { haiku: 0, sonnet: 0, opus: 0 };\n   873→  const modelDQ = { haiku: [], sonnet: [], opus: [] };\n   874→\n   875→  for (const h of last7d) {\n   876→    if (h.model) modelCounts[h.model]++;\n   877→    if (h.model && h.dqScore) modelDQ[h.model].push(h.dqScore);\n   878→  }\n   879→\n   880→  const avgDQ = {};\n   881→  for (const [model, scores] of Object.entries(modelDQ)) {\n   882→    avgDQ[model] = scores.length > 0\n   883→      ? (scores.reduce((a, b) => a + b, 0) / scores.length).toFixed(3)\n   884→      : 'N/A';\n   885→  }\n   886→\n   887→  return {\n   888→    total: history.length,\n   889→    last24h: last24h.length,\n   890→    last7d: last7d.length,\n   891→    modelDistribution: modelCounts,\n   892→    averageDQ: avgDQ,\n   893→    overallAvgDQ: last7d.length > 0\n   894→      ? (last7d.reduce((sum, h) => sum + (h.dqScore || 0), 0) / last7d.length).toFixed(3)\n   895→      : 'N/A'\n   896→  };\n   897→}\n   898→\n   899→// ═══════════════════════════════════════════════════════════════════════════\n   900→// CLI INTERFACE\n   901→// ═══════════════════════════════════════════════════════════════════════════\n   902→\n   903→if (require.main === module) {\n   904→  const args = process.argv.slice(2);\n   905→  const command = args[0];\n   906→\n   907→  switch (command) {\n   908→    case 'route':\n   909→      // Route a query: node dq-scorer.js route \"query here\"\n   910→      const query = args.slice(1).join(' ');\n   911→      if (!query) {\n   912→        console.error('Usage: dq-scorer.js route \"query\"');\n   913→        process.exit(1);\n   914→      }\n   915→      const result = route(query);\n   916→      console.log(JSON.stringify(result, null, 2));\n   917→      break;\n   918→\n   919→    case 'model':\n   920→      // Just get the model: node dq-scorer.js model \"query\"\n   921→      const q = args.slice(1).join(' ');\n   922→      const r = route(q);\n   923→      console.log(r.model);\n   924→      break;\n   925→\n   926→    case 'feedback':\n   927→      // Record feedback: node dq-scorer.js feedback \"query prefix\" success|failure\n   928→      const prefix = args[1];\n   929→      const success = args[2] === 'success';\n   930→      const recorded = recordFeedback(prefix, success);\n   931→      console.log(recorded ? 'Feedback recorded' : 'Query not found');\n   932→      break;\n   933→\n   934→    case 'stats':\n   935→      // Get statistics: node dq-scorer.js stats\n   936→      console.log(JSON.stringify(getStats(), null, 2));\n   937→      break;\n   938→\n   939→    case 'score':\n   940→      // Score a specific model choice: node dq-scorer.js score \"query\" model\n   941→      const scoreQuery = args[1];\n   942→      const model = args[2] || 'sonnet';\n   943→      const complexity = estimateComplexity(scoreQuery);\n   944→      const dq = calculateDQ(scoreQuery, complexity.score, model, loadHistory());\n   945→      console.log(JSON.stringify({ complexity: complexity.score, model, dq }, null, 2));\n   946→      break;\n   947→\n   948→    default:\n   949→      console.log('DQ Scorer - Decision Quality Framework for Model Routing');\n   950→      console.log('');\n   951→      console.log('Commands:');\n   952→      console.log('  route \"query\"              - Route query to optimal model');\n   953→      console.log('  model \"query\"              - Get just the model name');\n   954→      console.log('  score \"query\" [model]      - Score a specific model choice');\n   955→      console.log('  feedback \"prefix\" success  - Record feedback on a decision');\n   956→      console.log('  stats                      - Get routing statistics');\n   957→  }\n   958→}\n   959→\n   960→module.exports = { route, calculateDQ, recordFeedback, getStats, computeDistributionalFeatures, computeSubgraphDensity, computeSubgraphDensityFromLinks, loadIRTBridge, computeIRTModifier, computeGraphSignal, loadGraphSignalWeights };\n   961→"}]},"parent_tool_use_id":null,"session_id":"87695b28-ee63-4b1b-b8c3-0bd6c57a2fa6","uuid":"e46e42e6-8ba5-4597-96cc-e8ca06884161","tool_use_result":{"type":"text","file":{"filePath":"/Users/dicoangelo/projects/core/meta-vengine/kernel/dq-scorer.js","content":"#!/usr/bin/env node\n/**\n * Decision Quality (DQ) Scorer - ACE Framework Implementation\n *\n * Based on: OS-App Adaptive Convergence Engine (ACE) DQ Framework\n * Measures: validity (0.4) + specificity (0.3) + correctness (0.3)\n *\n * Scores routing decisions and learns from history.\n */\n\nconst fs = require('fs');\nconst path = require('path');\nconst crypto = require('crypto');\nconst { execSync } = require('child_process');\nconst { estimateComplexity } = require('./complexity-analyzer');\nconst { PRICING } = require(path.join(process.env.HOME, '.claude/config/pricing.js'));\n\n// ═══════════════════════════════════════════════════════════════════════════\n// BASELINES LOADING\n// ═══════════════════════════════════════════════════════════════════════════\n\nconst BASELINES_PATH = path.join(process.env.HOME, '.claude/kernel/baselines.json');\n\nfunction loadBaselines() {\n  if (!fs.existsSync(BASELINES_PATH)) {\n    return null;  // Use hardcoded defaults\n  }\n\n  try {\n    const data = fs.readFileSync(BASELINES_PATH, 'utf8');\n    return JSON.parse(data);\n  } catch (e) {\n    console.error('Error loading baselines:', e.message);\n    return null;\n  }\n}\n\nconst BASELINES = loadBaselines();\n\n// ═══════════════════════════════════════════════════════════════════════════\n// DQ WEIGHTS (from ACE Framework + Cognitive OS adjustments)\n// ═══════════════════════════════════════════════════════════════════════════\n\nconst COGNITIVE_DQ_WEIGHTS_PATH = path.join(process.env.HOME, '.claude/kernel/cognitive-os/cognitive-dq-weights.json');\nconst EXPERTISE_ROUTING_STATE_PATH = path.join(process.env.HOME, '.claude/kernel/expertise-routing-state.json');\n\nfunction loadCognitiveDQWeights() {\n  // Try to load cognitive-aware weights from Cognitive OS\n  if (fs.existsSync(COGNITIVE_DQ_WEIGHTS_PATH)) {\n    try {\n      const data = JSON.parse(fs.readFileSync(COGNITIVE_DQ_WEIGHTS_PATH, 'utf8'));\n      const fileAge = Date.now() - new Date(data.timestamp).getTime();\n      // Only use if less than 30 minutes old\n      if (fileAge < 30 * 60 * 1000 && data.dq_weights) {\n        return {\n          weights: data.dq_weights,\n          complexityModifier: data.complexity_threshold_modifier || 1.0,\n          cognitiveMode: data.cognitive_mode,\n          reasoning: data.reasoning\n        };\n      }\n    } catch (e) {\n      // Fall through to defaults\n    }\n  }\n  return null;\n}\n\nconst COGNITIVE_WEIGHTS = loadCognitiveDQWeights();\n\nconst DQ_WEIGHTS = COGNITIVE_WEIGHTS?.weights || BASELINES?.dq_weights || {\n  validity: 0.4,      // Does the routing make logical sense?\n  specificity: 0.3,   // How precise is the model selection?\n  correctness: 0.3    // Historical accuracy of similar queries\n};\n\n// Complexity threshold modifier from Cognitive OS (affects model selection boundaries)\nconst COMPLEXITY_MODIFIER = COGNITIVE_WEIGHTS?.complexityModifier || 1.0;\n\n// ═══════════════════════════════════════════════════════════════════════════\n// EXPERTISE ROUTING\n// ═══════════════════════════════════════════════════════════════════════════\n\nfunction loadExpertiseState() {\n  if (fs.existsSync(EXPERTISE_ROUTING_STATE_PATH)) {\n    try {\n      const data = JSON.parse(fs.readFileSync(EXPERTISE_ROUTING_STATE_PATH, 'utf8'));\n      const fileAge = Date.now() - new Date(data.timestamp).getTime();\n      // Use if less than 1 hour old\n      if (fileAge < 60 * 60 * 1000) {\n        return data;\n      }\n    } catch (e) {}\n  }\n  return null;\n}\n\nconst EXPERTISE_STATE = loadExpertiseState();\n\n/**\n * Detect domain of query and check expertise level\n */\nfunction getExpertiseAdjustment(query) {\n  if (!EXPERTISE_STATE) return null;\n\n  const highExpertise = EXPERTISE_STATE.high_expertise_domains || [];\n  const lowExpertise = EXPERTISE_STATE.low_expertise_domains || [];\n  const queryLower = query.toLowerCase();\n\n  // Check if query matches high expertise domains\n  for (const domain of highExpertise) {\n    if (queryLower.includes(domain) ||\n        (domain === 'react' && (queryLower.includes('component') || queryLower.includes('hook'))) ||\n        (domain === 'typescript' && queryLower.includes('type')) ||\n        (domain === 'python' && queryLower.includes('.py'))) {\n      return { domain, adjustment: 'downgrade', expertise: 'high' };\n    }\n  }\n\n  // Check if query matches low expertise domains\n  for (const domain of lowExpertise) {\n    if (queryLower.includes(domain)) {\n      return { domain, adjustment: 'upgrade', expertise: 'low' };\n    }\n  }\n\n  return null;\n}\n\n// Actionable threshold\nconst DQ_THRESHOLD = BASELINES?.dq_thresholds?.actionable || 0.5;\n\n// Model capabilities (for validity assessment)\n// Load from baselines if available, otherwise use hardcoded\nconst MODEL_CAPABILITIES = BASELINES?.complexity_thresholds ? {\n  haiku: {\n    strengths: ['quick answers', 'simple tasks', 'formatting', 'short responses'],\n    weaknesses: ['complex reasoning', 'long context', 'code generation', 'architecture'],\n    maxComplexity: BASELINES.complexity_thresholds.haiku.range[1],\n    costPerMToken: BASELINES.cost_per_mtok?.haiku || { input: 0.25, output: 1.25 }\n  },\n  sonnet: {\n    strengths: ['code generation', 'analysis', 'moderate reasoning', 'balanced tasks'],\n    weaknesses: ['expert-level problems', 'novel architecture', 'research synthesis'],\n    maxComplexity: BASELINES.complexity_thresholds.sonnet.range[1],\n    costPerMToken: BASELINES.cost_per_mtok?.sonnet || { input: 3, output: 15 }\n  },\n  opus: {\n    strengths: ['complex reasoning', 'novel problems', 'architecture', 'research', 'expert tasks'],\n    weaknesses: ['cost', 'latency for simple tasks'],\n    maxComplexity: BASELINES.complexity_thresholds.opus.range[1],\n    costPerMToken: BASELINES.cost_per_mtok?.opus || { input: 5, output: 25 }\n  }\n} : {\n  // Fallback values from centralized pricing config\n  haiku: {\n    strengths: ['quick answers', 'simple tasks', 'formatting', 'short responses'],\n    weaknesses: ['complex reasoning', 'long context', 'code generation', 'architecture'],\n    maxComplexity: 0.30,\n    costPerMToken: { input: PRICING.haiku.input, output: PRICING.haiku.output }\n  },\n  sonnet: {\n    strengths: ['code generation', 'analysis', 'moderate reasoning', 'balanced tasks'],\n    weaknesses: ['expert-level problems', 'novel architecture', 'research synthesis'],\n    maxComplexity: 0.70,\n    costPerMToken: { input: PRICING.sonnet.input, output: PRICING.sonnet.output }\n  },\n  opus: {\n    strengths: ['complex reasoning', 'novel problems', 'architecture', 'research', 'expert tasks'],\n    weaknesses: ['cost', 'latency for simple tasks'],\n    maxComplexity: 1.0,\n    costPerMToken: { input: PRICING.opus.input, output: PRICING.opus.output }\n  }\n};\n\n// Adaptive thresholds (from ACE)\nconst ADAPTIVE_THRESHOLDS = {\n  simple:   { complexity: [0, 0.25],   model: 'haiku',  rounds: 3,  gap: 2 },\n  moderate: { complexity: [0.25, 0.50], model: 'sonnet', rounds: 7,  gap: 3 },\n  complex:  { complexity: [0.50, 0.75], model: 'sonnet', rounds: 12, gap: 4 },\n  expert:   { complexity: [0.75, 1.0],  model: 'opus',   rounds: 15, gap: 5 }\n};\n\n// ═══════════════════════════════════════════════════════════════════════════\n// HISTORY MANAGEMENT\n// ═══════════════════════════════════════════════════════════════════════════\n\nconst HISTORY_PATH = path.join(process.env.HOME, '.claude/kernel/dq-scores.jsonl');\n\nfunction loadHistory() {\n  if (!fs.existsSync(HISTORY_PATH)) return [];\n\n  try {\n    const lines = fs.readFileSync(HISTORY_PATH, 'utf8').split('\\n').filter(l => l.trim());\n    return lines.map(l => JSON.parse(l));\n  } catch (e) {\n    return [];\n  }\n}\n\nfunction saveDecision(decision) {\n  const line = JSON.stringify(decision) + '\\n';\n  fs.appendFileSync(HISTORY_PATH, line);\n}\n\n/**\n * Apply cognitive complexity modifier to adjust thresholds\n */\nfunction applyCognitiveModifier(complexity) {\n  // If modifier > 1, we can handle more complexity (raise thresholds effectively)\n  // If modifier < 1, we should use simpler models (lower thresholds effectively)\n  return complexity / COMPLEXITY_MODIFIER;\n}\n\n// ═══════════════════════════════════════════════════════════════════════════\n// DISTRIBUTIONAL FEATURES (US-001: Multi-Feature Graph Signal)\n// ═══════════════════════════════════════════════════════════════════════════\n\n/**\n * Compute distributional features from supermemory retrieval score distributions.\n * Used by the multi-feature graph signal (US-004) to replace single skewness metric.\n *\n * @param {number[]} scores - Raw retrieval scores from supermemory\n * @returns {{entropy: number, gini: number, skewness: number, sampleSize: number} | null}\n *          Returns null when scores.length < 5 (minimum sample threshold per Security Architect)\n */\nfunction computeDistributionalFeatures(scores) {\n  if (!Array.isArray(scores) || scores.length < 5) {\n    return null;\n  }\n\n  const n = scores.length;\n\n  // Normalize scores to a probability distribution (sum to 1)\n  const sum = scores.reduce((a, b) => a + b, 0);\n  if (sum === 0) {\n    return { entropy: 0, gini: 1 / n, skewness: 0, sampleSize: n };\n  }\n  const probs = scores.map(s => s / sum);\n\n  // Shannon entropy: -Σ(p * log(p)), skip p=0 terms\n  const entropy = -probs.reduce((acc, p) => {\n    if (p > 0) acc += p * Math.log(p);\n    return acc;\n  }, 0);\n\n  // Gini impurity: 1 - Σ(p_i²)\n  const gini = 1 - probs.reduce((acc, p) => acc + p * p, 0);\n\n  // Skewness (Fisher-Pearson, sample-adjusted)\n  const mean = scores.reduce((a, b) => a + b, 0) / n;\n  const variance = scores.reduce((acc, s) => acc + (s - mean) ** 2, 0) / n;\n  const stdDev = Math.sqrt(variance);\n  let skewness = 0;\n  if (stdDev > 0 && n >= 3) {\n    const m3 = scores.reduce((acc, s) => acc + ((s - mean) / stdDev) ** 3, 0) / n;\n    // Apply sample adjustment factor\n    skewness = (Math.sqrt(n * (n - 1)) / (n - 2)) * m3;\n  }\n\n  return {\n    entropy: parseFloat(entropy.toFixed(6)),\n    gini: parseFloat(gini.toFixed(6)),\n    skewness: parseFloat(skewness.toFixed(6)),\n    sampleSize: n\n  };\n}\n\n// ═══════════════════════════════════════════════════════════════════════════\n// IRT DIFFICULTY BRIDGE (US-003: Multi-Feature Graph Signal — IRT Integration)\n// ═══════════════════════════════════════════════════════════════════════════\n\nconst IRT_BRIDGE_PATH = path.join(process.env.HOME, '.claude/kernel/hsrgs/irt-bridge.json');\n\n/**\n * Load IRT difficulty data from the HSRGS bridge file (Python → Node.js).\n * Returns the bridge data if fresh (< 60 seconds old), null otherwise.\n *\n * @param {string} [queryHash] - Optional query hash to match against bridge data\n * @returns {{difficulty: number, discrimination: number, domain_signature: string,\n *            irt_predictions: Object, selected_model: string, timestamp: number} | null}\n */\nfunction loadIRTBridge(queryHash) {\n  try {\n    if (!fs.existsSync(IRT_BRIDGE_PATH)) return null;\n\n    const data = JSON.parse(fs.readFileSync(IRT_BRIDGE_PATH, 'utf8'));\n\n    // Staleness check: bridge data must be < 60 seconds old\n    const ageMs = Date.now() - data.timestamp;\n    if (ageMs > 60000) return null;\n\n    // If queryHash provided, verify it matches\n    if (queryHash && data.query_hash !== queryHash) return null;\n\n    // Validate required fields\n    if (typeof data.difficulty !== 'number') return null;\n\n    return data;\n  } catch (e) {\n    return null;\n  }\n}\n\n/**\n * Compute IRT difficulty modifier for routing.\n * High IRT difficulty (> 0.7) biases toward Opus (positive modifier).\n * Low IRT difficulty (< 0.3) biases toward Haiku (negative modifier).\n * Mid-range: no effect.\n *\n * @param {number} irtDifficulty - IRT difficulty from HSRGS (0.0-1.0)\n * @returns {number} Modifier to apply to complexity score (-0.15 to +0.15)\n */\nfunction computeIRTModifier(irtDifficulty) {\n  if (typeof irtDifficulty !== 'number' || isNaN(irtDifficulty)) return 0.0;\n\n  // Clamp to valid range\n  const d = Math.max(0.0, Math.min(1.0, irtDifficulty));\n\n  if (d > 0.7) {\n    // High difficulty: bias toward more capable model (Opus)\n    // Scale: 0.7 → 0.0, 1.0 → +0.15\n    return parseFloat(((d - 0.7) / 0.3 * 0.15).toFixed(4));\n  } else if (d < 0.3) {\n    // Low difficulty: bias toward cheaper model (Haiku)\n    // Scale: 0.3 → 0.0, 0.0 → -0.15\n    return parseFloat(((d - 0.3) / 0.3 * 0.15).toFixed(4));\n  }\n\n  // Mid-range: no modification\n  return 0.0;\n}\n\n// ═══════════════════════════════════════════════════════════════════════════\n// SUBGRAPH DENSITY (US-002: Multi-Feature Graph Signal)\n// ═══════════════════════════════════════════════════════════════════════════\n\nconst SUPERMEMORY_DB_PATH = path.join(process.env.HOME, '.claude/memory/supermemory.db');\n\n/**\n * Query supermemory.db via sqlite3 CLI (zero-dependency, no native modules).\n * Uses UNION for indexed lookups on both from_id and to_id.\n *\n * @param {string} sql - SQL query to execute\n * @returns {string} Raw output from sqlite3\n */\nfunction querySuperMemory(sql) {\n  try {\n    return execSync(\n      `sqlite3 \"${SUPERMEMORY_DB_PATH}\" \"${sql.replace(/\"/g, '\\\\\"')}\"`,\n      { encoding: 'utf8', timeout: 5000 }\n    ).trim();\n  } catch (e) {\n    return '';\n  }\n}\n\n/**\n * Compute subgraph density for a set of retrieved knowledge nodes.\n * Sparse subgraphs (density < 0.1) cause ~30% of KG-RAG errors (GraphRouter ICLR 2025).\n *\n * @param {string[]} retrievedNodes - Array of node IDs from supermemory retrieval\n * @param {string} [queryTopic] - Optional topic string for coverage rate estimation via FTS\n * @returns {{density: number, nodeCount: number, edgeCount: number, coverageRate: number} | null}\n *          Returns null when retrievedNodes.length < 2 (need at least 2 nodes for density)\n */\nfunction computeSubgraphDensity(retrievedNodes, queryTopic) {\n  if (!Array.isArray(retrievedNodes) || retrievedNodes.length < 2) {\n    return null;\n  }\n\n  // Deduplicate nodes\n  const nodes = [...new Set(retrievedNodes)];\n  const nodeCount = nodes.length;\n\n  if (nodeCount < 2) {\n    return null;\n  }\n\n  // Maximum possible edges in an undirected graph: n*(n-1)/2\n  const maxEdges = (nodeCount * (nodeCount - 1)) / 2;\n\n  // Query actual edges among retrieved nodes using indexed UNION approach\n  // Build IN clause for the node set\n  const inClause = nodes.map(n => `'${n.replace(/'/g, \"''\")}'`).join(',');\n\n  // Count edges where BOTH endpoints are in the retrieved set\n  // UNION approach uses indexes on both from_id and to_id efficiently\n  const edgeSql = `SELECT COUNT(*) FROM (\n    SELECT DISTINCT from_id, to_id FROM (\n      SELECT from_id, to_id FROM memory_links WHERE from_id IN (${inClause}) AND to_id IN (${inClause})\n      UNION\n      SELECT from_id, to_id FROM memory_links WHERE to_id IN (${inClause}) AND from_id IN (${inClause})\n    )\n  )`;\n\n  const edgeResult = querySuperMemory(edgeSql);\n  const edgeCount = parseInt(edgeResult, 10) || 0;\n\n  // Density = actual edges / possible edges\n  const density = maxEdges > 0 ? edgeCount / maxEdges : 0;\n\n  // Coverage rate: retrieved nodes / estimated relevant nodes\n  // Use FTS match count from memory_items as the estimate of relevant nodes\n  let coverageRate = 1.0; // Default: assume full coverage if no topic\n  if (queryTopic && queryTopic.trim()) {\n    const safeTopic = queryTopic.replace(/\"/g, '').replace(/'/g, \"''\").replace(/[^\\w\\s-]/g, '');\n    if (safeTopic.trim()) {\n      const ftsSql = `SELECT COUNT(*) FROM memory_fts WHERE memory_fts MATCH '${safeTopic}'`;\n      const ftsResult = querySuperMemory(ftsSql);\n      const relevantCount = parseInt(ftsResult, 10) || 0;\n      if (relevantCount > 0) {\n        coverageRate = Math.min(1.0, nodeCount / relevantCount);\n      }\n    }\n  }\n\n  return {\n    density: parseFloat(density.toFixed(6)),\n    nodeCount,\n    edgeCount,\n    coverageRate: parseFloat(coverageRate.toFixed(6))\n  };\n}\n\n/**\n * Compute subgraph density from pre-fetched graph links (no DB access needed).\n * Used for testing and when links are already loaded.\n *\n * @param {string[]} retrievedNodes - Array of node IDs\n * @param {{from_id: string, to_id: string}[]} graphLinks - Pre-fetched edge list\n * @returns {{density: number, nodeCount: number, edgeCount: number, coverageRate: number} | null}\n */\nfunction computeSubgraphDensityFromLinks(retrievedNodes, graphLinks) {\n  if (!Array.isArray(retrievedNodes) || retrievedNodes.length < 2) {\n    return null;\n  }\n  if (!Array.isArray(graphLinks)) {\n    return null;\n  }\n\n  const nodeSet = new Set(retrievedNodes);\n  const nodeCount = nodeSet.size;\n\n  if (nodeCount < 2) {\n    return null;\n  }\n\n  const maxEdges = (nodeCount * (nodeCount - 1)) / 2;\n\n  // Count unique edges where both endpoints are in the node set\n  const edgeSet = new Set();\n  for (const link of graphLinks) {\n    if (nodeSet.has(link.from_id) && nodeSet.has(link.to_id) && link.from_id !== link.to_id) {\n      // Normalize edge direction for undirected counting\n      const edgeKey = [link.from_id, link.to_id].sort().join('::');\n      edgeSet.add(edgeKey);\n    }\n  }\n\n  const edgeCount = edgeSet.size;\n  const density = maxEdges > 0 ? edgeCount / maxEdges : 0;\n\n  return {\n    density: parseFloat(density.toFixed(6)),\n    nodeCount,\n    edgeCount,\n    coverageRate: 1.0 // No topic available for in-memory computation\n  };\n}\n\n// ═══════════════════════════════════════════════════════════════════════════\n// MULTI-FEATURE GRAPH SIGNAL (US-004: Signal Composition)\n// ═══════════════════════════════════════════════════════════════════════════\n\nconst GRAPH_SIGNAL_WEIGHTS_PATH = path.join(__dirname, '..', 'config', 'graph-signal-weights.json');\n\n/**\n * Load graph signal weights from config file (the ONLY authority).\n * Designed as a future Optimas Local Reward Function (learnable).\n *\n * @returns {{entropy: number, gini: number, subgraphDensity: number, irtDifficulty: number}}\n */\nfunction loadGraphSignalWeights() {\n  try {\n    if (fs.existsSync(GRAPH_SIGNAL_WEIGHTS_PATH)) {\n      const config = JSON.parse(fs.readFileSync(GRAPH_SIGNAL_WEIGHTS_PATH, 'utf8'));\n      if (config.weights) return config.weights;\n    }\n  } catch (e) {\n    // Fall through to defaults\n  }\n  // Emergency fallback only — should never be used in production\n  return { entropy: 0.30, gini: 0.25, subgraphDensity: 0.25, irtDifficulty: 0.20 };\n}\n\n/**\n * Compose entropy, Gini, subgraph density, and IRT difficulty into a single\n * graphComplexity score (0.0-1.0). Replaces keyword-based complexity for routing.\n *\n * Higher graphComplexity means the query is harder (sparse knowledge, concentrated\n * retrieval scores, high IRT difficulty) and should route to more capable models.\n *\n * Feature normalization:\n * - entropy: inverted (high entropy = well-distributed knowledge = EASIER)\n *   normalized to [0,1] via 1 - entropy/maxEntropy\n * - gini: inverted (high Gini = diverse distribution = EASIER)\n *   normalized to [0,1] via 1 - gini\n * - subgraphDensity: inverted (dense subgraph = well-connected knowledge = EASIER)\n *   normalized to [0,1] via 1 - density\n * - irtDifficulty: direct (high difficulty = HARDER), already [0,1]\n *\n * @param {Object} params\n * @param {Object|null} params.distributional - Output of computeDistributionalFeatures()\n * @param {Object|null} params.subgraph - Output of computeSubgraphDensity()\n * @param {number|null} params.irtDifficulty - IRT difficulty from HSRGS bridge (0.0-1.0)\n * @returns {{graphComplexity: number, features: Object, weights: Object, featureCount: number} | null}\n *          Returns null if no features are available\n */\nfunction computeGraphSignal({ distributional, subgraph, irtDifficulty }) {\n  const weights = loadGraphSignalWeights();\n  const features = {};\n  let totalWeight = 0;\n  let weightedSum = 0;\n\n  // Entropy: invert so high entropy (easy) → low complexity\n  if (distributional && typeof distributional.entropy === 'number') {\n    // Max entropy for n items = ln(n). Use sampleSize for normalization.\n    const maxEntropy = Math.log(distributional.sampleSize);\n    const normalizedEntropy = maxEntropy > 0 ? distributional.entropy / maxEntropy : 0;\n    const complexityFromEntropy = 1 - normalizedEntropy; // invert: low entropy = high complexity\n    features.entropy = parseFloat(complexityFromEntropy.toFixed(6));\n    weightedSum += features.entropy * weights.entropy;\n    totalWeight += weights.entropy;\n  }\n\n  // Gini: invert so high Gini (diverse) → low complexity\n  if (distributional && typeof distributional.gini === 'number') {\n    const complexityFromGini = 1 - distributional.gini; // invert: low diversity = high complexity\n    features.gini = parseFloat(complexityFromGini.toFixed(6));\n    weightedSum += features.gini * weights.gini;\n    totalWeight += weights.gini;\n  }\n\n  // Subgraph density: invert so dense graph → low complexity\n  if (subgraph && typeof subgraph.density === 'number') {\n    const complexityFromDensity = 1 - subgraph.density; // invert: sparse = high complexity\n    features.subgraphDensity = parseFloat(complexityFromDensity.toFixed(6));\n    weightedSum += features.subgraphDensity * weights.subgraphDensity;\n    totalWeight += weights.subgraphDensity;\n  }\n\n  // IRT difficulty: direct mapping (already 0-1, high = hard)\n  if (typeof irtDifficulty === 'number' && !isNaN(irtDifficulty)) {\n    const clampedIRT = Math.max(0, Math.min(1, irtDifficulty));\n    features.irtDifficulty = parseFloat(clampedIRT.toFixed(6));\n    weightedSum += features.irtDifficulty * weights.irtDifficulty;\n    totalWeight += weights.irtDifficulty;\n  }\n\n  const featureCount = Object.keys(features).length;\n  if (featureCount === 0) return null;\n\n  // Normalize by actual weight used (handles partial feature availability)\n  const graphComplexity = totalWeight > 0 ? weightedSum / totalWeight : 0;\n\n  return {\n    graphComplexity: parseFloat(Math.max(0, Math.min(1, graphComplexity)).toFixed(6)),\n    features,\n    weights,\n    featureCount\n  };\n}\n\n// ═══════════════════════════════════════════════════════════════════════════\n// DQ SCORING FUNCTIONS\n// ═══════════════════════════════════════════════════════════════════════════\n\n/**\n * Assess validity: Does the model selection make logical sense?\n */\nfunction assessValidity(complexity, model) {\n  const modelCaps = MODEL_CAPABILITIES[model];\n  if (!modelCaps) return 0;\n\n  // Perfect validity: complexity within model's range\n  if (complexity <= modelCaps.maxComplexity) {\n    // Penalize over-provisioning (using opus for simple tasks)\n    const overProvision = modelCaps.maxComplexity - complexity;\n    if (model === 'opus' && complexity < 0.5) {\n      return 0.6; // Wasteful but valid\n    }\n    if (model === 'sonnet' && complexity < 0.2) {\n      return 0.7; // Slightly wasteful\n    }\n    return 1.0 - (overProvision * 0.2); // Small penalty for over-provisioning\n  }\n\n  // Under-provisioning is worse\n  const underProvision = complexity - modelCaps.maxComplexity;\n  return Math.max(0, 1.0 - (underProvision * 2)); // Heavy penalty\n}\n\n/**\n * Assess specificity: How precise is the model selection?\n */\nfunction assessSpecificity(query, complexity, model) {\n  // Check if model matches the ideal for this complexity\n  let idealModel;\n  for (const [level, config] of Object.entries(ADAPTIVE_THRESHOLDS)) {\n    if (complexity >= config.complexity[0] && complexity < config.complexity[1]) {\n      idealModel = config.model;\n      break;\n    }\n  }\n  if (!idealModel) idealModel = 'opus';\n\n  if (model === idealModel) return 1.0;\n\n  // Adjacent model is acceptable\n  const models = ['haiku', 'sonnet', 'opus'];\n  const idealIdx = models.indexOf(idealModel);\n  const actualIdx = models.indexOf(model);\n  const distance = Math.abs(idealIdx - actualIdx);\n\n  return Math.max(0, 1.0 - (distance * 0.4));\n}\n\n/**\n * Assess correctness: Historical accuracy for similar queries\n */\nfunction assessCorrectness(query, model, history) {\n  if (history.length === 0) return 0.5; // No history, neutral\n\n  // Find similar queries\n  const queryTokens = new Set(query.toLowerCase().split(/\\s+/));\n  const similar = history.filter(h => {\n    if (!h.query) return false;\n    const histTokens = new Set(h.query.toLowerCase().split(/\\s+/));\n    const intersection = [...queryTokens].filter(t => histTokens.has(t)).length;\n    return intersection / Math.max(queryTokens.size, histTokens.size) > 0.3;\n  });\n\n  if (similar.length === 0) return 0.5;\n\n  // Check success rate for this model on similar queries\n  const modelMatches = similar.filter(s => s.model === model);\n  if (modelMatches.length === 0) return 0.5;\n\n  // If we have feedback, use it\n  const withFeedback = modelMatches.filter(m => m.success !== undefined);\n  if (withFeedback.length > 0) {\n    const successRate = withFeedback.filter(m => m.success).length / withFeedback.length;\n    return successRate;\n  }\n\n  // Otherwise, assume DQ score is a proxy for success\n  const avgDQ = modelMatches.reduce((sum, m) => sum + (m.dqScore || 0.5), 0) / modelMatches.length;\n  return avgDQ;\n}\n\n/**\n * Calculate composite DQ score\n */\nfunction calculateDQ(query, complexity, model, history = []) {\n  const validity = assessValidity(complexity, model);\n  const specificity = assessSpecificity(query, complexity, model);\n  const correctness = assessCorrectness(query, model, history);\n\n  const score = (validity * DQ_WEIGHTS.validity) +\n                (specificity * DQ_WEIGHTS.specificity) +\n                (correctness * DQ_WEIGHTS.correctness);\n\n  return {\n    score: parseFloat(score.toFixed(3)),\n    components: {\n      validity: parseFloat(validity.toFixed(3)),\n      specificity: parseFloat(specificity.toFixed(3)),\n      correctness: parseFloat(correctness.toFixed(3))\n    },\n    actionable: score >= DQ_THRESHOLD\n  };\n}\n\n// ═══════════════════════════════════════════════════════════════════════════\n// ROUTING DECISION\n// ═══════════════════════════════════════════════════════════════════════════\n\n/**\n * Make a routing decision with DQ scoring\n */\nfunction route(query) {\n  const history = loadHistory();\n  const complexity = estimateComplexity(query);\n\n  // Apply cognitive modifier to complexity for threshold comparisons\n  const adjustedComplexity = applyCognitiveModifier(complexity.score);\n\n  // Apply IRT difficulty modifier (US-003: cross-runtime bridge from HSRGS)\n  const queryHash = crypto.createHash('md5').update(query).digest('hex');\n  const irtBridge = loadIRTBridge(queryHash);\n  const irtDifficulty = irtBridge ? irtBridge.difficulty : null;\n  const IRT_MOD = computeIRTModifier(irtDifficulty);\n  const irtAdjustedComplexity = Math.max(0, Math.min(1, adjustedComplexity + IRT_MOD));\n\n  // US-004: Compute multi-feature graph signal\n  // Attempt to gather distributional features and subgraph density\n  // These may be null if no retrieval scores / nodes are available for this query\n  const graphSignal = computeGraphSignal({\n    distributional: null, // Populated by caller or retrieval pipeline when available\n    subgraph: null,       // Populated by caller or retrieval pipeline when available\n    irtDifficulty: irtDifficulty\n  });\n\n  // A/B test: determine which complexity signal to use for routing\n  // Odd session timestamps use graph signal, even use keyword (deterministic)\n  const sessionId = Math.floor(Date.now() / 1000);\n  const useGraphSignal = graphSignal && graphSignal.featureCount >= 2 && (sessionId % 2 === 1);\n  const routingComplexity = useGraphSignal ? graphSignal.graphComplexity : irtAdjustedComplexity;\n\n  // Try each model and pick best DQ\n  const candidates = ['haiku', 'sonnet', 'opus'].map(model => {\n    // Use the selected complexity signal for DQ calculation\n    const dq = calculateDQ(query, routingComplexity, model, history);\n    return { model, dq, complexity: complexity.score, adjustedComplexity: routingComplexity };\n  });\n\n  // Sort by DQ score (highest first), then by cost (lowest first for ties)\n  candidates.sort((a, b) => {\n    if (Math.abs(a.dq.score - b.dq.score) > 0.05) {\n      return b.dq.score - a.dq.score;\n    }\n    // If DQ scores are similar, prefer cheaper model\n    const costOrder = { haiku: 0, sonnet: 1, opus: 2 };\n    return costOrder[a.model] - costOrder[b.model];\n  });\n\n  let best = candidates[0];\n\n  // Apply expertise-based adjustment\n  const expertiseAdj = getExpertiseAdjustment(query);\n  let expertiseOverride = null;\n\n  if (expertiseAdj) {\n    const models = ['haiku', 'sonnet', 'opus'];\n    const currentIdx = models.indexOf(best.model);\n\n    if (expertiseAdj.adjustment === 'downgrade' && currentIdx > 0) {\n      // High expertise - can use cheaper model\n      const newModel = models[currentIdx - 1];\n      expertiseOverride = {\n        original: best.model,\n        adjusted: newModel,\n        domain: expertiseAdj.domain,\n        reason: `High expertise in ${expertiseAdj.domain}`\n      };\n      // Find the candidate for the new model\n      const newCandidate = candidates.find(c => c.model === newModel);\n      if (newCandidate) {\n        best = newCandidate;\n      }\n    } else if (expertiseAdj.adjustment === 'upgrade' && currentIdx < models.length - 1) {\n      // Low expertise - need more capable model\n      const newModel = models[currentIdx + 1];\n      expertiseOverride = {\n        original: best.model,\n        adjusted: newModel,\n        domain: expertiseAdj.domain,\n        reason: `Low expertise in ${expertiseAdj.domain}`\n      };\n      const newCandidate = candidates.find(c => c.model === newModel);\n      if (newCandidate) {\n        best = newCandidate;\n      }\n    }\n  }\n\n  // Estimate cost for this routing decision\n  function estimateCost(model, queryText) {\n    const modelCaps = MODEL_CAPABILITIES[model];\n    if (!modelCaps) return 0;\n\n    // Rough estimate: query ~100 tokens, response ~500 tokens\n    const estInputTokens = Math.max(100, queryText.length / 4);\n    const estOutputTokens = 500;\n\n    const cost = (estInputTokens * modelCaps.costPerMToken.input / 1_000_000 +\n                  estOutputTokens * modelCaps.costPerMToken.output / 1_000_000);\n\n    return cost;\n  }\n\n  // Log the decision with enhanced metadata\n  const decision = {\n    ts: Math.floor(Date.now() / 1000),  // Unix seconds (not ms)\n    query_hash: crypto.createHash('md5').update(query).digest('hex'),\n    query: query.slice(0, 200), // Truncate for storage\n    query_preview: query.slice(0, 50),\n    complexity: complexity.score,\n    adjusted_complexity: irtAdjustedComplexity,\n    complexity_reasoning: complexity.reasoning,\n    irt: irtBridge ? {\n      difficulty: irtDifficulty,\n      modifier: IRT_MOD,\n      source: 'hsrgs-bridge'\n    } : null,\n    graphSignal: graphSignal || null,\n    ab_test: {\n      keyword_complexity: irtAdjustedComplexity,\n      graph_complexity: graphSignal ? graphSignal.graphComplexity : null,\n      signal_used: useGraphSignal ? 'graph' : 'keyword',\n      session_id: sessionId\n    },\n    model: best.model,\n    dqScore: best.dq.score,\n    dqComponents: best.dq.components,\n    reasoning: complexity.reasoning,\n    alternatives: candidates.slice(1).map(c => ({ model: c.model, dq: c.dq.score })),\n    cost_estimate: estimateCost(best.model, query),\n    baseline_version: BASELINES ? BASELINES.version : 'hardcoded',\n    cognitive: COGNITIVE_WEIGHTS ? {\n      mode: COGNITIVE_WEIGHTS.cognitiveMode,\n      modifier: COMPLEXITY_MODIFIER,\n      weights_applied: true\n    } : null,\n    expertise: expertiseOverride\n  };\n\n  saveDecision(decision);\n\n  return {\n    model: best.model,\n    complexity: complexity.score,\n    dq: best.dq,\n    reasoning: complexity.reasoning,\n    cost_estimate: decision.cost_estimate,\n    baseline_version: decision.baseline_version,\n    cognitive: decision.cognitive,\n    expertise: decision.expertise\n  };\n}\n\n/**\n * Record feedback on a routing decision\n */\nfunction recordFeedback(queryPrefix, success) {\n  const history = loadHistory();\n\n  // Find most recent matching query\n  for (let i = history.length - 1; i >= 0; i--) {\n    if (history[i].query && history[i].query.startsWith(queryPrefix)) {\n      history[i].success = success;\n      history[i].feedbackTs = Date.now();\n\n      // Rewrite history file\n      const content = history.map(h => JSON.stringify(h)).join('\\n') + '\\n';\n      fs.writeFileSync(HISTORY_PATH, content);\n      return true;\n    }\n  }\n  return false;\n}\n\n/**\n * Get statistics on routing decisions\n */\nfunction getStats() {\n  const history = loadHistory();\n  const last24h = history.filter(h => h.ts > Date.now() - 86400000);\n  const last7d = history.filter(h => h.ts > Date.now() - 604800000);\n\n  const modelCounts = { haiku: 0, sonnet: 0, opus: 0 };\n  const modelDQ = { haiku: [], sonnet: [], opus: [] };\n\n  for (const h of last7d) {\n    if (h.model) modelCounts[h.model]++;\n    if (h.model && h.dqScore) modelDQ[h.model].push(h.dqScore);\n  }\n\n  const avgDQ = {};\n  for (const [model, scores] of Object.entries(modelDQ)) {\n    avgDQ[model] = scores.length > 0\n      ? (scores.reduce((a, b) => a + b, 0) / scores.length).toFixed(3)\n      : 'N/A';\n  }\n\n  return {\n    total: history.length,\n    last24h: last24h.length,\n    last7d: last7d.length,\n    modelDistribution: modelCounts,\n    averageDQ: avgDQ,\n    overallAvgDQ: last7d.length > 0\n      ? (last7d.reduce((sum, h) => sum + (h.dqScore || 0), 0) / last7d.length).toFixed(3)\n      : 'N/A'\n  };\n}\n\n// ═══════════════════════════════════════════════════════════════════════════\n// CLI INTERFACE\n// ═══════════════════════════════════════════════════════════════════════════\n\nif (require.main === module) {\n  const args = process.argv.slice(2);\n  const command = args[0];\n\n  switch (command) {\n    case 'route':\n      // Route a query: node dq-scorer.js route \"query here\"\n      const query = args.slice(1).join(' ');\n      if (!query) {\n        console.error('Usage: dq-scorer.js route \"query\"');\n        process.exit(1);\n      }\n      const result = route(query);\n      console.log(JSON.stringify(result, null, 2));\n      break;\n\n    case 'model':\n      // Just get the model: node dq-scorer.js model \"query\"\n      const q = args.slice(1).join(' ');\n      const r = route(q);\n      console.log(r.model);\n      break;\n\n    case 'feedback':\n      // Record feedback: node dq-scorer.js feedback \"query prefix\" success|failure\n      const prefix = args[1];\n      const success = args[2] === 'success';\n      const recorded = recordFeedback(prefix, success);\n      console.log(recorded ? 'Feedback recorded' : 'Query not found');\n      break;\n\n    case 'stats':\n      // Get statistics: node dq-scorer.js stats\n      console.log(JSON.stringify(getStats(), null, 2));\n      break;\n\n    case 'score':\n      // Score a specific model choice: node dq-scorer.js score \"query\" model\n      const scoreQuery = args[1];\n      const model = args[2] || 'sonnet';\n      const complexity = estimateComplexity(scoreQuery);\n      const dq = calculateDQ(scoreQuery, complexity.score, model, loadHistory());\n      console.log(JSON.stringify({ complexity: complexity.score, model, dq }, null, 2));\n      break;\n\n    default:\n      console.log('DQ Scorer - Decision Quality Framework for Model Routing');\n      console.log('');\n      console.log('Commands:');\n      console.log('  route \"query\"              - Route query to optimal model');\n      console.log('  model \"query\"              - Get just the model name');\n      console.log('  score \"query\" [model]      - Score a specific model choice');\n      console.log('  feedback \"prefix\" success  - Record feedback on a decision');\n      console.log('  stats                      - Get routing statistics');\n  }\n}\n\nmodule.exports = { route, calculateDQ, recordFeedback, getStats, computeDistributionalFeatures, computeSubgraphDensity, computeSubgraphDensityFromLinks, loadIRTBridge, computeIRTModifier, computeGraphSignal, loadGraphSignalWeights };\n","numLines":961,"startLine":1,"totalLines":961}}}
