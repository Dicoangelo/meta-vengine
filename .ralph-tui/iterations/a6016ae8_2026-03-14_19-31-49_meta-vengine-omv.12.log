{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PQch6G6Lo8sqn67dSktaeH","type":"tool_result","content":"     1→#!/usr/bin/env python3\n     2→\"\"\"\n     3→A/B Test Analyzer for HSRGS vs Keyword DQ Routing\n     4→\n     5→Analyzes routing decisions from the coevo data pipeline to compare:\n     6→- HSRGS (Homeomorphic Self-Routing Gödel System)\n     7→- Keyword DQ (original keyword-based Decision Quality scoring)\n     8→\n     9→Usage:\n    10→    ab-test-analyzer.py              # Show current results\n    11→    ab-test-analyzer.py --days 7     # Last 7 days\n    12→    ab-test-analyzer.py --detailed   # Show per-query breakdown\n    13→    ab-test-analyzer.py --feedback   # Include feedback signals\n    14→\"\"\"\n    15→\n    16→import json\n    17→import sys\n    18→from pathlib import Path\n    19→from datetime import datetime, timedelta\n    20→from collections import defaultdict\n    21→from typing import Dict, List, Optional\n    22→\n    23→# Import timestamp normalization\n    24→sys.path.insert(0, str(Path.home() / \".claude/scripts\"))\n    25→from lib.timestamps import normalize_ts\n    26→\n    27→COEVO_DQ_FILE = Path.home() / \".claude\" / \"kernel\" / \"dq-scores.jsonl\"\n    28→FEEDBACK_FILE = Path.home() / \".claude\" / \"data\" / \"ai-routing.log\"\n    29→\n    30→# ANSI colors\n    31→class C:\n    32→    RESET = \"\\033[0m\"\n    33→    BOLD = \"\\033[1m\"\n    34→    DIM = \"\\033[2m\"\n    35→    GREEN = \"\\033[38;5;82m\"\n    36→    RED = \"\\033[38;5;196m\"\n    37→    YELLOW = \"\\033[38;5;220m\"\n    38→    BLUE = \"\\033[38;5;75m\"\n    39→    PURPLE = \"\\033[38;5;183m\"\n    40→\n    41→\n    42→def load_routing_decisions(days: int = 30) -> List[Dict]:\n    43→    \"\"\"Load routing decisions from coevo data pipeline\"\"\"\n    44→    if not COEVO_DQ_FILE.exists():\n    45→        return []\n    46→\n    47→    cutoff = datetime.now() - timedelta(days=days)\n    48→    cutoff_ts = int(cutoff.timestamp())  # Use seconds\n    49→\n    50→    decisions = []\n    51→    with open(COEVO_DQ_FILE) as f:\n    52→        for line in f:\n    53→            try:\n    54→                record = json.loads(line)\n    55→                # Normalize timestamp for comparison\n    56→                record_ts = normalize_ts(record.get(\"ts\", 0)) or 0\n    57→                if record_ts >= cutoff_ts:\n    58→                    # Only include A/B test records\n    59→                    if record.get(\"ab_test_mode\") or record.get(\"ab_variant\"):\n    60→                        decisions.append(record)\n    61→            except json.JSONDecodeError:\n    62→                continue\n    63→\n    64→    return decisions\n    65→\n    66→\n    67→def load_feedback() -> Dict[str, bool]:\n    68→    \"\"\"Load feedback signals (ai-good/ai-bad) mapped by query hash\"\"\"\n    69→    feedback = {}\n    70→    if not FEEDBACK_FILE.exists():\n    71→        return feedback\n    72→\n    73→    with open(FEEDBACK_FILE) as f:\n    74→        for line in f:\n    75→            try:\n    76→                record = json.loads(line)\n    77→                query_hash = record.get(\"query_hash\")\n    78→                if query_hash:\n    79→                    # True = positive feedback, False = negative\n    80→                    feedback[query_hash] = record.get(\"feedback\") == \"good\""}]},"parent_tool_use_id":null,"session_id":"f59780b5-1930-46ef-aa3b-e5f15bcaa26c","uuid":"c876db21-9291-4eaa-9c95-c7a3b6e0f2e7","tool_use_result":{"type":"text","file":{"filePath":"/Users/dicoangelo/projects/core/meta-vengine/scripts/ab-test-analyzer.py","content":"#!/usr/bin/env python3\n\"\"\"\nA/B Test Analyzer for HSRGS vs Keyword DQ Routing\n\nAnalyzes routing decisions from the coevo data pipeline to compare:\n- HSRGS (Homeomorphic Self-Routing Gödel System)\n- Keyword DQ (original keyword-based Decision Quality scoring)\n\nUsage:\n    ab-test-analyzer.py              # Show current results\n    ab-test-analyzer.py --days 7     # Last 7 days\n    ab-test-analyzer.py --detailed   # Show per-query breakdown\n    ab-test-analyzer.py --feedback   # Include feedback signals\n\"\"\"\n\nimport json\nimport sys\nfrom pathlib import Path\nfrom datetime import datetime, timedelta\nfrom collections import defaultdict\nfrom typing import Dict, List, Optional\n\n# Import timestamp normalization\nsys.path.insert(0, str(Path.home() / \".claude/scripts\"))\nfrom lib.timestamps import normalize_ts\n\nCOEVO_DQ_FILE = Path.home() / \".claude\" / \"kernel\" / \"dq-scores.jsonl\"\nFEEDBACK_FILE = Path.home() / \".claude\" / \"data\" / \"ai-routing.log\"\n\n# ANSI colors\nclass C:\n    RESET = \"\\033[0m\"\n    BOLD = \"\\033[1m\"\n    DIM = \"\\033[2m\"\n    GREEN = \"\\033[38;5;82m\"\n    RED = \"\\033[38;5;196m\"\n    YELLOW = \"\\033[38;5;220m\"\n    BLUE = \"\\033[38;5;75m\"\n    PURPLE = \"\\033[38;5;183m\"\n\n\ndef load_routing_decisions(days: int = 30) -> List[Dict]:\n    \"\"\"Load routing decisions from coevo data pipeline\"\"\"\n    if not COEVO_DQ_FILE.exists():\n        return []\n\n    cutoff = datetime.now() - timedelta(days=days)\n    cutoff_ts = int(cutoff.timestamp())  # Use seconds\n\n    decisions = []\n    with open(COEVO_DQ_FILE) as f:\n        for line in f:\n            try:\n                record = json.loads(line)\n                # Normalize timestamp for comparison\n                record_ts = normalize_ts(record.get(\"ts\", 0)) or 0\n                if record_ts >= cutoff_ts:\n                    # Only include A/B test records\n                    if record.get(\"ab_test_mode\") or record.get(\"ab_variant\"):\n                        decisions.append(record)\n            except json.JSONDecodeError:\n                continue\n\n    return decisions\n\n\ndef load_feedback() -> Dict[str, bool]:\n    \"\"\"Load feedback signals (ai-good/ai-bad) mapped by query hash\"\"\"\n    feedback = {}\n    if not FEEDBACK_FILE.exists():\n        return feedback\n\n    with open(FEEDBACK_FILE) as f:\n        for line in f:\n            try:\n                record = json.loads(line)\n                query_hash = record.get(\"query_hash\")\n                if query_hash:\n                    # True = positive feedback, False = negative\n                    feedback[query_hash] = record.get(\"feedback\") == \"good\"","numLines":80,"startLine":1,"totalLines":256}}}
