{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DzepjonHHBS7X4o4STvEVG","type":"tool_result","content":"   770→      };\n   771→      const newCandidate = candidates.find(c => c.model === newModel);\n   772→      if (newCandidate) {\n   773→        best = newCandidate;\n   774→      }\n   775→    }\n   776→  }\n   777→\n   778→  // Estimate cost for this routing decision\n   779→  function estimateCost(model, queryText) {\n   780→    const modelCaps = MODEL_CAPABILITIES[model];\n   781→    if (!modelCaps) return 0;\n   782→\n   783→    // Rough estimate: query ~100 tokens, response ~500 tokens\n   784→    const estInputTokens = Math.max(100, queryText.length / 4);\n   785→    const estOutputTokens = 500;\n   786→\n   787→    const cost = (estInputTokens * modelCaps.costPerMToken.input / 1_000_000 +\n   788→                  estOutputTokens * modelCaps.costPerMToken.output / 1_000_000);\n   789→\n   790→    return cost;\n   791→  }\n   792→\n   793→  // Log the decision with enhanced metadata\n   794→  const decision = {\n   795→    ts: Math.floor(Date.now() / 1000),  // Unix seconds (not ms)\n   796→    query_hash: crypto.createHash('md5').update(query).digest('hex'),\n   797→    query: query.slice(0, 200), // Truncate for storage\n   798→    query_preview: query.slice(0, 50),\n   799→    complexity: complexity.score,\n   800→    adjusted_complexity: irtAdjustedComplexity,\n   801→    complexity_reasoning: complexity.reasoning,\n   802→    irt: irtBridge ? {\n   803→      difficulty: irtDifficulty,\n   804→      modifier: IRT_MOD,\n   805→      source: 'hsrgs-bridge'\n   806→    } : null,\n   807→    graphSignal: graphSignal || null,\n   808→    ab_test: {\n   809→      keyword_complexity: irtAdjustedComplexity,\n   810→      graph_complexity: graphSignal ? graphSignal.graphComplexity : null,\n   811→      signal_used: useGraphSignal ? 'graph' : 'keyword',\n   812→      session_id: sessionId\n   813→    },\n   814→    model: best.model,\n   815→    dqScore: best.dq.score,\n   816→    dqComponents: best.dq.components,\n   817→    reasoning: complexity.reasoning,\n   818→    alternatives: candidates.slice(1).map(c => ({ model: c.model, dq: c.dq.score })),\n   819→    cost_estimate: estimateCost(best.model, query),\n   820→    baseline_version: BASELINES ? BASELINES.version : 'hardcoded',\n   821→    cognitive: COGNITIVE_WEIGHTS ? {\n   822→      mode: COGNITIVE_WEIGHTS.cognitiveMode,\n   823→      modifier: COMPLEXITY_MODIFIER,\n   824→      weights_applied: true\n   825→    } : null,\n   826→    expertise: expertiseOverride\n   827→  };\n   828→\n   829→  saveDecision(decision);"}]},"parent_tool_use_id":null,"session_id":"1c891cc5-27f8-4bc6-8060-c18a8fb0442f","uuid":"6759a7cd-51f9-41bf-9c8c-20da12fe97e6","tool_use_result":{"type":"text","file":{"filePath":"/Users/dicoangelo/projects/core/meta-vengine/kernel/dq-scorer.js","content":"      };\n      const newCandidate = candidates.find(c => c.model === newModel);\n      if (newCandidate) {\n        best = newCandidate;\n      }\n    }\n  }\n\n  // Estimate cost for this routing decision\n  function estimateCost(model, queryText) {\n    const modelCaps = MODEL_CAPABILITIES[model];\n    if (!modelCaps) return 0;\n\n    // Rough estimate: query ~100 tokens, response ~500 tokens\n    const estInputTokens = Math.max(100, queryText.length / 4);\n    const estOutputTokens = 500;\n\n    const cost = (estInputTokens * modelCaps.costPerMToken.input / 1_000_000 +\n                  estOutputTokens * modelCaps.costPerMToken.output / 1_000_000);\n\n    return cost;\n  }\n\n  // Log the decision with enhanced metadata\n  const decision = {\n    ts: Math.floor(Date.now() / 1000),  // Unix seconds (not ms)\n    query_hash: crypto.createHash('md5').update(query).digest('hex'),\n    query: query.slice(0, 200), // Truncate for storage\n    query_preview: query.slice(0, 50),\n    complexity: complexity.score,\n    adjusted_complexity: irtAdjustedComplexity,\n    complexity_reasoning: complexity.reasoning,\n    irt: irtBridge ? {\n      difficulty: irtDifficulty,\n      modifier: IRT_MOD,\n      source: 'hsrgs-bridge'\n    } : null,\n    graphSignal: graphSignal || null,\n    ab_test: {\n      keyword_complexity: irtAdjustedComplexity,\n      graph_complexity: graphSignal ? graphSignal.graphComplexity : null,\n      signal_used: useGraphSignal ? 'graph' : 'keyword',\n      session_id: sessionId\n    },\n    model: best.model,\n    dqScore: best.dq.score,\n    dqComponents: best.dq.components,\n    reasoning: complexity.reasoning,\n    alternatives: candidates.slice(1).map(c => ({ model: c.model, dq: c.dq.score })),\n    cost_estimate: estimateCost(best.model, query),\n    baseline_version: BASELINES ? BASELINES.version : 'hardcoded',\n    cognitive: COGNITIVE_WEIGHTS ? {\n      mode: COGNITIVE_WEIGHTS.cognitiveMode,\n      modifier: COMPLEXITY_MODIFIER,\n      weights_applied: true\n    } : null,\n    expertise: expertiseOverride\n  };\n\n  saveDecision(decision);","numLines":60,"startLine":770,"totalLines":961}}}
