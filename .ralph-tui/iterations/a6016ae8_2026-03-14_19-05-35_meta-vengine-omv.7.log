{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011hmsk4kHbCvznfWMx4BSMb","type":"tool_result","content":"     1→#!/usr/bin/env python3\n     2→\"\"\"\n     3→Multi-Agent Orchestrator - Main coordinator for parallel Claude agents.\n     4→\n     5→Orchestrates multiple agents for:\n     6→- Parallel research (multiple explore agents)\n     7→- Parallel implementation (locked files)\n     8→- Review + build (concurrent)\n     9→- Full orchestration (research → build → review)\n    10→\"\"\"\n    11→\n    12→import json\n    13→import sys\n    14→import uuid\n    15→import time\n    16→from pathlib import Path\n    17→from datetime import datetime\n    18→from typing import Dict, List, Optional, Tuple\n    19→from dataclasses import dataclass, asdict\n    20→\n    21→# Add parent to path for imports\n    22→sys.path.insert(0, str(Path(__file__).parent))\n    23→\n    24→from registry import AgentRegistry, AgentState, AgentRecord\n    25→from conflict import ConflictManager, detect_potential_conflicts, LockType\n    26→from distribution import WorkDistributor, TaskAssignment, decompose_task\n    27→from executor import AgentExecutor, AgentConfig, AgentResult\n    28→\n    29→\n    30→@dataclass\n    31→class CoordinationResult:\n    32→    \"\"\"Result of a multi-agent coordination.\"\"\"\n    33→    task_id: str\n    34→    task: str\n    35→    strategy: str\n    36→    status: str  # success, partial, failed\n    37→    duration_seconds: float\n    38→    agent_results: Dict[str, Dict]\n    39→    synthesis: Dict\n    40→    total_cost: float\n    41→\n    42→\n    43→class ACESynthesizer:\n    44→    \"\"\"\n    45→    Synthesizes results from multiple agents using ACE consensus.\n    46→\n    47→    Adapted from ~/.claude/scripts/observatory/ace_consensus.py\n    48→    \"\"\"\n    49→\n    50→    DQ_WEIGHTS = {\n    51→        \"validity\": 0.4,\n    52→        \"specificity\": 0.3,\n    53→        \"correctness\": 0.3\n    54→    }\n    55→\n    56→    def synthesize(self, agent_results: Dict[str, AgentResult], subtasks: List[str]) -> Dict:\n    57→        \"\"\"\n    58→        Combine results from multiple agents into a unified response.\n    59→\n    60→        Args:\n    61→            agent_results: Dict of agent_id -> AgentResult\n    62→            subtasks: Original subtask descriptions\n    63→\n    64→        Returns:\n    65→            Synthesized result with confidence\n    66→        \"\"\"\n    67→        successful = [r for r in agent_results.values() if r.success]\n    68→        failed = [r for r in agent_results.values() if not r.success]\n    69→\n    70→        # Calculate overall success rate\n    71→        success_rate = len(successful) / len(agent_results) if agent_results else 0\n    72→\n    73→        # Combine outputs\n    74→        combined_output = self._merge_outputs([r.output for r in successful])\n    75→\n    76→        # Calculate confidence\n    77→        confidence = self._calculate_confidence(agent_results)\n    78→\n    79→        # Extract files modified across all agents\n    80→        all_files = set()\n    81→        for r in agent_results.values():\n    82→            all_files.update(r.files_modified or [])\n    83→\n    84→        return {\n    85→            \"status\": self._determine_status(success_rate),\n    86→            \"success_rate\": success_rate,\n    87→            \"confidence\": confidence,\n    88→            \"combined_output\": combined_output,\n    89→            \"files_modified\": list(all_files),\n    90→            \"successful_agents\": len(successful),\n    91→            \"failed_agents\": len(failed),\n    92→            \"errors\": [r.error for r in failed if r.error]\n    93→        }\n    94→\n    95→    def _merge_outputs(self, outputs: List[str]) -> str:\n    96→        \"\"\"Merge multiple agent outputs intelligently.\"\"\"\n    97→        if not outputs:\n    98→            return \"\"\n    99→\n   100→        if len(outputs) == 1:\n   101→            return outputs[0]\n   102→\n   103→        # Simple concatenation with headers\n   104→        merged = []\n   105→        for i, output in enumerate(outputs, 1):\n   106→            if output.strip():\n   107→                merged.append(f\"## Agent {i} Result\\n{output.strip()}\")\n   108→\n   109→        return \"\\n\\n\".join(merged)\n   110→\n   111→    def _calculate_confidence(self, agent_results: Dict[str, AgentResult]) -> float:\n   112→        \"\"\"Calculate confidence in the combined result.\"\"\"\n   113→        if not agent_results:\n   114→            return 0.0\n   115→\n   116→        # Base confidence on success rate\n   117→        success_rate = sum(1 for r in agent_results.values() if r.success) / len(agent_results)\n   118→\n   119→        # Adjust for consistency (do outputs agree?)\n   120→        consistency = 0.7  # Placeholder - would need semantic analysis\n   121→\n   122→        return round(success_rate * 0.6 + consistency * 0.4, 3)\n   123→\n   124→    def _determine_status(self, success_rate: float) -> str:\n   125→        \"\"\"Determine overall status from success rate.\"\"\"\n   126→        if success_rate >= 0.9:\n   127→            return \"success\"\n   128→        elif success_rate >= 0.5:\n   129→            return \"partial\"\n   130→        else:\n   131→            return \"failed\"\n   132→\n   133→\n   134→class MultiAgentOrchestrator:\n   135→    \"\"\"\n   136→    Main orchestrator for multi-agent coordination.\n   137→\n   138→    Workflow:\n   139→    1. Decompose task into subtasks\n   140→    2. Detect dependencies (parallel vs sequential)\n   141→    3. Check file conflicts\n   142→    4. Select strategy (research/implement/review/full)\n   143→    5. Execute with appropriate strategy\n   144→    6. Synthesize results with ACE\n   145→    \"\"\"\n   146→\n   147→    DATA_DIR = Path.home() / \".claude\" / \"coordinator\" / \"data\"\n   148→    LOG_FILE = DATA_DIR / \"coordination-log.jsonl\"\n   149→\n   150→    # Cost confirmation threshold\n   151→    COST_CONFIRM_THRESHOLD = 1.0  # USD\n   152→\n   153→    def __init__(self):\n   154→        self.registry = AgentRegistry()\n   155→        self.conflict_mgr = ConflictManager()\n   156→        self.distributor = WorkDistributor()\n   157→        self.executor = AgentExecutor(self.registry, self.conflict_mgr)\n   158→        self.synthesizer = ACESynthesizer()\n   159→        self.DATA_DIR.mkdir(parents=True, exist_ok=True)\n   160→\n   161→    def coordinate(self, task: str, strategy: str = \"auto\", confirm_cost: bool = True) -> CoordinationResult:\n   162→        \"\"\"\n   163→        Main coordination entry point.\n   164→\n   165→        Args:\n   166→            task: High-level task description\n   167→            strategy: \"auto\", \"research\", \"implement\", \"review-build\", \"full\"\n   168→            confirm_cost: Require confirmation for high-cost operations\n   169→\n   170→        Returns:\n   171→            CoordinationResult with status and outputs\n   172→        \"\"\"\n   173→        task_id = f\"coord-{uuid.uuid4().hex[:8]}\"\n   174→        start_time = time.time()\n   175→\n   176→        # 1. Decompose task\n   177→        subtasks = self._decompose_task(task, strategy)\n   178→\n   179→        # 2. Assign models and estimate costs\n   180→        assignments = self.distributor.assign(subtasks)\n   181→\n   182→        # 3. Check conflicts and determine parallelization\n   183→        conflict_analysis = detect_potential_conflicts([\n   184→            {\"files\": a.files, \"lock_type\": a.lock_type}\n   185→            for a in assignments\n   186→        ])\n   187→\n   188→        # 4. Estimate total cost\n   189→        cost_estimate = self.distributor.estimate_total_cost(assignments)\n   190→\n   191→        if confirm_cost and cost_estimate[\"total\"] > self.COST_CONFIRM_THRESHOLD:\n   192→            print(f\"\\nEstimated cost: ${cost_estimate['total']:.4f}\")\n   193→            print(f\"Agents: {cost_estimate['agent_count']}\")\n   194→            print(f\"  Haiku: ${cost_estimate['by_model'].get('haiku', 0):.4f}\")\n   195→            print(f\"  Sonnet: ${cost_estimate['by_model'].get('sonnet', 0):.4f}\")\n   196→            print(f\"  Opus: ${cost_estimate['by_model'].get('opus', 0):.4f}\")\n   197→            response = input(\"\\nProceed? [y/N]: \")\n   198→            if response.lower() != 'y':\n   199→                return CoordinationResult(\n   200→                    task_id=task_id,\n   201→                    task=task,\n   202→                    strategy=strategy,\n   203→                    status=\"cancelled\",\n   204→                    duration_seconds=0,\n   205→                    agent_results={},\n   206→                    synthesis={\"status\": \"cancelled\", \"reason\": \"User declined\"},\n   207→                    total_cost=0\n   208→                )\n   209→\n   210→        # 5. Select and execute strategy\n   211→        if strategy == \"auto\":\n   212→            strategy = self._detect_strategy(task, assignments, conflict_analysis)\n   213→\n   214→        print(f\"\\nExecuting strategy: {strategy}\")\n   215→        print(f\"Subtasks: {len(assignments)}\")\n   216→        print(f\"Can parallelize: {conflict_analysis['can_parallelize']}\")\n   217→\n   218→        # Import and run strategy\n   219→        agent_results = self._execute_strategy(\n   220→            strategy, task_id, task, assignments, conflict_analysis\n   221→        )\n   222→\n   223→        # 6. Synthesize results\n   224→        synthesis = self.synthesizer.synthesize(\n   225→            agent_results,\n   226→            [a.subtask for a in assignments]\n   227→        )\n   228→\n   229→        duration = time.time() - start_time\n   230→\n   231→        # Calculate actual cost (would need token tracking)\n   232→        total_cost = sum(a.cost_estimate for a in assignments)\n   233→\n   234→        result = CoordinationResult(\n   235→            task_id=task_id,\n   236→            task=task,\n   237→            strategy=strategy,\n   238→            status=synthesis[\"status\"],\n   239→            duration_seconds=round(duration, 2),\n   240→            agent_results={k: asdict(v) if hasattr(v, '__dataclass_fields__') else v\n   241→                          for k, v in agent_results.items()},\n   242→            synthesis=synthesis,\n   243→            total_cost=total_cost\n   244→        )\n   245→\n   246→        # Log result\n   247→        self._log_coordination(result)\n   248→\n   249→        return result\n   250→\n   251→    def _decompose_task(self, task: str, strategy: str) -> List[Dict]:\n   252→        \"\"\"Decompose task based on strategy.\"\"\"\n   253→        if strategy == \"research\":\n   254→            # Multiple explore angles\n   255→            return [\n   256→                {\"subtask\": f\"Explore architecture for: {task}\", \"agent_type\": \"Explore\", \"lock_type\": \"read\", \"priority\": 0},\n   257→                {\"subtask\": f\"Find similar patterns for: {task}\", \"agent_type\": \"Explore\", \"lock_type\": \"read\", \"priority\": 0},\n   258→                {\"subtask\": f\"Analyze dependencies for: {task}\", \"agent_type\": \"Explore\", \"lock_type\": \"read\", \"priority\": 0},\n   259→            ]\n   260→        elif strategy == \"implement\":\n   261→            return [\n   262→                {\"subtask\": f\"Implement: {task}\", \"agent_type\": \"general-purpose\", \"lock_type\": \"write\", \"priority\": 0},\n   263→            ]\n   264→        elif strategy == \"review-build\":\n   265→            return [\n   266→                {\"subtask\": f\"Build: {task}\", \"agent_type\": \"general-purpose\", \"lock_type\": \"write\", \"priority\": 0},\n   267→                {\"subtask\": f\"Review implementation for: {task}\", \"agent_type\": \"Explore\", \"lock_type\": \"read\", \"priority\": 0},\n   268→            ]\n   269→        else:\n   270→            # Auto decomposition\n   271→            return decompose_task(task)\n   272→\n   273→    def _detect_strategy(self, task: str, assignments: List[TaskAssignment], conflicts: Dict) -> str:\n   274→        \"\"\"Auto-detect best strategy for task.\"\"\"\n   275→        task_lower = task.lower()\n   276→\n   277→        # Research indicators\n   278→        if any(kw in task_lower for kw in [\"understand\", \"explore\", \"find\", \"analyze\", \"investigate\", \"how does\"]):\n   279→            return \"research\"\n   280→\n   281→        # Implementation with review\n   282→        if any(kw in task_lower for kw in [\"implement\", \"add\", \"create\", \"build\"]):\n   283→            if len(assignments) > 1 and not conflicts[\"has_conflicts\"]:\n   284→                return \"full\"\n   285→            return \"review-build\"\n   286→\n   287→        # Default to full orchestration\n   288→        return \"full\"\n   289→\n   290→    def _execute_strategy(self, strategy: str, task_id: str, task: str,\n   291→                          assignments: List[TaskAssignment], conflicts: Dict) -> Dict[str, AgentResult]:\n   292→        \"\"\"Execute the selected strategy.\"\"\"\n   293→        # Import strategy modules\n   294→        strategies_dir = Path(__file__).parent / \"strategies\"\n   295→\n   296→        if strategy == \"research\":\n   297→            from strategies.parallel_research import execute_parallel_research\n   298→            return execute_parallel_research(self, task_id, task, assignments)\n   299→\n   300→        elif strategy == \"implement\":\n   301→            from strategies.parallel_implement import execute_parallel_implement\n   302→            return execute_parallel_implement(self, task_id, task, assignments, conflicts)\n   303→\n   304→        elif strategy == \"review-build\":\n   305→            from strategies.review_build import execute_review_build\n   306→            return execute_review_build(self, task_id, task, assignments)\n   307→\n   308→        elif strategy == \"full\":\n   309→            from strategies.full_orchestration import execute_full_orchestration\n   310→            return execute_full_orchestration(self, task_id, task, assignments, conflicts)\n   311→\n   312→        else:\n   313→            # Fallback: sequential execution\n   314→            return self._execute_sequential(task_id, assignments)\n   315→\n   316→    def _execute_sequential(self, task_id: str, assignments: List[TaskAssignment]) -> Dict[str, AgentResult]:\n   317→        \"\"\"Fallback: execute assignments sequentially.\"\"\"\n   318→        results = {}\n   319→\n   320→        for assignment in assignments:\n   321→            config = AgentConfig(\n   322→                subtask=assignment.subtask,\n   323→                prompt=assignment.subtask,\n   324→                agent_type=assignment.agent_type,\n   325→                model=assignment.model,\n   326→                files_to_lock=assignment.files,\n   327→                lock_type=assignment.lock_type,\n   328→                dq_score=assignment.dq_score,\n   329→                cost_estimate=assignment.cost_estimate\n   330→            )\n   331→\n   332→            agent_id = self.executor.spawn_cli_agent(config, task_id)\n   333→            agent = self.registry.get(agent_id)\n   334→\n   335→            results[agent_id] = AgentResult(\n   336→                agent_id=agent_id,\n   337→                success=agent.state == AgentState.COMPLETED.value if agent else False,\n   338→                output=agent.result.get(\"output\", \"\") if agent and agent.result else \"\",\n   339→                error=agent.error if agent else \"Agent not found\"\n   340→            )\n   341→\n   342→        return results\n   343→\n   344→    def _log_coordination(self, result: CoordinationResult):\n   345→        \"\"\"Log coordination result.\"\"\"\n   346→        with open(self.LOG_FILE, 'a') as f:\n   347→            log_entry = {\n   348→                \"timestamp\": datetime.now().isoformat(),\n   349→                \"task_id\": result.task_id,\n   350→                \"task\": result.task[:100],\n   351→                \"strategy\": result.strategy,\n   352→                \"status\": result.status,\n   353→                \"duration_seconds\": result.duration_seconds,\n   354→                \"total_cost\": result.total_cost,\n   355→                \"agent_count\": len(result.agent_results)\n   356→            }\n   357→            f.write(json.dumps(log_entry) + \"\\n\")\n   358→\n   359→    def status(self, task_id: str = None) -> Dict:\n   360→        \"\"\"Get status of coordination tasks.\"\"\"\n   361→        if task_id:\n   362→            agents = self.registry.get_task_agents(task_id)\n   363→            return {\n   364→                \"task_id\": task_id,\n   365→                \"agents\": [asdict(a) for a in agents],\n   366→                \"stats\": self.registry.get_stats()\n   367→            }\n   368→        else:\n   369→            return {\n   370→                \"registry\": self.registry.get_stats(),\n   371→                \"locks\": self.conflict_mgr.get_stats()\n   372→            }\n   373→\n   374→    def cancel(self, task_id: str):\n   375→        \"\"\"Cancel a coordination task.\"\"\"\n   376→        self.executor.cancel_task(task_id)\n   377→\n   378→\n   379→def main():\n   380→    \"\"\"CLI entry point.\"\"\"\n   381→    import argparse\n   382→\n   383→    parser = argparse.ArgumentParser(\n   384→        description=\"Multi-Agent Coordinator\",\n   385→        formatter_class=argparse.RawDescriptionHelpFormatter,\n   386→        epilog=\"\"\"\n   387→Examples:\n   388→  coord research \"How does the routing system work?\"\n   389→  coord implement \"Add logging to all API endpoints\"\n   390→  coord review-build \"Implement rate limiting middleware\"\n   391→  coord full \"Add user preferences feature\"\n   392→  coord status\n   393→        \"\"\"\n   394→    )\n   395→\n   396→    parser.add_argument(\"command\", nargs=\"?\", default=\"status\",\n   397→                        help=\"Command: research, implement, review-build, full, status, cancel\")\n   398→    parser.add_argument(\"task\", nargs=\"?\", help=\"Task description\")\n   399→    parser.add_argument(\"--task-id\", help=\"Task ID (for status/cancel)\")\n   400→    parser.add_argument(\"--no-confirm\", action=\"store_true\", help=\"Skip cost confirmation\")\n   401→\n   402→    args = parser.parse_args()\n   403→\n   404→    orchestrator = MultiAgentOrchestrator()\n   405→\n   406→    if args.command == \"status\":\n   407→        status = orchestrator.status(args.task_id)\n   408→        print(json.dumps(status, indent=2))\n   409→\n   410→    elif args.command == \"cancel\" and args.task_id:\n   411→        orchestrator.cancel(args.task_id)\n   412→        print(f\"Cancelled task: {args.task_id}\")\n   413→\n   414→    elif args.command in [\"research\", \"implement\", \"review-build\", \"full\"] and args.task:\n   415→        result = orchestrator.coordinate(\n   416→            task=args.task,\n   417→            strategy=args.command,\n   418→            confirm_cost=not args.no_confirm\n   419→        )\n   420→\n   421→        print(f\"\\n{'='*60}\")\n   422→        print(f\"Task ID: {result.task_id}\")\n   423→        print(f\"Status: {result.status}\")\n   424→        print(f\"Duration: {result.duration_seconds}s\")\n   425→        print(f\"Cost: ${result.total_cost:.4f}\")\n   426→        print(f\"{'='*60}\")\n   427→\n   428→        if result.synthesis.get(\"combined_output\"):\n   429→            print(\"\\n## Combined Output\")\n   430→            print(result.synthesis[\"combined_output\"][:2000])\n   431→\n   432→        if result.synthesis.get(\"errors\"):\n   433→            print(\"\\n## Errors\")\n   434→            for err in result.synthesis[\"errors\"]:\n   435→                print(f\"  - {err}\")\n   436→\n   437→    elif args.task:\n   438→        # Auto-detect strategy\n   439→        result = orchestrator.coordinate(\n   440→            task=args.task,\n   441→            strategy=\"auto\",\n   442→            confirm_cost=not args.no_confirm\n   443→        )\n   444→\n   445→        print(f\"\\nTask ID: {result.task_id}\")\n   446→        print(f\"Strategy: {result.strategy}\")\n   447→        print(f\"Status: {result.status}\")\n   448→\n   449→    else:\n   450→        parser.print_help()\n   451→\n   452→\n   453→if __name__ == \"__main__\":\n   454→    main()\n   455→"}]},"parent_tool_use_id":null,"session_id":"1c891cc5-27f8-4bc6-8060-c18a8fb0442f","uuid":"30113b99-27d8-44b2-a958-75cc621a1400","tool_use_result":{"type":"text","file":{"filePath":"/Users/dicoangelo/projects/core/meta-vengine/coordinator/orchestrator.py","content":"#!/usr/bin/env python3\n\"\"\"\nMulti-Agent Orchestrator - Main coordinator for parallel Claude agents.\n\nOrchestrates multiple agents for:\n- Parallel research (multiple explore agents)\n- Parallel implementation (locked files)\n- Review + build (concurrent)\n- Full orchestration (research → build → review)\n\"\"\"\n\nimport json\nimport sys\nimport uuid\nimport time\nfrom pathlib import Path\nfrom datetime import datetime\nfrom typing import Dict, List, Optional, Tuple\nfrom dataclasses import dataclass, asdict\n\n# Add parent to path for imports\nsys.path.insert(0, str(Path(__file__).parent))\n\nfrom registry import AgentRegistry, AgentState, AgentRecord\nfrom conflict import ConflictManager, detect_potential_conflicts, LockType\nfrom distribution import WorkDistributor, TaskAssignment, decompose_task\nfrom executor import AgentExecutor, AgentConfig, AgentResult\n\n\n@dataclass\nclass CoordinationResult:\n    \"\"\"Result of a multi-agent coordination.\"\"\"\n    task_id: str\n    task: str\n    strategy: str\n    status: str  # success, partial, failed\n    duration_seconds: float\n    agent_results: Dict[str, Dict]\n    synthesis: Dict\n    total_cost: float\n\n\nclass ACESynthesizer:\n    \"\"\"\n    Synthesizes results from multiple agents using ACE consensus.\n\n    Adapted from ~/.claude/scripts/observatory/ace_consensus.py\n    \"\"\"\n\n    DQ_WEIGHTS = {\n        \"validity\": 0.4,\n        \"specificity\": 0.3,\n        \"correctness\": 0.3\n    }\n\n    def synthesize(self, agent_results: Dict[str, AgentResult], subtasks: List[str]) -> Dict:\n        \"\"\"\n        Combine results from multiple agents into a unified response.\n\n        Args:\n            agent_results: Dict of agent_id -> AgentResult\n            subtasks: Original subtask descriptions\n\n        Returns:\n            Synthesized result with confidence\n        \"\"\"\n        successful = [r for r in agent_results.values() if r.success]\n        failed = [r for r in agent_results.values() if not r.success]\n\n        # Calculate overall success rate\n        success_rate = len(successful) / len(agent_results) if agent_results else 0\n\n        # Combine outputs\n        combined_output = self._merge_outputs([r.output for r in successful])\n\n        # Calculate confidence\n        confidence = self._calculate_confidence(agent_results)\n\n        # Extract files modified across all agents\n        all_files = set()\n        for r in agent_results.values():\n            all_files.update(r.files_modified or [])\n\n        return {\n            \"status\": self._determine_status(success_rate),\n            \"success_rate\": success_rate,\n            \"confidence\": confidence,\n            \"combined_output\": combined_output,\n            \"files_modified\": list(all_files),\n            \"successful_agents\": len(successful),\n            \"failed_agents\": len(failed),\n            \"errors\": [r.error for r in failed if r.error]\n        }\n\n    def _merge_outputs(self, outputs: List[str]) -> str:\n        \"\"\"Merge multiple agent outputs intelligently.\"\"\"\n        if not outputs:\n            return \"\"\n\n        if len(outputs) == 1:\n            return outputs[0]\n\n        # Simple concatenation with headers\n        merged = []\n        for i, output in enumerate(outputs, 1):\n            if output.strip():\n                merged.append(f\"## Agent {i} Result\\n{output.strip()}\")\n\n        return \"\\n\\n\".join(merged)\n\n    def _calculate_confidence(self, agent_results: Dict[str, AgentResult]) -> float:\n        \"\"\"Calculate confidence in the combined result.\"\"\"\n        if not agent_results:\n            return 0.0\n\n        # Base confidence on success rate\n        success_rate = sum(1 for r in agent_results.values() if r.success) / len(agent_results)\n\n        # Adjust for consistency (do outputs agree?)\n        consistency = 0.7  # Placeholder - would need semantic analysis\n\n        return round(success_rate * 0.6 + consistency * 0.4, 3)\n\n    def _determine_status(self, success_rate: float) -> str:\n        \"\"\"Determine overall status from success rate.\"\"\"\n        if success_rate >= 0.9:\n            return \"success\"\n        elif success_rate >= 0.5:\n            return \"partial\"\n        else:\n            return \"failed\"\n\n\nclass MultiAgentOrchestrator:\n    \"\"\"\n    Main orchestrator for multi-agent coordination.\n\n    Workflow:\n    1. Decompose task into subtasks\n    2. Detect dependencies (parallel vs sequential)\n    3. Check file conflicts\n    4. Select strategy (research/implement/review/full)\n    5. Execute with appropriate strategy\n    6. Synthesize results with ACE\n    \"\"\"\n\n    DATA_DIR = Path.home() / \".claude\" / \"coordinator\" / \"data\"\n    LOG_FILE = DATA_DIR / \"coordination-log.jsonl\"\n\n    # Cost confirmation threshold\n    COST_CONFIRM_THRESHOLD = 1.0  # USD\n\n    def __init__(self):\n        self.registry = AgentRegistry()\n        self.conflict_mgr = ConflictManager()\n        self.distributor = WorkDistributor()\n        self.executor = AgentExecutor(self.registry, self.conflict_mgr)\n        self.synthesizer = ACESynthesizer()\n        self.DATA_DIR.mkdir(parents=True, exist_ok=True)\n\n    def coordinate(self, task: str, strategy: str = \"auto\", confirm_cost: bool = True) -> CoordinationResult:\n        \"\"\"\n        Main coordination entry point.\n\n        Args:\n            task: High-level task description\n            strategy: \"auto\", \"research\", \"implement\", \"review-build\", \"full\"\n            confirm_cost: Require confirmation for high-cost operations\n\n        Returns:\n            CoordinationResult with status and outputs\n        \"\"\"\n        task_id = f\"coord-{uuid.uuid4().hex[:8]}\"\n        start_time = time.time()\n\n        # 1. Decompose task\n        subtasks = self._decompose_task(task, strategy)\n\n        # 2. Assign models and estimate costs\n        assignments = self.distributor.assign(subtasks)\n\n        # 3. Check conflicts and determine parallelization\n        conflict_analysis = detect_potential_conflicts([\n            {\"files\": a.files, \"lock_type\": a.lock_type}\n            for a in assignments\n        ])\n\n        # 4. Estimate total cost\n        cost_estimate = self.distributor.estimate_total_cost(assignments)\n\n        if confirm_cost and cost_estimate[\"total\"] > self.COST_CONFIRM_THRESHOLD:\n            print(f\"\\nEstimated cost: ${cost_estimate['total']:.4f}\")\n            print(f\"Agents: {cost_estimate['agent_count']}\")\n            print(f\"  Haiku: ${cost_estimate['by_model'].get('haiku', 0):.4f}\")\n            print(f\"  Sonnet: ${cost_estimate['by_model'].get('sonnet', 0):.4f}\")\n            print(f\"  Opus: ${cost_estimate['by_model'].get('opus', 0):.4f}\")\n            response = input(\"\\nProceed? [y/N]: \")\n            if response.lower() != 'y':\n                return CoordinationResult(\n                    task_id=task_id,\n                    task=task,\n                    strategy=strategy,\n                    status=\"cancelled\",\n                    duration_seconds=0,\n                    agent_results={},\n                    synthesis={\"status\": \"cancelled\", \"reason\": \"User declined\"},\n                    total_cost=0\n                )\n\n        # 5. Select and execute strategy\n        if strategy == \"auto\":\n            strategy = self._detect_strategy(task, assignments, conflict_analysis)\n\n        print(f\"\\nExecuting strategy: {strategy}\")\n        print(f\"Subtasks: {len(assignments)}\")\n        print(f\"Can parallelize: {conflict_analysis['can_parallelize']}\")\n\n        # Import and run strategy\n        agent_results = self._execute_strategy(\n            strategy, task_id, task, assignments, conflict_analysis\n        )\n\n        # 6. Synthesize results\n        synthesis = self.synthesizer.synthesize(\n            agent_results,\n            [a.subtask for a in assignments]\n        )\n\n        duration = time.time() - start_time\n\n        # Calculate actual cost (would need token tracking)\n        total_cost = sum(a.cost_estimate for a in assignments)\n\n        result = CoordinationResult(\n            task_id=task_id,\n            task=task,\n            strategy=strategy,\n            status=synthesis[\"status\"],\n            duration_seconds=round(duration, 2),\n            agent_results={k: asdict(v) if hasattr(v, '__dataclass_fields__') else v\n                          for k, v in agent_results.items()},\n            synthesis=synthesis,\n            total_cost=total_cost\n        )\n\n        # Log result\n        self._log_coordination(result)\n\n        return result\n\n    def _decompose_task(self, task: str, strategy: str) -> List[Dict]:\n        \"\"\"Decompose task based on strategy.\"\"\"\n        if strategy == \"research\":\n            # Multiple explore angles\n            return [\n                {\"subtask\": f\"Explore architecture for: {task}\", \"agent_type\": \"Explore\", \"lock_type\": \"read\", \"priority\": 0},\n                {\"subtask\": f\"Find similar patterns for: {task}\", \"agent_type\": \"Explore\", \"lock_type\": \"read\", \"priority\": 0},\n                {\"subtask\": f\"Analyze dependencies for: {task}\", \"agent_type\": \"Explore\", \"lock_type\": \"read\", \"priority\": 0},\n            ]\n        elif strategy == \"implement\":\n            return [\n                {\"subtask\": f\"Implement: {task}\", \"agent_type\": \"general-purpose\", \"lock_type\": \"write\", \"priority\": 0},\n            ]\n        elif strategy == \"review-build\":\n            return [\n                {\"subtask\": f\"Build: {task}\", \"agent_type\": \"general-purpose\", \"lock_type\": \"write\", \"priority\": 0},\n                {\"subtask\": f\"Review implementation for: {task}\", \"agent_type\": \"Explore\", \"lock_type\": \"read\", \"priority\": 0},\n            ]\n        else:\n            # Auto decomposition\n            return decompose_task(task)\n\n    def _detect_strategy(self, task: str, assignments: List[TaskAssignment], conflicts: Dict) -> str:\n        \"\"\"Auto-detect best strategy for task.\"\"\"\n        task_lower = task.lower()\n\n        # Research indicators\n        if any(kw in task_lower for kw in [\"understand\", \"explore\", \"find\", \"analyze\", \"investigate\", \"how does\"]):\n            return \"research\"\n\n        # Implementation with review\n        if any(kw in task_lower for kw in [\"implement\", \"add\", \"create\", \"build\"]):\n            if len(assignments) > 1 and not conflicts[\"has_conflicts\"]:\n                return \"full\"\n            return \"review-build\"\n\n        # Default to full orchestration\n        return \"full\"\n\n    def _execute_strategy(self, strategy: str, task_id: str, task: str,\n                          assignments: List[TaskAssignment], conflicts: Dict) -> Dict[str, AgentResult]:\n        \"\"\"Execute the selected strategy.\"\"\"\n        # Import strategy modules\n        strategies_dir = Path(__file__).parent / \"strategies\"\n\n        if strategy == \"research\":\n            from strategies.parallel_research import execute_parallel_research\n            return execute_parallel_research(self, task_id, task, assignments)\n\n        elif strategy == \"implement\":\n            from strategies.parallel_implement import execute_parallel_implement\n            return execute_parallel_implement(self, task_id, task, assignments, conflicts)\n\n        elif strategy == \"review-build\":\n            from strategies.review_build import execute_review_build\n            return execute_review_build(self, task_id, task, assignments)\n\n        elif strategy == \"full\":\n            from strategies.full_orchestration import execute_full_orchestration\n            return execute_full_orchestration(self, task_id, task, assignments, conflicts)\n\n        else:\n            # Fallback: sequential execution\n            return self._execute_sequential(task_id, assignments)\n\n    def _execute_sequential(self, task_id: str, assignments: List[TaskAssignment]) -> Dict[str, AgentResult]:\n        \"\"\"Fallback: execute assignments sequentially.\"\"\"\n        results = {}\n\n        for assignment in assignments:\n            config = AgentConfig(\n                subtask=assignment.subtask,\n                prompt=assignment.subtask,\n                agent_type=assignment.agent_type,\n                model=assignment.model,\n                files_to_lock=assignment.files,\n                lock_type=assignment.lock_type,\n                dq_score=assignment.dq_score,\n                cost_estimate=assignment.cost_estimate\n            )\n\n            agent_id = self.executor.spawn_cli_agent(config, task_id)\n            agent = self.registry.get(agent_id)\n\n            results[agent_id] = AgentResult(\n                agent_id=agent_id,\n                success=agent.state == AgentState.COMPLETED.value if agent else False,\n                output=agent.result.get(\"output\", \"\") if agent and agent.result else \"\",\n                error=agent.error if agent else \"Agent not found\"\n            )\n\n        return results\n\n    def _log_coordination(self, result: CoordinationResult):\n        \"\"\"Log coordination result.\"\"\"\n        with open(self.LOG_FILE, 'a') as f:\n            log_entry = {\n                \"timestamp\": datetime.now().isoformat(),\n                \"task_id\": result.task_id,\n                \"task\": result.task[:100],\n                \"strategy\": result.strategy,\n                \"status\": result.status,\n                \"duration_seconds\": result.duration_seconds,\n                \"total_cost\": result.total_cost,\n                \"agent_count\": len(result.agent_results)\n            }\n            f.write(json.dumps(log_entry) + \"\\n\")\n\n    def status(self, task_id: str = None) -> Dict:\n        \"\"\"Get status of coordination tasks.\"\"\"\n        if task_id:\n            agents = self.registry.get_task_agents(task_id)\n            return {\n                \"task_id\": task_id,\n                \"agents\": [asdict(a) for a in agents],\n                \"stats\": self.registry.get_stats()\n            }\n        else:\n            return {\n                \"registry\": self.registry.get_stats(),\n                \"locks\": self.conflict_mgr.get_stats()\n            }\n\n    def cancel(self, task_id: str):\n        \"\"\"Cancel a coordination task.\"\"\"\n        self.executor.cancel_task(task_id)\n\n\ndef main():\n    \"\"\"CLI entry point.\"\"\"\n    import argparse\n\n    parser = argparse.ArgumentParser(\n        description=\"Multi-Agent Coordinator\",\n        formatter_class=argparse.RawDescriptionHelpFormatter,\n        epilog=\"\"\"\nExamples:\n  coord research \"How does the routing system work?\"\n  coord implement \"Add logging to all API endpoints\"\n  coord review-build \"Implement rate limiting middleware\"\n  coord full \"Add user preferences feature\"\n  coord status\n        \"\"\"\n    )\n\n    parser.add_argument(\"command\", nargs=\"?\", default=\"status\",\n                        help=\"Command: research, implement, review-build, full, status, cancel\")\n    parser.add_argument(\"task\", nargs=\"?\", help=\"Task description\")\n    parser.add_argument(\"--task-id\", help=\"Task ID (for status/cancel)\")\n    parser.add_argument(\"--no-confirm\", action=\"store_true\", help=\"Skip cost confirmation\")\n\n    args = parser.parse_args()\n\n    orchestrator = MultiAgentOrchestrator()\n\n    if args.command == \"status\":\n        status = orchestrator.status(args.task_id)\n        print(json.dumps(status, indent=2))\n\n    elif args.command == \"cancel\" and args.task_id:\n        orchestrator.cancel(args.task_id)\n        print(f\"Cancelled task: {args.task_id}\")\n\n    elif args.command in [\"research\", \"implement\", \"review-build\", \"full\"] and args.task:\n        result = orchestrator.coordinate(\n            task=args.task,\n            strategy=args.command,\n            confirm_cost=not args.no_confirm\n        )\n\n        print(f\"\\n{'='*60}\")\n        print(f\"Task ID: {result.task_id}\")\n        print(f\"Status: {result.status}\")\n        print(f\"Duration: {result.duration_seconds}s\")\n        print(f\"Cost: ${result.total_cost:.4f}\")\n        print(f\"{'='*60}\")\n\n        if result.synthesis.get(\"combined_output\"):\n            print(\"\\n## Combined Output\")\n            print(result.synthesis[\"combined_output\"][:2000])\n\n        if result.synthesis.get(\"errors\"):\n            print(\"\\n## Errors\")\n            for err in result.synthesis[\"errors\"]:\n                print(f\"  - {err}\")\n\n    elif args.task:\n        # Auto-detect strategy\n        result = orchestrator.coordinate(\n            task=args.task,\n            strategy=\"auto\",\n            confirm_cost=not args.no_confirm\n        )\n\n        print(f\"\\nTask ID: {result.task_id}\")\n        print(f\"Strategy: {result.strategy}\")\n        print(f\"Status: {result.status}\")\n\n    else:\n        parser.print_help()\n\n\nif __name__ == \"__main__\":\n    main()\n","numLines":455,"startLine":1,"totalLines":455}}}
