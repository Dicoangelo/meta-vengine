{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Qv2oxFpPFnEuTU7kxA1z73","type":"tool_result","content":"   690→ * Make a routing decision with DQ scoring\n   691→ */\n   692→function route(query) {\n   693→  const history = loadHistory();\n   694→  const complexity = estimateComplexity(query);\n   695→\n   696→  // Apply cognitive modifier to complexity for threshold comparisons\n   697→  const adjustedComplexity = applyCognitiveModifier(complexity.score);\n   698→\n   699→  // Apply IRT difficulty modifier (US-003: cross-runtime bridge from HSRGS)\n   700→  const queryHash = crypto.createHash('md5').update(query).digest('hex');\n   701→  const irtBridge = loadIRTBridge(queryHash);\n   702→  const irtDifficulty = irtBridge ? irtBridge.difficulty : null;\n   703→  const IRT_MOD = computeIRTModifier(irtDifficulty);\n   704→  const irtAdjustedComplexity = Math.max(0, Math.min(1, adjustedComplexity + IRT_MOD));\n   705→\n   706→  // US-004: Compute multi-feature graph signal\n   707→  // Attempt to gather distributional features and subgraph density\n   708→  // These may be null if no retrieval scores / nodes are available for this query\n   709→  const graphSignal = computeGraphSignal({\n   710→    distributional: null, // Populated by caller or retrieval pipeline when available\n   711→    subgraph: null,       // Populated by caller or retrieval pipeline when available\n   712→    irtDifficulty: irtDifficulty\n   713→  });\n   714→\n   715→  // A/B test: determine which complexity signal to use for routing\n   716→  // Odd session timestamps use graph signal, even use keyword (deterministic)\n   717→  const sessionId = Math.floor(Date.now() / 1000);\n   718→  const useGraphSignal = graphSignal && graphSignal.featureCount >= 2 && (sessionId % 2 === 1);\n   719→  const routingComplexity = useGraphSignal ? graphSignal.graphComplexity : irtAdjustedComplexity;\n   720→\n   721→  // Try each model and pick best DQ\n   722→  const candidates = ['haiku', 'sonnet', 'opus'].map(model => {\n   723→    // Use the selected complexity signal for DQ calculation\n   724→    const dq = calculateDQ(query, routingComplexity, model, history);\n   725→    return { model, dq, complexity: complexity.score, adjustedComplexity: routingComplexity };\n   726→  });\n   727→\n   728→  // Sort by DQ score (highest first), then by cost (lowest first for ties)\n   729→  candidates.sort((a, b) => {\n   730→    if (Math.abs(a.dq.score - b.dq.score) > 0.05) {\n   731→      return b.dq.score - a.dq.score;\n   732→    }\n   733→    // If DQ scores are similar, prefer cheaper model\n   734→    const costOrder = { haiku: 0, sonnet: 1, opus: 2 };\n   735→    return costOrder[a.model] - costOrder[b.model];\n   736→  });\n   737→\n   738→  let best = candidates[0];\n   739→\n   740→  // Apply expertise-based adjustment\n   741→  const expertiseAdj = getExpertiseAdjustment(query);\n   742→  let expertiseOverride = null;\n   743→\n   744→  if (expertiseAdj) {\n   745→    const models = ['haiku', 'sonnet', 'opus'];\n   746→    const currentIdx = models.indexOf(best.model);\n   747→\n   748→    if (expertiseAdj.adjustment === 'downgrade' && currentIdx > 0) {\n   749→      // High expertise - can use cheaper model"}]},"parent_tool_use_id":null,"session_id":"1c891cc5-27f8-4bc6-8060-c18a8fb0442f","uuid":"d7f86eb8-77ad-449e-868b-46184d3bce21","tool_use_result":{"type":"text","file":{"filePath":"/Users/dicoangelo/projects/core/meta-vengine/kernel/dq-scorer.js","content":" * Make a routing decision with DQ scoring\n */\nfunction route(query) {\n  const history = loadHistory();\n  const complexity = estimateComplexity(query);\n\n  // Apply cognitive modifier to complexity for threshold comparisons\n  const adjustedComplexity = applyCognitiveModifier(complexity.score);\n\n  // Apply IRT difficulty modifier (US-003: cross-runtime bridge from HSRGS)\n  const queryHash = crypto.createHash('md5').update(query).digest('hex');\n  const irtBridge = loadIRTBridge(queryHash);\n  const irtDifficulty = irtBridge ? irtBridge.difficulty : null;\n  const IRT_MOD = computeIRTModifier(irtDifficulty);\n  const irtAdjustedComplexity = Math.max(0, Math.min(1, adjustedComplexity + IRT_MOD));\n\n  // US-004: Compute multi-feature graph signal\n  // Attempt to gather distributional features and subgraph density\n  // These may be null if no retrieval scores / nodes are available for this query\n  const graphSignal = computeGraphSignal({\n    distributional: null, // Populated by caller or retrieval pipeline when available\n    subgraph: null,       // Populated by caller or retrieval pipeline when available\n    irtDifficulty: irtDifficulty\n  });\n\n  // A/B test: determine which complexity signal to use for routing\n  // Odd session timestamps use graph signal, even use keyword (deterministic)\n  const sessionId = Math.floor(Date.now() / 1000);\n  const useGraphSignal = graphSignal && graphSignal.featureCount >= 2 && (sessionId % 2 === 1);\n  const routingComplexity = useGraphSignal ? graphSignal.graphComplexity : irtAdjustedComplexity;\n\n  // Try each model and pick best DQ\n  const candidates = ['haiku', 'sonnet', 'opus'].map(model => {\n    // Use the selected complexity signal for DQ calculation\n    const dq = calculateDQ(query, routingComplexity, model, history);\n    return { model, dq, complexity: complexity.score, adjustedComplexity: routingComplexity };\n  });\n\n  // Sort by DQ score (highest first), then by cost (lowest first for ties)\n  candidates.sort((a, b) => {\n    if (Math.abs(a.dq.score - b.dq.score) > 0.05) {\n      return b.dq.score - a.dq.score;\n    }\n    // If DQ scores are similar, prefer cheaper model\n    const costOrder = { haiku: 0, sonnet: 1, opus: 2 };\n    return costOrder[a.model] - costOrder[b.model];\n  });\n\n  let best = candidates[0];\n\n  // Apply expertise-based adjustment\n  const expertiseAdj = getExpertiseAdjustment(query);\n  let expertiseOverride = null;\n\n  if (expertiseAdj) {\n    const models = ['haiku', 'sonnet', 'opus'];\n    const currentIdx = models.indexOf(best.model);\n\n    if (expertiseAdj.adjustment === 'downgrade' && currentIdx > 0) {\n      // High expertise - can use cheaper model","numLines":60,"startLine":690,"totalLines":961}}}
