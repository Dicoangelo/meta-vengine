{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01276Ybe9bEjwbeD21izQA69","type":"tool_result","content":"     1→#!/usr/bin/env python3\n     2→\"\"\"\n     3→Agent Executor - Spawns and manages Claude agents.\n     4→\n     5→Supports two execution methods:\n     6→1. Task tool (in-session subagents) - shares context, native integration\n     7→2. CLI subprocess (isolated) - separate process, independent context\n     8→\"\"\"\n     9→\n    10→import os\n    11→import sys\n    12→import json\n    13→import subprocess\n    14→import tempfile\n    15→import time\n    16→import asyncio\n    17→from pathlib import Path\n    18→from datetime import datetime\n    19→from typing import Dict, List, Optional, Callable, Any\n    20→from dataclasses import dataclass\n    21→from concurrent.futures import ThreadPoolExecutor, as_completed\n    22→\n    23→from registry import AgentRegistry, AgentState\n    24→from conflict import ConflictManager, LockType\n    25→\n    26→\n    27→@dataclass\n    28→class AgentConfig:\n    29→    \"\"\"Configuration for an agent to spawn.\"\"\"\n    30→    subtask: str\n    31→    prompt: str\n    32→    agent_type: str  # explore, general-purpose, Bash, Plan\n    33→    model: str = \"sonnet\"  # haiku, sonnet, opus\n    34→    timeout: int = 300  # seconds\n    35→    run_in_background: bool = True\n    36→    files_to_lock: List[str] = None\n    37→    lock_type: str = \"read\"\n    38→    dq_score: float = 0.5\n    39→    cost_estimate: float = 0.0\n    40→\n    41→    def __post_init__(self):\n    42→        if self.files_to_lock is None:\n    43→            self.files_to_lock = []\n    44→\n    45→\n    46→@dataclass\n    47→class AgentResult:\n    48→    \"\"\"Result from an agent execution.\"\"\"\n    49→    agent_id: str\n    50→    success: bool\n    51→    output: str\n    52→    error: Optional[str] = None\n    53→    duration_seconds: float = 0.0\n    54→    files_modified: List[str] = None\n    55→\n    56→    def __post_init__(self):\n    57→        if self.files_modified is None:\n    58→            self.files_modified = []\n    59→\n    60→\n    61→class AgentExecutor:\n    62→    \"\"\"\n    63→    Executes agents via CLI subprocess.\n    64→\n    65→    Note: The Task tool is used natively within Claude Code sessions.\n    66→    This executor is for programmatic spawning from Python scripts.\n    67→    \"\"\"\n    68→\n    69→    # Model mapping\n    70→    MODEL_MAP = {\n    71→        \"haiku\": \"claude-3-5-haiku-latest\",\n    72→        \"sonnet\": \"claude-sonnet-4-6\",\n    73→        \"opus\": \"claude-opus-4-6\"\n    74→    }\n    75→\n    76→    # Default timeouts by model\n    77→    DEFAULT_TIMEOUTS = {\n    78→        \"haiku\": 120,\n    79→        \"sonnet\": 300,\n    80→        \"opus\": 600\n    81→    }\n    82→\n    83→    def __init__(self, registry: AgentRegistry = None, conflict_mgr: ConflictManager = None):\n    84→        self.registry = registry or AgentRegistry()\n    85→        self.conflict_mgr = conflict_mgr or ConflictManager()\n    86→        self._active_processes: Dict[str, subprocess.Popen] = {}\n    87→\n    88→    def spawn_cli_agent(self, config: AgentConfig, task_id: str) -> str:\n    89→        \"\"\"\n    90→        Spawn an agent using Claude CLI.\n    91→\n    92→        Args:\n    93→            config: Agent configuration\n    94→            task_id: Parent coordination task ID\n    95→\n    96→        Returns:\n    97→            agent_id of the spawned agent\n    98→        \"\"\"\n    99→        # Register agent\n   100→        agent_id = self.registry.register(\n   101→            task_id=task_id,\n   102→            subtask=config.subtask,\n   103→            agent_type=config.agent_type,\n   104→            model=config.model,\n   105→            files_to_lock=config.files_to_lock,\n   106→            dq_score=config.dq_score,\n   107→            cost_estimate=config.cost_estimate\n   108→        )\n   109→\n   110→        # Acquire file locks\n   111→        if config.files_to_lock:\n   112→            success, failed = self.conflict_mgr.acquire_batch(\n   113→                config.files_to_lock,\n   114→                agent_id,\n   115→                config.lock_type\n   116→            )\n   117→            if not success:\n   118→                self.registry.fail(agent_id, f\"Could not acquire locks: {failed}\")\n   119→                return agent_id\n   120→\n   121→        # Build command\n   122→        model = self.MODEL_MAP.get(config.model, config.model)\n   123→        timeout = config.timeout or self.DEFAULT_TIMEOUTS.get(config.model, 300)\n   124→\n   125→        cmd = [\n   126→            \"claude\",\n   127→            \"--model\", model,\n   128→            \"--max-turns\", \"50\",\n   129→            \"-p\", config.prompt\n   130→        ]\n   131→\n   132→        # Mark as started\n   133→        self.registry.start(agent_id)\n   134→\n   135→        try:\n   136→            # Run subprocess\n   137→            result = subprocess.run(\n   138→                cmd,\n   139→                capture_output=True,\n   140→                text=True,\n   141→                timeout=timeout,\n   142→                cwd=str(Path.home())\n   143→            )\n   144→\n   145→            if result.returncode == 0:\n   146→                self.registry.complete(agent_id, {\n   147→                    \"output\": result.stdout,\n   148→                    \"stderr\": result.stderr\n   149→                })\n   150→            else:\n   151→                self.registry.fail(agent_id, result.stderr or \"Non-zero exit code\")\n   152→\n   153→        except subprocess.TimeoutExpired:\n   154→            self.registry.timeout(agent_id)\n   155→\n   156→        except Exception as e:\n   157→            self.registry.fail(agent_id, str(e))\n   158→\n   159→        finally:\n   160→            # Release locks\n   161→            self.conflict_mgr.release_agent(agent_id)\n   162→\n   163→        return agent_id\n   164→\n   165→    def spawn_cli_agent_async(self, config: AgentConfig, task_id: str) -> str:\n   166→        \"\"\"\n   167→        Spawn an agent asynchronously (non-blocking).\n   168→\n   169→        Returns agent_id immediately, runs in background.\n   170→        \"\"\"\n   171→        # Register agent\n   172→        agent_id = self.registry.register(\n   173→            task_id=task_id,\n   174→            subtask=config.subtask,\n   175→            agent_type=config.agent_type,\n   176→            model=config.model,\n   177→            files_to_lock=config.files_to_lock,\n   178→            dq_score=config.dq_score,\n   179→            cost_estimate=config.cost_estimate\n   180→        )\n   181→\n   182→        # Acquire file locks\n   183→        if config.files_to_lock:\n   184→            success, failed = self.conflict_mgr.acquire_batch(\n   185→                config.files_to_lock,\n   186→                agent_id,\n   187→                config.lock_type\n   188→            )\n   189→            if not success:\n   190→                self.registry.fail(agent_id, f\"Could not acquire locks: {failed}\")\n   191→                return agent_id\n   192→\n   193→        # Build command\n   194→        model = self.MODEL_MAP.get(config.model, config.model)\n   195→\n   196→        cmd = [\n   197→            \"claude\",\n   198→            \"--model\", model,\n   199→            \"--max-turns\", \"50\",\n   200→            \"-p\", config.prompt\n   201→        ]\n   202→\n   203→        # Mark as started\n   204→        self.registry.start(agent_id)\n   205→\n   206→        # Create output file for capturing\n   207→        output_file = Path(tempfile.gettempdir()) / f\"claude-agent-{agent_id}.out\"\n   208→\n   209→        # Start subprocess\n   210→        with open(output_file, 'w') as f:\n   211→            proc = subprocess.Popen(\n   212→                cmd,\n   213→                stdout=f,\n   214→                stderr=subprocess.STDOUT,\n   215→                cwd=str(Path.home())\n   216→            )\n   217→\n   218→        self._active_processes[agent_id] = proc\n   219→\n   220→        # Store output file path\n   221→        self.registry.heartbeat(agent_id, 0.1)\n   222→\n   223→        return agent_id\n   224→\n   225→    def spawn_parallel(self, configs: List[AgentConfig], task_id: str, max_workers: int = 5) -> List[str]:\n   226→        \"\"\"\n   227→        Spawn multiple agents in parallel.\n   228→\n   229→        Args:\n   230→            configs: List of agent configurations\n   231→            task_id: Parent coordination task ID\n   232→            max_workers: Maximum parallel agents\n   233→\n   234→        Returns:\n   235→            List of agent_ids\n   236→        \"\"\"\n   237→        agent_ids = []\n   238→\n   239→        with ThreadPoolExecutor(max_workers=max_workers) as executor:\n   240→            futures = {\n   241→                executor.submit(self.spawn_cli_agent, config, task_id): config\n   242→                for config in configs\n   243→            }\n   244→\n   245→            for future in as_completed(futures):\n   246→                try:\n   247→                    agent_id = future.result()\n   248→                    agent_ids.append(agent_id)\n   249→                except Exception as e:\n   250→                    print(f\"Agent spawn failed: {e}\", file=sys.stderr)\n   251→\n   252→        return agent_ids\n   253→\n   254→    def wait_for_agents(self, agent_ids: List[str], timeout: int = 600) -> Dict[str, AgentResult]:\n   255→        \"\"\"\n   256→        Wait for multiple agents to complete.\n   257→\n   258→        Args:\n   259→            agent_ids: List of agent IDs to wait for\n   260→            timeout: Maximum wait time in seconds\n   261→\n   262→        Returns:\n   263→            Dict mapping agent_id to AgentResult\n   264→        \"\"\"\n   265→        results = {}\n   266→        start_time = time.time()\n   267→\n   268→        while True:\n   269→            all_done = True\n   270→\n   271→            for agent_id in agent_ids:\n   272→                if agent_id in results:\n   273→                    continue\n   274→\n   275→                agent = self.registry.get(agent_id)\n   276→                if not agent:\n   277→                    results[agent_id] = AgentResult(\n   278→                        agent_id=agent_id,\n   279→                        success=False,\n   280→                        output=\"\",\n   281→                        error=\"Agent not found\"\n   282→                    )\n   283→                    continue\n   284→\n   285→                if agent.state in [\n   286→                    AgentState.COMPLETED.value,\n   287→                    AgentState.FAILED.value,\n   288→                    AgentState.TIMEOUT.value,\n   289→                    AgentState.CANCELLED.value\n   290→                ]:\n   291→                    results[agent_id] = AgentResult(\n   292→                        agent_id=agent_id,\n   293→                        success=agent.state == AgentState.COMPLETED.value,\n   294→                        output=agent.result.get(\"output\", \"\") if agent.result else \"\",\n   295→                        error=agent.error\n   296→                    )\n   297→                else:\n   298→                    all_done = False\n   299→\n   300→            if all_done:\n   301→                break\n   302→\n   303→            if time.time() - start_time > timeout:\n   304→                # Mark remaining as timed out\n   305→                for agent_id in agent_ids:\n   306→                    if agent_id not in results:\n   307→                        self.registry.timeout(agent_id)\n   308→                        results[agent_id] = AgentResult(\n   309→                            agent_id=agent_id,\n   310→                            success=False,\n   311→                            output=\"\",\n   312→                            error=\"Wait timeout exceeded\"\n   313→                        )\n   314→                break\n   315→\n   316→            time.sleep(1)  # Poll interval\n   317→\n   318→        return results\n   319→\n   320→    def cancel_agent(self, agent_id: str):\n   321→        \"\"\"Cancel a running agent.\"\"\"\n   322→        # Kill subprocess if tracked\n   323→        if agent_id in self._active_processes:\n   324→            proc = self._active_processes[agent_id]\n   325→            proc.terminate()\n   326→            try:\n   327→                proc.wait(timeout=5)\n   328→            except subprocess.TimeoutExpired:\n   329→                proc.kill()\n   330→            del self._active_processes[agent_id]\n   331→\n   332→        # Update registry\n   333→        self.registry.cancel(agent_id)\n   334→\n   335→        # Release locks\n   336→        self.conflict_mgr.release_agent(agent_id)\n   337→\n   338→    def cancel_task(self, task_id: str):\n   339→        \"\"\"Cancel all agents for a coordination task.\"\"\"\n   340→        agents = self.registry.get_task_agents(task_id)\n   341→        for agent in agents:\n   342→            if agent.state in [AgentState.PENDING.value, AgentState.RUNNING.value]:\n   343→                self.cancel_agent(agent.agent_id)\n   344→\n   345→    def get_agent_output(self, agent_id: str) -> Optional[str]:\n   346→        \"\"\"Get output from an async agent.\"\"\"\n   347→        output_file = Path(tempfile.gettempdir()) / f\"claude-agent-{agent_id}.out\"\n   348→        if output_file.exists():\n   349→            return output_file.read_text()\n   350→        return None\n   351→\n   352→\n   353→def generate_task_prompt(subtask: str, context: str = \"\", instructions: str = \"\") -> str:\n   354→    \"\"\"\n   355→    Generate a prompt for an agent task.\n   356→\n   357→    Args:\n   358→        subtask: The specific subtask to perform\n   359→        context: Additional context about the codebase\n   360→        instructions: Specific instructions for the agent\n   361→\n   362→    Returns:\n   363→        Formatted prompt string\n   364→    \"\"\"\n   365→    parts = [f\"## Task\\n{subtask}\"]\n   366→\n   367→    if context:\n   368→        parts.append(f\"\\n## Context\\n{context}\")\n   369→\n   370→    if instructions:\n   371→        parts.append(f\"\\n## Instructions\\n{instructions}\")\n   372→\n   373→    parts.append(\"\\n## Output\\nProvide a clear, structured response with your findings or changes.\")\n   374→\n   375→    return \"\\n\".join(parts)\n   376→\n   377→\n   378→# Task tool configuration generator (for use within Claude Code sessions)\n   379→def generate_task_tool_config(config: AgentConfig) -> Dict:\n   380→    \"\"\"\n   381→    Generate configuration for the Task tool.\n   382→\n   383→    This is used when calling the Task tool from within a Claude Code session.\n   384→\n   385→    Returns:\n   386→        Dict with Task tool parameters\n   387→    \"\"\"\n   388→    return {\n   389→        \"description\": config.subtask[:50],  # 3-5 word summary\n   390→        \"prompt\": config.prompt,\n   391→        \"subagent_type\": config.agent_type,\n   392→        \"model\": config.model,\n   393→        \"run_in_background\": config.run_in_background\n   394→    }\n   395→\n   396→\n   397→# CLI interface\n   398→if __name__ == \"__main__\":\n   399→    import argparse\n   400→\n   401→    parser = argparse.ArgumentParser(description=\"Agent Executor CLI\")\n   402→    parser.add_argument(\"action\", choices=[\"spawn\", \"cancel\", \"output\", \"list\"])\n   403→    parser.add_argument(\"--prompt\", \"-p\", help=\"Agent prompt\")\n   404→    parser.add_argument(\"--model\", \"-m\", default=\"sonnet\", choices=[\"haiku\", \"sonnet\", \"opus\"])\n   405→    parser.add_argument(\"--type\", \"-t\", default=\"general-purpose\", help=\"Agent type\")\n   406→    parser.add_argument(\"--task-id\", default=\"cli-task\", help=\"Parent task ID\")\n   407→    parser.add_argument(\"--agent-id\", help=\"Agent ID (for cancel/output)\")\n   408→    parser.add_argument(\"--timeout\", type=int, default=300, help=\"Timeout in seconds\")\n   409→\n   410→    args = parser.parse_args()\n   411→\n   412→    executor = AgentExecutor()\n   413→\n   414→    if args.action == \"spawn\":\n   415→        if not args.prompt:\n   416→            print(\"Error: --prompt required\", file=sys.stderr)\n   417→            sys.exit(1)\n   418→\n   419→        config = AgentConfig(\n   420→            subtask=args.prompt[:50],\n   421→            prompt=args.prompt,\n   422→            agent_type=args.type,\n   423→            model=args.model,\n   424→            timeout=args.timeout\n   425→        )\n   426→\n   427→        agent_id = executor.spawn_cli_agent(config, args.task_id)\n   428→        print(f\"Spawned agent: {agent_id}\")\n   429→\n   430→    elif args.action == \"cancel\":\n   431→        if not args.agent_id:\n   432→            print(\"Error: --agent-id required\", file=sys.stderr)\n   433→            sys.exit(1)\n   434→\n   435→        executor.cancel_agent(args.agent_id)\n   436→        print(f\"Cancelled agent: {args.agent_id}\")\n   437→\n   438→    elif args.action == \"output\":\n   439→        if not args.agent_id:\n   440→            print(\"Error: --agent-id required\", file=sys.stderr)\n   441→            sys.exit(1)\n   442→\n   443→        output = executor.get_agent_output(args.agent_id)\n   444→        if output:\n   445→            print(output)\n   446→        else:\n   447→            print(\"No output available\")\n   448→\n   449→    elif args.action == \"list\":\n   450→        registry = AgentRegistry()\n   451→        agents = registry.get_active()\n   452→        if agents:\n   453→            for a in agents:\n   454→                print(f\"{a.agent_id}: {a.subtask} [{a.state}] ({a.model})\")\n   455→        else:\n   456→            print(\"No active agents\")\n   457→"}]},"parent_tool_use_id":null,"session_id":"1c891cc5-27f8-4bc6-8060-c18a8fb0442f","uuid":"e7c4ee8f-3528-4c11-af8b-9da15ea3feef","tool_use_result":{"type":"text","file":{"filePath":"/Users/dicoangelo/projects/core/meta-vengine/coordinator/executor.py","content":"#!/usr/bin/env python3\n\"\"\"\nAgent Executor - Spawns and manages Claude agents.\n\nSupports two execution methods:\n1. Task tool (in-session subagents) - shares context, native integration\n2. CLI subprocess (isolated) - separate process, independent context\n\"\"\"\n\nimport os\nimport sys\nimport json\nimport subprocess\nimport tempfile\nimport time\nimport asyncio\nfrom pathlib import Path\nfrom datetime import datetime\nfrom typing import Dict, List, Optional, Callable, Any\nfrom dataclasses import dataclass\nfrom concurrent.futures import ThreadPoolExecutor, as_completed\n\nfrom registry import AgentRegistry, AgentState\nfrom conflict import ConflictManager, LockType\n\n\n@dataclass\nclass AgentConfig:\n    \"\"\"Configuration for an agent to spawn.\"\"\"\n    subtask: str\n    prompt: str\n    agent_type: str  # explore, general-purpose, Bash, Plan\n    model: str = \"sonnet\"  # haiku, sonnet, opus\n    timeout: int = 300  # seconds\n    run_in_background: bool = True\n    files_to_lock: List[str] = None\n    lock_type: str = \"read\"\n    dq_score: float = 0.5\n    cost_estimate: float = 0.0\n\n    def __post_init__(self):\n        if self.files_to_lock is None:\n            self.files_to_lock = []\n\n\n@dataclass\nclass AgentResult:\n    \"\"\"Result from an agent execution.\"\"\"\n    agent_id: str\n    success: bool\n    output: str\n    error: Optional[str] = None\n    duration_seconds: float = 0.0\n    files_modified: List[str] = None\n\n    def __post_init__(self):\n        if self.files_modified is None:\n            self.files_modified = []\n\n\nclass AgentExecutor:\n    \"\"\"\n    Executes agents via CLI subprocess.\n\n    Note: The Task tool is used natively within Claude Code sessions.\n    This executor is for programmatic spawning from Python scripts.\n    \"\"\"\n\n    # Model mapping\n    MODEL_MAP = {\n        \"haiku\": \"claude-3-5-haiku-latest\",\n        \"sonnet\": \"claude-sonnet-4-6\",\n        \"opus\": \"claude-opus-4-6\"\n    }\n\n    # Default timeouts by model\n    DEFAULT_TIMEOUTS = {\n        \"haiku\": 120,\n        \"sonnet\": 300,\n        \"opus\": 600\n    }\n\n    def __init__(self, registry: AgentRegistry = None, conflict_mgr: ConflictManager = None):\n        self.registry = registry or AgentRegistry()\n        self.conflict_mgr = conflict_mgr or ConflictManager()\n        self._active_processes: Dict[str, subprocess.Popen] = {}\n\n    def spawn_cli_agent(self, config: AgentConfig, task_id: str) -> str:\n        \"\"\"\n        Spawn an agent using Claude CLI.\n\n        Args:\n            config: Agent configuration\n            task_id: Parent coordination task ID\n\n        Returns:\n            agent_id of the spawned agent\n        \"\"\"\n        # Register agent\n        agent_id = self.registry.register(\n            task_id=task_id,\n            subtask=config.subtask,\n            agent_type=config.agent_type,\n            model=config.model,\n            files_to_lock=config.files_to_lock,\n            dq_score=config.dq_score,\n            cost_estimate=config.cost_estimate\n        )\n\n        # Acquire file locks\n        if config.files_to_lock:\n            success, failed = self.conflict_mgr.acquire_batch(\n                config.files_to_lock,\n                agent_id,\n                config.lock_type\n            )\n            if not success:\n                self.registry.fail(agent_id, f\"Could not acquire locks: {failed}\")\n                return agent_id\n\n        # Build command\n        model = self.MODEL_MAP.get(config.model, config.model)\n        timeout = config.timeout or self.DEFAULT_TIMEOUTS.get(config.model, 300)\n\n        cmd = [\n            \"claude\",\n            \"--model\", model,\n            \"--max-turns\", \"50\",\n            \"-p\", config.prompt\n        ]\n\n        # Mark as started\n        self.registry.start(agent_id)\n\n        try:\n            # Run subprocess\n            result = subprocess.run(\n                cmd,\n                capture_output=True,\n                text=True,\n                timeout=timeout,\n                cwd=str(Path.home())\n            )\n\n            if result.returncode == 0:\n                self.registry.complete(agent_id, {\n                    \"output\": result.stdout,\n                    \"stderr\": result.stderr\n                })\n            else:\n                self.registry.fail(agent_id, result.stderr or \"Non-zero exit code\")\n\n        except subprocess.TimeoutExpired:\n            self.registry.timeout(agent_id)\n\n        except Exception as e:\n            self.registry.fail(agent_id, str(e))\n\n        finally:\n            # Release locks\n            self.conflict_mgr.release_agent(agent_id)\n\n        return agent_id\n\n    def spawn_cli_agent_async(self, config: AgentConfig, task_id: str) -> str:\n        \"\"\"\n        Spawn an agent asynchronously (non-blocking).\n\n        Returns agent_id immediately, runs in background.\n        \"\"\"\n        # Register agent\n        agent_id = self.registry.register(\n            task_id=task_id,\n            subtask=config.subtask,\n            agent_type=config.agent_type,\n            model=config.model,\n            files_to_lock=config.files_to_lock,\n            dq_score=config.dq_score,\n            cost_estimate=config.cost_estimate\n        )\n\n        # Acquire file locks\n        if config.files_to_lock:\n            success, failed = self.conflict_mgr.acquire_batch(\n                config.files_to_lock,\n                agent_id,\n                config.lock_type\n            )\n            if not success:\n                self.registry.fail(agent_id, f\"Could not acquire locks: {failed}\")\n                return agent_id\n\n        # Build command\n        model = self.MODEL_MAP.get(config.model, config.model)\n\n        cmd = [\n            \"claude\",\n            \"--model\", model,\n            \"--max-turns\", \"50\",\n            \"-p\", config.prompt\n        ]\n\n        # Mark as started\n        self.registry.start(agent_id)\n\n        # Create output file for capturing\n        output_file = Path(tempfile.gettempdir()) / f\"claude-agent-{agent_id}.out\"\n\n        # Start subprocess\n        with open(output_file, 'w') as f:\n            proc = subprocess.Popen(\n                cmd,\n                stdout=f,\n                stderr=subprocess.STDOUT,\n                cwd=str(Path.home())\n            )\n\n        self._active_processes[agent_id] = proc\n\n        # Store output file path\n        self.registry.heartbeat(agent_id, 0.1)\n\n        return agent_id\n\n    def spawn_parallel(self, configs: List[AgentConfig], task_id: str, max_workers: int = 5) -> List[str]:\n        \"\"\"\n        Spawn multiple agents in parallel.\n\n        Args:\n            configs: List of agent configurations\n            task_id: Parent coordination task ID\n            max_workers: Maximum parallel agents\n\n        Returns:\n            List of agent_ids\n        \"\"\"\n        agent_ids = []\n\n        with ThreadPoolExecutor(max_workers=max_workers) as executor:\n            futures = {\n                executor.submit(self.spawn_cli_agent, config, task_id): config\n                for config in configs\n            }\n\n            for future in as_completed(futures):\n                try:\n                    agent_id = future.result()\n                    agent_ids.append(agent_id)\n                except Exception as e:\n                    print(f\"Agent spawn failed: {e}\", file=sys.stderr)\n\n        return agent_ids\n\n    def wait_for_agents(self, agent_ids: List[str], timeout: int = 600) -> Dict[str, AgentResult]:\n        \"\"\"\n        Wait for multiple agents to complete.\n\n        Args:\n            agent_ids: List of agent IDs to wait for\n            timeout: Maximum wait time in seconds\n\n        Returns:\n            Dict mapping agent_id to AgentResult\n        \"\"\"\n        results = {}\n        start_time = time.time()\n\n        while True:\n            all_done = True\n\n            for agent_id in agent_ids:\n                if agent_id in results:\n                    continue\n\n                agent = self.registry.get(agent_id)\n                if not agent:\n                    results[agent_id] = AgentResult(\n                        agent_id=agent_id,\n                        success=False,\n                        output=\"\",\n                        error=\"Agent not found\"\n                    )\n                    continue\n\n                if agent.state in [\n                    AgentState.COMPLETED.value,\n                    AgentState.FAILED.value,\n                    AgentState.TIMEOUT.value,\n                    AgentState.CANCELLED.value\n                ]:\n                    results[agent_id] = AgentResult(\n                        agent_id=agent_id,\n                        success=agent.state == AgentState.COMPLETED.value,\n                        output=agent.result.get(\"output\", \"\") if agent.result else \"\",\n                        error=agent.error\n                    )\n                else:\n                    all_done = False\n\n            if all_done:\n                break\n\n            if time.time() - start_time > timeout:\n                # Mark remaining as timed out\n                for agent_id in agent_ids:\n                    if agent_id not in results:\n                        self.registry.timeout(agent_id)\n                        results[agent_id] = AgentResult(\n                            agent_id=agent_id,\n                            success=False,\n                            output=\"\",\n                            error=\"Wait timeout exceeded\"\n                        )\n                break\n\n            time.sleep(1)  # Poll interval\n\n        return results\n\n    def cancel_agent(self, agent_id: str):\n        \"\"\"Cancel a running agent.\"\"\"\n        # Kill subprocess if tracked\n        if agent_id in self._active_processes:\n            proc = self._active_processes[agent_id]\n            proc.terminate()\n            try:\n                proc.wait(timeout=5)\n            except subprocess.TimeoutExpired:\n                proc.kill()\n            del self._active_processes[agent_id]\n\n        # Update registry\n        self.registry.cancel(agent_id)\n\n        # Release locks\n        self.conflict_mgr.release_agent(agent_id)\n\n    def cancel_task(self, task_id: str):\n        \"\"\"Cancel all agents for a coordination task.\"\"\"\n        agents = self.registry.get_task_agents(task_id)\n        for agent in agents:\n            if agent.state in [AgentState.PENDING.value, AgentState.RUNNING.value]:\n                self.cancel_agent(agent.agent_id)\n\n    def get_agent_output(self, agent_id: str) -> Optional[str]:\n        \"\"\"Get output from an async agent.\"\"\"\n        output_file = Path(tempfile.gettempdir()) / f\"claude-agent-{agent_id}.out\"\n        if output_file.exists():\n            return output_file.read_text()\n        return None\n\n\ndef generate_task_prompt(subtask: str, context: str = \"\", instructions: str = \"\") -> str:\n    \"\"\"\n    Generate a prompt for an agent task.\n\n    Args:\n        subtask: The specific subtask to perform\n        context: Additional context about the codebase\n        instructions: Specific instructions for the agent\n\n    Returns:\n        Formatted prompt string\n    \"\"\"\n    parts = [f\"## Task\\n{subtask}\"]\n\n    if context:\n        parts.append(f\"\\n## Context\\n{context}\")\n\n    if instructions:\n        parts.append(f\"\\n## Instructions\\n{instructions}\")\n\n    parts.append(\"\\n## Output\\nProvide a clear, structured response with your findings or changes.\")\n\n    return \"\\n\".join(parts)\n\n\n# Task tool configuration generator (for use within Claude Code sessions)\ndef generate_task_tool_config(config: AgentConfig) -> Dict:\n    \"\"\"\n    Generate configuration for the Task tool.\n\n    This is used when calling the Task tool from within a Claude Code session.\n\n    Returns:\n        Dict with Task tool parameters\n    \"\"\"\n    return {\n        \"description\": config.subtask[:50],  # 3-5 word summary\n        \"prompt\": config.prompt,\n        \"subagent_type\": config.agent_type,\n        \"model\": config.model,\n        \"run_in_background\": config.run_in_background\n    }\n\n\n# CLI interface\nif __name__ == \"__main__\":\n    import argparse\n\n    parser = argparse.ArgumentParser(description=\"Agent Executor CLI\")\n    parser.add_argument(\"action\", choices=[\"spawn\", \"cancel\", \"output\", \"list\"])\n    parser.add_argument(\"--prompt\", \"-p\", help=\"Agent prompt\")\n    parser.add_argument(\"--model\", \"-m\", default=\"sonnet\", choices=[\"haiku\", \"sonnet\", \"opus\"])\n    parser.add_argument(\"--type\", \"-t\", default=\"general-purpose\", help=\"Agent type\")\n    parser.add_argument(\"--task-id\", default=\"cli-task\", help=\"Parent task ID\")\n    parser.add_argument(\"--agent-id\", help=\"Agent ID (for cancel/output)\")\n    parser.add_argument(\"--timeout\", type=int, default=300, help=\"Timeout in seconds\")\n\n    args = parser.parse_args()\n\n    executor = AgentExecutor()\n\n    if args.action == \"spawn\":\n        if not args.prompt:\n            print(\"Error: --prompt required\", file=sys.stderr)\n            sys.exit(1)\n\n        config = AgentConfig(\n            subtask=args.prompt[:50],\n            prompt=args.prompt,\n            agent_type=args.type,\n            model=args.model,\n            timeout=args.timeout\n        )\n\n        agent_id = executor.spawn_cli_agent(config, args.task_id)\n        print(f\"Spawned agent: {agent_id}\")\n\n    elif args.action == \"cancel\":\n        if not args.agent_id:\n            print(\"Error: --agent-id required\", file=sys.stderr)\n            sys.exit(1)\n\n        executor.cancel_agent(args.agent_id)\n        print(f\"Cancelled agent: {args.agent_id}\")\n\n    elif args.action == \"output\":\n        if not args.agent_id:\n            print(\"Error: --agent-id required\", file=sys.stderr)\n            sys.exit(1)\n\n        output = executor.get_agent_output(args.agent_id)\n        if output:\n            print(output)\n        else:\n            print(\"No output available\")\n\n    elif args.action == \"list\":\n        registry = AgentRegistry()\n        agents = registry.get_active()\n        if agents:\n            for a in agents:\n                print(f\"{a.agent_id}: {a.subtask} [{a.state}] ({a.model})\")\n        else:\n            print(\"No active agents\")\n","numLines":457,"startLine":1,"totalLines":457}}}
