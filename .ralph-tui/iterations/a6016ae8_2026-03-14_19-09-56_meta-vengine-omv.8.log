{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_019y97y2MNjRqpmxdzQgduBo","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01NemqrEZTARy31TVjkjaBR1","name":"Write","input":{"file_path":"/Users/dicoangelo/projects/core/meta-vengine/coordinator/tests/test_free_mad.py","content":"#!/usr/bin/env python3\n\"\"\"\nTests for US-008: SUPERMAX v2 — Free-MAD Trajectory Scoring.\n\nTests cover:\n  - DQEvaluation creation and composite scoring\n  - Anonymization of peer reasoning (anti-sycophancy)\n  - Stability score computation (exponential decay)\n  - Trajectory weight normalization\n  - Sycophancy detection (unanimous convergence)\n  - Disagreement dimension detection\n  - Weighted consensus computation\n  - FreeMadSynthesizer end-to-end\n  - Trajectory logging to JSONL\n  - Integration: stable agent gets higher weight than capitulating agent\n  - SupermaxV2 orchestrator integration\n\"\"\"\n\nimport json\nimport math\nimport sys\nimport tempfile\nimport os\nfrom pathlib import Path\n\n# Allow imports from coordinator/\nsys.path.insert(0, str(Path(__file__).resolve().parent.parent.parent))\n\nfrom coordinator.synthesizer import (\n    DQEvaluation,\n    AgentTrajectory,\n    SynthesisResult,\n    FreeMadSynthesizer,\n    anonymize_reasoning,\n    compute_stability_score,\n    compute_trajectory_weights,\n    detect_sycophancy,\n    find_disagreement_dimensions,\n    synthesize_consensus,\n    log_trajectory,\n    load_free_mad_config,\n)\nfrom coordinator.supermax import PredictiveSpawner, SupermaxV2\n\n\npassed = 0\nfailed = 0\n\n\ndef assert_true(condition, msg):\n    global passed, failed\n    if condition:\n        passed += 1\n    else:\n        failed += 1\n        print(f\"  FAIL: {msg}\")\n\n\ndef assert_close(actual, expected, msg, tol=0.01):\n    global passed, failed\n    if abs(actual - expected) <= tol:\n        passed += 1\n    else:\n        failed += 1\n        print(f\"  FAIL: {msg} — expected {expected}, got {actual}\")\n\n\n# ─── DQEvaluation ───────────────────────────────────────────────────────────\n\nprint(\"=== DQEvaluation ===\")\n\nev = DQEvaluation(\"TestAgent\", 0.8, 0.7, 0.9, \"Some reasoning\")\nassert_close(ev.composite_dq, 0.8 * 0.4 + 0.7 * 0.3 + 0.9 * 0.3, \"composite DQ formula\")\nassert_true(ev.agent_name == \"TestAgent\", \"agent name preserved\")\nassert_true(ev.reasoning == \"Some reasoning\", \"reasoning preserved\")\n\ndims = ev.dimensions()\nassert_close(dims[\"validity\"], 0.8, \"dimensions dict validity\")\nassert_close(dims[\"specificity\"], 0.7, \"dimensions dict specificity\")\nassert_close(dims[\"correctness\"], 0.9, \"dimensions dict correctness\")\n\n# Perfect scores\nev_perfect = DQEvaluation(\"Perfect\", 1.0, 1.0, 1.0)\nassert_close(ev_perfect.composite_dq, 1.0, \"perfect composite = 1.0\")\n\n# Zero scores\nev_zero = DQEvaluation(\"Zero\", 0.0, 0.0, 0.0)\nassert_close(ev_zero.composite_dq, 0.0, \"zero composite = 0.0\")\n\n\n# ─── Anonymize Reasoning ────────────────────────────────────────────────────\n\nprint(\"\\n=== Anonymize Reasoning ===\")\n\nevals = [\n    DQEvaluation(\"PrincipalEngineer\", 0.8, 0.7, 0.9, \"Tech analysis\"),\n    DQEvaluation(\"SecurityArchitect\", 0.6, 0.8, 0.7, \"Risk assessment\"),\n    DQEvaluation(\"ProductStrategist\", 0.9, 0.6, 0.8, \"User value check\"),\n]\n\nanon = anonymize_reasoning(evals)\nassert_true(len(anon) == 3, \"3 anonymized entries\")\nassert_true(anon[0][\"evaluator\"] == \"Evaluator A\", \"first evaluator is A\")\nassert_true(anon[1][\"evaluator\"] == \"Evaluator B\", \"second evaluator is B\")\nassert_true(anon[2][\"evaluator\"] == \"Evaluator C\", \"third evaluator is C\")\n\n# Verify agent names are NOT in anonymized output\nfor entry in anon:\n    text = json.dumps(entry)\n    assert_true(\"PrincipalEngineer\" not in text, f\"no agent name in {entry['evaluator']}\")\n    assert_true(\"SecurityArchitect\" not in text, f\"no agent name in {entry['evaluator']}\")\n    assert_true(\"ProductStrategist\" not in text, f\"no agent name in {entry['evaluator']}\")\n\n# Verify scores are preserved\nassert_close(anon[0][\"scores\"][\"validity\"], 0.8, \"anon scores preserved\")\nassert_true(anon[0][\"reasoning\"] == \"Tech analysis\", \"anon reasoning preserved\")\n\n\n# ─── Stability Score ────────────────────────────────────────────────────────\n\nprint(\"\\n=== Stability Score ===\")\n\n# Perfectly stable agent (delta = 0)\nt_stable = AgentTrajectory(\n    \"Stable\",\n    DQEvaluation(\"Stable\", 0.8, 0.7, 0.9),\n    DQEvaluation(\"Stable\", 0.8, 0.7, 0.9),\n)\nassert_close(compute_stability_score(t_stable), 1.0, \"zero delta → stability 1.0\")\n\n# Completely unstable agent (large delta)\nt_unstable = AgentTrajectory(\n    \"Unstable\",\n    DQEvaluation(\"Unstable\", 0.2, 0.3, 0.1),\n    DQEvaluation(\"Unstable\", 0.9, 0.8, 0.9),\n)\nstability_unstable = compute_stability_score(t_unstable)\nassert_true(stability_unstable < 0.1, f\"large delta → low stability ({stability_unstable:.4f})\")\n\n# Moderate delta\nt_moderate = AgentTrajectory(\n    \"Moderate\",\n    DQEvaluation(\"Moderate\", 0.7, 0.6, 0.8),\n    DQEvaluation(\"Moderate\", 0.75, 0.65, 0.85),\n)\nstability_mod = compute_stability_score(t_moderate)\nassert_true(0.3 < stability_mod < 0.9, f\"moderate delta → mid stability ({stability_mod:.4f})\")\n\n# Verify exponential decay formula\ndelta = 0.1\nexpected = math.exp(-5.0 * delta)\nt_known = AgentTrajectory(\n    \"Known\",\n    DQEvaluation(\"Known\", 0.5, 0.5, 0.5),\n    DQEvaluation(\"Known\", 0.6, 0.5, 0.5),  # delta_validity = 0.1\n)\nassert_close(compute_stability_score(t_known), expected, \"exp decay formula matches\")\n\n# Custom decay rate\nassert_close(\n    compute_stability_score(t_known, decay_rate=10.0),\n    math.exp(-10.0 * 0.1),\n    \"custom decay rate\"\n)\n\n\n# ─── Trajectory Weights ────────────────────────────────────────────────────\n\nprint(\"\\n=== Trajectory Weights ===\")\n\ntrajectories = [t_stable, t_unstable, t_moderate]\nweighted = compute_trajectory_weights(trajectories)\n\n# Stable agent should get highest weight\nassert_true(\n    t_stable.trajectory_weight > t_unstable.trajectory_weight,\n    \"stable agent gets higher weight than unstable\"\n)\n\n# Weights sum to 1.0\ntotal_weight = sum(t.trajectory_weight for t in weighted)\nassert_close(total_weight, 1.0, \"weights sum to 1.0\")\n\n# All weights > 0 (min weight guarantee)\nfor t in weighted:\n    assert_true(t.trajectory_weight > 0, f\"{t.agent_name} weight > 0\")\n\n# Uniform case: all equally stable\nequal_trajs = [\n    AgentTrajectory(\"A\", DQEvaluation(\"A\", 0.5, 0.5, 0.5), DQEvaluation(\"A\", 0.5, 0.5, 0.5)),\n    AgentTrajectory(\"B\", DQEvaluation(\"B\", 0.5, 0.5, 0.5), DQEvaluation(\"B\", 0.5, 0.5, 0.5)),\n    AgentTrajectory(\"C\", DQEvaluation(\"C\", 0.5, 0.5, 0.5), DQEvaluation(\"C\", 0.5, 0.5, 0.5)),\n]\ncompute_trajectory_weights(equal_trajs)\nfor t in equal_trajs:\n    assert_close(t.trajectory_weight, 1.0 / 3, f\"equal stability → uniform weight ({t.agent_name})\")\n\n\n# ─── Sycophancy Detection ──────────────────────────────────────────────────\n\nprint(\"\\n=== Sycophancy Detection ===\")\n\n# Sycophancy case: all agents converge to same score after initially disagreeing\nsyc_trajs = [\n    AgentTrajectory(\n        \"A\",\n        DQEvaluation(\"A\", 0.9, 0.9, 0.9),  # R1: high\n        DQEvaluation(\"A\", 0.7, 0.7, 0.7),  # R2: converged to 0.7\n    ),\n    AgentTrajectory(\n        \"B\",\n        DQEvaluation(\"B\", 0.5, 0.5, 0.5),  # R1: low\n        DQEvaluation(\"B\", 0.7, 0.7, 0.7),  # R2: converged to 0.7\n    ),\n    AgentTrajectory(\n        \"C\",\n        DQEvaluation(\"C\", 0.7, 0.7, 0.7),  # R1: medium\n        DQEvaluation(\"C\", 0.71, 0.71, 0.71),  # R2: converged to ~0.7\n    ),\n]\nassert_true(detect_sycophancy(syc_trajs, 0.05), \"unanimous convergence → sycophancy flagged\")\n\n# Non-sycophancy: agents hold positions\nnon_syc_trajs = [\n    AgentTrajectory(\n        \"A\",\n        DQEvaluation(\"A\", 0.9, 0.9, 0.9),\n        DQEvaluation(\"A\", 0.9, 0.9, 0.9),  # Held position (delta = 0)\n    ),\n    AgentTrajectory(\n        \"B\",\n        DQEvaluation(\"B\", 0.5, 0.5, 0.5),\n        DQEvaluation(\"B\", 0.55, 0.55, 0.55),  # Minor shift\n    ),\n]\nassert_true(not detect_sycophancy(non_syc_trajs, 0.05), \"one agent held → no sycophancy\")\n\n# Single agent: cannot have sycophancy\nsingle = [AgentTrajectory(\"A\", DQEvaluation(\"A\", 0.5, 0.5, 0.5), DQEvaluation(\"A\", 0.7, 0.7, 0.7))]\nassert_true(not detect_sycophancy(single), \"single agent → no sycophancy\")\n\n# No initial disagreement: all start and end similar\nno_disagree = [\n    AgentTrajectory(\"A\", DQEvaluation(\"A\", 0.7, 0.7, 0.7), DQEvaluation(\"A\", 0.71, 0.71, 0.71)),\n    AgentTrajectory(\"B\", DQEvaluation(\"B\", 0.7, 0.7, 0.7), DQEvaluation(\"B\", 0.72, 0.72, 0.72)),\n]\nassert_true(not detect_sycophancy(no_disagree, 0.05), \"no initial disagreement → no sycophancy\")\n\n\n# ─── Disagreement Dimensions ───────────────────────────────────────────────\n\nprint(\"\\n=== Disagreement Dimensions ===\")\n\n# Validity diverges, others agree\ndiv_trajs = [\n    AgentTrajectory(\n        \"A\",\n        DQEvaluation(\"A\", 0.9, 0.7, 0.8),\n        DQEvaluation(\"A\", 0.9, 0.7, 0.8),\n    ),\n    AgentTrajectory(\n        \"B\",\n        DQEvaluation(\"B\", 0.5, 0.7, 0.8),\n        DQEvaluation(\"B\", 0.5, 0.7, 0.8),\n    ),\n]\ndims = find_disagreement_dimensions(div_trajs, 0.15)\nassert_true(\"validity\" in dims, \"validity diverges → in disagreement dims\")\nassert_true(\"specificity\" not in dims, \"specificity agrees → not in disagreement dims\")\nassert_true(\"correctness\" not in dims, \"correctness agrees → not in disagreement dims\")\n\n# All agree within threshold\nagree_trajs = [\n    AgentTrajectory(\"A\", DQEvaluation(\"A\", 0.7, 0.7, 0.7), DQEvaluation(\"A\", 0.7, 0.7, 0.7)),\n    AgentTrajectory(\"B\", DQEvaluation(\"B\", 0.75, 0.72, 0.73), DQEvaluation(\"B\", 0.75, 0.72, 0.73)),\n]\ndims_none = find_disagreement_dimensions(agree_trajs, 0.15)\nassert_true(len(dims_none) == 0, \"all agree → no disagreement dimensions\")\n\n# Multiple divergent dimensions\nmulti_div = [\n    AgentTrajectory(\"A\", DQEvaluation(\"A\", 0.9, 0.9, 0.9), DQEvaluation(\"A\", 0.9, 0.9, 0.9)),\n    AgentTrajectory(\"B\", DQEvaluation(\"B\", 0.5, 0.5, 0.5), DQEvaluation(\"B\", 0.5, 0.5, 0.5)),\n]\ndims_multi = find_disagreement_dimensions(multi_div, 0.15)\nassert_true(len(dims_multi) == 3, \"all dimensions diverge → 3 disagreement dims\")\n\n\n# ─── Consensus Computation ──────────────────────────────────────────────────\n\nprint(\"\\n=== Consensus Computation ===\")\n\n# Equal weights → simple average\neq_trajs = [\n    AgentTrajectory(\"A\", DQEvaluation(\"A\", 0.8, 0.6, 0.7), DQEvaluation(\"A\", 0.8, 0.6, 0.7)),\n    AgentTrajectory(\"B\", DQEvaluation(\"B\", 0.6, 0.8, 0.9), DQEvaluation(\"B\", 0.6, 0.8, 0.9)),\n]\neq_trajs[0].trajectory_weight = 0.5\neq_trajs[1].trajectory_weight = 0.5\nconsensus = synthesize_consensus(eq_trajs)\nassert_close(consensus[\"validity\"], 0.7, \"equal weight consensus validity\")\nassert_close(consensus[\"specificity\"], 0.7, \"equal weight consensus specificity\")\nassert_close(consensus[\"correctness\"], 0.8, \"equal weight consensus correctness\")\n\n# Skewed weights → weighted toward dominant\nsk_trajs = [\n    AgentTrajectory(\"A\", DQEvaluation(\"A\", 1.0, 1.0, 1.0), DQEvaluation(\"A\", 1.0, 1.0, 1.0)),\n    AgentTrajectory(\"B\", DQEvaluation(\"B\", 0.0, 0.0, 0.0), DQEvaluation(\"B\", 0.0, 0.0, 0.0)),\n]\nsk_trajs[0].trajectory_weight = 0.9\nsk_trajs[1].trajectory_weight = 0.1\nconsensus_sk = synthesize_consensus(sk_trajs)\nassert_close(consensus_sk[\"validity\"], 0.9, \"skewed weight → dominant agent\")\nassert_close(consensus_sk[\"composite_dq\"], 0.9, \"skewed composite\")\n\n\n# ─── FreeMadSynthesizer End-to-End ──────────────────────────────────────────\n\nprint(\"\\n=== FreeMadSynthesizer E2E ===\")\n\nsynth = FreeMadSynthesizer()\n\n# Standard case: 3 agents, varying stability\nr1 = [\n    DQEvaluation(\"PrincipalEngineer\", 0.8, 0.7, 0.9, \"Tech solid\"),\n    DQEvaluation(\"SecurityArchitect\", 0.6, 0.8, 0.7, \"Risky\"),\n    DQEvaluation(\"ProductStrategist\", 0.9, 0.6, 0.8, \"User value\"),\n]\nr2 = [\n    DQEvaluation(\"PrincipalEngineer\", 0.8, 0.72, 0.88, \"Held position\"),\n    DQEvaluation(\"SecurityArchitect\", 0.78, 0.75, 0.82, \"Shifted a lot\"),\n    DQEvaluation(\"ProductStrategist\", 0.85, 0.65, 0.8, \"Minor shift\"),\n]\n\nresult = synth.synthesize(r1, r2)\nassert_true(isinstance(result, SynthesisResult), \"returns SynthesisResult\")\nassert_true(0.0 <= result.consensus_dq <= 1.0, \"consensus DQ in range\")\nassert_true(len(result.trajectories) == 3, \"3 trajectories\")\nassert_true(result.method == \"free_mad_trajectory\", \"method is free_mad_trajectory\")\nassert_true(not result.sycophancy_flagged, \"no sycophancy in standard case\")\n\n# Verify stable agent (Engineer) gets higher weight than unstable (Architect)\neng_traj = result.trajectories[0]\narch_traj = result.trajectories[1]\nassert_true(\n    eng_traj.trajectory_weight > arch_traj.trajectory_weight,\n    \"Engineer (stable) > Architect (shifted)\"\n)\n\n# Mismatched round counts → error\ntry:\n    synth.synthesize(r1[:2], r2)\n    assert_true(False, \"should raise on mismatched counts\")\nexcept ValueError:\n    assert_true(True, \"raises ValueError on mismatched counts\")\n\n# Mismatched agent names → error\nr2_wrong = [\n    DQEvaluation(\"Wrong\", 0.8, 0.7, 0.9),\n    DQEvaluation(\"SecurityArchitect\", 0.6, 0.8, 0.7),\n    DQEvaluation(\"ProductStrategist\", 0.9, 0.6, 0.8),\n]\ntry:\n    synth.synthesize(r1, r2_wrong)\n    assert_true(False, \"should raise on mismatched agent names\")\nexcept ValueError:\n    assert_true(True, \"raises ValueError on mismatched names\")\n\n\n# ─── Peer Context Preparation ──────────────────────────────────────────────\n\nprint(\"\\n=== Peer Context ===\")\n\npeer_ctx = synth.prepare_peer_context(r1)\nassert_true(len(peer_ctx) == 3, \"3 peer context entries\")\nassert_true(all(\"evaluator\" in p for p in peer_ctx), \"all have evaluator label\")\n\n# No agent names leaked\nall_text = json.dumps(peer_ctx)\nassert_true(\"PrincipalEngineer\" not in all_text, \"no Engineer name in peer context\")\nassert_true(\"SecurityArchitect\" not in all_text, \"no Architect name in peer context\")\n\n\n# ─── Trajectory Logging ────────────────────────────────────────────────────\n\nprint(\"\\n=== Trajectory Logging ===\")\n\nwith tempfile.TemporaryDirectory() as tmpdir:\n    tmp_path = Path(tmpdir)\n    log_trajectory(\"abc123\", result, log_dir=tmp_path)\n\n    log_file = tmp_path / \"supermax-trajectories.jsonl\"\n    assert_true(log_file.exists(), \"trajectory log file created\")\n\n    with open(log_file) as f:\n        entry = json.loads(f.readline())\n\n    assert_true(entry[\"query_hash\"] == \"abc123\", \"query hash logged\")\n    assert_true(entry[\"method\"] == \"free_mad_trajectory\", \"method logged\")\n    assert_true(len(entry[\"trajectories\"]) == 3, \"3 trajectory entries logged\")\n    assert_true(\"sycophancy_flagged\" in entry, \"sycophancy flag logged\")\n    assert_true(\"disagreement_dimensions\" in entry, \"disagreement dims logged\")\n    assert_true(\"ts\" in entry, \"timestamp logged\")\n\n    # Verify trajectory detail structure\n    t0 = entry[\"trajectories\"][0]\n    assert_true(\"agent\" in t0, \"agent name in trajectory\")\n    assert_true(\"round1_dq\" in t0, \"round1_dq in trajectory\")\n    assert_true(\"round2_dq\" in t0, \"round2_dq in trajectory\")\n    assert_true(\"stability_score\" in t0, \"stability_score in trajectory\")\n    assert_true(\"trajectory_weight\" in t0, \"trajectory_weight in trajectory\")\n    assert_true(\"delta_validity\" in t0, \"delta_validity in trajectory\")\n\n    # Append-only: log again, verify 2 lines\n    log_trajectory(\"def456\", result, log_dir=tmp_path)\n    with open(log_file) as f:\n        lines = f.readlines()\n    assert_true(len(lines) == 2, \"append-only: 2 entries after 2 logs\")\n\n\n# ─── Integration: Stable Agent Beats Capitulating Agent ─────────────────────\n\nprint(\"\\n=== Integration: Stability Wins ===\")\n\n# Scenario: Engineer holds firm, Architect completely capitulates to peer pressure\nr1_int = [\n    DQEvaluation(\"PrincipalEngineer\", 0.85, 0.80, 0.90, \"This is technically correct\"),\n    DQEvaluation(\"SecurityArchitect\", 0.50, 0.60, 0.40, \"I see security risks\"),\n]\n# After peer exposure:\n# Engineer barely moves (confident in analysis)\n# Architect completely reverses position (sycophancy to Engineer)\nr2_int = [\n    DQEvaluation(\"PrincipalEngineer\", 0.84, 0.79, 0.91, \"Still correct after review\"),\n    DQEvaluation(\"SecurityArchitect\", 0.83, 0.78, 0.88, \"Actually, Engineer is right\"),\n]\n\nresult_int = synth.synthesize(r1_int, r2_int)\n\neng = result_int.trajectories[0]\narch = result_int.trajectories[1]\n\nassert_true(\n    eng.trajectory_weight > arch.trajectory_weight,\n    f\"stable Engineer ({eng.trajectory_weight:.3f}) > capitulating Architect ({arch.trajectory_weight:.3f})\"\n)\nassert_true(eng.stability_score > 0.9, f\"Engineer stability high ({eng.stability_score:.4f})\")\nassert_true(arch.stability_score < 0.5, f\"Architect stability low ({arch.stability_score:.4f})\")\n\n# Consensus should be closer to Engineer's scores (higher weight)\nassert_true(\n    result_int.consensus_validity > 0.80,\n    f\"consensus validity weighted toward stable agent ({result_int.consensus_validity:.3f})\"\n)\n\n\n# ─── Sycophancy → Contrarian Trigger ───────────────────────────────────────\n\nprint(\"\\n=== Sycophancy → Contrarian ===\")\n\nr1_syc = [\n    DQEvaluation(\"PrincipalEngineer\", 0.9, 0.9, 0.9, \"High confidence\"),\n    DQEvaluation(\"SecurityArchitect\", 0.5, 0.5, 0.5, \"Low confidence\"),\n    DQEvaluation(\"ProductStrategist\", 0.7, 0.7, 0.7, \"Medium\"),\n]\n# All converge to same score\nr2_syc = [\n    DQEvaluation(\"PrincipalEngineer\", 0.7, 0.7, 0.7, \"Adjusted down\"),\n    DQEvaluation(\"SecurityArchitect\", 0.7, 0.7, 0.7, \"Adjusted up\"),\n    DQEvaluation(\"ProductStrategist\", 0.71, 0.71, 0.71, \"Converged\"),\n]\n\nresult_syc = synth.synthesize(r1_syc, r2_syc)\nassert_true(result_syc.sycophancy_flagged, \"sycophancy detected\")\nassert_true(result_syc.contrarian_triggered, \"contrarian triggered on sycophancy\")\n\n\n# ─── Config Loading ─────────────────────────────────────────────────────────\n\nprint(\"\\n=== Config Loading ===\")\n\ncfg = load_free_mad_config()\nassert_true(\"stabilityDecayRate\" in cfg, \"config has stabilityDecayRate\")\nassert_true(\"sycophancyConvergenceThreshold\" in cfg, \"config has sycophancy threshold\")\nassert_true(\"disagreementEscalationThreshold\" in cfg, \"config has escalation threshold\")\n\n# Fallback on missing file\ncfg_missing = load_free_mad_config(Path(\"/nonexistent/path.json\"))\nassert_true(\"stabilityDecayRate\" in cfg_missing, \"fallback config has decay rate\")\n\n\n# ─── SupermaxV2 Orchestrator ───────────────────────────────────────────────\n\nprint(\"\\n=== SupermaxV2 Orchestrator ===\")\n\nv2 = SupermaxV2()\nplan = v2.plan_agents(0.7)\nassert_true(plan.difficulty_tier == \"complex\", \"0.7 → complex tier\")\nassert_true(plan.agent_count == 4, \"complex → 4 agents\")\n\n# Synthesize through orchestrator\nresult_v2 = v2.synthesize(r1, r2)\nassert_true(isinstance(result_v2, SynthesisResult), \"orchestrator returns SynthesisResult\")\nassert_true(result_v2.consensus_dq > 0, \"orchestrator consensus > 0\")\n\n# Peer context through orchestrator\nctx = v2.prepare_peer_context(r1)\nassert_true(len(ctx) == 3, \"orchestrator peer context\")\n\n# Log through orchestrator\nwith tempfile.TemporaryDirectory() as tmpdir:\n    import coordinator.synthesizer as synth_mod\n    import coordinator.supermax as supermax_mod\n    orig_traj_dir = synth_mod._TRAJECTORIES_DIR\n    orig_cost_dir = supermax_mod._COSTS_DIR\n    synth_mod._TRAJECTORIES_DIR = Path(tmpdir)\n    supermax_mod._COSTS_DIR = Path(tmpdir)\n    try:\n        v2.log(\"test_hash\", plan, result_v2, cost_estimate=0.05)\n        assert_true((Path(tmpdir) / \"supermax-trajectories.jsonl\").exists(), \"trajectory log via orchestrator\")\n        assert_true((Path(tmpdir) / \"supermax-costs.jsonl\").exists(), \"cost log via orchestrator\")\n    finally:\n        synth_mod._TRAJECTORIES_DIR = orig_traj_dir\n        supermax_mod._COSTS_DIR = orig_cost_dir\n\n\n# ─── Summary ────────────────────────────────────────────────────────────────\n\nprint(f\"\\n{'='*60}\")\nprint(f\"Results: {passed} passed, {failed} failed, {passed + failed} total\")\nprint(f\"{'='*60}\")\nsys.exit(1 if failed > 0 else 0)\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":404,"cache_read_input_tokens":52766,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":404},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"e58d1a98-5dd9-41f6-879c-0a65c1ed08a6","uuid":"b4487f20-30ba-4936-ab29-100ec46db3cc"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NemqrEZTARy31TVjkjaBR1","type":"tool_result","content":"File created successfully at: /Users/dicoangelo/projects/core/meta-vengine/coordinator/tests/test_free_mad.py"}]},"parent_tool_use_id":null,"session_id":"e58d1a98-5dd9-41f6-879c-0a65c1ed08a6","uuid":"8b17859e-f6e0-46cd-8fd4-a0a6d0140473","tool_use_result":{"type":"create","filePath":"/Users/dicoangelo/projects/core/meta-vengine/coordinator/tests/test_free_mad.py","content":"#!/usr/bin/env python3\n\"\"\"\nTests for US-008: SUPERMAX v2 — Free-MAD Trajectory Scoring.\n\nTests cover:\n  - DQEvaluation creation and composite scoring\n  - Anonymization of peer reasoning (anti-sycophancy)\n  - Stability score computation (exponential decay)\n  - Trajectory weight normalization\n  - Sycophancy detection (unanimous convergence)\n  - Disagreement dimension detection\n  - Weighted consensus computation\n  - FreeMadSynthesizer end-to-end\n  - Trajectory logging to JSONL\n  - Integration: stable agent gets higher weight than capitulating agent\n  - SupermaxV2 orchestrator integration\n\"\"\"\n\nimport json\nimport math\nimport sys\nimport tempfile\nimport os\nfrom pathlib import Path\n\n# Allow imports from coordinator/\nsys.path.insert(0, str(Path(__file__).resolve().parent.parent.parent))\n\nfrom coordinator.synthesizer import (\n    DQEvaluation,\n    AgentTrajectory,\n    SynthesisResult,\n    FreeMadSynthesizer,\n    anonymize_reasoning,\n    compute_stability_score,\n    compute_trajectory_weights,\n    detect_sycophancy,\n    find_disagreement_dimensions,\n    synthesize_consensus,\n    log_trajectory,\n    load_free_mad_config,\n)\nfrom coordinator.supermax import PredictiveSpawner, SupermaxV2\n\n\npassed = 0\nfailed = 0\n\n\ndef assert_true(condition, msg):\n    global passed, failed\n    if condition:\n        passed += 1\n    else:\n        failed += 1\n        print(f\"  FAIL: {msg}\")\n\n\ndef assert_close(actual, expected, msg, tol=0.01):\n    global passed, failed\n    if abs(actual - expected) <= tol:\n        passed += 1\n    else:\n        failed += 1\n        print(f\"  FAIL: {msg} — expected {expected}, got {actual}\")\n\n\n# ─── DQEvaluation ───────────────────────────────────────────────────────────\n\nprint(\"=== DQEvaluation ===\")\n\nev = DQEvaluation(\"TestAgent\", 0.8, 0.7, 0.9, \"Some reasoning\")\nassert_close(ev.composite_dq, 0.8 * 0.4 + 0.7 * 0.3 + 0.9 * 0.3, \"composite DQ formula\")\nassert_true(ev.agent_name == \"TestAgent\", \"agent name preserved\")\nassert_true(ev.reasoning == \"Some reasoning\", \"reasoning preserved\")\n\ndims = ev.dimensions()\nassert_close(dims[\"validity\"], 0.8, \"dimensions dict validity\")\nassert_close(dims[\"specificity\"], 0.7, \"dimensions dict specificity\")\nassert_close(dims[\"correctness\"], 0.9, \"dimensions dict correctness\")\n\n# Perfect scores\nev_perfect = DQEvaluation(\"Perfect\", 1.0, 1.0, 1.0)\nassert_close(ev_perfect.composite_dq, 1.0, \"perfect composite = 1.0\")\n\n# Zero scores\nev_zero = DQEvaluation(\"Zero\", 0.0, 0.0, 0.0)\nassert_close(ev_zero.composite_dq, 0.0, \"zero composite = 0.0\")\n\n\n# ─── Anonymize Reasoning ────────────────────────────────────────────────────\n\nprint(\"\\n=== Anonymize Reasoning ===\")\n\nevals = [\n    DQEvaluation(\"PrincipalEngineer\", 0.8, 0.7, 0.9, \"Tech analysis\"),\n    DQEvaluation(\"SecurityArchitect\", 0.6, 0.8, 0.7, \"Risk assessment\"),\n    DQEvaluation(\"ProductStrategist\", 0.9, 0.6, 0.8, \"User value check\"),\n]\n\nanon = anonymize_reasoning(evals)\nassert_true(len(anon) == 3, \"3 anonymized entries\")\nassert_true(anon[0][\"evaluator\"] == \"Evaluator A\", \"first evaluator is A\")\nassert_true(anon[1][\"evaluator\"] == \"Evaluator B\", \"second evaluator is B\")\nassert_true(anon[2][\"evaluator\"] == \"Evaluator C\", \"third evaluator is C\")\n\n# Verify agent names are NOT in anonymized output\nfor entry in anon:\n    text = json.dumps(entry)\n    assert_true(\"PrincipalEngineer\" not in text, f\"no agent name in {entry['evaluator']}\")\n    assert_true(\"SecurityArchitect\" not in text, f\"no agent name in {entry['evaluator']}\")\n    assert_true(\"ProductStrategist\" not in text, f\"no agent name in {entry['evaluator']}\")\n\n# Verify scores are preserved\nassert_close(anon[0][\"scores\"][\"validity\"], 0.8, \"anon scores preserved\")\nassert_true(anon[0][\"reasoning\"] == \"Tech analysis\", \"anon reasoning preserved\")\n\n\n# ─── Stability Score ────────────────────────────────────────────────────────\n\nprint(\"\\n=== Stability Score ===\")\n\n# Perfectly stable agent (delta = 0)\nt_stable = AgentTrajectory(\n    \"Stable\",\n    DQEvaluation(\"Stable\", 0.8, 0.7, 0.9),\n    DQEvaluation(\"Stable\", 0.8, 0.7, 0.9),\n)\nassert_close(compute_stability_score(t_stable), 1.0, \"zero delta → stability 1.0\")\n\n# Completely unstable agent (large delta)\nt_unstable = AgentTrajectory(\n    \"Unstable\",\n    DQEvaluation(\"Unstable\", 0.2, 0.3, 0.1),\n    DQEvaluation(\"Unstable\", 0.9, 0.8, 0.9),\n)\nstability_unstable = compute_stability_score(t_unstable)\nassert_true(stability_unstable < 0.1, f\"large delta → low stability ({stability_unstable:.4f})\")\n\n# Moderate delta\nt_moderate = AgentTrajectory(\n    \"Moderate\",\n    DQEvaluation(\"Moderate\", 0.7, 0.6, 0.8),\n    DQEvaluation(\"Moderate\", 0.75, 0.65, 0.85),\n)\nstability_mod = compute_stability_score(t_moderate)\nassert_true(0.3 < stability_mod < 0.9, f\"moderate delta → mid stability ({stability_mod:.4f})\")\n\n# Verify exponential decay formula\ndelta = 0.1\nexpected = math.exp(-5.0 * delta)\nt_known = AgentTrajectory(\n    \"Known\",\n    DQEvaluation(\"Known\", 0.5, 0.5, 0.5),\n    DQEvaluation(\"Known\", 0.6, 0.5, 0.5),  # delta_validity = 0.1\n)\nassert_close(compute_stability_score(t_known), expected, \"exp decay formula matches\")\n\n# Custom decay rate\nassert_close(\n    compute_stability_score(t_known, decay_rate=10.0),\n    math.exp(-10.0 * 0.1),\n    \"custom decay rate\"\n)\n\n\n# ─── Trajectory Weights ────────────────────────────────────────────────────\n\nprint(\"\\n=== Trajectory Weights ===\")\n\ntrajectories = [t_stable, t_unstable, t_moderate]\nweighted = compute_trajectory_weights(trajectories)\n\n# Stable agent should get highest weight\nassert_true(\n    t_stable.trajectory_weight > t_unstable.trajectory_weight,\n    \"stable agent gets higher weight than unstable\"\n)\n\n# Weights sum to 1.0\ntotal_weight = sum(t.trajectory_weight for t in weighted)\nassert_close(total_weight, 1.0, \"weights sum to 1.0\")\n\n# All weights > 0 (min weight guarantee)\nfor t in weighted:\n    assert_true(t.trajectory_weight > 0, f\"{t.agent_name} weight > 0\")\n\n# Uniform case: all equally stable\nequal_trajs = [\n    AgentTrajectory(\"A\", DQEvaluation(\"A\", 0.5, 0.5, 0.5), DQEvaluation(\"A\", 0.5, 0.5, 0.5)),\n    AgentTrajectory(\"B\", DQEvaluation(\"B\", 0.5, 0.5, 0.5), DQEvaluation(\"B\", 0.5, 0.5, 0.5)),\n    AgentTrajectory(\"C\", DQEvaluation(\"C\", 0.5, 0.5, 0.5), DQEvaluation(\"C\", 0.5, 0.5, 0.5)),\n]\ncompute_trajectory_weights(equal_trajs)\nfor t in equal_trajs:\n    assert_close(t.trajectory_weight, 1.0 / 3, f\"equal stability → uniform weight ({t.agent_name})\")\n\n\n# ─── Sycophancy Detection ──────────────────────────────────────────────────\n\nprint(\"\\n=== Sycophancy Detection ===\")\n\n# Sycophancy case: all agents converge to same score after initially disagreeing\nsyc_trajs = [\n    AgentTrajectory(\n        \"A\",\n        DQEvaluation(\"A\", 0.9, 0.9, 0.9),  # R1: high\n        DQEvaluation(\"A\", 0.7, 0.7, 0.7),  # R2: converged to 0.7\n    ),\n    AgentTrajectory(\n        \"B\",\n        DQEvaluation(\"B\", 0.5, 0.5, 0.5),  # R1: low\n        DQEvaluation(\"B\", 0.7, 0.7, 0.7),  # R2: converged to 0.7\n    ),\n    AgentTrajectory(\n        \"C\",\n        DQEvaluation(\"C\", 0.7, 0.7, 0.7),  # R1: medium\n        DQEvaluation(\"C\", 0.71, 0.71, 0.71),  # R2: converged to ~0.7\n    ),\n]\nassert_true(detect_sycophancy(syc_trajs, 0.05), \"unanimous convergence → sycophancy flagged\")\n\n# Non-sycophancy: agents hold positions\nnon_syc_trajs = [\n    AgentTrajectory(\n        \"A\",\n        DQEvaluation(\"A\", 0.9, 0.9, 0.9),\n        DQEvaluation(\"A\", 0.9, 0.9, 0.9),  # Held position (delta = 0)\n    ),\n    AgentTrajectory(\n        \"B\",\n        DQEvaluation(\"B\", 0.5, 0.5, 0.5),\n        DQEvaluation(\"B\", 0.55, 0.55, 0.55),  # Minor shift\n    ),\n]\nassert_true(not detect_sycophancy(non_syc_trajs, 0.05), \"one agent held → no sycophancy\")\n\n# Single agent: cannot have sycophancy\nsingle = [AgentTrajectory(\"A\", DQEvaluation(\"A\", 0.5, 0.5, 0.5), DQEvaluation(\"A\", 0.7, 0.7, 0.7))]\nassert_true(not detect_sycophancy(single), \"single agent → no sycophancy\")\n\n# No initial disagreement: all start and end similar\nno_disagree = [\n    AgentTrajectory(\"A\", DQEvaluation(\"A\", 0.7, 0.7, 0.7), DQEvaluation(\"A\", 0.71, 0.71, 0.71)),\n    AgentTrajectory(\"B\", DQEvaluation(\"B\", 0.7, 0.7, 0.7), DQEvaluation(\"B\", 0.72, 0.72, 0.72)),\n]\nassert_true(not detect_sycophancy(no_disagree, 0.05), \"no initial disagreement → no sycophancy\")\n\n\n# ─── Disagreement Dimensions ───────────────────────────────────────────────\n\nprint(\"\\n=== Disagreement Dimensions ===\")\n\n# Validity diverges, others agree\ndiv_trajs = [\n    AgentTrajectory(\n        \"A\",\n        DQEvaluation(\"A\", 0.9, 0.7, 0.8),\n        DQEvaluation(\"A\", 0.9, 0.7, 0.8),\n    ),\n    AgentTrajectory(\n        \"B\",\n        DQEvaluation(\"B\", 0.5, 0.7, 0.8),\n        DQEvaluation(\"B\", 0.5, 0.7, 0.8),\n    ),\n]\ndims = find_disagreement_dimensions(div_trajs, 0.15)\nassert_true(\"validity\" in dims, \"validity diverges → in disagreement dims\")\nassert_true(\"specificity\" not in dims, \"specificity agrees → not in disagreement dims\")\nassert_true(\"correctness\" not in dims, \"correctness agrees → not in disagreement dims\")\n\n# All agree within threshold\nagree_trajs = [\n    AgentTrajectory(\"A\", DQEvaluation(\"A\", 0.7, 0.7, 0.7), DQEvaluation(\"A\", 0.7, 0.7, 0.7)),\n    AgentTrajectory(\"B\", DQEvaluation(\"B\", 0.75, 0.72, 0.73), DQEvaluation(\"B\", 0.75, 0.72, 0.73)),\n]\ndims_none = find_disagreement_dimensions(agree_trajs, 0.15)\nassert_true(len(dims_none) == 0, \"all agree → no disagreement dimensions\")\n\n# Multiple divergent dimensions\nmulti_div = [\n    AgentTrajectory(\"A\", DQEvaluation(\"A\", 0.9, 0.9, 0.9), DQEvaluation(\"A\", 0.9, 0.9, 0.9)),\n    AgentTrajectory(\"B\", DQEvaluation(\"B\", 0.5, 0.5, 0.5), DQEvaluation(\"B\", 0.5, 0.5, 0.5)),\n]\ndims_multi = find_disagreement_dimensions(multi_div, 0.15)\nassert_true(len(dims_multi) == 3, \"all dimensions diverge → 3 disagreement dims\")\n\n\n# ─── Consensus Computation ──────────────────────────────────────────────────\n\nprint(\"\\n=== Consensus Computation ===\")\n\n# Equal weights → simple average\neq_trajs = [\n    AgentTrajectory(\"A\", DQEvaluation(\"A\", 0.8, 0.6, 0.7), DQEvaluation(\"A\", 0.8, 0.6, 0.7)),\n    AgentTrajectory(\"B\", DQEvaluation(\"B\", 0.6, 0.8, 0.9), DQEvaluation(\"B\", 0.6, 0.8, 0.9)),\n]\neq_trajs[0].trajectory_weight = 0.5\neq_trajs[1].trajectory_weight = 0.5\nconsensus = synthesize_consensus(eq_trajs)\nassert_close(consensus[\"validity\"], 0.7, \"equal weight consensus validity\")\nassert_close(consensus[\"specificity\"], 0.7, \"equal weight consensus specificity\")\nassert_close(consensus[\"correctness\"], 0.8, \"equal weight consensus correctness\")\n\n# Skewed weights → weighted toward dominant\nsk_trajs = [\n    AgentTrajectory(\"A\", DQEvaluation(\"A\", 1.0, 1.0, 1.0), DQEvaluation(\"A\", 1.0, 1.0, 1.0)),\n    AgentTrajectory(\"B\", DQEvaluation(\"B\", 0.0, 0.0, 0.0), DQEvaluation(\"B\", 0.0, 0.0, 0.0)),\n]\nsk_trajs[0].trajectory_weight = 0.9\nsk_trajs[1].trajectory_weight = 0.1\nconsensus_sk = synthesize_consensus(sk_trajs)\nassert_close(consensus_sk[\"validity\"], 0.9, \"skewed weight → dominant agent\")\nassert_close(consensus_sk[\"composite_dq\"], 0.9, \"skewed composite\")\n\n\n# ─── FreeMadSynthesizer End-to-End ──────────────────────────────────────────\n\nprint(\"\\n=== FreeMadSynthesizer E2E ===\")\n\nsynth = FreeMadSynthesizer()\n\n# Standard case: 3 agents, varying stability\nr1 = [\n    DQEvaluation(\"PrincipalEngineer\", 0.8, 0.7, 0.9, \"Tech solid\"),\n    DQEvaluation(\"SecurityArchitect\", 0.6, 0.8, 0.7, \"Risky\"),\n    DQEvaluation(\"ProductStrategist\", 0.9, 0.6, 0.8, \"User value\"),\n]\nr2 = [\n    DQEvaluation(\"PrincipalEngineer\", 0.8, 0.72, 0.88, \"Held position\"),\n    DQEvaluation(\"SecurityArchitect\", 0.78, 0.75, 0.82, \"Shifted a lot\"),\n    DQEvaluation(\"ProductStrategist\", 0.85, 0.65, 0.8, \"Minor shift\"),\n]\n\nresult = synth.synthesize(r1, r2)\nassert_true(isinstance(result, SynthesisResult), \"returns SynthesisResult\")\nassert_true(0.0 <= result.consensus_dq <= 1.0, \"consensus DQ in range\")\nassert_true(len(result.trajectories) == 3, \"3 trajectories\")\nassert_true(result.method == \"free_mad_trajectory\", \"method is free_mad_trajectory\")\nassert_true(not result.sycophancy_flagged, \"no sycophancy in standard case\")\n\n# Verify stable agent (Engineer) gets higher weight than unstable (Architect)\neng_traj = result.trajectories[0]\narch_traj = result.trajectories[1]\nassert_true(\n    eng_traj.trajectory_weight > arch_traj.trajectory_weight,\n    \"Engineer (stable) > Architect (shifted)\"\n)\n\n# Mismatched round counts → error\ntry:\n    synth.synthesize(r1[:2], r2)\n    assert_true(False, \"should raise on mismatched counts\")\nexcept ValueError:\n    assert_true(True, \"raises ValueError on mismatched counts\")\n\n# Mismatched agent names → error\nr2_wrong = [\n    DQEvaluation(\"Wrong\", 0.8, 0.7, 0.9),\n    DQEvaluation(\"SecurityArchitect\", 0.6, 0.8, 0.7),\n    DQEvaluation(\"ProductStrategist\", 0.9, 0.6, 0.8),\n]\ntry:\n    synth.synthesize(r1, r2_wrong)\n    assert_true(False, \"should raise on mismatched agent names\")\nexcept ValueError:\n    assert_true(True, \"raises ValueError on mismatched names\")\n\n\n# ─── Peer Context Preparation ──────────────────────────────────────────────\n\nprint(\"\\n=== Peer Context ===\")\n\npeer_ctx = synth.prepare_peer_context(r1)\nassert_true(len(peer_ctx) == 3, \"3 peer context entries\")\nassert_true(all(\"evaluator\" in p for p in peer_ctx), \"all have evaluator label\")\n\n# No agent names leaked\nall_text = json.dumps(peer_ctx)\nassert_true(\"PrincipalEngineer\" not in all_text, \"no Engineer name in peer context\")\nassert_true(\"SecurityArchitect\" not in all_text, \"no Architect name in peer context\")\n\n\n# ─── Trajectory Logging ────────────────────────────────────────────────────\n\nprint(\"\\n=== Trajectory Logging ===\")\n\nwith tempfile.TemporaryDirectory() as tmpdir:\n    tmp_path = Path(tmpdir)\n    log_trajectory(\"abc123\", result, log_dir=tmp_path)\n\n    log_file = tmp_path / \"supermax-trajectories.jsonl\"\n    assert_true(log_file.exists(), \"trajectory log file created\")\n\n    with open(log_file) as f:\n        entry = json.loads(f.readline())\n\n    assert_true(entry[\"query_hash\"] == \"abc123\", \"query hash logged\")\n    assert_true(entry[\"method\"] == \"free_mad_trajectory\", \"method logged\")\n    assert_true(len(entry[\"trajectories\"]) == 3, \"3 trajectory entries logged\")\n    assert_true(\"sycophancy_flagged\" in entry, \"sycophancy flag logged\")\n    assert_true(\"disagreement_dimensions\" in entry, \"disagreement dims logged\")\n    assert_true(\"ts\" in entry, \"timestamp logged\")\n\n    # Verify trajectory detail structure\n    t0 = entry[\"trajectories\"][0]\n    assert_true(\"agent\" in t0, \"agent name in trajectory\")\n    assert_true(\"round1_dq\" in t0, \"round1_dq in trajectory\")\n    assert_true(\"round2_dq\" in t0, \"round2_dq in trajectory\")\n    assert_true(\"stability_score\" in t0, \"stability_score in trajectory\")\n    assert_true(\"trajectory_weight\" in t0, \"trajectory_weight in trajectory\")\n    assert_true(\"delta_validity\" in t0, \"delta_validity in trajectory\")\n\n    # Append-only: log again, verify 2 lines\n    log_trajectory(\"def456\", result, log_dir=tmp_path)\n    with open(log_file) as f:\n        lines = f.readlines()\n    assert_true(len(lines) == 2, \"append-only: 2 entries after 2 logs\")\n\n\n# ─── Integration: Stable Agent Beats Capitulating Agent ─────────────────────\n\nprint(\"\\n=== Integration: Stability Wins ===\")\n\n# Scenario: Engineer holds firm, Architect completely capitulates to peer pressure\nr1_int = [\n    DQEvaluation(\"PrincipalEngineer\", 0.85, 0.80, 0.90, \"This is technically correct\"),\n    DQEvaluation(\"SecurityArchitect\", 0.50, 0.60, 0.40, \"I see security risks\"),\n]\n# After peer exposure:\n# Engineer barely moves (confident in analysis)\n# Architect completely reverses position (sycophancy to Engineer)\nr2_int = [\n    DQEvaluation(\"PrincipalEngineer\", 0.84, 0.79, 0.91, \"Still correct after review\"),\n    DQEvaluation(\"SecurityArchitect\", 0.83, 0.78, 0.88, \"Actually, Engineer is right\"),\n]\n\nresult_int = synth.synthesize(r1_int, r2_int)\n\neng = result_int.trajectories[0]\narch = result_int.trajectories[1]\n\nassert_true(\n    eng.trajectory_weight > arch.trajectory_weight,\n    f\"stable Engineer ({eng.trajectory_weight:.3f}) > capitulating Architect ({arch.trajectory_weight:.3f})\"\n)\nassert_true(eng.stability_score > 0.9, f\"Engineer stability high ({eng.stability_score:.4f})\")\nassert_true(arch.stability_score < 0.5, f\"Architect stability low ({arch.stability_score:.4f})\")\n\n# Consensus should be closer to Engineer's scores (higher weight)\nassert_true(\n    result_int.consensus_validity > 0.80,\n    f\"consensus validity weighted toward stable agent ({result_int.consensus_validity:.3f})\"\n)\n\n\n# ─── Sycophancy → Contrarian Trigger ───────────────────────────────────────\n\nprint(\"\\n=== Sycophancy → Contrarian ===\")\n\nr1_syc = [\n    DQEvaluation(\"PrincipalEngineer\", 0.9, 0.9, 0.9, \"High confidence\"),\n    DQEvaluation(\"SecurityArchitect\", 0.5, 0.5, 0.5, \"Low confidence\"),\n    DQEvaluation(\"ProductStrategist\", 0.7, 0.7, 0.7, \"Medium\"),\n]\n# All converge to same score\nr2_syc = [\n    DQEvaluation(\"PrincipalEngineer\", 0.7, 0.7, 0.7, \"Adjusted down\"),\n    DQEvaluation(\"SecurityArchitect\", 0.7, 0.7, 0.7, \"Adjusted up\"),\n    DQEvaluation(\"ProductStrategist\", 0.71, 0.71, 0.71, \"Converged\"),\n]\n\nresult_syc = synth.synthesize(r1_syc, r2_syc)\nassert_true(result_syc.sycophancy_flagged, \"sycophancy detected\")\nassert_true(result_syc.contrarian_triggered, \"contrarian triggered on sycophancy\")\n\n\n# ─── Config Loading ─────────────────────────────────────────────────────────\n\nprint(\"\\n=== Config Loading ===\")\n\ncfg = load_free_mad_config()\nassert_true(\"stabilityDecayRate\" in cfg, \"config has stabilityDecayRate\")\nassert_true(\"sycophancyConvergenceThreshold\" in cfg, \"config has sycophancy threshold\")\nassert_true(\"disagreementEscalationThreshold\" in cfg, \"config has escalation threshold\")\n\n# Fallback on missing file\ncfg_missing = load_free_mad_config(Path(\"/nonexistent/path.json\"))\nassert_true(\"stabilityDecayRate\" in cfg_missing, \"fallback config has decay rate\")\n\n\n# ─── SupermaxV2 Orchestrator ───────────────────────────────────────────────\n\nprint(\"\\n=== SupermaxV2 Orchestrator ===\")\n\nv2 = SupermaxV2()\nplan = v2.plan_agents(0.7)\nassert_true(plan.difficulty_tier == \"complex\", \"0.7 → complex tier\")\nassert_true(plan.agent_count == 4, \"complex → 4 agents\")\n\n# Synthesize through orchestrator\nresult_v2 = v2.synthesize(r1, r2)\nassert_true(isinstance(result_v2, SynthesisResult), \"orchestrator returns SynthesisResult\")\nassert_true(result_v2.consensus_dq > 0, \"orchestrator consensus > 0\")\n\n# Peer context through orchestrator\nctx = v2.prepare_peer_context(r1)\nassert_true(len(ctx) == 3, \"orchestrator peer context\")\n\n# Log through orchestrator\nwith tempfile.TemporaryDirectory() as tmpdir:\n    import coordinator.synthesizer as synth_mod\n    import coordinator.supermax as supermax_mod\n    orig_traj_dir = synth_mod._TRAJECTORIES_DIR\n    orig_cost_dir = supermax_mod._COSTS_DIR\n    synth_mod._TRAJECTORIES_DIR = Path(tmpdir)\n    supermax_mod._COSTS_DIR = Path(tmpdir)\n    try:\n        v2.log(\"test_hash\", plan, result_v2, cost_estimate=0.05)\n        assert_true((Path(tmpdir) / \"supermax-trajectories.jsonl\").exists(), \"trajectory log via orchestrator\")\n        assert_true((Path(tmpdir) / \"supermax-costs.jsonl\").exists(), \"cost log via orchestrator\")\n    finally:\n        synth_mod._TRAJECTORIES_DIR = orig_traj_dir\n        supermax_mod._COSTS_DIR = orig_cost_dir\n\n\n# ─── Summary ────────────────────────────────────────────────────────────────\n\nprint(f\"\\n{'='*60}\")\nprint(f\"Results: {passed} passed, {failed} failed, {passed + failed} total\")\nprint(f\"{'='*60}\")\nsys.exit(1 if failed > 0 else 0)\n","structuredPatch":[],"originalFile":null}}
