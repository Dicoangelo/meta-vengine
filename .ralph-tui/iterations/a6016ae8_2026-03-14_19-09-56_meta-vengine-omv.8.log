{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019LaeEqrJhrVechRirTTgwf","type":"tool_result","content":"     1→#!/usr/bin/env python3\n     2→\"\"\"\n     3→SUPERMAX v2 — Adaptive Agent Count with Difficulty-Aware Spawning.\n     4→\n     5→US-007: Dynamically selects agent count (1-5) based on graphComplexity\n     6→from the multi-feature graph signal (US-004). Simple queries use 1 agent,\n     7→complex queries get full council evaluation.\n     8→\n     9→Agent priority order:\n    10→  1. Principal Engineer (technical correctness, waste penalties)\n    11→  2. Security Architect (risk, safety margins, compliance)\n    12→  3. Product Strategist (user value, speed, cost)\n    13→  4. Contrarian (adversarial challenge, from ACE)\n    14→  5. Arbiter (final adjudication, cross-perspective synthesis)\n    15→\n    16→All thresholds stored in config/supermax-v2.json (learnable, not hardcoded).\n    17→\"\"\"\n    18→\n    19→import json\n    20→import sys\n    21→import os\n    22→import time\n    23→from pathlib import Path\n    24→from datetime import datetime\n    25→from dataclasses import dataclass, field\n    26→from typing import List, Optional, Dict, Any\n    27→\n    28→# Resolve paths relative to the meta-vengine root\n    29→_ROOT = Path(__file__).resolve().parent.parent\n    30→_CONFIG_PATH = _ROOT / \"config\" / \"supermax-v2.json\"\n    31→_COSTS_DIR = _ROOT / \"data\"\n    32→\n    33→\n    34→@dataclass\n    35→class AgentSpec:\n    36→    \"\"\"Specification for a SUPERMAX agent to spawn.\"\"\"\n    37→    name: str\n    38→    perspective: str\n    39→    model: str\n    40→    index: int  # priority order (0-based)\n    41→\n    42→\n    43→@dataclass\n    44→class SpawnPlan:\n    45→    \"\"\"Result of PredictiveSpawner.plan() — describes which agents to spawn.\"\"\"\n    46→    graph_complexity: float\n    47→    difficulty_tier: str\n    48→    agent_count: int\n    49→    agents: List[AgentSpec]\n    50→    thresholds_used: Dict[str, Any]\n    51→\n    52→\n    53→def load_config(config_path: Path = None) -> dict:\n    54→    \"\"\"Load SUPERMAX v2 config from JSON. Falls back to defaults if missing.\"\"\"\n    55→    path = config_path or _CONFIG_PATH\n    56→    try:\n    57→        if path.exists():\n    58→            with open(path, \"r\") as f:\n    59→                return json.load(f)\n    60→    except (json.JSONDecodeError, OSError):\n    61→        pass\n    62→    # Emergency fallback — should never be used in production\n    63→    return {\n    64→        \"agentCountThresholds\": {\n    65→            \"trivial\": {\"max\": 0.25, \"agentCount\": 1},\n    66→            \"simple\": {\"max\": 0.45, \"agentCount\": 2},\n    67→            \"moderate\": {\"max\": 0.65, \"agentCount\": 3},\n    68→            \"complex\": {\"max\": 0.85, \"agentCount\": 4},\n    69→            \"expert\": {\"max\": 1.00, \"agentCount\": 5},\n    70→        },\n    71→        \"agentPriority\": [\n    72→            {\"name\": \"PrincipalEngineer\", \"perspective\": \"Technical correctness, waste penalties\", \"model\": \"sonnet\"},\n    73→            {\"name\": \"SecurityArchitect\", \"perspective\": \"Risk, safety margins, compliance\", \"model\": \"sonnet\"},\n    74→            {\"name\": \"ProductStrategist\", \"perspective\": \"User value, speed, cost\", \"model\": \"sonnet\"},\n    75→            {\"name\": \"Contrarian\", \"perspective\": \"Adversarial challenge, assumption stress-testing\", \"model\": \"sonnet\"},\n    76→            {\"name\": \"Arbiter\", \"perspective\": \"Final adjudication, cross-perspective synthesis\", \"model\": \"opus\"},\n    77→        ],\n    78→        \"constraints\": {\"minAgents\": 1, \"maxAgents\": 5, \"defaultAgentCount\": 3},\n    79→    }\n    80→\n    81→\n    82→class PredictiveSpawner:\n    83→    \"\"\"\n    84→    Difficulty-aware agent spawner for SUPERMAX v2.\n    85→\n    86→    Consumes graphComplexity (0.0-1.0) from the multi-feature graph signal\n    87→    (US-004) and selects the appropriate number of council agents.\n    88→\n    89→    Thresholds and agent definitions are loaded from config/supermax-v2.json\n    90→    (learnable — future Optimas LRF).\n    91→    \"\"\"\n    92→\n    93→    def __init__(self, config_path: Path = None):\n    94→        self.config = load_config(config_path)\n    95→        self._thresholds = self._parse_thresholds()\n    96→        self._agents = self._parse_agents()\n    97→        self._constraints = self.config.get(\"constraints\", {})\n    98→\n    99→    def _parse_thresholds(self) -> List[dict]:\n   100→        \"\"\"Parse and sort thresholds by max value ascending.\"\"\"\n   101→        raw = self.config.get(\"agentCountThresholds\", {})\n   102→        tiers = []\n   103→        for tier_name, tier_data in raw.items():\n   104→            tiers.append({\n   105→                \"tier\": tier_name,\n   106→                \"max\": tier_data[\"max\"],\n   107→                \"agentCount\": tier_data[\"agentCount\"],\n   108→            })\n   109→        tiers.sort(key=lambda t: t[\"max\"])\n   110→        return tiers\n   111→\n   112→    def _parse_agents(self) -> List[AgentSpec]:\n   113→        \"\"\"Parse agent priority list from config.\"\"\"\n   114→        raw = self.config.get(\"agentPriority\", [])\n   115→        agents = []\n   116→        for i, entry in enumerate(raw):\n   117→            agents.append(AgentSpec(\n   118→                name=entry[\"name\"],\n   119→                perspective=entry.get(\"perspective\", \"\"),\n   120→                model=entry.get(\"model\", \"sonnet\"),\n   121→                index=i,\n   122→            ))\n   123→        return agents\n   124→\n   125→    def classify_difficulty(self, graph_complexity: float) -> tuple:\n   126→        \"\"\"\n   127→        Classify a graphComplexity score into a difficulty tier and agent count.\n   128→\n   129→        Args:\n   130→            graph_complexity: 0.0-1.0 composite score from computeGraphSignal()\n   131→\n   132→        Returns:\n   133→            (tier_name, agent_count) tuple\n   134→        \"\"\"\n   135→        clamped = max(0.0, min(1.0, graph_complexity))\n   136→\n   137→        for tier in self._thresholds:\n   138→            if clamped < tier[\"max\"] or (clamped == tier[\"max\"] and tier[\"tier\"] == \"expert\"):\n   139→                return tier[\"tier\"], tier[\"agentCount\"]\n   140→\n   141→        # Fallback: if complexity exactly equals 1.0 and no tier matched\n   142→        if self._thresholds:\n   143→            last = self._thresholds[-1]\n   144→            return last[\"tier\"], last[\"agentCount\"]\n   145→\n   146→        # Ultimate fallback\n   147→        default_count = self._constraints.get(\"defaultAgentCount\", 3)\n   148→        return \"unknown\", default_count\n   149→\n   150→    def select_agents(self, count: int) -> List[AgentSpec]:\n   151→        \"\"\"\n   152→        Select agents in priority order up to the given count.\n   153→\n   154→        Priority: PrincipalEngineer > SecurityArchitect > ProductStrategist > Contrarian > Arbiter\n   155→\n   156→        Args:\n   157→            count: Number of agents to select (1-5)\n   158→\n   159→        Returns:\n   160→            List of AgentSpec in priority order\n   161→        \"\"\"\n   162→        min_agents = self._constraints.get(\"minAgents\", 1)\n   163→        max_agents = self._constraints.get(\"maxAgents\", 5)\n   164→        clamped_count = max(min_agents, min(max_agents, count))\n   165→\n   166→        return self._agents[:clamped_count]\n   167→\n   168→    def plan(self, graph_complexity: float) -> SpawnPlan:\n   169→        \"\"\"\n   170→        Create a spawn plan based on graphComplexity.\n   171→\n   172→        This is the main entry point — takes a difficulty score and returns\n   173→        a complete plan for which agents to spawn.\n   174→\n   175→        Args:\n   176→            graph_complexity: 0.0-1.0 from computeGraphSignal() (US-004)\n   177→\n   178→        Returns:\n   179→            SpawnPlan with tier, count, and agent list\n   180→        \"\"\"\n   181→        tier, count = self.classify_difficulty(graph_complexity)\n   182→        agents = self.select_agents(count)\n   183→\n   184→        return SpawnPlan(\n   185→            graph_complexity=graph_complexity,\n   186→            difficulty_tier=tier,\n   187→            agent_count=len(agents),\n   188→            agents=agents,\n   189→            thresholds_used={t[\"tier\"]: t for t in self._thresholds},\n   190→        )\n   191→\n   192→    def plan_with_default(self, graph_complexity: Optional[float] = None) -> SpawnPlan:\n   193→        \"\"\"\n   194→        Plan with graceful degradation when graphComplexity is unavailable.\n   195→\n   196→        Falls back to the default agent count from config when no\n   197→        graph signal is available.\n   198→\n   199→        Args:\n   200→            graph_complexity: 0.0-1.0 or None if unavailable\n   201→\n   202→        Returns:\n   203→            SpawnPlan\n   204→        \"\"\"\n   205→        if graph_complexity is not None:\n   206→            return self.plan(graph_complexity)\n   207→\n   208→        # Fallback: use default agent count\n   209→        default_count = self._constraints.get(\"defaultAgentCount\", 3)\n   210→        agents = self.select_agents(default_count)\n   211→\n   212→        return SpawnPlan(\n   213→            graph_complexity=-1.0,  # sentinel: unavailable\n   214→            difficulty_tier=\"default\",\n   215→            agent_count=len(agents),\n   216→            agents=agents,\n   217→            thresholds_used={t[\"tier\"]: t for t in self._thresholds},\n   218→        )\n   219→\n   220→\n   221→def log_supermax_cost(\n   222→    query_hash: str,\n   223→    agent_count: int,\n   224→    difficulty_tier: str,\n   225→    graph_complexity: float,\n   226→    agents_used: List[str],\n   227→    cost_estimate: float = 0.0,\n   228→    log_dir: Path = None,\n   229→):\n   230→    \"\"\"\n   231→    Append cost tracking entry to data/supermax-costs.jsonl.\n   232→\n   233→    Args:\n   234→        query_hash: MD5 hash of the query\n   235→        agent_count: Number of agents spawned\n   236→        difficulty_tier: Classified difficulty tier\n   237→        graph_complexity: The graphComplexity score used\n   238→        agents_used: List of agent names\n   239→        cost_estimate: Estimated USD cost\n   240→        log_dir: Override for the data directory\n   241→    \"\"\"\n   242→    out_dir = log_dir or _COSTS_DIR\n   243→    out_dir.mkdir(parents=True, exist_ok=True)\n   244→    log_path = out_dir / \"supermax-costs.jsonl\"\n   245→\n   246→    entry = {\n   247→        \"ts\": datetime.now(tz=__import__('datetime').timezone.utc).isoformat(),\n   248→        \"query_hash\": query_hash,\n   249→        \"agent_count\": agent_count,\n   250→        \"difficulty_tier\": difficulty_tier,\n   251→        \"graph_complexity\": graph_complexity,\n   252→        \"agents_used\": agents_used,\n   253→        \"cost_estimate\": cost_estimate,\n   254→    }\n   255→\n   256→    with open(log_path, \"a\") as f:\n   257→        f.write(json.dumps(entry) + \"\\n\")\n   258→\n   259→\n   260→# ─────────────────────────────────────────────────────────────────────────────\n   261→# CLI interface\n   262→# ─────────────────────────────────────────────────────────────────────────────\n   263→\n   264→def main():\n   265→    \"\"\"CLI entry point for SUPERMAX v2.\"\"\"\n   266→    import argparse\n   267→\n   268→    parser = argparse.ArgumentParser(\n   269→        description=\"SUPERMAX v2 — Adaptive Agent Count\",\n   270→        formatter_class=argparse.RawDescriptionHelpFormatter,\n   271→        epilog=\"\"\"\n   272→Examples:\n   273→  python3 coordinator/supermax.py plan 0.15    # trivial → 1 agent\n   274→  python3 coordinator/supermax.py plan 0.50    # moderate → 3 agents\n   275→  python3 coordinator/supermax.py plan 0.90    # expert → 5 agents\n   276→  python3 coordinator/supermax.py classify 0.30  # → simple, 2 agents\n   277→        \"\"\",\n   278→    )\n   279→\n   280→    parser.add_argument(\"command\", choices=[\"plan\", \"classify\", \"config\"])\n   281→    parser.add_argument(\"complexity\", nargs=\"?\", type=float, help=\"graphComplexity (0.0-1.0)\")\n   282→\n   283→    args = parser.parse_args()\n   284→\n   285→    spawner = PredictiveSpawner()\n   286→\n   287→    if args.command == \"config\":\n   288→        print(json.dumps(spawner.config, indent=2))\n   289→\n   290→    elif args.command == \"classify\":\n   291→        if args.complexity is None:\n   292→            parser.error(\"classify requires a complexity value\")\n   293→        tier, count = spawner.classify_difficulty(args.complexity)\n   294→        print(f\"Complexity: {args.complexity}\")\n   295→        print(f\"Tier: {tier}\")\n   296→        print(f\"Agent count: {count}\")\n   297→\n   298→    elif args.command == \"plan\":\n   299→        if args.complexity is None:\n   300→            parser.error(\"plan requires a complexity value\")\n   301→        plan = spawner.plan(args.complexity)\n   302→        print(f\"Complexity: {plan.graph_complexity}\")\n   303→        print(f\"Tier: {plan.difficulty_tier}\")\n   304→        print(f\"Agent count: {plan.agent_count}\")\n   305→        print(f\"Agents:\")\n   306→        for a in plan.agents:\n   307→            print(f\"  {a.index + 1}. {a.name} ({a.model}) — {a.perspective}\")\n   308→\n   309→\n   310→if __name__ == \"__main__\":\n   311→    main()\n   312→"}]},"parent_tool_use_id":null,"session_id":"e58d1a98-5dd9-41f6-879c-0a65c1ed08a6","uuid":"cc4fff9d-284b-4bc3-9bce-e3d30b248894","tool_use_result":{"type":"text","file":{"filePath":"/Users/dicoangelo/projects/core/meta-vengine/coordinator/supermax.py","content":"#!/usr/bin/env python3\n\"\"\"\nSUPERMAX v2 — Adaptive Agent Count with Difficulty-Aware Spawning.\n\nUS-007: Dynamically selects agent count (1-5) based on graphComplexity\nfrom the multi-feature graph signal (US-004). Simple queries use 1 agent,\ncomplex queries get full council evaluation.\n\nAgent priority order:\n  1. Principal Engineer (technical correctness, waste penalties)\n  2. Security Architect (risk, safety margins, compliance)\n  3. Product Strategist (user value, speed, cost)\n  4. Contrarian (adversarial challenge, from ACE)\n  5. Arbiter (final adjudication, cross-perspective synthesis)\n\nAll thresholds stored in config/supermax-v2.json (learnable, not hardcoded).\n\"\"\"\n\nimport json\nimport sys\nimport os\nimport time\nfrom pathlib import Path\nfrom datetime import datetime\nfrom dataclasses import dataclass, field\nfrom typing import List, Optional, Dict, Any\n\n# Resolve paths relative to the meta-vengine root\n_ROOT = Path(__file__).resolve().parent.parent\n_CONFIG_PATH = _ROOT / \"config\" / \"supermax-v2.json\"\n_COSTS_DIR = _ROOT / \"data\"\n\n\n@dataclass\nclass AgentSpec:\n    \"\"\"Specification for a SUPERMAX agent to spawn.\"\"\"\n    name: str\n    perspective: str\n    model: str\n    index: int  # priority order (0-based)\n\n\n@dataclass\nclass SpawnPlan:\n    \"\"\"Result of PredictiveSpawner.plan() — describes which agents to spawn.\"\"\"\n    graph_complexity: float\n    difficulty_tier: str\n    agent_count: int\n    agents: List[AgentSpec]\n    thresholds_used: Dict[str, Any]\n\n\ndef load_config(config_path: Path = None) -> dict:\n    \"\"\"Load SUPERMAX v2 config from JSON. Falls back to defaults if missing.\"\"\"\n    path = config_path or _CONFIG_PATH\n    try:\n        if path.exists():\n            with open(path, \"r\") as f:\n                return json.load(f)\n    except (json.JSONDecodeError, OSError):\n        pass\n    # Emergency fallback — should never be used in production\n    return {\n        \"agentCountThresholds\": {\n            \"trivial\": {\"max\": 0.25, \"agentCount\": 1},\n            \"simple\": {\"max\": 0.45, \"agentCount\": 2},\n            \"moderate\": {\"max\": 0.65, \"agentCount\": 3},\n            \"complex\": {\"max\": 0.85, \"agentCount\": 4},\n            \"expert\": {\"max\": 1.00, \"agentCount\": 5},\n        },\n        \"agentPriority\": [\n            {\"name\": \"PrincipalEngineer\", \"perspective\": \"Technical correctness, waste penalties\", \"model\": \"sonnet\"},\n            {\"name\": \"SecurityArchitect\", \"perspective\": \"Risk, safety margins, compliance\", \"model\": \"sonnet\"},\n            {\"name\": \"ProductStrategist\", \"perspective\": \"User value, speed, cost\", \"model\": \"sonnet\"},\n            {\"name\": \"Contrarian\", \"perspective\": \"Adversarial challenge, assumption stress-testing\", \"model\": \"sonnet\"},\n            {\"name\": \"Arbiter\", \"perspective\": \"Final adjudication, cross-perspective synthesis\", \"model\": \"opus\"},\n        ],\n        \"constraints\": {\"minAgents\": 1, \"maxAgents\": 5, \"defaultAgentCount\": 3},\n    }\n\n\nclass PredictiveSpawner:\n    \"\"\"\n    Difficulty-aware agent spawner for SUPERMAX v2.\n\n    Consumes graphComplexity (0.0-1.0) from the multi-feature graph signal\n    (US-004) and selects the appropriate number of council agents.\n\n    Thresholds and agent definitions are loaded from config/supermax-v2.json\n    (learnable — future Optimas LRF).\n    \"\"\"\n\n    def __init__(self, config_path: Path = None):\n        self.config = load_config(config_path)\n        self._thresholds = self._parse_thresholds()\n        self._agents = self._parse_agents()\n        self._constraints = self.config.get(\"constraints\", {})\n\n    def _parse_thresholds(self) -> List[dict]:\n        \"\"\"Parse and sort thresholds by max value ascending.\"\"\"\n        raw = self.config.get(\"agentCountThresholds\", {})\n        tiers = []\n        for tier_name, tier_data in raw.items():\n            tiers.append({\n                \"tier\": tier_name,\n                \"max\": tier_data[\"max\"],\n                \"agentCount\": tier_data[\"agentCount\"],\n            })\n        tiers.sort(key=lambda t: t[\"max\"])\n        return tiers\n\n    def _parse_agents(self) -> List[AgentSpec]:\n        \"\"\"Parse agent priority list from config.\"\"\"\n        raw = self.config.get(\"agentPriority\", [])\n        agents = []\n        for i, entry in enumerate(raw):\n            agents.append(AgentSpec(\n                name=entry[\"name\"],\n                perspective=entry.get(\"perspective\", \"\"),\n                model=entry.get(\"model\", \"sonnet\"),\n                index=i,\n            ))\n        return agents\n\n    def classify_difficulty(self, graph_complexity: float) -> tuple:\n        \"\"\"\n        Classify a graphComplexity score into a difficulty tier and agent count.\n\n        Args:\n            graph_complexity: 0.0-1.0 composite score from computeGraphSignal()\n\n        Returns:\n            (tier_name, agent_count) tuple\n        \"\"\"\n        clamped = max(0.0, min(1.0, graph_complexity))\n\n        for tier in self._thresholds:\n            if clamped < tier[\"max\"] or (clamped == tier[\"max\"] and tier[\"tier\"] == \"expert\"):\n                return tier[\"tier\"], tier[\"agentCount\"]\n\n        # Fallback: if complexity exactly equals 1.0 and no tier matched\n        if self._thresholds:\n            last = self._thresholds[-1]\n            return last[\"tier\"], last[\"agentCount\"]\n\n        # Ultimate fallback\n        default_count = self._constraints.get(\"defaultAgentCount\", 3)\n        return \"unknown\", default_count\n\n    def select_agents(self, count: int) -> List[AgentSpec]:\n        \"\"\"\n        Select agents in priority order up to the given count.\n\n        Priority: PrincipalEngineer > SecurityArchitect > ProductStrategist > Contrarian > Arbiter\n\n        Args:\n            count: Number of agents to select (1-5)\n\n        Returns:\n            List of AgentSpec in priority order\n        \"\"\"\n        min_agents = self._constraints.get(\"minAgents\", 1)\n        max_agents = self._constraints.get(\"maxAgents\", 5)\n        clamped_count = max(min_agents, min(max_agents, count))\n\n        return self._agents[:clamped_count]\n\n    def plan(self, graph_complexity: float) -> SpawnPlan:\n        \"\"\"\n        Create a spawn plan based on graphComplexity.\n\n        This is the main entry point — takes a difficulty score and returns\n        a complete plan for which agents to spawn.\n\n        Args:\n            graph_complexity: 0.0-1.0 from computeGraphSignal() (US-004)\n\n        Returns:\n            SpawnPlan with tier, count, and agent list\n        \"\"\"\n        tier, count = self.classify_difficulty(graph_complexity)\n        agents = self.select_agents(count)\n\n        return SpawnPlan(\n            graph_complexity=graph_complexity,\n            difficulty_tier=tier,\n            agent_count=len(agents),\n            agents=agents,\n            thresholds_used={t[\"tier\"]: t for t in self._thresholds},\n        )\n\n    def plan_with_default(self, graph_complexity: Optional[float] = None) -> SpawnPlan:\n        \"\"\"\n        Plan with graceful degradation when graphComplexity is unavailable.\n\n        Falls back to the default agent count from config when no\n        graph signal is available.\n\n        Args:\n            graph_complexity: 0.0-1.0 or None if unavailable\n\n        Returns:\n            SpawnPlan\n        \"\"\"\n        if graph_complexity is not None:\n            return self.plan(graph_complexity)\n\n        # Fallback: use default agent count\n        default_count = self._constraints.get(\"defaultAgentCount\", 3)\n        agents = self.select_agents(default_count)\n\n        return SpawnPlan(\n            graph_complexity=-1.0,  # sentinel: unavailable\n            difficulty_tier=\"default\",\n            agent_count=len(agents),\n            agents=agents,\n            thresholds_used={t[\"tier\"]: t for t in self._thresholds},\n        )\n\n\ndef log_supermax_cost(\n    query_hash: str,\n    agent_count: int,\n    difficulty_tier: str,\n    graph_complexity: float,\n    agents_used: List[str],\n    cost_estimate: float = 0.0,\n    log_dir: Path = None,\n):\n    \"\"\"\n    Append cost tracking entry to data/supermax-costs.jsonl.\n\n    Args:\n        query_hash: MD5 hash of the query\n        agent_count: Number of agents spawned\n        difficulty_tier: Classified difficulty tier\n        graph_complexity: The graphComplexity score used\n        agents_used: List of agent names\n        cost_estimate: Estimated USD cost\n        log_dir: Override for the data directory\n    \"\"\"\n    out_dir = log_dir or _COSTS_DIR\n    out_dir.mkdir(parents=True, exist_ok=True)\n    log_path = out_dir / \"supermax-costs.jsonl\"\n\n    entry = {\n        \"ts\": datetime.now(tz=__import__('datetime').timezone.utc).isoformat(),\n        \"query_hash\": query_hash,\n        \"agent_count\": agent_count,\n        \"difficulty_tier\": difficulty_tier,\n        \"graph_complexity\": graph_complexity,\n        \"agents_used\": agents_used,\n        \"cost_estimate\": cost_estimate,\n    }\n\n    with open(log_path, \"a\") as f:\n        f.write(json.dumps(entry) + \"\\n\")\n\n\n# ─────────────────────────────────────────────────────────────────────────────\n# CLI interface\n# ─────────────────────────────────────────────────────────────────────────────\n\ndef main():\n    \"\"\"CLI entry point for SUPERMAX v2.\"\"\"\n    import argparse\n\n    parser = argparse.ArgumentParser(\n        description=\"SUPERMAX v2 — Adaptive Agent Count\",\n        formatter_class=argparse.RawDescriptionHelpFormatter,\n        epilog=\"\"\"\nExamples:\n  python3 coordinator/supermax.py plan 0.15    # trivial → 1 agent\n  python3 coordinator/supermax.py plan 0.50    # moderate → 3 agents\n  python3 coordinator/supermax.py plan 0.90    # expert → 5 agents\n  python3 coordinator/supermax.py classify 0.30  # → simple, 2 agents\n        \"\"\",\n    )\n\n    parser.add_argument(\"command\", choices=[\"plan\", \"classify\", \"config\"])\n    parser.add_argument(\"complexity\", nargs=\"?\", type=float, help=\"graphComplexity (0.0-1.0)\")\n\n    args = parser.parse_args()\n\n    spawner = PredictiveSpawner()\n\n    if args.command == \"config\":\n        print(json.dumps(spawner.config, indent=2))\n\n    elif args.command == \"classify\":\n        if args.complexity is None:\n            parser.error(\"classify requires a complexity value\")\n        tier, count = spawner.classify_difficulty(args.complexity)\n        print(f\"Complexity: {args.complexity}\")\n        print(f\"Tier: {tier}\")\n        print(f\"Agent count: {count}\")\n\n    elif args.command == \"plan\":\n        if args.complexity is None:\n            parser.error(\"plan requires a complexity value\")\n        plan = spawner.plan(args.complexity)\n        print(f\"Complexity: {plan.graph_complexity}\")\n        print(f\"Tier: {plan.difficulty_tier}\")\n        print(f\"Agent count: {plan.agent_count}\")\n        print(f\"Agents:\")\n        for a in plan.agents:\n            print(f\"  {a.index + 1}. {a.name} ({a.model}) — {a.perspective}\")\n\n\nif __name__ == \"__main__\":\n    main()\n","numLines":312,"startLine":1,"totalLines":312}}}
