, 0.0, 0.0, 0.0)),","+        ]","+        trajs[0].trajectory_weight = 0.9","+        trajs[1].trajectory_weight = 0.1","+        c = synthesize_consensus(trajs)","+        assert abs(c[\"validity\"] - 0.9) < 0.01","+        assert abs(c[\"composite_dq\"] - 0.9) < 0.01"," ","-# Skewed weights → weighted toward dominant","-sk_trajs = [","-    AgentTrajectory(\"A\", DQEvaluation(\"A\", 1.0, 1.0, 1.0), DQEvaluation(\"A\", 1.0, 1.0, 1.0)),","-    AgentTrajectory(\"B\", DQEvaluation(\"B\", 0.0, 0.0, 0.0), DQEvaluation(\"B\", 0.0, 0.0, 0.0)),","-]","-sk_trajs[0].trajectory_weight = 0.9","-sk_trajs[1].trajectory_weight = 0.1","-consensus_sk = synthesize_consensus(sk_trajs)","-assert_close(consensus_sk[\"validity\"], 0.9, \"skewed weight → dominant agent\")","-assert_close(consensus_sk[\"composite_dq\"], 0.9, \"skewed composite\")"," ","+# ─── FreeMadSynthesizer E2E ────────────────────────────────────────────────"," ","-# ─── FreeMadSynthesizer End-to-End ──────────────────────────────────────────","+class TestFreeMadSynthesizer:","+    @pytest.fixture","+    def synth(self):","+        return FreeMadSynthesizer()"," ","-print(\"\\n=== FreeMadSynthesizer E2E ===\")","+    @pytest.fixture","+    def standard_evals(self):","+        r1 = [","+            DQEvaluation(\"PrincipalEngineer\", 0.8, 0.7, 0.9, \"Tech solid\"),","+            DQEvaluation(\"SecurityArchitect\", 0.6, 0.8, 0.7, \"Risky\"),","+            DQEvaluation(\"ProductStrategist\", 0.9, 0.6, 0.8, \"User value\"),","+        ]","+        r2 = [","+            DQEvaluation(\"PrincipalEngineer\", 0.8, 0.72, 0.88, \"Held position\"),","+            DQEvaluation(\"SecurityArchitect\", 0.78, 0.75, 0.82, \"Shifted a lot\"),","+            DQEvaluation(\"ProductStrategist\", 0.85, 0.65, 0.8, \"Minor shift\"),","+        ]","+        return r1, r2"," ","-synth = FreeMadSynthesizer()","+    def test_returns_synthesis_result(self, synth, standard_evals):","+        r1, r2 = standard_evals","+        result = synth.synthesize(r1, r2)","+        assert isinstance(result, SynthesisResult)"," ","-# Standard case: 3 agents, varying stability","-r1 = [","-    DQEvaluation(\"PrincipalEngineer\", 0.8, 0.7, 0.9, \"Tech solid\"),","-    DQEvaluation(\"SecurityArchitect\", 0.6, 0.8, 0.7, \"Risky\"),","-    DQEvaluation(\"ProductStrategist\", 0.9, 0.6, 0.8, \"User value\"),","-]","-r2 = [","-    DQEvaluation(\"PrincipalEngineer\", 0.8, 0.72, 0.88, \"Held position\"),","-    DQEvaluation(\"SecurityArchitect\", 0.78, 0.75, 0.82, \"Shifted a lot\"),","-    DQEvaluation(\"ProductStrategist\", 0.85, 0.65, 0.8, \"Minor shift\"),","-]","+    def test_consensus_in_range(self, synth, standard_evals):","+        r1, r2 = standard_evals","+        result = synth.synthesize(r1, r2)","+        assert 0.0 <= result.consensus_dq <= 1.0"," ","-result = synth.synthesize(r1, r2)","-assert_true(isinstance(result, SynthesisResult), \"returns SynthesisResult\")","-assert_true(0.0 <= result.consensus_dq <= 1.0, \"consensus DQ in range\")","-assert_true(len(result.trajectories) == 3, \"3 trajectories\")","-assert_true(result.method == \"free_mad_trajectory\", \"method is free_mad_trajectory\")","-assert_true(not result.sycophancy_flagged, \"no sycophancy in standard case\")","+    def test_correct_trajectory_count(self, synth, standard_evals):","+        r1, r2 = standard_evals","+        result = synth.synthesize(r1, r2)","+        assert len(result.trajectories) == 3"," ","-# Verify stable agent (Engineer) gets higher weight than unstable (Architect)","-eng_traj = result.trajectories[0]","-arch_traj = result.trajectories[1]","-assert_true(","-    eng_traj.trajectory_weight > arch_traj.trajectory_weight,","-    \"Engineer (stable) > Architect (shifted)\"","-)","+    def test_method_label(self, synth, standard_evals):","+        r1, r2 = standard_evals","+        result = synth.synthesize(r1, r2)","+        assert result.method == \"free_mad_trajectory\""," ","-# Mismatched round counts → error","-try:","-    synt