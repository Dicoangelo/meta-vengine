[0][\"evaluator\"] == \"Evaluator A\"","+        assert anon[1][\"evaluator\"] == \"Evaluator B\"","+        assert anon[2][\"evaluator\"] == \"Evaluator C\""," ","-# Verify agent names are NOT in anonymized output","-for entry in anon:","-    text = json.dumps(entry)","-    assert_true(\"PrincipalEngineer\" not in text, f\"no agent name in {entry['evaluator']}\")","-    assert_true(\"SecurityArchitect\" not in text, f\"no agent name in {entry['evaluator']}\")","-    assert_true(\"ProductStrategist\" not in text, f\"no agent name in {entry['evaluator']}\")","+    def test_agent_names_stripped(self, evals):","+        anon = anonymize_reasoning(evals)","+        all_text = json.dumps(anon)","+        assert \"PrincipalEngineer\" not in all_text","+        assert \"SecurityArchitect\" not in all_text","+        assert \"ProductStrategist\" not in all_text"," ","-# Verify scores are preserved","-assert_close(anon[0][\"scores\"][\"validity\"], 0.8, \"anon scores preserved\")","-assert_true(anon[0][\"reasoning\"] == \"Tech analysis\", \"anon reasoning preserved\")","+    def test_scores_preserved(self, evals):","+        anon = anonymize_reasoning(evals)","+        assert abs(anon[0][\"scores\"][\"validity\"] - 0.8) < 0.001"," ","+    def test_reasoning_preserved(self, evals):","+        anon = anonymize_reasoning(evals)","+        assert anon[0][\"reasoning\"] == \"Tech analysis\""," ","+"," # ─── Stability Score ────────────────────────────────────────────────────────"," ","-print(\"\\n=== Stability Score ===\")","+class TestStabilityScore:","+    def test_zero_delta_perfect_stability(self):","+        t = AgentTrajectory(","+            \"Stable\",","+            DQEvaluation(\"Stable\", 0.8, 0.7, 0.9),","+            DQEvaluation(\"Stable\", 0.8, 0.7, 0.9),","+        )","+        assert abs(compute_stability_score(t) - 1.0) < 0.001"," ","-# Perfectly stable agent (delta = 0)","-t_stable = AgentTrajectory(","-    \"Stable\",","-    DQEvaluation(\"Stable\", 0.8, 0.7, 0.9),","-    DQEvaluation(\"Stable\", 0.8, 0.7, 0.9),","-)","-assert_close(compute_stability_score(t_stable), 1.0, \"zero delta → stability 1.0\")","+    def test_large_delta_low_stability(self):","+        t = AgentTrajectory(","+            \"Unstable\",","+            DQEvaluation(\"Unstable\", 0.2, 0.3, 0.1),","+            DQEvaluation(\"Unstable\", 0.9, 0.8, 0.9),","+        )","+        assert compute_stability_score(t) < 0.1"," ","-# Completely unstable agent (large delta)","-t_unstable = AgentTrajectory(","-    \"Unstable\",","-    DQEvaluation(\"Unstable\", 0.2, 0.3, 0.1),","-    DQEvaluation(\"Unstable\", 0.9, 0.8, 0.9),","-)","-stability_unstable = compute_stability_score(t_unstable)","-assert_true(stability_unstable < 0.1, f\"large delta → low stability ({stability_unstable:.4f})\")","+    def test_moderate_delta_mid_stability(self):","+        t = AgentTrajectory(","+            \"Moderate\",","+            DQEvaluation(\"Moderate\", 0.7, 0.6, 0.8),","+            DQEvaluation(\"Moderate\", 0.75, 0.65, 0.85),","+        )","+        s = compute_stability_score(t)","+        assert 0.3 < s < 0.9"," ","-# Moderate delta","-t_moderate = AgentTrajectory(","-    \"Moderate\",","-    DQEvaluation(\"Moderate\", 0.7, 0.6, 0.8),","-    DQEvaluation(\"Moderate\", 0.75, 0.65, 0.85),","-)","-stability_mod = compute_stability_score(t_moderate)","-assert_true(0.3 < stability_mod < 0.9, f\"moderate delta → mid stability ({stability_mod:.4f})\")","+    def test_exponential_decay_formula(self):","+        t = AgentTrajectory(","+            \"Known\",","+            DQEvaluation(\"Known\", 0.5, 0.5, 0.5),","+            DQEvaluation(\"Known\", 0.6, 0.5, 0.5),","+        )","+        expected = math.exp(-5.0 * 0.1)","+        assert abs(compute_stability_score(t) - expected) < 0.001"," ","-# Verify exponential decay formula","-delta = 0.1","-expected = math.exp(-5.0 * delta)","-t_known = AgentTrajectory(","-    \"Known\",","-    DQEvaluation(\"Known\", 0.5, 0.5, 0.5),","-    DQEvaluation(\"Known\", 0.6, 0.5, 0.5),  # delta_validity = 0.1","-)","-assert_close(compute_stability_score(t_known), expected, \"exp decay formula matches\")","+    def test_custom_decay_rate(self):","+        t = AgentTrajectory(","+            \"Known\",","+            DQEvaluation(\"Known\", 0.5, 0.5, 0.5),","+            DQEvaluation(\"Known\", 0.6, 0.5, 0.5),","+        )","+        expected = math.exp(-10.0 * 0.1)","+        assert abs(compute_stability_score(t, decay_rate=10.0) - expected) < 0.001"," ","-# Custom decay rate","-assert_close(","-    compute_stability_score(t_known, decay_rate=10.0),","-    math.exp(-10.0 * 0.1),","-    \"custom decay rate\"","-)"," ","-"," # ─── Trajectory Weights ────────────────────────────────────────────────────"," ","-print(\"\\n=== Trajectory Weights ===\")","+class TestTrajectoryWeights:","+    @pytest.fixture","+    def trajectories(self):","+        t_stable = AgentTrajectory(","+            \"Stable\",","+            DQEvaluation(\"Stable\", 0.8, 0.7, 0.9),","+            DQEvaluation(\"Stable\", 0.8, 0.7, 0.9),","+        )","+        t_unstable = AgentTrajectory(","+            \"Unstable\",","+            DQEvaluation(\"Unstable\", 0.2, 0.3, 0.1),","+            DQEvaluation(\"Unstable\", 0.9, 0.8, 0.9),","+        )","+        t_moderate = AgentTrajectory(","+            \"Moderate\",","+            DQEvaluation(\"Moderate\", 0.7, 0.6, 0.8),","+            DQEvaluation(\"Moderate\", 0.75, 0.65, 0.85),","+        )","+        return [t_stable, t_unstable, t_moderate]"," ","-trajectories = [t_stable, t_unstable, t_moderate]","-weighted = compute_trajectory_weights(trajectories)","+    def test_stable_gets_highest_weight(self, trajectories):","+        compute_trajectory_weights(trajectories)","+        assert trajectories[0].trajectory_weight > trajectories[1].trajectory_weight"," ","-# Stable agent should get highest weight","-assert_true(","-    t_stable.trajectory_weight > t_unstable.trajectory_weight,","-    \"stable agent gets higher weight than unstable\"","-)","+    def test_weights_sum_to_one(self, trajectories):","+        compute_trajectory_weights(trajectories)","+        total = sum(t.trajectory_weight for t in trajectories)","+        assert abs(total - 1.0) < 0.001"," ","-# Weights sum to 1.0","-total_weight = sum(t.trajectory_weight for t in weighted)","-assert_close(total_weight, 1.0, \"weights sum to 1.0\")","+    def test_all_weights_positive(self, trajectories):","+        compute_trajectory_weights(trajectories)","+        for t in trajectories:","+            assert t.trajectory_weight > 0"," ","-# All weights > 0 (min weight guarantee)","-for t in weighted:","-    assert_true(t.trajectory_weight > 0, f\"{t.agent_name} weight > 0\")","+    def test_equal_stability_uniform_weights(self):","+        trajs = [","+            AgentTrajectory(\"A\", DQEvaluation(\"A\", 0.5, 0.5, 0.5), DQEvaluation(\"A\", 0.5, 0.5, 0.5)),","+            AgentTrajectory(\"B\", DQEvaluation(\"B\", 0.5, 0.5, 0.5), DQEvaluation(\"B\", 0.5, 0.5, 0.5)),","+            AgentTrajectory(\"C\", DQEvaluation(\"C\", 0.5, 0.5, 0.5), DQEvaluation(\"C\", 0.5, 0.5, 0.5)),","+        ]","+        compute_trajectory_weights(trajs)","+        for t in trajs:","+            assert abs(t.trajectory_weight - 1.0 / 3) < 0.01"," ","-# Uniform case: all equally stable","-equal_trajs = [","-    AgentTrajectory(\"A\", DQEvaluation(\"A\", 0.5, 0.5, 0.5), DQEvaluation(\"A\", 0.5, 0.5, 0.5)),","-    AgentTrajectory(\"B\", DQEvaluation(\"B\", 0.5, 0.5, 0.5), DQEvaluation(\"B\", 0.5, 0.5, 0.5)),","-    AgentTrajectory(\"C\", DQEvaluation(\"C\", 0.5, 0.5, 0.5), DQEvaluation(\"C\", 0.5, 0.5, 0.5)),","-]","-compute_trajectory_weights(equal_trajs)","-for t in equal_trajs:","-    assert_close(t.trajectory_weight, 1.0 / 3, f\"equal stability → uniform weight ({t.agent_name})\")"," ","-"," # ─── Sycophancy Detection ──────────────────────────────────────────────────"," ","-print(\"\\n=== Sycophancy Detection ===\")","+class TestSycophancyDetection:","+    def test_unanimous_convergence_flagged(self):","+        trajs = [","+            AgentTrajectory(\"A\", DQEvaluation(\"A\", 0.9, 0.9, 0.9), DQEvaluation(\"A\", 0.7, 0.7, 0.7)),","+            AgentTrajectory(\"B\", DQEvaluation(\"B\", 0.5, 0.5, 0.5), DQEvaluation(\"B\", 0.7, 0.7, 0.7)),","+            AgentTrajectory(\"C\", DQEvaluation(\"C\", 0.7, 0.7, 0.7), DQEvaluation(\"C\", 0.71, 0.71, 0.71)),","+        ]","+        assert detect_sycophancy(trajs, 0.05)"," ","-# Sycophancy case: all agents converge to same score after initially disagreeing","-syc_trajs = [","-    AgentTrajectory(","-        \"A\",","-        DQEvaluation(\"A\", 0.9, 0.9, 0.9),  # R1: high","-        DQEvaluation(\"A\", 0.7, 0.7, 0.7),  # R2: converged to 0.7","-    ),","-    AgentTrajectory(","-        \"B\",","-        DQEvaluation(\"B\", 0.5, 0.5, 0.5),  # R1: low","-        DQEvaluation(\"B\", 0.7, 0.7, 0.7),  # R2: converged to 0.7","-    ),","-    AgentTrajectory(","-        \"C\",","-        DQEvaluation(\"C\", 0.7, 0.7, 0.7),  # R1: medium","-        DQEvaluation(\"C\", 0.71, 0.71, 0.71),  # R2: converged to ~0.7","-    ),","-]","-assert_true(detect_sycophancy(syc_trajs, 0.05), \"unanimous convergence → sycophancy flagged\")","+    def test_one_agent_holds_no_sycophancy(self):","+        trajs = [","+            AgentTrajectory(\"A\", DQEvaluation(\"A\", 0.9, 0.9, 0.9), DQEvaluation(\"A\", 0.9, 0.9, 0.9)),","+            AgentTrajectory(\"B\", DQEvaluation(\"B\", 0.5, 0.5, 0.5), DQEvaluation(\"B\", 0.55, 0.55, 0.55)),","+        ]","+        assert not detect_sycophancy(trajs, 0.05)"," ","-# Non-sycophancy: agents hold positions","-non_syc_trajs = [","-    AgentTrajectory(","-        \"A\",","-        DQEvaluation(\"A\", 0.9, 0.9, 0.9),","-        DQEvaluation(\"A\", 0.9, 0.9, 0.9),  # Held position (delta = 0)","-    ),","-    AgentTrajectory(","-        \"B\",","-        DQEvaluation(\"B\", 0.5, 0.5, 0.5),","-        DQEvaluation(\"B\", 0.55, 0.55, 0.55),  # Minor shift","-    ),","-]","-assert_true(not detect_sycophancy(non_syc_trajs, 0.05), \"one agent held → no sycophancy\")","+    def test_single_agent_no_sycophancy(self):","+        trajs = [AgentTrajectory(\"A\", DQEvaluation(\"A\", 0.5, 0.5, 0.5), DQEvaluation(\"A\", 0.7, 0.7, 0.7))]","+        assert not detect_sycophancy(trajs)"," ","-# Single agent: cannot have sycophancy","-single = [AgentTrajectory(\"A\", DQEvaluation(\"A\", 0.5, 0.5, 0.5), DQEvaluation(\"A\", 0.7, 0.7, 0.7))]","-assert_true(not detect_sycophancy(single), \"single agent → no sycophancy\")","+    def test_no_initial_disagreement_no_sycophancy(self):","+        trajs = [","+            AgentTrajectory(\"A\", DQEvaluation(\"A\", 0.7, 0.7, 0.7), DQEvaluation(\"A\", 0.71, 0.71, 0.71)),","+            AgentTrajectory(\"B\", DQEvaluation(\"B\", 0.7, 0.7, 0.7), DQEvaluation(\"B\", 0.72, 0.72, 0.72)),","+        ]","+        assert not detect_sycophancy(trajs, 0.05)"," ","-# No initial disagreement: all start and end similar","-no_disagree = [","-    AgentTrajectory(\"A\", DQEvaluation(\"A\", 0.7, 0.7, 0.7), DQEvaluation(\"A\", 0.71, 0.71, 0.71)),","-    AgentTrajectory(\"B\", DQEvaluation(\"B\", 0.7, 0.7, 0.7), DQEvaluation(\"B\", 0.72, 0.72, 0.72)),","-]","-assert_true(not detect_sycophancy(no_disagree, 0.05), \"no initial disagreement → no sycophancy\")"," ","-"," # ─── Disagreement Dimensions ───────────────────────────────────────────────"," ","-print(\"\\n=== Disagreement Dimensions ===\")","+class TestDisagreementDimensions:","+    def test_validity_diverges(self):","+        trajs = [","+            AgentTrajectory(\"A\", DQEvaluation(\"A\", 0.9, 0.7, 0.8), DQEvaluation(\"A\", 0.9, 0.7, 0.8)),","+            AgentTrajectory(\"B\", DQEvaluation(\"B\", 0.5, 0.7, 0.8), DQEvaluation(\"B\", 0.5, 0.7, 0.8)),","+        ]","+        dims = find_disagreement_dimensions(trajs, 0.15)","+        assert \"validity\" in dims","+        assert \"specificity\" not in dims","+        assert \"correctness\" not in dims"," ","-# Validity diverges, others agree","-div_trajs = [","-    AgentTrajectory(","-        \"A\",","-        DQEvaluation(\"A\", 0.9, 0.7, 0.8),","-        DQEvaluation(\"A\", 0.9, 0.7, 0.8),","-    ),","-    AgentTrajectory(","-        \"B\",","-        DQEvaluation(\"B\", 0.5, 0.7, 0.8),","-        DQEvaluation(\"B\", 0.5, 0.7, 0.8),","-    ),","-]","-dims = find_disagreement_dimensions(div_trajs, 0.15)","-assert_true(\"validity\" in dims, \"validity diverges → in disagreement dims\")","-assert_true(\"specificity\" not in dims, \"specificity agrees → not in disagreement dims\")","-assert_true(\"correctness\" not in dims, \"correctness agrees → not in disagreement dims\")","+    def test_all_agree_no_dimensions(self):","+        trajs = [","+            AgentTrajectory(\"A\", DQEvaluation(\"A\", 0.7, 0.7, 0.7), DQEvaluation(\"A\", 0.7, 0.7, 0.7)),","+            AgentTrajectory(\"B\", DQEvaluation(\"B\", 0.75, 0.72, 0.73), DQEvaluation(\"B\", 0.75, 0.72, 0.73)),","+        ]","+        assert len(find_disagreement_dimensions(trajs, 0.15)) == 0"," ","-# All agree within threshold","-agree_trajs = [","-    AgentTrajectory(\"A\", DQEvaluation(\"A\", 0.7, 0.7, 0.7), DQEvaluation(\"A\", 0.7, 0.7, 0.7)),","-    AgentTrajectory(\"B\", DQEvaluation(\"B\", 0.75, 0.72, 0.73), DQEvaluation(\"B\", 0.75, 0.72, 0.73)),","-]","-dims_none = find_disagreement_dimensions(agree_trajs, 0.15)","-assert_true(len(dims_none) == 0, \"all agree → no disagreement dimensions\")","+    def test_all_dimensions_diverge(self):","+        trajs = [","+            AgentTrajectory(\"A\", DQEvaluation(\"A\", 0.9, 0.9, 0.9), DQEvaluation(\"A\", 0.9, 0.9, 0.9)),","+            AgentTrajectory(\"B\", DQEvaluation(\"B\", 0.5, 0.5, 0.5), DQEvaluation(\"B\", 0.5, 0.5, 0.5)),","+        ]","+        assert len(find_disagreement_dimensions(trajs, 0.15)) == 3"," ","-# Multiple divergent dimensions","-multi_div = [","-    AgentTrajectory(\"A\", DQEvaluation(\"A\", 0.9, 0.9, 