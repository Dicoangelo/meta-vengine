{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WAX9CT4zjyF8rEosUc2fba","type":"tool_result","content":"     1→#!/usr/bin/env node\n     2→/**\n     3→ * Decision Quality (DQ) Scorer - ACE Framework Implementation\n     4→ *\n     5→ * Based on: OS-App Adaptive Convergence Engine (ACE) DQ Framework\n     6→ * Measures: validity (0.4) + specificity (0.3) + correctness (0.3)\n     7→ *\n     8→ * Scores routing decisions and learns from history.\n     9→ */\n    10→\n    11→const fs = require('fs');\n    12→const path = require('path');\n    13→const crypto = require('crypto');\n    14→const { estimateComplexity } = require('./complexity-analyzer');\n    15→const { PRICING } = require(path.join(process.env.HOME, '.claude/config/pricing.js'));\n    16→\n    17→// ═══════════════════════════════════════════════════════════════════════════\n    18→// BASELINES LOADING\n    19→// ═══════════════════════════════════════════════════════════════════════════\n    20→\n    21→const BASELINES_PATH = path.join(process.env.HOME, '.claude/kernel/baselines.json');\n    22→\n    23→function loadBaselines() {\n    24→  if (!fs.existsSync(BASELINES_PATH)) {\n    25→    return null;  // Use hardcoded defaults\n    26→  }\n    27→\n    28→  try {\n    29→    const data = fs.readFileSync(BASELINES_PATH, 'utf8');\n    30→    return JSON.parse(data);\n    31→  } catch (e) {\n    32→    console.error('Error loading baselines:', e.message);\n    33→    return null;\n    34→  }\n    35→}\n    36→\n    37→const BASELINES = loadBaselines();\n    38→\n    39→// ═══════════════════════════════════════════════════════════════════════════\n    40→// DQ WEIGHTS (from ACE Framework + Cognitive OS adjustments)\n    41→// ═══════════════════════════════════════════════════════════════════════════\n    42→\n    43→const COGNITIVE_DQ_WEIGHTS_PATH = path.join(process.env.HOME, '.claude/kernel/cognitive-os/cognitive-dq-weights.json');\n    44→const EXPERTISE_ROUTING_STATE_PATH = path.join(process.env.HOME, '.claude/kernel/expertise-routing-state.json');\n    45→\n    46→function loadCognitiveDQWeights() {\n    47→  // Try to load cognitive-aware weights from Cognitive OS\n    48→  if (fs.existsSync(COGNITIVE_DQ_WEIGHTS_PATH)) {\n    49→    try {\n    50→      const data = JSON.parse(fs.readFileSync(COGNITIVE_DQ_WEIGHTS_PATH, 'utf8'));\n    51→      const fileAge = Date.now() - new Date(data.timestamp).getTime();\n    52→      // Only use if less than 30 minutes old\n    53→      if (fileAge < 30 * 60 * 1000 && data.dq_weights) {\n    54→        return {\n    55→          weights: data.dq_weights,\n    56→          complexityModifier: data.complexity_threshold_modifier || 1.0,\n    57→          cognitiveMode: data.cognitive_mode,\n    58→          reasoning: data.reasoning\n    59→        };\n    60→      }\n    61→    } catch (e) {\n    62→      // Fall through to defaults\n    63→    }\n    64→  }\n    65→  return null;\n    66→}\n    67→\n    68→const COGNITIVE_WEIGHTS = loadCognitiveDQWeights();\n    69→\n    70→const DQ_WEIGHTS = COGNITIVE_WEIGHTS?.weights || BASELINES?.dq_weights || {\n    71→  validity: 0.4,      // Does the routing make logical sense?\n    72→  specificity: 0.3,   // How precise is the model selection?\n    73→  correctness: 0.3    // Historical accuracy of similar queries\n    74→};\n    75→\n    76→// Complexity threshold modifier from Cognitive OS (affects model selection boundaries)\n    77→const COMPLEXITY_MODIFIER = COGNITIVE_WEIGHTS?.complexityModifier || 1.0;\n    78→\n    79→// ═══════════════════════════════════════════════════════════════════════════\n    80→// EXPERTISE ROUTING\n    81→// ═══════════════════════════════════════════════════════════════════════════\n    82→\n    83→function loadExpertiseState() {\n    84→  if (fs.existsSync(EXPERTISE_ROUTING_STATE_PATH)) {\n    85→    try {\n    86→      const data = JSON.parse(fs.readFileSync(EXPERTISE_ROUTING_STATE_PATH, 'utf8'));\n    87→      const fileAge = Date.now() - new Date(data.timestamp).getTime();\n    88→      // Use if less than 1 hour old\n    89→      if (fileAge < 60 * 60 * 1000) {\n    90→        return data;\n    91→      }\n    92→    } catch (e) {}\n    93→  }\n    94→  return null;\n    95→}\n    96→\n    97→const EXPERTISE_STATE = loadExpertiseState();\n    98→\n    99→/**\n   100→ * Detect domain of query and check expertise level\n   101→ */\n   102→function getExpertiseAdjustment(query) {\n   103→  if (!EXPERTISE_STATE) return null;\n   104→\n   105→  const highExpertise = EXPERTISE_STATE.high_expertise_domains || [];\n   106→  const lowExpertise = EXPERTISE_STATE.low_expertise_domains || [];\n   107→  const queryLower = query.toLowerCase();\n   108→\n   109→  // Check if query matches high expertise domains\n   110→  for (const domain of highExpertise) {\n   111→    if (queryLower.includes(domain) ||\n   112→        (domain === 'react' && (queryLower.includes('component') || queryLower.includes('hook'))) ||\n   113→        (domain === 'typescript' && queryLower.includes('type')) ||\n   114→        (domain === 'python' && queryLower.includes('.py'))) {\n   115→      return { domain, adjustment: 'downgrade', expertise: 'high' };\n   116→    }\n   117→  }\n   118→\n   119→  // Check if query matches low expertise domains\n   120→  for (const domain of lowExpertise) {\n   121→    if (queryLower.includes(domain)) {\n   122→      return { domain, adjustment: 'upgrade', expertise: 'low' };\n   123→    }\n   124→  }\n   125→\n   126→  return null;\n   127→}\n   128→\n   129→// Actionable threshold\n   130→const DQ_THRESHOLD = BASELINES?.dq_thresholds?.actionable || 0.5;\n   131→\n   132→// Model capabilities (for validity assessment)\n   133→// Load from baselines if available, otherwise use hardcoded\n   134→const MODEL_CAPABILITIES = BASELINES?.complexity_thresholds ? {\n   135→  haiku: {\n   136→    strengths: ['quick answers', 'simple tasks', 'formatting', 'short responses'],\n   137→    weaknesses: ['complex reasoning', 'long context', 'code generation', 'architecture'],\n   138→    maxComplexity: BASELINES.complexity_thresholds.haiku.range[1],\n   139→    costPerMToken: BASELINES.cost_per_mtok?.haiku || { input: 0.25, output: 1.25 }\n   140→  },\n   141→  sonnet: {\n   142→    strengths: ['code generation', 'analysis', 'moderate reasoning', 'balanced tasks'],\n   143→    weaknesses: ['expert-level problems', 'novel architecture', 'research synthesis'],\n   144→    maxComplexity: BASELINES.complexity_thresholds.sonnet.range[1],\n   145→    costPerMToken: BASELINES.cost_per_mtok?.sonnet || { input: 3, output: 15 }\n   146→  },\n   147→  opus: {\n   148→    strengths: ['complex reasoning', 'novel problems', 'architecture', 'research', 'expert tasks'],\n   149→    weaknesses: ['cost', 'latency for simple tasks'],\n   150→    maxComplexity: BASELINES.complexity_thresholds.opus.range[1],\n   151→    costPerMToken: BASELINES.cost_per_mtok?.opus || { input: 5, output: 25 }\n   152→  }\n   153→} : {\n   154→  // Fallback values from centralized pricing config\n   155→  haiku: {\n   156→    strengths: ['quick answers', 'simple tasks', 'formatting', 'short responses'],\n   157→    weaknesses: ['complex reasoning', 'long context', 'code generation', 'architecture'],\n   158→    maxComplexity: 0.30,\n   159→    costPerMToken: { input: PRICING.haiku.input, output: PRICING.haiku.output }\n   160→  },\n   161→  sonnet: {\n   162→    strengths: ['code generation', 'analysis', 'moderate reasoning', 'balanced tasks'],\n   163→    weaknesses: ['expert-level problems', 'novel architecture', 'research synthesis'],\n   164→    maxComplexity: 0.70,\n   165→    costPerMToken: { input: PRICING.sonnet.input, output: PRICING.sonnet.output }\n   166→  },\n   167→  opus: {\n   168→    strengths: ['complex reasoning', 'novel problems', 'architecture', 'research', 'expert tasks'],\n   169→    weaknesses: ['cost', 'latency for simple tasks'],\n   170→    maxComplexity: 1.0,\n   171→    costPerMToken: { input: PRICING.opus.input, output: PRICING.opus.output }\n   172→  }\n   173→};\n   174→\n   175→// Adaptive thresholds (from ACE)\n   176→const ADAPTIVE_THRESHOLDS = {\n   177→  simple:   { complexity: [0, 0.25],   model: 'haiku',  rounds: 3,  gap: 2 },\n   178→  moderate: { complexity: [0.25, 0.50], model: 'sonnet', rounds: 7,  gap: 3 },\n   179→  complex:  { complexity: [0.50, 0.75], model: 'sonnet', rounds: 12, gap: 4 },\n   180→  expert:   { complexity: [0.75, 1.0],  model: 'opus',   rounds: 15, gap: 5 }\n   181→};\n   182→\n   183→// ═══════════════════════════════════════════════════════════════════════════\n   184→// HISTORY MANAGEMENT\n   185→// ═══════════════════════════════════════════════════════════════════════════\n   186→\n   187→const HISTORY_PATH = path.join(process.env.HOME, '.claude/kernel/dq-scores.jsonl');\n   188→\n   189→function loadHistory() {\n   190→  if (!fs.existsSync(HISTORY_PATH)) return [];\n   191→\n   192→  try {\n   193→    const lines = fs.readFileSync(HISTORY_PATH, 'utf8').split('\\n').filter(l => l.trim());\n   194→    return lines.map(l => JSON.parse(l));\n   195→  } catch (e) {\n   196→    return [];\n   197→  }\n   198→}\n   199→\n   200→function saveDecision(decision) {\n   201→  const line = JSON.stringify(decision) + '\\n';\n   202→  fs.appendFileSync(HISTORY_PATH, line);\n   203→}\n   204→\n   205→/**\n   206→ * Apply cognitive complexity modifier to adjust thresholds\n   207→ */\n   208→function applyCognitiveModifier(complexity) {\n   209→  // If modifier > 1, we can handle more complexity (raise thresholds effectively)\n   210→  // If modifier < 1, we should use simpler models (lower thresholds effectively)\n   211→  return complexity / COMPLEXITY_MODIFIER;\n   212→}\n   213→\n   214→// ═══════════════════════════════════════════════════════════════════════════\n   215→// DQ SCORING FUNCTIONS\n   216→// ═══════════════════════════════════════════════════════════════════════════\n   217→\n   218→/**\n   219→ * Assess validity: Does the model selection make logical sense?\n   220→ */\n   221→function assessValidity(complexity, model) {\n   222→  const modelCaps = MODEL_CAPABILITIES[model];\n   223→  if (!modelCaps) return 0;\n   224→\n   225→  // Perfect validity: complexity within model's range\n   226→  if (complexity <= modelCaps.maxComplexity) {\n   227→    // Penalize over-provisioning (using opus for simple tasks)\n   228→    const overProvision = modelCaps.maxComplexity - complexity;\n   229→    if (model === 'opus' && complexity < 0.5) {\n   230→      return 0.6; // Wasteful but valid\n   231→    }\n   232→    if (model === 'sonnet' && complexity < 0.2) {\n   233→      return 0.7; // Slightly wasteful\n   234→    }\n   235→    return 1.0 - (overProvision * 0.2); // Small penalty for over-provisioning\n   236→  }\n   237→\n   238→  // Under-provisioning is worse\n   239→  const underProvision = complexity - modelCaps.maxComplexity;\n   240→  return Math.max(0, 1.0 - (underProvision * 2)); // Heavy penalty\n   241→}\n   242→\n   243→/**\n   244→ * Assess specificity: How precise is the model selection?\n   245→ */\n   246→function assessSpecificity(query, complexity, model) {\n   247→  // Check if model matches the ideal for this complexity\n   248→  let idealModel;\n   249→  for (const [level, config] of Object.entries(ADAPTIVE_THRESHOLDS)) {\n   250→    if (complexity >= config.complexity[0] && complexity < config.complexity[1]) {\n   251→      idealModel = config.model;\n   252→      break;\n   253→    }\n   254→  }\n   255→  if (!idealModel) idealModel = 'opus';\n   256→\n   257→  if (model === idealModel) return 1.0;\n   258→\n   259→  // Adjacent model is acceptable\n   260→  const models = ['haiku', 'sonnet', 'opus'];\n   261→  const idealIdx = models.indexOf(idealModel);\n   262→  const actualIdx = models.indexOf(model);\n   263→  const distance = Math.abs(idealIdx - actualIdx);\n   264→\n   265→  return Math.max(0, 1.0 - (distance * 0.4));\n   266→}\n   267→\n   268→/**\n   269→ * Assess correctness: Historical accuracy for similar queries\n   270→ */\n   271→function assessCorrectness(query, model, history) {\n   272→  if (history.length === 0) return 0.5; // No history, neutral\n   273→\n   274→  // Find similar queries\n   275→  const queryTokens = new Set(query.toLowerCase().split(/\\s+/));\n   276→  const similar = history.filter(h => {\n   277→    if (!h.query) return false;\n   278→    const histTokens = new Set(h.query.toLowerCase().split(/\\s+/));\n   279→    const intersection = [...queryTokens].filter(t => histTokens.has(t)).length;\n   280→    return intersection / Math.max(queryTokens.size, histTokens.size) > 0.3;\n   281→  });\n   282→\n   283→  if (similar.length === 0) return 0.5;\n   284→\n   285→  // Check success rate for this model on similar queries\n   286→  const modelMatches = similar.filter(s => s.model === model);\n   287→  if (modelMatches.length === 0) return 0.5;\n   288→\n   289→  // If we have feedback, use it\n   290→  const withFeedback = modelMatches.filter(m => m.success !== undefined);\n   291→  if (withFeedback.length > 0) {\n   292→    const successRate = withFeedback.filter(m => m.success).length / withFeedback.length;\n   293→    return successRate;\n   294→  }\n   295→\n   296→  // Otherwise, assume DQ score is a proxy for success\n   297→  const avgDQ = modelMatches.reduce((sum, m) => sum + (m.dqScore || 0.5), 0) / modelMatches.length;\n   298→  return avgDQ;\n   299→}\n   300→\n   301→/**\n   302→ * Calculate composite DQ score\n   303→ */\n   304→function calculateDQ(query, complexity, model, history = []) {\n   305→  const validity = assessValidity(complexity, model);\n   306→  const specificity = assessSpecificity(query, complexity, model);\n   307→  const correctness = assessCorrectness(query, model, history);\n   308→\n   309→  const score = (validity * DQ_WEIGHTS.validity) +\n   310→                (specificity * DQ_WEIGHTS.specificity) +\n   311→                (correctness * DQ_WEIGHTS.correctness);\n   312→\n   313→  return {\n   314→    score: parseFloat(score.toFixed(3)),\n   315→    components: {\n   316→      validity: parseFloat(validity.toFixed(3)),\n   317→      specificity: parseFloat(specificity.toFixed(3)),\n   318→      correctness: parseFloat(correctness.toFixed(3))\n   319→    },\n   320→    actionable: score >= DQ_THRESHOLD\n   321→  };\n   322→}\n   323→\n   324→// ═══════════════════════════════════════════════════════════════════════════\n   325→// ROUTING DECISION\n   326→// ═══════════════════════════════════════════════════════════════════════════\n   327→\n   328→/**\n   329→ * Make a routing decision with DQ scoring\n   330→ */\n   331→function route(query) {\n   332→  const history = loadHistory();\n   333→  const complexity = estimateComplexity(query);\n   334→\n   335→  // Apply cognitive modifier to complexity for threshold comparisons\n   336→  const adjustedComplexity = applyCognitiveModifier(complexity.score);\n   337→\n   338→  // Try each model and pick best DQ\n   339→  const candidates = ['haiku', 'sonnet', 'opus'].map(model => {\n   340→    // Use adjusted complexity for DQ calculation\n   341→    const dq = calculateDQ(query, adjustedComplexity, model, history);\n   342→    return { model, dq, complexity: complexity.score, adjustedComplexity };\n   343→  });\n   344→\n   345→  // Sort by DQ score (highest first), then by cost (lowest first for ties)\n   346→  candidates.sort((a, b) => {\n   347→    if (Math.abs(a.dq.score - b.dq.score) > 0.05) {\n   348→      return b.dq.score - a.dq.score;\n   349→    }\n   350→    // If DQ scores are similar, prefer cheaper model\n   351→    const costOrder = { haiku: 0, sonnet: 1, opus: 2 };\n   352→    return costOrder[a.model] - costOrder[b.model];\n   353→  });\n   354→\n   355→  let best = candidates[0];\n   356→\n   357→  // Apply expertise-based adjustment\n   358→  const expertiseAdj = getExpertiseAdjustment(query);\n   359→  let expertiseOverride = null;\n   360→\n   361→  if (expertiseAdj) {\n   362→    const models = ['haiku', 'sonnet', 'opus'];\n   363→    const currentIdx = models.indexOf(best.model);\n   364→\n   365→    if (expertiseAdj.adjustment === 'downgrade' && currentIdx > 0) {\n   366→      // High expertise - can use cheaper model\n   367→      const newModel = models[currentIdx - 1];\n   368→      expertiseOverride = {\n   369→        original: best.model,\n   370→        adjusted: newModel,\n   371→        domain: expertiseAdj.domain,\n   372→        reason: `High expertise in ${expertiseAdj.domain}`\n   373→      };\n   374→      // Find the candidate for the new model\n   375→      const newCandidate = candidates.find(c => c.model === newModel);\n   376→      if (newCandidate) {\n   377→        best = newCandidate;\n   378→      }\n   379→    } else if (expertiseAdj.adjustment === 'upgrade' && currentIdx < models.length - 1) {\n   380→      // Low expertise - need more capable model\n   381→      const newModel = models[currentIdx + 1];\n   382→      expertiseOverride = {\n   383→        original: best.model,\n   384→        adjusted: newModel,\n   385→        domain: expertiseAdj.domain,\n   386→        reason: `Low expertise in ${expertiseAdj.domain}`\n   387→      };\n   388→      const newCandidate = candidates.find(c => c.model === newModel);\n   389→      if (newCandidate) {\n   390→        best = newCandidate;\n   391→      }\n   392→    }\n   393→  }\n   394→\n   395→  // Estimate cost for this routing decision\n   396→  function estimateCost(model, queryText) {\n   397→    const modelCaps = MODEL_CAPABILITIES[model];\n   398→    if (!modelCaps) return 0;\n   399→\n   400→    // Rough estimate: query ~100 tokens, response ~500 tokens\n   401→    const estInputTokens = Math.max(100, queryText.length / 4);\n   402→    const estOutputTokens = 500;\n   403→\n   404→    const cost = (estInputTokens * modelCaps.costPerMToken.input / 1_000_000 +\n   405→                  estOutputTokens * modelCaps.costPerMToken.output / 1_000_000);\n   406→\n   407→    return cost;\n   408→  }\n   409→\n   410→  // Log the decision with enhanced metadata\n   411→  const decision = {\n   412→    ts: Math.floor(Date.now() / 1000),  // Unix seconds (not ms)\n   413→    query_hash: crypto.createHash('md5').update(query).digest('hex'),\n   414→    query: query.slice(0, 200), // Truncate for storage\n   415→    query_preview: query.slice(0, 50),\n   416→    complexity: complexity.score,\n   417→    adjusted_complexity: adjustedComplexity,\n   418→    complexity_reasoning: complexity.reasoning,\n   419→    model: best.model,\n   420→    dqScore: best.dq.score,\n   421→    dqComponents: best.dq.components,\n   422→    reasoning: complexity.reasoning,\n   423→    alternatives: candidates.slice(1).map(c => ({ model: c.model, dq: c.dq.score })),\n   424→    cost_estimate: estimateCost(best.model, query),\n   425→    baseline_version: BASELINES ? BASELINES.version : 'hardcoded',\n   426→    cognitive: COGNITIVE_WEIGHTS ? {\n   427→      mode: COGNITIVE_WEIGHTS.cognitiveMode,\n   428→      modifier: COMPLEXITY_MODIFIER,\n   429→      weights_applied: true\n   430→    } : null,\n   431→    expertise: expertiseOverride\n   432→  };\n   433→\n   434→  saveDecision(decision);\n   435→\n   436→  return {\n   437→    model: best.model,\n   438→    complexity: complexity.score,\n   439→    dq: best.dq,\n   440→    reasoning: complexity.reasoning,\n   441→    cost_estimate: decision.cost_estimate,\n   442→    baseline_version: decision.baseline_version,\n   443→    cognitive: decision.cognitive,\n   444→    expertise: decision.expertise\n   445→  };\n   446→}\n   447→\n   448→/**\n   449→ * Record feedback on a routing decision\n   450→ */\n   451→function recordFeedback(queryPrefix, success) {\n   452→  const history = loadHistory();\n   453→\n   454→  // Find most recent matching query\n   455→  for (let i = history.length - 1; i >= 0; i--) {\n   456→    if (history[i].query && history[i].query.startsWith(queryPrefix)) {\n   457→      history[i].success = success;\n   458→      history[i].feedbackTs = Date.now();\n   459→\n   460→      // Rewrite history file\n   461→      const content = history.map(h => JSON.stringify(h)).join('\\n') + '\\n';\n   462→      fs.writeFileSync(HISTORY_PATH, content);\n   463→      return true;\n   464→    }\n   465→  }\n   466→  return false;\n   467→}\n   468→\n   469→/**\n   470→ * Get statistics on routing decisions\n   471→ */\n   472→function getStats() {\n   473→  const history = loadHistory();\n   474→  const last24h = history.filter(h => h.ts > Date.now() - 86400000);\n   475→  const last7d = history.filter(h => h.ts > Date.now() - 604800000);\n   476→\n   477→  const modelCounts = { haiku: 0, sonnet: 0, opus: 0 };\n   478→  const modelDQ = { haiku: [], sonnet: [], opus: [] };\n   479→\n   480→  for (const h of last7d) {\n   481→    if (h.model) modelCounts[h.model]++;\n   482→    if (h.model && h.dqScore) modelDQ[h.model].push(h.dqScore);\n   483→  }\n   484→\n   485→  const avgDQ = {};\n   486→  for (const [model, scores] of Object.entries(modelDQ)) {\n   487→    avgDQ[model] = scores.length > 0\n   488→      ? (scores.reduce((a, b) => a + b, 0) / scores.length).toFixed(3)\n   489→      : 'N/A';\n   490→  }\n   491→\n   492→  return {\n   493→    total: history.length,\n   494→    last24h: last24h.length,\n   495→    last7d: last7d.length,\n   496→    modelDistribution: modelCounts,\n   497→    averageDQ: avgDQ,\n   498→    overallAvgDQ: last7d.length > 0\n   499→      ? (last7d.reduce((sum, h) => sum + (h.dqScore || 0), 0) / last7d.length).toFixed(3)\n   500→      : 'N/A'\n   501→  };\n   502→}\n   503→\n   504→// ═══════════════════════════════════════════════════════════════════════════\n   505→// CLI INTERFACE\n   506→// ═══════════════════════════════════════════════════════════════════════════\n   507→\n   508→if (require.main === module) {\n   509→  const args = process.argv.slice(2);\n   510→  const command = args[0];\n   511→\n   512→  switch (command) {\n   513→    case 'route':\n   514→      // Route a query: node dq-scorer.js route \"query here\"\n   515→      const query = args.slice(1).join(' ');\n   516→      if (!query) {\n   517→        console.error('Usage: dq-scorer.js route \"query\"');\n   518→        process.exit(1);\n   519→      }\n   520→      const result = route(query);\n   521→      console.log(JSON.stringify(result, null, 2));\n   522→      break;\n   523→\n   524→    case 'model':\n   525→      // Just get the model: node dq-scorer.js model \"query\"\n   526→      const q = args.slice(1).join(' ');\n   527→      const r = route(q);\n   528→      console.log(r.model);\n   529→      break;\n   530→\n   531→    case 'feedback':\n   532→      // Record feedback: node dq-scorer.js feedback \"query prefix\" success|failure\n   533→      const prefix = args[1];\n   534→      const success = args[2] === 'success';\n   535→      const recorded = recordFeedback(prefix, success);\n   536→      console.log(recorded ? 'Feedback recorded' : 'Query not found');\n   537→      break;\n   538→\n   539→    case 'stats':\n   540→      // Get statistics: node dq-scorer.js stats\n   541→      console.log(JSON.stringify(getStats(), null, 2));\n   542→      break;\n   543→\n   544→    case 'score':\n   545→      // Score a specific model choice: node dq-scorer.js score \"query\" model\n   546→      const scoreQuery = args[1];\n   547→      const model = args[2] || 'sonnet';\n   548→      const complexity = estimateComplexity(scoreQuery);\n   549→      const dq = calculateDQ(scoreQuery, complexity.score, model, loadHistory());\n   550→      console.log(JSON.stringify({ complexity: complexity.score, model, dq }, null, 2));\n   551→      break;\n   552→\n   553→    default:\n   554→      console.log('DQ Scorer - Decision Quality Framework for Model Routing');\n   555→      console.log('');\n   556→      console.log('Commands:');\n   557→      console.log('  route \"query\"              - Route query to optimal model');\n   558→      console.log('  model \"query\"              - Get just the model name');\n   559→      console.log('  score \"query\" [model]      - Score a specific model choice');\n   560→      console.log('  feedback \"prefix\" success  - Record feedback on a decision');\n   561→      console.log('  stats                      - Get routing statistics');\n   562→  }\n   563→}\n   564→\n   565→module.exports = { route, calculateDQ, recordFeedback, getStats };\n   566→"}]},"parent_tool_use_id":null,"session_id":"9a35f34f-308d-4c6d-9db8-99acc209c315","uuid":"e30d7c77-3c03-40c1-b028-6e40daf15e41","tool_use_result":{"type":"text","file":{"filePath":"/Users/dicoangelo/projects/core/meta-vengine/kernel/dq-scorer.js","content":"#!/usr/bin/env node\n/**\n * Decision Quality (DQ) Scorer - ACE Framework Implementation\n *\n * Based on: OS-App Adaptive Convergence Engine (ACE) DQ Framework\n * Measures: validity (0.4) + specificity (0.3) + correctness (0.3)\n *\n * Scores routing decisions and learns from history.\n */\n\nconst fs = require('fs');\nconst path = require('path');\nconst crypto = require('crypto');\nconst { estimateComplexity } = require('./complexity-analyzer');\nconst { PRICING } = require(path.join(process.env.HOME, '.claude/config/pricing.js'));\n\n// ═══════════════════════════════════════════════════════════════════════════\n// BASELINES LOADING\n// ═══════════════════════════════════════════════════════════════════════════\n\nconst BASELINES_PATH = path.join(process.env.HOME, '.claude/kernel/baselines.json');\n\nfunction loadBaselines() {\n  if (!fs.existsSync(BASELINES_PATH)) {\n    return null;  // Use hardcoded defaults\n  }\n\n  try {\n    const data = fs.readFileSync(BASELINES_PATH, 'utf8');\n    return JSON.parse(data);\n  } catch (e) {\n    console.error('Error loading baselines:', e.message);\n    return null;\n  }\n}\n\nconst BASELINES = loadBaselines();\n\n// ═══════════════════════════════════════════════════════════════════════════\n// DQ WEIGHTS (from ACE Framework + Cognitive OS adjustments)\n// ═══════════════════════════════════════════════════════════════════════════\n\nconst COGNITIVE_DQ_WEIGHTS_PATH = path.join(process.env.HOME, '.claude/kernel/cognitive-os/cognitive-dq-weights.json');\nconst EXPERTISE_ROUTING_STATE_PATH = path.join(process.env.HOME, '.claude/kernel/expertise-routing-state.json');\n\nfunction loadCognitiveDQWeights() {\n  // Try to load cognitive-aware weights from Cognitive OS\n  if (fs.existsSync(COGNITIVE_DQ_WEIGHTS_PATH)) {\n    try {\n      const data = JSON.parse(fs.readFileSync(COGNITIVE_DQ_WEIGHTS_PATH, 'utf8'));\n      const fileAge = Date.now() - new Date(data.timestamp).getTime();\n      // Only use if less than 30 minutes old\n      if (fileAge < 30 * 60 * 1000 && data.dq_weights) {\n        return {\n          weights: data.dq_weights,\n          complexityModifier: data.complexity_threshold_modifier || 1.0,\n          cognitiveMode: data.cognitive_mode,\n          reasoning: data.reasoning\n        };\n      }\n    } catch (e) {\n      // Fall through to defaults\n    }\n  }\n  return null;\n}\n\nconst COGNITIVE_WEIGHTS = loadCognitiveDQWeights();\n\nconst DQ_WEIGHTS = COGNITIVE_WEIGHTS?.weights || BASELINES?.dq_weights || {\n  validity: 0.4,      // Does the routing make logical sense?\n  specificity: 0.3,   // How precise is the model selection?\n  correctness: 0.3    // Historical accuracy of similar queries\n};\n\n// Complexity threshold modifier from Cognitive OS (affects model selection boundaries)\nconst COMPLEXITY_MODIFIER = COGNITIVE_WEIGHTS?.complexityModifier || 1.0;\n\n// ═══════════════════════════════════════════════════════════════════════════\n// EXPERTISE ROUTING\n// ═══════════════════════════════════════════════════════════════════════════\n\nfunction loadExpertiseState() {\n  if (fs.existsSync(EXPERTISE_ROUTING_STATE_PATH)) {\n    try {\n      const data = JSON.parse(fs.readFileSync(EXPERTISE_ROUTING_STATE_PATH, 'utf8'));\n      const fileAge = Date.now() - new Date(data.timestamp).getTime();\n      // Use if less than 1 hour old\n      if (fileAge < 60 * 60 * 1000) {\n        return data;\n      }\n    } catch (e) {}\n  }\n  return null;\n}\n\nconst EXPERTISE_STATE = loadExpertiseState();\n\n/**\n * Detect domain of query and check expertise level\n */\nfunction getExpertiseAdjustment(query) {\n  if (!EXPERTISE_STATE) return null;\n\n  const highExpertise = EXPERTISE_STATE.high_expertise_domains || [];\n  const lowExpertise = EXPERTISE_STATE.low_expertise_domains || [];\n  const queryLower = query.toLowerCase();\n\n  // Check if query matches high expertise domains\n  for (const domain of highExpertise) {\n    if (queryLower.includes(domain) ||\n        (domain === 'react' && (queryLower.includes('component') || queryLower.includes('hook'))) ||\n        (domain === 'typescript' && queryLower.includes('type')) ||\n        (domain === 'python' && queryLower.includes('.py'))) {\n      return { domain, adjustment: 'downgrade', expertise: 'high' };\n    }\n  }\n\n  // Check if query matches low expertise domains\n  for (const domain of lowExpertise) {\n    if (queryLower.includes(domain)) {\n      return { domain, adjustment: 'upgrade', expertise: 'low' };\n    }\n  }\n\n  return null;\n}\n\n// Actionable threshold\nconst DQ_THRESHOLD = BASELINES?.dq_thresholds?.actionable || 0.5;\n\n// Model capabilities (for validity assessment)\n// Load from baselines if available, otherwise use hardcoded\nconst MODEL_CAPABILITIES = BASELINES?.complexity_thresholds ? {\n  haiku: {\n    strengths: ['quick answers', 'simple tasks', 'formatting', 'short responses'],\n    weaknesses: ['complex reasoning', 'long context', 'code generation', 'architecture'],\n    maxComplexity: BASELINES.complexity_thresholds.haiku.range[1],\n    costPerMToken: BASELINES.cost_per_mtok?.haiku || { input: 0.25, output: 1.25 }\n  },\n  sonnet: {\n    strengths: ['code generation', 'analysis', 'moderate reasoning', 'balanced tasks'],\n    weaknesses: ['expert-level problems', 'novel architecture', 'research synthesis'],\n    maxComplexity: BASELINES.complexity_thresholds.sonnet.range[1],\n    costPerMToken: BASELINES.cost_per_mtok?.sonnet || { input: 3, output: 15 }\n  },\n  opus: {\n    strengths: ['complex reasoning', 'novel problems', 'architecture', 'research', 'expert tasks'],\n    weaknesses: ['cost', 'latency for simple tasks'],\n    maxComplexity: BASELINES.complexity_thresholds.opus.range[1],\n    costPerMToken: BASELINES.cost_per_mtok?.opus || { input: 5, output: 25 }\n  }\n} : {\n  // Fallback values from centralized pricing config\n  haiku: {\n    strengths: ['quick answers', 'simple tasks', 'formatting', 'short responses'],\n    weaknesses: ['complex reasoning', 'long context', 'code generation', 'architecture'],\n    maxComplexity: 0.30,\n    costPerMToken: { input: PRICING.haiku.input, output: PRICING.haiku.output }\n  },\n  sonnet: {\n    strengths: ['code generation', 'analysis', 'moderate reasoning', 'balanced tasks'],\n    weaknesses: ['expert-level problems', 'novel architecture', 'research synthesis'],\n    maxComplexity: 0.70,\n    costPerMToken: { input: PRICING.sonnet.input, output: PRICING.sonnet.output }\n  },\n  opus: {\n    strengths: ['complex reasoning', 'novel problems', 'architecture', 'research', 'expert tasks'],\n    weaknesses: ['cost', 'latency for simple tasks'],\n    maxComplexity: 1.0,\n    costPerMToken: { input: PRICING.opus.input, output: PRICING.opus.output }\n  }\n};\n\n// Adaptive thresholds (from ACE)\nconst ADAPTIVE_THRESHOLDS = {\n  simple:   { complexity: [0, 0.25],   model: 'haiku',  rounds: 3,  gap: 2 },\n  moderate: { complexity: [0.25, 0.50], model: 'sonnet', rounds: 7,  gap: 3 },\n  complex:  { complexity: [0.50, 0.75], model: 'sonnet', rounds: 12, gap: 4 },\n  expert:   { complexity: [0.75, 1.0],  model: 'opus',   rounds: 15, gap: 5 }\n};\n\n// ═══════════════════════════════════════════════════════════════════════════\n// HISTORY MANAGEMENT\n// ═══════════════════════════════════════════════════════════════════════════\n\nconst HISTORY_PATH = path.join(process.env.HOME, '.claude/kernel/dq-scores.jsonl');\n\nfunction loadHistory() {\n  if (!fs.existsSync(HISTORY_PATH)) return [];\n\n  try {\n    const lines = fs.readFileSync(HISTORY_PATH, 'utf8').split('\\n').filter(l => l.trim());\n    return lines.map(l => JSON.parse(l));\n  } catch (e) {\n    return [];\n  }\n}\n\nfunction saveDecision(decision) {\n  const line = JSON.stringify(decision) + '\\n';\n  fs.appendFileSync(HISTORY_PATH, line);\n}\n\n/**\n * Apply cognitive complexity modifier to adjust thresholds\n */\nfunction applyCognitiveModifier(complexity) {\n  // If modifier > 1, we can handle more complexity (raise thresholds effectively)\n  // If modifier < 1, we should use simpler models (lower thresholds effectively)\n  return complexity / COMPLEXITY_MODIFIER;\n}\n\n// ═══════════════════════════════════════════════════════════════════════════\n// DQ SCORING FUNCTIONS\n// ═══════════════════════════════════════════════════════════════════════════\n\n/**\n * Assess validity: Does the model selection make logical sense?\n */\nfunction assessValidity(complexity, model) {\n  const modelCaps = MODEL_CAPABILITIES[model];\n  if (!modelCaps) return 0;\n\n  // Perfect validity: complexity within model's range\n  if (complexity <= modelCaps.maxComplexity) {\n    // Penalize over-provisioning (using opus for simple tasks)\n    const overProvision = modelCaps.maxComplexity - complexity;\n    if (model === 'opus' && complexity < 0.5) {\n      return 0.6; // Wasteful but valid\n    }\n    if (model === 'sonnet' && complexity < 0.2) {\n      return 0.7; // Slightly wasteful\n    }\n    return 1.0 - (overProvision * 0.2); // Small penalty for over-provisioning\n  }\n\n  // Under-provisioning is worse\n  const underProvision = complexity - modelCaps.maxComplexity;\n  return Math.max(0, 1.0 - (underProvision * 2)); // Heavy penalty\n}\n\n/**\n * Assess specificity: How precise is the model selection?\n */\nfunction assessSpecificity(query, complexity, model) {\n  // Check if model matches the ideal for this complexity\n  let idealModel;\n  for (const [level, config] of Object.entries(ADAPTIVE_THRESHOLDS)) {\n    if (complexity >= config.complexity[0] && complexity < config.complexity[1]) {\n      idealModel = config.model;\n      break;\n    }\n  }\n  if (!idealModel) idealModel = 'opus';\n\n  if (model === idealModel) return 1.0;\n\n  // Adjacent model is acceptable\n  const models = ['haiku', 'sonnet', 'opus'];\n  const idealIdx = models.indexOf(idealModel);\n  const actualIdx = models.indexOf(model);\n  const distance = Math.abs(idealIdx - actualIdx);\n\n  return Math.max(0, 1.0 - (distance * 0.4));\n}\n\n/**\n * Assess correctness: Historical accuracy for similar queries\n */\nfunction assessCorrectness(query, model, history) {\n  if (history.length === 0) return 0.5; // No history, neutral\n\n  // Find similar queries\n  const queryTokens = new Set(query.toLowerCase().split(/\\s+/));\n  const similar = history.filter(h => {\n    if (!h.query) return false;\n    const histTokens = new Set(h.query.toLowerCase().split(/\\s+/));\n    const intersection = [...queryTokens].filter(t => histTokens.has(t)).length;\n    return intersection / Math.max(queryTokens.size, histTokens.size) > 0.3;\n  });\n\n  if (similar.length === 0) return 0.5;\n\n  // Check success rate for this model on similar queries\n  const modelMatches = similar.filter(s => s.model === model);\n  if (modelMatches.length === 0) return 0.5;\n\n  // If we have feedback, use it\n  const withFeedback = modelMatches.filter(m => m.success !== undefined);\n  if (withFeedback.length > 0) {\n    const successRate = withFeedback.filter(m => m.success).length / withFeedback.length;\n    return successRate;\n  }\n\n  // Otherwise, assume DQ score is a proxy for success\n  const avgDQ = modelMatches.reduce((sum, m) => sum + (m.dqScore || 0.5), 0) / modelMatches.length;\n  return avgDQ;\n}\n\n/**\n * Calculate composite DQ score\n */\nfunction calculateDQ(query, complexity, model, history = []) {\n  const validity = assessValidity(complexity, model);\n  const specificity = assessSpecificity(query, complexity, model);\n  const correctness = assessCorrectness(query, model, history);\n\n  const score = (validity * DQ_WEIGHTS.validity) +\n                (specificity * DQ_WEIGHTS.specificity) +\n                (correctness * DQ_WEIGHTS.correctness);\n\n  return {\n    score: parseFloat(score.toFixed(3)),\n    components: {\n      validity: parseFloat(validity.toFixed(3)),\n      specificity: parseFloat(specificity.toFixed(3)),\n      correctness: parseFloat(correctness.toFixed(3))\n    },\n    actionable: score >= DQ_THRESHOLD\n  };\n}\n\n// ═══════════════════════════════════════════════════════════════════════════\n// ROUTING DECISION\n// ═══════════════════════════════════════════════════════════════════════════\n\n/**\n * Make a routing decision with DQ scoring\n */\nfunction route(query) {\n  const history = loadHistory();\n  const complexity = estimateComplexity(query);\n\n  // Apply cognitive modifier to complexity for threshold comparisons\n  const adjustedComplexity = applyCognitiveModifier(complexity.score);\n\n  // Try each model and pick best DQ\n  const candidates = ['haiku', 'sonnet', 'opus'].map(model => {\n    // Use adjusted complexity for DQ calculation\n    const dq = calculateDQ(query, adjustedComplexity, model, history);\n    return { model, dq, complexity: complexity.score, adjustedComplexity };\n  });\n\n  // Sort by DQ score (highest first), then by cost (lowest first for ties)\n  candidates.sort((a, b) => {\n    if (Math.abs(a.dq.score - b.dq.score) > 0.05) {\n      return b.dq.score - a.dq.score;\n    }\n    // If DQ scores are similar, prefer cheaper model\n    const costOrder = { haiku: 0, sonnet: 1, opus: 2 };\n    return costOrder[a.model] - costOrder[b.model];\n  });\n\n  let best = candidates[0];\n\n  // Apply expertise-based adjustment\n  const expertiseAdj = getExpertiseAdjustment(query);\n  let expertiseOverride = null;\n\n  if (expertiseAdj) {\n    const models = ['haiku', 'sonnet', 'opus'];\n    const currentIdx = models.indexOf(best.model);\n\n    if (expertiseAdj.adjustment === 'downgrade' && currentIdx > 0) {\n      // High expertise - can use cheaper model\n      const newModel = models[currentIdx - 1];\n      expertiseOverride = {\n        original: best.model,\n        adjusted: newModel,\n        domain: expertiseAdj.domain,\n        reason: `High expertise in ${expertiseAdj.domain}`\n      };\n      // Find the candidate for the new model\n      const newCandidate = candidates.find(c => c.model === newModel);\n      if (newCandidate) {\n        best = newCandidate;\n      }\n    } else if (expertiseAdj.adjustment === 'upgrade' && currentIdx < models.length - 1) {\n      // Low expertise - need more capable model\n      const newModel = models[currentIdx + 1];\n      expertiseOverride = {\n        original: best.model,\n        adjusted: newModel,\n        domain: expertiseAdj.domain,\n        reason: `Low expertise in ${expertiseAdj.domain}`\n      };\n      const newCandidate = candidates.find(c => c.model === newModel);\n      if (newCandidate) {\n        best = newCandidate;\n      }\n    }\n  }\n\n  // Estimate cost for this routing decision\n  function estimateCost(model, queryText) {\n    const modelCaps = MODEL_CAPABILITIES[model];\n    if (!modelCaps) return 0;\n\n    // Rough estimate: query ~100 tokens, response ~500 tokens\n    const estInputTokens = Math.max(100, queryText.length / 4);\n    const estOutputTokens = 500;\n\n    const cost = (estInputTokens * modelCaps.costPerMToken.input / 1_000_000 +\n                  estOutputTokens * modelCaps.costPerMToken.output / 1_000_000);\n\n    return cost;\n  }\n\n  // Log the decision with enhanced metadata\n  const decision = {\n    ts: Math.floor(Date.now() / 1000),  // Unix seconds (not ms)\n    query_hash: crypto.createHash('md5').update(query).digest('hex'),\n    query: query.slice(0, 200), // Truncate for storage\n    query_preview: query.slice(0, 50),\n    complexity: complexity.score,\n    adjusted_complexity: adjustedComplexity,\n    complexity_reasoning: complexity.reasoning,\n    model: best.model,\n    dqScore: best.dq.score,\n    dqComponents: best.dq.components,\n    reasoning: complexity.reasoning,\n    alternatives: candidates.slice(1).map(c => ({ model: c.model, dq: c.dq.score })),\n    cost_estimate: estimateCost(best.model, query),\n    baseline_version: BASELINES ? BASELINES.version : 'hardcoded',\n    cognitive: COGNITIVE_WEIGHTS ? {\n      mode: COGNITIVE_WEIGHTS.cognitiveMode,\n      modifier: COMPLEXITY_MODIFIER,\n      weights_applied: true\n    } : null,\n    expertise: expertiseOverride\n  };\n\n  saveDecision(decision);\n\n  return {\n    model: best.model,\n    complexity: complexity.score,\n    dq: best.dq,\n    reasoning: complexity.reasoning,\n    cost_estimate: decision.cost_estimate,\n    baseline_version: decision.baseline_version,\n    cognitive: decision.cognitive,\n    expertise: decision.expertise\n  };\n}\n\n/**\n * Record feedback on a routing decision\n */\nfunction recordFeedback(queryPrefix, success) {\n  const history = loadHistory();\n\n  // Find most recent matching query\n  for (let i = history.length - 1; i >= 0; i--) {\n    if (history[i].query && history[i].query.startsWith(queryPrefix)) {\n      history[i].success = success;\n      history[i].feedbackTs = Date.now();\n\n      // Rewrite history file\n      const content = history.map(h => JSON.stringify(h)).join('\\n') + '\\n';\n      fs.writeFileSync(HISTORY_PATH, content);\n      return true;\n    }\n  }\n  return false;\n}\n\n/**\n * Get statistics on routing decisions\n */\nfunction getStats() {\n  const history = loadHistory();\n  const last24h = history.filter(h => h.ts > Date.now() - 86400000);\n  const last7d = history.filter(h => h.ts > Date.now() - 604800000);\n\n  const modelCounts = { haiku: 0, sonnet: 0, opus: 0 };\n  const modelDQ = { haiku: [], sonnet: [], opus: [] };\n\n  for (const h of last7d) {\n    if (h.model) modelCounts[h.model]++;\n    if (h.model && h.dqScore) modelDQ[h.model].push(h.dqScore);\n  }\n\n  const avgDQ = {};\n  for (const [model, scores] of Object.entries(modelDQ)) {\n    avgDQ[model] = scores.length > 0\n      ? (scores.reduce((a, b) => a + b, 0) / scores.length).toFixed(3)\n      : 'N/A';\n  }\n\n  return {\n    total: history.length,\n    last24h: last24h.length,\n    last7d: last7d.length,\n    modelDistribution: modelCounts,\n    averageDQ: avgDQ,\n    overallAvgDQ: last7d.length > 0\n      ? (last7d.reduce((sum, h) => sum + (h.dqScore || 0), 0) / last7d.length).toFixed(3)\n      : 'N/A'\n  };\n}\n\n// ═══════════════════════════════════════════════════════════════════════════\n// CLI INTERFACE\n// ═══════════════════════════════════════════════════════════════════════════\n\nif (require.main === module) {\n  const args = process.argv.slice(2);\n  const command = args[0];\n\n  switch (command) {\n    case 'route':\n      // Route a query: node dq-scorer.js route \"query here\"\n      const query = args.slice(1).join(' ');\n      if (!query) {\n        console.error('Usage: dq-scorer.js route \"query\"');\n        process.exit(1);\n      }\n      const result = route(query);\n      console.log(JSON.stringify(result, null, 2));\n      break;\n\n    case 'model':\n      // Just get the model: node dq-scorer.js model \"query\"\n      const q = args.slice(1).join(' ');\n      const r = route(q);\n      console.log(r.model);\n      break;\n\n    case 'feedback':\n      // Record feedback: node dq-scorer.js feedback \"query prefix\" success|failure\n      const prefix = args[1];\n      const success = args[2] === 'success';\n      const recorded = recordFeedback(prefix, success);\n      console.log(recorded ? 'Feedback recorded' : 'Query not found');\n      break;\n\n    case 'stats':\n      // Get statistics: node dq-scorer.js stats\n      console.log(JSON.stringify(getStats(), null, 2));\n      break;\n\n    case 'score':\n      // Score a specific model choice: node dq-scorer.js score \"query\" model\n      const scoreQuery = args[1];\n      const model = args[2] || 'sonnet';\n      const complexity = estimateComplexity(scoreQuery);\n      const dq = calculateDQ(scoreQuery, complexity.score, model, loadHistory());\n      console.log(JSON.stringify({ complexity: complexity.score, model, dq }, null, 2));\n      break;\n\n    default:\n      console.log('DQ Scorer - Decision Quality Framework for Model Routing');\n      console.log('');\n      console.log('Commands:');\n      console.log('  route \"query\"              - Route query to optimal model');\n      console.log('  model \"query\"              - Get just the model name');\n      console.log('  score \"query\" [model]      - Score a specific model choice');\n      console.log('  feedback \"prefix\" success  - Record feedback on a decision');\n      console.log('  stats                      - Get routing statistics');\n  }\n}\n\nmodule.exports = { route, calculateDQ, recordFeedback, getStats };\n","numLines":566,"startLine":1,"totalLines":566}}}
