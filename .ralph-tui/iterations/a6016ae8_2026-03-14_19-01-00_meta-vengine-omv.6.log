{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012AE9upvvbv6c2hvb5nx6d2","type":"tool_result","content":"     1→#!/usr/bin/env python3\n     2→\"\"\"\n     3→HSRGS: Homeomorphic Self-Routing Gödel System\n     4→\n     5→A revolutionary routing system that:\n     6→1. Encodes queries AND models in a universal homeomorphic latent space\n     7→2. Uses IRT (Item Response Theory) to predict P(success|query, model)\n     8→3. Self-modifies its own routing logic via Gödel machine principles\n     9→4. Selects models via emergent pressure gradients, not explicit rules\n    10→\n    11→Based on convergence of:\n    12→- ZeroRouter (arXiv:2601.06220) - Universal latent space\n    13→- ULHM (arXiv:2601.09025) - Homeomorphic manifold unification\n    14→- IRT-Router (arXiv:2506.01048) - Psychometric routing\n    15→- Darwin Gödel Machine (arXiv:2505.22954) - Open-ended self-improvement\n    16→- Emergent Coordination (arXiv:2601.08129) - Pressure field selection\n    17→\n    18→Author: D-Ecosystem / Metaventions AI\n    19→\"\"\"\n    20→\n    21→import json\n    22→import hashlib\n    23→import time\n    24→import math\n    25→import sys\n    26→from pathlib import Path\n    27→from typing import Optional, Dict, List, Tuple, Any\n    28→from dataclasses import dataclass, field, asdict\n    29→import numpy as np\n    30→\n    31→# Import centralized pricing\n    32→sys.path.insert(0, str(Path.home() / \".claude/config\"))\n    33→try:\n    34→    from pricing import PRICING as _CENTRALIZED_PRICING\n    35→except ImportError:\n    36→    _CENTRALIZED_PRICING = {\"opus\": {\"input\": 5}, \"sonnet\": {\"input\": 3}, \"haiku\": {\"input\": 0.8}}\n    37→\n    38→# Lazy load heavy dependencies\n    39→_encoder = None\n    40→_model_embeddings = None\n    41→\n    42→# ============================================================\n    43→# CONFIGURATION\n    44→# ============================================================\n    45→\n    46→HSRGS_DIR = Path.home() / \".claude\" / \"kernel\" / \"hsrgs\"\n    47→CONFIG_FILE = HSRGS_DIR / \"config.json\"\n    48→EMBEDDINGS_FILE = HSRGS_DIR / \"model_embeddings.npz\"\n    49→IRT_PARAMS_FILE = HSRGS_DIR / \"irt_params.json\"\n    50→EVOLUTION_ARCHIVE = HSRGS_DIR / \"evolution_archive.jsonl\"\n    51→ROUTING_LOG = HSRGS_DIR / \"routing_log.jsonl\"\n    52→IRT_BRIDGE_FILE = HSRGS_DIR / \"irt-bridge.json\"\n    53→\n    54→# Coevo integration - shared data pipeline\n    55→COEVO_DQ_FILE = Path.home() / \".claude\" / \"kernel\" / \"dq-scores.jsonl\"\n    56→\n    57→DEFAULT_CONFIG = {\n    58→    \"encoder_model\": \"all-MiniLM-L6-v2\",  # Fast, good quality\n    59→    \"embedding_dim\": 384,\n    60→    \"irt_learning_rate\": 0.01,\n    61→    \"pressure_weights\": {\n    62→        \"cost\": 0.3,\n    63→        \"quality\": 0.5,\n    64→        \"latency\": 0.2\n    65→    },\n    66→    \"evolution_enabled\": True,\n    67→    \"mutation_rate\": 0.1,\n    68→    \"archive_max_size\": 100,\n    69→    \"version\": \"1.0.0\"\n    70→}\n    71→\n    72→# Model characteristics (costs from centralized config, others learned over time)\n    73→MODEL_PROFILES = {\n    74→    \"local\": {\"cost\": 0.0, \"latency\": 0.1, \"capability\": 0.3, \"tier\": 0},\n    75→    \"local-fast\": {\"cost\": 0.0, \"latency\": 0.05, \"capability\": 0.2, \"tier\": 0},\n    76→    \"flash\": {\"cost\": 0.075, \"latency\": 0.3, \"capability\": 0.5, \"tier\": 1},\n    77→    \"haiku\": {\"cost\": _CENTRALIZED_PRICING.get(\"haiku\", {}).get(\"input\", 0.8), \"latency\": 0.4, \"capability\": 0.6, \"tier\": 2},\n    78→    \"gpt-mini\": {\"cost\": 0.15, \"latency\": 0.35, \"capability\": 0.55, \"tier\": 2},\n    79→    \"sonnet\": {\"cost\": _CENTRALIZED_PRICING.get(\"sonnet\", {}).get(\"input\", 3.0), \"latency\": 0.8, \"capability\": 0.85, \"tier\": 3},\n    80→    \"gpt-4o\": {\"cost\": 2.5, \"latency\": 0.7, \"capability\": 0.82, \"tier\": 3},\n    81→    \"pro\": {\"cost\": 1.25, \"latency\": 0.6, \"capability\": 0.75, \"tier\": 3},\n    82→    \"opus\": {\"cost\": _CENTRALIZED_PRICING.get(\"opus\", {}).get(\"input\", 5.0), \"latency\": 1.5, \"capability\": 1.0, \"tier\": 4},\n    83→}\n    84→\n    85→\n    86→# ============================================================\n    87→# DATA CLASSES\n    88→# ============================================================\n    89→\n    90→@dataclass\n    91→class LatentRepresentation:\n    92→    \"\"\"Universal latent space representation\"\"\"\n    93→    embedding: np.ndarray\n    94→    difficulty: float  # IRT difficulty parameter (0-1)\n    95→    discrimination: float  # IRT discrimination parameter\n    96→    domain_signature: str  # Hash of semantic domain\n    97→\n    98→@dataclass\n    99→class IRTParams:\n   100→    \"\"\"Item Response Theory parameters for a model\"\"\"\n   101→    ability: float  # Model's general ability (theta)\n   102→    domain_abilities: Dict[str, float] = field(default_factory=dict)  # Per-domain abilities\n   103→    guessing: float = 0.1  # Probability of correct by chance\n   104→\n   105→@dataclass\n   106→class PressureField:\n   107→    \"\"\"Emergent pressure gradients for model selection\"\"\"\n   108→    cost_pressure: float\n   109→    quality_pressure: float\n   110→    latency_pressure: float\n   111→    total_pressure: float\n   112→\n   113→@dataclass\n   114→class RoutingDecision:\n   115→    \"\"\"Complete routing decision with provenance\"\"\"\n   116→    query_hash: str\n   117→    selected_model: str\n   118→    latent: LatentRepresentation\n   119→    pressures: Dict[str, PressureField]\n   120→    irt_predictions: Dict[str, float]\n   121→    confidence: float\n   122→    reasoning: str\n   123→    timestamp: int\n   124→    version: str\n   125→\n   126→\n   127→# ============================================================\n   128→# HOMEOMORPHIC ENCODER\n   129→# ============================================================\n   130→\n   131→class HomeomorphicEncoder:\n   132→    \"\"\"\n   133→    Encodes queries into a universal latent space that is homeomorphic\n   134→    to the model capability space, enabling zero-shot model onboarding.\n   135→\n   136→    Based on ZeroRouter + ULHM principles:\n   137→    - Query difficulty decoupled from model profiling\n   138→    - Continuous bijection preserving topological structure\n   139→    \"\"\"\n   140→\n   141→    def __init__(self, model_name: str = \"all-MiniLM-L6-v2\"):\n   142→        self.model_name = model_name\n   143→        self._encoder = None\n   144→        self._model_embeddings = {}\n   145→        self._domain_centroids = {}\n   146→\n   147→    def _load_encoder(self):\n   148→        \"\"\"Lazy load the sentence transformer\"\"\"\n   149→        if self._encoder is None:\n   150→            from sentence_transformers import SentenceTransformer\n   151→            self._encoder = SentenceTransformer(self.model_name)\n   152→        return self._encoder\n   153→\n   154→    def encode_query(self, query: str) -> LatentRepresentation:\n   155→        \"\"\"\n   156→        Encode query into universal latent space.\n   157→\n   158→        Returns:\n   159→            LatentRepresentation with:\n   160→            - embedding: Dense vector in universal space\n   161→            - difficulty: Estimated query difficulty (0-1)\n   162→            - discrimination: How much difficulty varies by model\n   163→            - domain_signature: Semantic domain hash\n   164→        \"\"\"\n   165→        encoder = self._load_encoder()\n   166→\n   167→        # Get dense embedding\n   168→        embedding = encoder.encode(query, convert_to_numpy=True)\n   169→\n   170→        # Estimate difficulty from embedding properties\n   171→        # Higher norm = more specific/complex query\n   172→        norm = np.linalg.norm(embedding)\n   173→\n   174→        # Difficulty estimation via multiple signals\n   175→        difficulty = self._estimate_difficulty(query, embedding)\n   176→\n   177→        # Discrimination: how much the query differentiates models\n   178→        discrimination = self._estimate_discrimination(query, embedding)\n   179→\n   180→        # Domain signature for domain-specific routing\n   181→        domain_signature = self._compute_domain_signature(embedding)\n   182→\n   183→        return LatentRepresentation(\n   184→            embedding=embedding,\n   185→            difficulty=difficulty,\n   186→            discrimination=discrimination,\n   187→            domain_signature=domain_signature\n   188→        )\n   189→\n   190→    def _estimate_difficulty(self, query: str, embedding: np.ndarray) -> float:\n   191→        \"\"\"\n   192→        Estimate query difficulty using multiple signals:\n   193→        1. Embedding norm (specificity)\n   194→        2. Query length and structure\n   195→        3. Technical term density\n   196→        4. Semantic complexity from embedding variance\n   197→        \"\"\"\n   198→        signals = []\n   199→\n   200→        # Signal 1: Embedding norm (normalized)\n   201→        norm = np.linalg.norm(embedding)\n   202→        norm_signal = min(norm / 20.0, 1.0)  # Normalize to 0-1\n   203→        signals.append(norm_signal * 0.2)\n   204→\n   205→        # Signal 2: Query length (log-scaled)\n   206→        length = len(query)\n   207→        length_signal = min(math.log(length + 1) / 7.0, 1.0)  # log(1000) ≈ 7\n   208→        signals.append(length_signal * 0.15)\n   209→\n   210→        # Signal 3: Technical term density\n   211→        technical_terms = [\n   212→            # Core architecture\n   213→            \"architecture\", \"system\", \"design\", \"implement\", \"algorithm\",\n   214→            \"optimize\", \"distributed\", \"scale\", \"microservices\", \"kubernetes\",\n   215→            # Data & storage\n   216→            \"database\", \"cache\", \"redis\", \"postgres\", \"mongodb\", \"kafka\",\n   217→            \"queue\", \"stream\", \"event\", \"cqrs\", \"saga\", \"transaction\",\n   218→            # Concurrency\n   219→            \"async\", \"concurrent\", \"parallel\", \"thread\", \"lock\", \"mutex\",\n   220→            # Reliability\n   221→            \"fault\", \"tolerance\", \"consistency\", \"availability\", \"partition\",\n   222→            \"circuit\", \"breaker\", \"bulkhead\", \"retry\", \"backoff\", \"resilience\",\n   223→            # Theory\n   224→            \"theorem\", \"proof\", \"analysis\", \"complexity\", \"tradeoff\", \"cap\",\n   225→            # ML/AI\n   226→            \"neural\", \"model\", \"training\", \"inference\", \"embedding\", \"transformer\",\n   227→            # Patterns\n   228→            \"pattern\", \"orchestration\", \"choreography\", \"observability\", \"tracing\",\n   229→            \"telemetry\", \"metrics\", \"logging\", \"multi-tenant\", \"saas\", \"api\"\n   230→        ]\n   231→        query_lower = query.lower()\n   232→        tech_count = sum(1 for t in technical_terms if t in query_lower)\n   233→        tech_signal = min(tech_count / 6.0, 1.0)  # Increased divisor for more terms\n   234→        signals.append(tech_signal * 0.35)\n   235→\n   236→        # Signal 4: Question complexity markers\n   237→        complexity_markers = [\n   238→            \"how would you\", \"design a\", \"architect\", \"compare and contrast\",\n   239→            \"what are the tradeoffs\", \"optimize for\", \"scale to\", \"handle\",\n   240→            \"implement a\", \"build a system\", \"evaluate\", \"analyze\",\n   241→            \"considering\", \"ensuring\", \"implementing\", \"complete\", \"full\",\n   242→            \"end-to-end\", \"production\", \"enterprise\", \"across\"\n   243→        ]\n   244→        complexity_count = sum(1 for m in complexity_markers if m in query_lower)\n   245→        complexity_signal = min(complexity_count / 3.0, 1.0)\n   246→        signals.append(complexity_signal * 0.3)\n   247→\n   248→        # Combine signals\n   249→        difficulty = sum(signals)\n   250→\n   251→        # Apply sigmoid for smooth 0-1 output\n   252→        difficulty = 1 / (1 + math.exp(-5 * (difficulty - 0.5)))\n   253→\n   254→        return round(difficulty, 3)\n   255→\n   256→    def _estimate_discrimination(self, query: str, embedding: np.ndarray) -> float:\n   257→        \"\"\"\n   258→        Estimate how much the query discriminates between models.\n   259→        High discrimination = only capable models can answer correctly.\n   260→        Low discrimination = most models perform similarly.\n   261→        \"\"\"\n   262→        # Embedding variance as discrimination proxy\n   263→        variance = np.var(embedding)\n   264→\n   265→        # Normalize to 0-1 range\n   266→        discrimination = min(variance * 10, 1.0)\n   267→\n   268→        # Boost for specific query types\n   269→        query_lower = query.lower()\n   270→        if any(term in query_lower for term in [\"explain\", \"simple\", \"basic\", \"what is\"]):\n   271→            discrimination *= 0.7  # Less discriminating\n   272→        if any(term in query_lower for term in [\"complex\", \"advanced\", \"optimize\", \"design\"]):\n   273→            discrimination *= 1.3  # More discriminating\n   274→\n   275→        return round(min(discrimination, 1.0), 3)\n   276→\n   277→    def _compute_domain_signature(self, embedding: np.ndarray) -> str:\n   278→        \"\"\"Compute semantic domain signature from embedding\"\"\"\n   279→        # Use embedding sign pattern as domain fingerprint\n   280→        sign_pattern = (embedding > 0).astype(np.uint8)\n   281→        return hashlib.md5(sign_pattern.tobytes()).hexdigest()[:8]\n   282→\n   283→    def compute_homeomorphism_score(self,\n   284→                                     query_latent: LatentRepresentation,\n   285→                                     model_embedding: np.ndarray) -> float:\n   286→        \"\"\"\n   287→        Verify homeomorphism between query and model latent spaces.\n   288→        Returns score 0-1 indicating structural compatibility.\n   289→\n   290→        Based on ULHM: checks local continuity preservation.\n   291→        \"\"\"\n   292→        # Cosine similarity as continuity measure\n   293→        query_norm = query_latent.embedding / (np.linalg.norm(query_latent.embedding) + 1e-8)\n   294→        model_norm = model_embedding / (np.linalg.norm(model_embedding) + 1e-8)\n   295→\n   296→        similarity = np.dot(query_norm, model_norm)\n   297→\n   298→        # Convert to 0-1 score\n   299→        score = (similarity + 1) / 2\n   300→\n   301→        return round(score, 3)\n   302→\n   303→\n   304→# ============================================================\n   305→# IRT PREDICTOR\n   306→# ============================================================\n   307→\n   308→class IRTPredictor:\n   309→    \"\"\"\n   310→    Item Response Theory predictor for routing decisions.\n   311→\n   312→    Models the probability of successful response as:\n   313→    P(success) = c + (1-c) * sigmoid(a * (theta - b))\n   314→\n   315→    Where:\n   316→    - theta: model ability\n   317→    - b: query difficulty\n   318→    - a: query discrimination\n   319→    - c: guessing parameter\n   320→\n   321→    Based on IRT-Router (arXiv:2506.01048)\n   322→    \"\"\"\n   323→\n   324→    def __init__(self):\n   325→        self.model_params: Dict[str, IRTParams] = {}\n   326→        self._load_params()\n   327→\n   328→    def _load_params(self):\n   329→        \"\"\"Load IRT parameters from disk\"\"\"\n   330→        if IRT_PARAMS_FILE.exists():\n   331→            try:\n   332→                with open(IRT_PARAMS_FILE) as f:\n   333→                    data = json.load(f)\n   334→                for model, params in data.items():\n   335→                    self.model_params[model] = IRTParams(**params)\n   336→            except Exception:\n   337→                pass\n   338→\n   339→        # Initialize defaults for known models\n   340→        for model, profile in MODEL_PROFILES.items():\n   341→            if model not in self.model_params:\n   342→                self.model_params[model] = IRTParams(\n   343→                    ability=profile[\"capability\"],\n   344→                    guessing=0.1 if profile[\"tier\"] < 2 else 0.05\n   345→                )\n   346→\n   347→    def save_params(self):\n   348→        \"\"\"Persist IRT parameters\"\"\"\n   349→        HSRGS_DIR.mkdir(parents=True, exist_ok=True)\n   350→        data = {}\n   351→        for model, params in self.model_params.items():\n   352→            data[model] = {\n   353→                \"ability\": params.ability,\n   354→                \"domain_abilities\": params.domain_abilities,\n   355→                \"guessing\": params.guessing\n   356→            }\n   357→        with open(IRT_PARAMS_FILE, \"w\") as f:\n   358→            json.dump(data, f, indent=2)\n   359→\n   360→    def predict(self,\n   361→                model: str,\n   362→                query_latent: LatentRepresentation) -> float:\n   363→        \"\"\"\n   364→        Predict P(success) for model on query using 2PL IRT model.\n   365→\n   366→        P(success) = c + (1-c) / (1 + exp(-a * (theta - b)))\n   367→        \"\"\"\n   368→        params = self.model_params.get(model)\n   369→        if not params:\n   370→            # Unknown model - use profile or default\n   371→            profile = MODEL_PROFILES.get(model, {\"capability\": 0.5})\n   372→            params = IRTParams(ability=profile.get(\"capability\", 0.5))\n   373→\n   374→        theta = params.ability  # Model ability\n   375→        b = query_latent.difficulty  # Query difficulty\n   376→        a = query_latent.discrimination  # Query discrimination\n   377→        c = params.guessing  # Guessing parameter\n   378→\n   379→        # Check for domain-specific ability\n   380→        domain = query_latent.domain_signature\n   381→        if domain in params.domain_abilities:\n   382→            theta = params.domain_abilities[domain]\n   383→\n   384→        # 2PL IRT formula with guessing\n   385→        exponent = -a * 2.0 * (theta - b)  # Scale factor of 2\n   386→        prob = c + (1 - c) / (1 + math.exp(exponent))\n   387→\n   388→        return round(prob, 3)\n   389→\n   390→    def update_from_outcome(self,\n   391→                            model: str,\n   392→                            query_latent: LatentRepresentation,\n   393→                            success: bool,\n   394→                            learning_rate: float = 0.01):\n   395→        \"\"\"\n   396→        Update IRT parameters based on observed outcome.\n   397→        Enables continuous learning from routing feedback.\n   398→        \"\"\"\n   399→        params = self.model_params.get(model)\n   400→        if not params:\n   401→            params = IRTParams(ability=0.5)\n   402→            self.model_params[model] = params\n   403→\n   404→        predicted = self.predict(model, query_latent)\n   405→        actual = 1.0 if success else 0.0\n   406→        error = actual - predicted\n   407→\n   408→        # Update ability parameter\n   409→        params.ability += learning_rate * error * query_latent.discrimination\n   410→        params.ability = max(0.0, min(1.0, params.ability))\n   411→\n   412→        # Update domain-specific ability\n   413→        domain = query_latent.domain_signature\n   414→        if domain not in params.domain_abilities:\n   415→            params.domain_abilities[domain] = params.ability\n   416→        params.domain_abilities[domain] += learning_rate * error * 1.5\n   417→        params.domain_abilities[domain] = max(0.0, min(1.0, params.domain_abilities[domain]))\n   418→\n   419→        self.save_params()\n   420→\n   421→\n   422→# ============================================================\n   423→# PRESSURE FIELD SELECTION\n   424→# ============================================================\n   425→\n   426→class PressureFieldSelector:\n   427→    \"\"\"\n   428→    Emergent model selection via pressure gradients.\n   429→\n   430→    Instead of explicit thresholds like \"if complexity > 0.7: opus\",\n   431→    uses continuous pressure fields that naturally route:\n   432→    - Simple queries → low cost models (cost pressure dominates)\n   433→    - Complex queries → capable models (quality pressure dominates)\n   434→\n   435→    Based on Emergent Coordination (arXiv:2601.08129):\n   436→    \"Implicit coordination through shared pressure gradients achieves\n   437→    parity with explicit hierarchical control\"\n   438→    \"\"\"\n   439→\n   440→    def __init__(self, weights: Optional[Dict[str, float]] = None):\n   441→        self.weights = weights or DEFAULT_CONFIG[\"pressure_weights\"]\n   442→\n   443→    def compute_pressure(self,\n   444→                         model: str,\n   445→                         query_latent: LatentRepresentation,\n   446→                         irt_prediction: float,\n   447→                         budget: float = 1.0,\n   448→                         deadline: float = 1.0) -> PressureField:\n   449→        \"\"\"\n   450→        Compute pressure field for a model on a query.\n   451→\n   452→        Lower pressure = better fit for this query.\n   453→\n   454→        Key insight from Emergent Coordination (arXiv:2601.08129):\n   455→        Pressure gradients should naturally route based on query needs.\n   456→        \"\"\"\n   457→        profile = MODEL_PROFILES.get(model, {\"cost\": 1.0, \"latency\": 1.0, \"capability\": 0.5})\n   458→        capability = profile[\"capability\"]\n   459→        difficulty = query_latent.difficulty\n   460→\n   461→        # Cost pressure: higher for expensive models, but REDUCED for complex queries\n   462→        # Complex queries NEED expensive models, so cost pressure drops\n   463→        base_cost = profile[\"cost\"] / 5.0  # Normalize by opus cost (Opus 4.5 pricing)\n   464→        difficulty_discount = math.exp(-3 * difficulty)  # Exponential decay with difficulty\n   465→        cost_pressure = base_cost * difficulty_discount / budget\n   466→\n   467→        # Quality pressure: measures capability GAP\n   468→        # If model capability < query difficulty, quality pressure is HIGH\n   469→        # This is the key innovation: pressure from capability mismatch\n   470→        capability_gap = max(0, difficulty - capability)\n   471→        quality_pressure = capability_gap ** 2 * 5  # Quadratic penalty for under-capability\n   472→        quality_pressure += (1 - irt_prediction) * difficulty * 0.5  # IRT contribution\n   473→\n   474→        # Latency pressure: based on model speed vs deadline\n   475→        # But complex queries tolerate more latency (they take time anyway)\n   476→        latency_tolerance = 1 + difficulty  # More tolerance for complex queries\n   477→        latency_pressure = profile[\"latency\"] / (deadline * latency_tolerance)\n   478→\n   479→        # Total pressure (weighted sum)\n   480→        total = (\n   481→            self.weights[\"cost\"] * cost_pressure +\n   482→            self.weights[\"quality\"] * quality_pressure +\n   483→            self.weights[\"latency\"] * latency_pressure\n   484→        )\n   485→\n   486→        return PressureField(\n   487→            cost_pressure=round(cost_pressure, 3),\n   488→            quality_pressure=round(quality_pressure, 3),\n   489→            latency_pressure=round(latency_pressure, 3),\n   490→            total_pressure=round(total, 3)\n   491→        )\n   492→\n   493→    def select(self,\n   494→               pressures: Dict[str, PressureField],\n   495→               available_models: List[str]) -> Tuple[str, float]:\n   496→        \"\"\"\n   497→        Select model with minimum total pressure.\n   498→        Returns (model, confidence).\n   499→        \"\"\"\n   500→        valid = [(m, p) for m, p in pressures.items() if m in available_models]\n   501→        if not valid:\n   502→            return \"sonnet\", 0.5  # Fallback\n   503→\n   504→        # Sort by total pressure (ascending)\n   505→        valid.sort(key=lambda x: x[1].total_pressure)\n   506→\n   507→        best_model = valid[0][0]\n   508→        best_pressure = valid[0][1].total_pressure\n   509→\n   510→        # Confidence based on pressure gap to second choice\n   511→        if len(valid) > 1:\n   512→            second_pressure = valid[1][1].total_pressure\n   513→            gap = second_pressure - best_pressure\n   514→            confidence = min(gap * 5, 1.0)  # Scale gap to confidence\n   515→        else:\n   516→            confidence = 0.8\n   517→\n   518→        return best_model, round(confidence, 2)\n   519→\n   520→\n   521→# ============================================================\n   522→# GÖDEL SELF-MODIFICATION ENGINE\n   523→# ============================================================\n   524→\n   525→class GodelEngine:\n   526→    \"\"\"\n   527→    Self-modification engine inspired by Gödel Agent.\n   528→\n   529→    Enables the router to modify its own parameters and logic\n   530→    based on empirical validation, not formal proofs.\n   531→\n   532→    Based on:\n   533→    - Gödel Agent (arXiv:2410.04444) - Self-referential improvement\n   534→    - Darwin Gödel Machine (arXiv:2505.22954) - Empirical validation\n   535→    \"\"\"\n   536→\n   537→    def __init__(self):\n   538→        self.archive: List[Dict] = []\n   539→        self.current_version = DEFAULT_CONFIG[\"version\"]\n   540→        self._load_archive()\n   541→\n   542→    def _load_archive(self):\n   543→        \"\"\"Load evolution archive from disk\"\"\"\n   544→        if EVOLUTION_ARCHIVE.exists():\n   545→            try:\n   546→                with open(EVOLUTION_ARCHIVE) as f:\n   547→                    for line in f:\n   548→                        self.archive.append(json.loads(line))\n   549→            except Exception:\n   550→                pass\n   551→\n   552→    def _save_to_archive(self, entry: Dict):\n   553→        \"\"\"Append entry to evolution archive\"\"\"\n   554→        HSRGS_DIR.mkdir(parents=True, exist_ok=True)\n   555→        with open(EVOLUTION_ARCHIVE, \"a\") as f:\n   556→            f.write(json.dumps(entry) + \"\\n\")\n   557→        self.archive.append(entry)\n   558→\n   559→        # Prune if too large\n   560→        max_size = DEFAULT_CONFIG[\"archive_max_size\"]\n   561→        if len(self.archive) > max_size:\n   562→            self.archive = self.archive[-max_size:]\n   563→            with open(EVOLUTION_ARCHIVE, \"w\") as f:\n   564→                for entry in self.archive:\n   565→                    f.write(json.dumps(entry) + \"\\n\")\n   566→\n   567→    def propose_mutation(self,\n   568→                         selector: PressureFieldSelector,\n   569→                         recent_outcomes: List[Dict]) -> Optional[Dict]:\n   570→        \"\"\"\n   571→        Propose a mutation to the routing parameters based on recent outcomes.\n   572→\n   573→        Returns mutation proposal or None if no improvement found.\n   574→        \"\"\"\n   575→        if len(recent_outcomes) < 10:\n   576→            return None  # Need more data\n   577→\n   578→        # Analyze recent performance\n   579→        successes = sum(1 for o in recent_outcomes if o.get(\"success\", False))\n   580→        success_rate = successes / len(recent_outcomes)\n   581→\n   582→        # Analyze cost efficiency\n   583→        total_cost = sum(o.get(\"cost\", 0) for o in recent_outcomes)\n   584→        avg_cost = total_cost / len(recent_outcomes)\n   585→\n   586→        # Propose mutation based on analysis\n   587→        mutation = {\n   588→            \"timestamp\": int(time.time() * 1000),\n   589→            \"type\": None,\n   590→            \"old_value\": None,\n   591→            \"new_value\": None,\n   592→            \"reasoning\": None\n   593→        }\n   594→\n   595→        if success_rate < 0.7:\n   596→            # Quality too low - increase quality pressure weight\n   597→            old_weight = selector.weights[\"quality\"]\n   598→            new_weight = min(old_weight * 1.1, 0.8)\n   599→            mutation.update({\n   600→                \"type\": \"pressure_weight\",\n   601→                \"param\": \"quality\",\n   602→                \"old_value\": old_weight,\n   603→                \"new_value\": new_weight,\n   604→                \"reasoning\": f\"Success rate {success_rate:.1%} below target, increasing quality pressure\"\n   605→            })\n   606→        elif avg_cost > 5.0 and success_rate > 0.85:\n   607→            # Cost too high with good success - increase cost pressure\n   608→            old_weight = selector.weights[\"cost\"]\n   609→            new_weight = min(old_weight * 1.1, 0.6)\n   610→            mutation.update({\n   611→                \"type\": \"pressure_weight\",\n   612→                \"param\": \"cost\",\n   613→                \"old_value\": old_weight,\n   614→                \"new_value\": new_weight,\n   615→                \"reasoning\": f\"Avg cost ${avg_cost:.2f} with {success_rate:.1%} success, increasing cost pressure\"\n   616→            })\n   617→        else:\n   618→            return None  # No mutation needed\n   619→\n   620→        return mutation\n   621→\n   622→    def apply_mutation(self,\n   623→                       mutation: Dict,\n   624→                       selector: PressureFieldSelector) -> bool:\n   625→        \"\"\"Apply a mutation to the selector\"\"\"\n   626→        if mutation[\"type\"] == \"pressure_weight\":\n   627→            param = mutation[\"param\"]\n   628→            selector.weights[param] = mutation[\"new_value\"]\n   629→\n   630→            # Renormalize weights\n   631→            total = sum(selector.weights.values())\n   632→            for k in selector.weights:\n   633→                selector.weights[k] /= total\n   634→\n   635→            self._save_to_archive(mutation)\n   636→            return True\n   637→\n   638→        return False\n   639→\n   640→    def rollback_mutation(self,\n   641→                          mutation: Dict,\n   642→                          selector: PressureFieldSelector):\n   643→        \"\"\"Rollback a mutation if it caused regression\"\"\"\n   644→        if mutation[\"type\"] == \"pressure_weight\":\n   645→            param = mutation[\"param\"]\n   646→            selector.weights[param] = mutation[\"old_value\"]\n   647→\n   648→            rollback_entry = {\n   649→                \"timestamp\": int(time.time() * 1000),\n   650→                \"type\": \"rollback\",\n   651→                \"original_mutation\": mutation\n   652→            }\n   653→            self._save_to_archive(rollback_entry)\n   654→\n   655→\n   656→# ============================================================\n   657→# MAIN ROUTER\n   658→# ============================================================\n   659→\n   660→class HSRGSRouter:\n   661→    \"\"\"\n   662→    Homeomorphic Self-Routing Gödel System\n   663→\n   664→    The main router that combines all components:\n   665→    1. Homeomorphic encoder for universal latent space\n   666→    2. IRT predictor for success probability\n   667→    3. Pressure field selector for emergent routing\n   668→    4. Gödel engine for self-modification\n   669→    \"\"\"\n   670→\n   671→    def __init__(self, available_models: Optional[List[str]] = None):\n   672→        self.encoder = HomeomorphicEncoder()\n   673→        self.irt = IRTPredictor()\n   674→        self.selector = PressureFieldSelector()\n   675→        self.godel = GodelEngine()\n   676→        self.available_models = available_models or list(MODEL_PROFILES.keys())\n   677→        self.recent_outcomes: List[Dict] = []\n   678→        self._load_config()\n   679→\n   680→    def _load_config(self):\n   681→        \"\"\"Load configuration\"\"\"\n   682→        HSRGS_DIR.mkdir(parents=True, exist_ok=True)\n   683→        if CONFIG_FILE.exists():\n   684→            try:\n   685→                with open(CONFIG_FILE) as f:\n   686→                    config = json.load(f)\n   687→                self.selector.weights = config.get(\"pressure_weights\", DEFAULT_CONFIG[\"pressure_weights\"])\n   688→            except Exception:\n   689→                pass\n   690→\n   691→    def save_config(self):\n   692→        \"\"\"Save configuration\"\"\"\n   693→        config = {\n   694→            **DEFAULT_CONFIG,\n   695→            \"pressure_weights\": self.selector.weights\n   696→        }\n   697→        with open(CONFIG_FILE, \"w\") as f:\n   698→            json.dump(config, f, indent=2)\n   699→\n   700→    def route(self,\n   701→              query: str,\n   702→              budget: float = 1.0,\n   703→              deadline: float = 1.0) -> RoutingDecision:\n   704→        \"\"\"\n   705→        Route a query to the optimal model.\n   706→\n   707→        Args:\n   708→            query: The user query\n   709→            budget: Cost budget multiplier (1.0 = normal, 0.5 = half budget)\n   710→            deadline: Latency deadline multiplier (1.0 = normal, 0.5 = need fast)\n   711→\n   712→        Returns:\n   713→            RoutingDecision with full provenance\n   714→        \"\"\"\n   715→        # 1. Encode query into universal latent space\n   716→        latent = self.encoder.encode_query(query)\n   717→\n   718→        # 2. Predict success probability for each model\n   719→        irt_predictions = {}\n   720→        for model in self.available_models:\n   721→            irt_predictions[model] = self.irt.predict(model, latent)\n   722→\n   723→        # 3. Compute pressure field for each model\n   724→        pressures = {}\n   725→        for model in self.available_models:\n   726→            pressures[model] = self.selector.compute_pressure(\n   727→                model, latent, irt_predictions[model], budget, deadline\n   728→            )\n   729→\n   730→        # 4. Select model with minimum pressure\n   731→        selected, confidence = self.selector.select(pressures, self.available_models)\n   732→\n   733→        # 5. Build reasoning explanation\n   734→        reasoning = self._build_reasoning(latent, irt_predictions, pressures, selected)\n   735→\n   736→        # 6. Create decision record\n   737→        decision = RoutingDecision(\n   738→            query_hash=hashlib.md5(query.encode()).hexdigest(),\n   739→            selected_model=selected,\n   740→            latent=latent,\n   741→            pressures={m: asdict(p) for m, p in pressures.items()},\n   742→            irt_predictions=irt_predictions,\n   743→            confidence=confidence,\n   744→            reasoning=reasoning,\n   745→            timestamp=int(time.time() * 1000),\n   746→            version=self.godel.current_version\n   747→        )\n   748→\n   749→        # 7. Log decision\n   750→        self._log_decision(query, decision)\n   751→\n   752→        return decision\n   753→\n   754→    def _build_reasoning(self,\n   755→                         latent: LatentRepresentation,\n   756→                         irt_predictions: Dict[str, float],\n   757→                         pressures: Dict[str, PressureField],\n   758→                         selected: str) -> str:\n   759→        \"\"\"Build human-readable reasoning for the decision\"\"\"\n   760→        parts = []\n   761→\n   762→        # Difficulty assessment\n   763→        if latent.difficulty < 0.3:\n   764→            parts.append(\"simple query\")\n   765→        elif latent.difficulty < 0.6:\n   766→            parts.append(\"moderate complexity\")\n   767→        else:\n   768→            parts.append(\"complex query\")\n   769→\n   770→        # Discrimination\n   771→        if latent.discrimination > 0.5:\n   772→            parts.append(\"high model differentiation\")\n   773→\n   774→        # IRT insight\n   775→        top_irt = max(irt_predictions.items(), key=lambda x: x[1])\n   776→        if top_irt[0] != selected:\n   777→            parts.append(f\"IRT favored {top_irt[0]} ({top_irt[1]:.0%})\")\n   778→\n   779→        # Pressure insight\n   780→        selected_pressure = pressures[selected]\n   781→        if selected_pressure.cost_pressure < selected_pressure.quality_pressure:\n   782→            parts.append(\"cost-optimized\")\n   783→        else:\n   784→            parts.append(\"quality-optimized\")\n   785→\n   786→        return \"; \".join(parts)\n   787→\n   788→    def _log_decision(self, query: str, decision: RoutingDecision):\n   789→        \"\"\"Log routing decision for learning\"\"\"\n   790→        HSRGS_DIR.mkdir(parents=True, exist_ok=True)\n   791→\n   792→        log_entry = {\n   793→            \"ts\": decision.timestamp,\n   794→            \"query_hash\": decision.query_hash,\n   795→            \"query_preview\": query[:80] if len(query) > 80 else query,\n   796→            \"model\": decision.selected_model,\n   797→            \"difficulty\": float(decision.latent.difficulty),\n   798→            \"discrimination\": float(decision.latent.discrimination),\n   799→            \"irt_pred\": float(decision.irt_predictions.get(decision.selected_model, 0)),\n   800→            \"confidence\": float(decision.confidence),\n   801→            \"version\": decision.version\n   802→        }\n   803→\n   804→        with open(ROUTING_LOG, \"a\") as f:\n   805→            f.write(json.dumps(log_entry) + \"\\n\")\n   806→\n   807→        # Write IRT bridge file for cross-runtime consumption (Node.js DQ scorer)\n   808→        self._write_irt_bridge(query, decision)\n   809→\n   810→        # Also log to coevo data pipeline for cross-system learning\n   811→        self._log_to_coevo(query, decision)\n   812→\n   813→    def _write_irt_bridge(self, query: str, decision: RoutingDecision):\n   814→        \"\"\"Write IRT difficulty data to bridge file for Node.js DQ scorer consumption.\"\"\"\n   815→        try:\n   816→            bridge_data = {\n   817→                \"query_hash\": decision.query_hash,\n   818→                \"difficulty\": float(decision.latent.difficulty),\n   819→                \"discrimination\": float(decision.latent.discrimination),\n   820→                \"domain_signature\": decision.latent.domain_signature,\n   821→                \"irt_predictions\": {m: float(p) for m, p in decision.irt_predictions.items()},\n   822→                \"selected_model\": decision.selected_model,\n   823→                \"timestamp\": decision.timestamp\n   824→            }\n   825→            HSRGS_DIR.mkdir(parents=True, exist_ok=True)\n   826→            with open(IRT_BRIDGE_FILE, \"w\") as f:\n   827→                json.dump(bridge_data, f, indent=2)\n   828→        except Exception:\n   829→            pass  # Silent fail — don't break routing\n   830→\n   831→    def _log_to_coevo(self, query: str, decision: RoutingDecision):\n   832→        \"\"\"Log to shared coevo data pipeline for meta-analyzer integration\"\"\"\n   833→        try:\n   834→            # Build alternatives from pressure rankings\n   835→            alternatives = []\n   836→            sorted_pressures = sorted(\n   837→                decision.pressures.items(),\n   838→                key=lambda x: x[1][\"total_pressure\"]\n   839→            )\n   840→            for model, pressure in sorted_pressures[1:4]:  # Top 3 alternatives\n   841→                if model != decision.selected_model:\n   842→                    # Estimate alternative DQ from IRT prediction\n   843→                    alt_dq = decision.irt_predictions.get(model, 0.5)\n   844→                    alternatives.append({\"model\": model, \"dq\": round(alt_dq, 2)})\n   845→\n   846→            coevo_record = {\n   847→                \"ts\": decision.timestamp,\n   848→                \"source\": \"hsrgs\",\n   849→                \"version\": decision.version,\n   850→                \"query_hash\": decision.query_hash,\n   851→                \"query_preview\": query[:80] if len(query) > 80 else query,\n   852→                \"complexity\": float(decision.latent.difficulty),\n   853→                \"complexity_reasoning\": decision.reasoning,\n   854→                \"model\": decision.selected_model,\n   855→                \"dqScore\": float(decision.latent.difficulty),\n   856→                \"dqComponents\": {\n   857→                    \"validity\": 1.0,  # HSRGS validates via embedding\n   858→                    \"specificity\": float(decision.latent.discrimination),\n   859→                    \"correctness\": float(decision.irt_predictions.get(decision.selected_model, 0.5))\n   860→                },\n   861→                \"hsrgs_data\": {\n   862→                    \"difficulty\": float(decision.latent.difficulty),\n   863→                    \"discrimination\": float(decision.latent.discrimination),\n   864→                    \"domain\": decision.latent.domain_signature,\n   865→                    \"confidence\": float(decision.confidence),\n   866→                    \"pressure_winner\": decision.selected_model,\n   867→                    \"irt_prediction\": float(decision.irt_predictions.get(decision.selected_model, 0))\n   868→                },\n   869→                \"alternatives\": alternatives\n   870→            }\n   871→\n   872→            COEVO_DQ_FILE.parent.mkdir(parents=True, exist_ok=True)\n   873→            with open(COEVO_DQ_FILE, \"a\") as f:\n   874→                f.write(json.dumps(coevo_record) + \"\\n\")\n   875→        except Exception:\n   876→            pass  # Silent fail - don't break routing\n   877→\n   878→    def record_outcome(self, query_hash: str, success: bool, cost: float = 0.0):\n   879→        \"\"\"\n   880→        Record outcome for learning.\n   881→        Enables IRT parameter updates and Gödel self-modification.\n   882→        \"\"\"\n   883→        # Find the decision\n   884→        if not ROUTING_LOG.exists():\n   885→            return\n   886→\n   887→        decision = None\n   888→        with open(ROUTING_LOG) as f:\n   889→            for line in f:\n   890→                entry = json.loads(line)\n   891→                if entry[\"query_hash\"] == query_hash:\n   892→                    decision = entry\n   893→\n   894→        if not decision:\n   895→            return\n   896→\n   897→        # Update IRT parameters\n   898→        # (Would need to reconstruct latent - simplified here)\n   899→\n   900→        # Record for Gödel engine\n   901→        self.recent_outcomes.append({\n   902→            \"query_hash\": query_hash,\n   903→            \"model\": decision[\"model\"],\n   904→            \"success\": success,\n   905→            \"cost\": cost,\n   906→            \"timestamp\": int(time.time() * 1000)\n   907→        })\n   908→\n   909→        # Keep only recent outcomes\n   910→        self.recent_outcomes = self.recent_outcomes[-100:]\n   911→\n   912→        # Check for self-modification opportunity\n   913→        if len(self.recent_outcomes) >= 20:\n   914→            mutation = self.godel.propose_mutation(self.selector, self.recent_outcomes)\n   915→            if mutation:\n   916→                self.godel.apply_mutation(mutation, self.selector)\n   917→                self.save_config()\n   918→\n   919→    def get_status(self) -> Dict:\n   920→        \"\"\"Get current router status\"\"\"\n   921→        return {\n   922→            \"version\": self.godel.current_version,\n   923→            \"available_models\": self.available_models,\n   924→            \"pressure_weights\": self.selector.weights,\n   925→            \"evolution_entries\": len(self.godel.archive),\n   926→            \"recent_outcomes\": len(self.recent_outcomes),\n   927→            \"irt_models\": list(self.irt.model_params.keys())\n   928→        }\n   929→\n   930→\n   931→# ============================================================\n   932→# CLI INTERFACE\n   933→# ============================================================\n   934→\n   935→def main():\n   936→    \"\"\"CLI for testing HSRGS\"\"\"\n   937→    import sys\n   938→\n   939→    router = HSRGSRouter()\n   940→\n   941→    if len(sys.argv) > 1:\n   942→        query = \" \".join(sys.argv[1:])\n   943→        decision = router.route(query)\n   944→\n   945→        print(f\"\\n{'='*60}\")\n   946→        print(f\"HSRGS Routing Decision\")\n   947→        print(f\"{'='*60}\")\n   948→        print(f\"Query: {query[:60]}...\")\n   949→        print(f\"{'─'*60}\")\n   950→        print(f\"Difficulty:      {decision.latent.difficulty:.2f}\")\n   951→        print(f\"Discrimination:  {decision.latent.discrimination:.2f}\")\n   952→        print(f\"Domain:          {decision.latent.domain_signature}\")\n   953→        print(f\"{'─'*60}\")\n   954→        print(f\"Selected Model:  {decision.selected_model}\")\n   955→        print(f\"Confidence:      {decision.confidence:.0%}\")\n   956→        print(f\"IRT Prediction:  {decision.irt_predictions[decision.selected_model]:.0%}\")\n   957→        print(f\"{'─'*60}\")\n   958→        print(f\"Reasoning: {decision.reasoning}\")\n   959→        print(f\"{'='*60}\\n\")\n   960→\n   961→        # Show pressure breakdown\n   962→        print(\"Pressure Field:\")\n   963→        for model, pressure in sorted(decision.pressures.items(),\n   964→                                       key=lambda x: x[1][\"total_pressure\"]):\n   965→            p = pressure\n   966→            marker = \" ← selected\" if model == decision.selected_model else \"\"\n   967→            print(f\"  {model:12} | cost:{p['cost_pressure']:.2f} quality:{p['quality_pressure']:.2f} \"\n   968→                  f\"latency:{p['latency_pressure']:.2f} | total:{p['total_pressure']:.2f}{marker}\")\n   969→        print()\n   970→    else:\n   971→        print(\"HSRGS Status:\")\n   972→        status = router.get_status()\n   973→        for k, v in status.items():\n   974→            print(f\"  {k}: {v}\")\n   975→\n   976→\n   977→if __name__ == \"__main__\":\n   978→    main()\n   979→"}]},"parent_tool_use_id":null,"session_id":"95a09e8b-7d79-4200-b0e6-9f92b46276f6","uuid":"0029a6c6-49f3-4321-9769-d1b9ab103892","tool_use_result":{"type":"text","file":{"filePath":"/Users/dicoangelo/projects/core/meta-vengine/kernel/hsrgs.py","content":"#!/usr/bin/env python3\n\"\"\"\nHSRGS: Homeomorphic Self-Routing Gödel System\n\nA revolutionary routing system that:\n1. Encodes queries AND models in a universal homeomorphic latent space\n2. Uses IRT (Item Response Theory) to predict P(success|query, model)\n3. Self-modifies its own routing logic via Gödel machine principles\n4. Selects models via emergent pressure gradients, not explicit rules\n\nBased on convergence of:\n- ZeroRouter (arXiv:2601.06220) - Universal latent space\n- ULHM (arXiv:2601.09025) - Homeomorphic manifold unification\n- IRT-Router (arXiv:2506.01048) - Psychometric routing\n- Darwin Gödel Machine (arXiv:2505.22954) - Open-ended self-improvement\n- Emergent Coordination (arXiv:2601.08129) - Pressure field selection\n\nAuthor: D-Ecosystem / Metaventions AI\n\"\"\"\n\nimport json\nimport hashlib\nimport time\nimport math\nimport sys\nfrom pathlib import Path\nfrom typing import Optional, Dict, List, Tuple, Any\nfrom dataclasses import dataclass, field, asdict\nimport numpy as np\n\n# Import centralized pricing\nsys.path.insert(0, str(Path.home() / \".claude/config\"))\ntry:\n    from pricing import PRICING as _CENTRALIZED_PRICING\nexcept ImportError:\n    _CENTRALIZED_PRICING = {\"opus\": {\"input\": 5}, \"sonnet\": {\"input\": 3}, \"haiku\": {\"input\": 0.8}}\n\n# Lazy load heavy dependencies\n_encoder = None\n_model_embeddings = None\n\n# ============================================================\n# CONFIGURATION\n# ============================================================\n\nHSRGS_DIR = Path.home() / \".claude\" / \"kernel\" / \"hsrgs\"\nCONFIG_FILE = HSRGS_DIR / \"config.json\"\nEMBEDDINGS_FILE = HSRGS_DIR / \"model_embeddings.npz\"\nIRT_PARAMS_FILE = HSRGS_DIR / \"irt_params.json\"\nEVOLUTION_ARCHIVE = HSRGS_DIR / \"evolution_archive.jsonl\"\nROUTING_LOG = HSRGS_DIR / \"routing_log.jsonl\"\nIRT_BRIDGE_FILE = HSRGS_DIR / \"irt-bridge.json\"\n\n# Coevo integration - shared data pipeline\nCOEVO_DQ_FILE = Path.home() / \".claude\" / \"kernel\" / \"dq-scores.jsonl\"\n\nDEFAULT_CONFIG = {\n    \"encoder_model\": \"all-MiniLM-L6-v2\",  # Fast, good quality\n    \"embedding_dim\": 384,\n    \"irt_learning_rate\": 0.01,\n    \"pressure_weights\": {\n        \"cost\": 0.3,\n        \"quality\": 0.5,\n        \"latency\": 0.2\n    },\n    \"evolution_enabled\": True,\n    \"mutation_rate\": 0.1,\n    \"archive_max_size\": 100,\n    \"version\": \"1.0.0\"\n}\n\n# Model characteristics (costs from centralized config, others learned over time)\nMODEL_PROFILES = {\n    \"local\": {\"cost\": 0.0, \"latency\": 0.1, \"capability\": 0.3, \"tier\": 0},\n    \"local-fast\": {\"cost\": 0.0, \"latency\": 0.05, \"capability\": 0.2, \"tier\": 0},\n    \"flash\": {\"cost\": 0.075, \"latency\": 0.3, \"capability\": 0.5, \"tier\": 1},\n    \"haiku\": {\"cost\": _CENTRALIZED_PRICING.get(\"haiku\", {}).get(\"input\", 0.8), \"latency\": 0.4, \"capability\": 0.6, \"tier\": 2},\n    \"gpt-mini\": {\"cost\": 0.15, \"latency\": 0.35, \"capability\": 0.55, \"tier\": 2},\n    \"sonnet\": {\"cost\": _CENTRALIZED_PRICING.get(\"sonnet\", {}).get(\"input\", 3.0), \"latency\": 0.8, \"capability\": 0.85, \"tier\": 3},\n    \"gpt-4o\": {\"cost\": 2.5, \"latency\": 0.7, \"capability\": 0.82, \"tier\": 3},\n    \"pro\": {\"cost\": 1.25, \"latency\": 0.6, \"capability\": 0.75, \"tier\": 3},\n    \"opus\": {\"cost\": _CENTRALIZED_PRICING.get(\"opus\", {}).get(\"input\", 5.0), \"latency\": 1.5, \"capability\": 1.0, \"tier\": 4},\n}\n\n\n# ============================================================\n# DATA CLASSES\n# ============================================================\n\n@dataclass\nclass LatentRepresentation:\n    \"\"\"Universal latent space representation\"\"\"\n    embedding: np.ndarray\n    difficulty: float  # IRT difficulty parameter (0-1)\n    discrimination: float  # IRT discrimination parameter\n    domain_signature: str  # Hash of semantic domain\n\n@dataclass\nclass IRTParams:\n    \"\"\"Item Response Theory parameters for a model\"\"\"\n    ability: float  # Model's general ability (theta)\n    domain_abilities: Dict[str, float] = field(default_factory=dict)  # Per-domain abilities\n    guessing: float = 0.1  # Probability of correct by chance\n\n@dataclass\nclass PressureField:\n    \"\"\"Emergent pressure gradients for model selection\"\"\"\n    cost_pressure: float\n    quality_pressure: float\n    latency_pressure: float\n    total_pressure: float\n\n@dataclass\nclass RoutingDecision:\n    \"\"\"Complete routing decision with provenance\"\"\"\n    query_hash: str\n    selected_model: str\n    latent: LatentRepresentation\n    pressures: Dict[str, PressureField]\n    irt_predictions: Dict[str, float]\n    confidence: float\n    reasoning: str\n    timestamp: int\n    version: str\n\n\n# ============================================================\n# HOMEOMORPHIC ENCODER\n# ============================================================\n\nclass HomeomorphicEncoder:\n    \"\"\"\n    Encodes queries into a universal latent space that is homeomorphic\n    to the model capability space, enabling zero-shot model onboarding.\n\n    Based on ZeroRouter + ULHM principles:\n    - Query difficulty decoupled from model profiling\n    - Continuous bijection preserving topological structure\n    \"\"\"\n\n    def __init__(self, model_name: str = \"all-MiniLM-L6-v2\"):\n        self.model_name = model_name\n        self._encoder = None\n        self._model_embeddings = {}\n        self._domain_centroids = {}\n\n    def _load_encoder(self):\n        \"\"\"Lazy load the sentence transformer\"\"\"\n        if self._encoder is None:\n            from sentence_transformers import SentenceTransformer\n            self._encoder = SentenceTransformer(self.model_name)\n        return self._encoder\n\n    def encode_query(self, query: str) -> LatentRepresentation:\n        \"\"\"\n        Encode query into universal latent space.\n\n        Returns:\n            LatentRepresentation with:\n            - embedding: Dense vector in universal space\n            - difficulty: Estimated query difficulty (0-1)\n            - discrimination: How much difficulty varies by model\n            - domain_signature: Semantic domain hash\n        \"\"\"\n        encoder = self._load_encoder()\n\n        # Get dense embedding\n        embedding = encoder.encode(query, convert_to_numpy=True)\n\n        # Estimate difficulty from embedding properties\n        # Higher norm = more specific/complex query\n        norm = np.linalg.norm(embedding)\n\n        # Difficulty estimation via multiple signals\n        difficulty = self._estimate_difficulty(query, embedding)\n\n        # Discrimination: how much the query differentiates models\n        discrimination = self._estimate_discrimination(query, embedding)\n\n        # Domain signature for domain-specific routing\n        domain_signature = self._compute_domain_signature(embedding)\n\n        return LatentRepresentation(\n            embedding=embedding,\n            difficulty=difficulty,\n            discrimination=discrimination,\n            domain_signature=domain_signature\n        )\n\n    def _estimate_difficulty(self, query: str, embedding: np.ndarray) -> float:\n        \"\"\"\n        Estimate query difficulty using multiple signals:\n        1. Embedding norm (specificity)\n        2. Query length and structure\n        3. Technical term density\n        4. Semantic complexity from embedding variance\n        \"\"\"\n        signals = []\n\n        # Signal 1: Embedding norm (normalized)\n        norm = np.linalg.norm(embedding)\n        norm_signal = min(norm / 20.0, 1.0)  # Normalize to 0-1\n        signals.append(norm_signal * 0.2)\n\n        # Signal 2: Query length (log-scaled)\n        length = len(query)\n        length_signal = min(math.log(length + 1) / 7.0, 1.0)  # log(1000) ≈ 7\n        signals.append(length_signal * 0.15)\n\n        # Signal 3: Technical term density\n        technical_terms = [\n            # Core architecture\n            \"architecture\", \"system\", \"design\", \"implement\", \"algorithm\",\n            \"optimize\", \"distributed\", \"scale\", \"microservices\", \"kubernetes\",\n            # Data & storage\n            \"database\", \"cache\", \"redis\", \"postgres\", \"mongodb\", \"kafka\",\n            \"queue\", \"stream\", \"event\", \"cqrs\", \"saga\", \"transaction\",\n            # Concurrency\n            \"async\", \"concurrent\", \"parallel\", \"thread\", \"lock\", \"mutex\",\n            # Reliability\n            \"fault\", \"tolerance\", \"consistency\", \"availability\", \"partition\",\n            \"circuit\", \"breaker\", \"bulkhead\", \"retry\", \"backoff\", \"resilience\",\n            # Theory\n            \"theorem\", \"proof\", \"analysis\", \"complexity\", \"tradeoff\", \"cap\",\n            # ML/AI\n            \"neural\", \"model\", \"training\", \"inference\", \"embedding\", \"transformer\",\n            # Patterns\n            \"pattern\", \"orchestration\", \"choreography\", \"observability\", \"tracing\",\n            \"telemetry\", \"metrics\", \"logging\", \"multi-tenant\", \"saas\", \"api\"\n        ]\n        query_lower = query.lower()\n        tech_count = sum(1 for t in technical_terms if t in query_lower)\n        tech_signal = min(tech_count / 6.0, 1.0)  # Increased divisor for more terms\n        signals.append(tech_signal * 0.35)\n\n        # Signal 4: Question complexity markers\n        complexity_markers = [\n            \"how would you\", \"design a\", \"architect\", \"compare and contrast\",\n            \"what are the tradeoffs\", \"optimize for\", \"scale to\", \"handle\",\n            \"implement a\", \"build a system\", \"evaluate\", \"analyze\",\n            \"considering\", \"ensuring\", \"implementing\", \"complete\", \"full\",\n            \"end-to-end\", \"production\", \"enterprise\", \"across\"\n        ]\n        complexity_count = sum(1 for m in complexity_markers if m in query_lower)\n        complexity_signal = min(complexity_count / 3.0, 1.0)\n        signals.append(complexity_signal * 0.3)\n\n        # Combine signals\n        difficulty = sum(signals)\n\n        # Apply sigmoid for smooth 0-1 output\n        difficulty = 1 / (1 + math.exp(-5 * (difficulty - 0.5)))\n\n        return round(difficulty, 3)\n\n    def _estimate_discrimination(self, query: str, embedding: np.ndarray) -> float:\n        \"\"\"\n        Estimate how much the query discriminates between models.\n        High discrimination = only capable models can answer correctly.\n        Low discrimination = most models perform similarly.\n        \"\"\"\n        # Embedding variance as discrimination proxy\n        variance = np.var(embedding)\n\n        # Normalize to 0-1 range\n        discrimination = min(variance * 10, 1.0)\n\n        # Boost for specific query types\n        query_lower = query.lower()\n        if any(term in query_lower for term in [\"explain\", \"simple\", \"basic\", \"what is\"]):\n            discrimination *= 0.7  # Less discriminating\n        if any(term in query_lower for term in [\"complex\", \"advanced\", \"optimize\", \"design\"]):\n            discrimination *= 1.3  # More discriminating\n\n        return round(min(discrimination, 1.0), 3)\n\n    def _compute_domain_signature(self, embedding: np.ndarray) -> str:\n        \"\"\"Compute semantic domain signature from embedding\"\"\"\n        # Use embedding sign pattern as domain fingerprint\n        sign_pattern = (embedding > 0).astype(np.uint8)\n        return hashlib.md5(sign_pattern.tobytes()).hexdigest()[:8]\n\n    def compute_homeomorphism_score(self,\n                                     query_latent: LatentRepresentation,\n                                     model_embedding: np.ndarray) -> float:\n        \"\"\"\n        Verify homeomorphism between query and model latent spaces.\n        Returns score 0-1 indicating structural compatibility.\n\n        Based on ULHM: checks local continuity preservation.\n        \"\"\"\n        # Cosine similarity as continuity measure\n        query_norm = query_latent.embedding / (np.linalg.norm(query_latent.embedding) + 1e-8)\n        model_norm = model_embedding / (np.linalg.norm(model_embedding) + 1e-8)\n\n        similarity = np.dot(query_norm, model_norm)\n\n        # Convert to 0-1 score\n        score = (similarity + 1) / 2\n\n        return round(score, 3)\n\n\n# ============================================================\n# IRT PREDICTOR\n# ============================================================\n\nclass IRTPredictor:\n    \"\"\"\n    Item Response Theory predictor for routing decisions.\n\n    Models the probability of successful response as:\n    P(success) = c + (1-c) * sigmoid(a * (theta - b))\n\n    Where:\n    - theta: model ability\n    - b: query difficulty\n    - a: query discrimination\n    - c: guessing parameter\n\n    Based on IRT-Router (arXiv:2506.01048)\n    \"\"\"\n\n    def __init__(self):\n        self.model_params: Dict[str, IRTParams] = {}\n        self._load_params()\n\n    def _load_params(self):\n        \"\"\"Load IRT parameters from disk\"\"\"\n        if IRT_PARAMS_FILE.exists():\n            try:\n                with open(IRT_PARAMS_FILE) as f:\n                    data = json.load(f)\n                for model, params in data.items():\n                    self.model_params[model] = IRTParams(**params)\n            except Exception:\n                pass\n\n        # Initialize defaults for known models\n        for model, profile in MODEL_PROFILES.items():\n            if model not in self.model_params:\n                self.model_params[model] = IRTParams(\n                    ability=profile[\"capability\"],\n                    guessing=0.1 if profile[\"tier\"] < 2 else 0.05\n                )\n\n    def save_params(self):\n        \"\"\"Persist IRT parameters\"\"\"\n        HSRGS_DIR.mkdir(parents=True, exist_ok=True)\n        data = {}\n        for model, params in self.model_params.items():\n            data[model] = {\n                \"ability\": params.ability,\n                \"domain_abilities\": params.domain_abilities,\n                \"guessing\": params.guessing\n            }\n        with open(IRT_PARAMS_FILE, \"w\") as f:\n            json.dump(data, f, indent=2)\n\n    def predict(self,\n                model: str,\n                query_latent: LatentRepresentation) -> float:\n        \"\"\"\n        Predict P(success) for model on query using 2PL IRT model.\n\n        P(success) = c + (1-c) / (1 + exp(-a * (theta - b)))\n        \"\"\"\n        params = self.model_params.get(model)\n        if not params:\n            # Unknown model - use profile or default\n            profile = MODEL_PROFILES.get(model, {\"capability\": 0.5})\n            params = IRTParams(ability=profile.get(\"capability\", 0.5))\n\n        theta = params.ability  # Model ability\n        b = query_latent.difficulty  # Query difficulty\n        a = query_latent.discrimination  # Query discrimination\n        c = params.guessing  # Guessing parameter\n\n        # Check for domain-specific ability\n        domain = query_latent.domain_signature\n        if domain in params.domain_abilities:\n            theta = params.domain_abilities[domain]\n\n        # 2PL IRT formula with guessing\n        exponent = -a * 2.0 * (theta - b)  # Scale factor of 2\n        prob = c + (1 - c) / (1 + math.exp(exponent))\n\n        return round(prob, 3)\n\n    def update_from_outcome(self,\n                            model: str,\n                            query_latent: LatentRepresentation,\n                            success: bool,\n                            learning_rate: float = 0.01):\n        \"\"\"\n        Update IRT parameters based on observed outcome.\n        Enables continuous learning from routing feedback.\n        \"\"\"\n        params = self.model_params.get(model)\n        if not params:\n            params = IRTParams(ability=0.5)\n            self.model_params[model] = params\n\n        predicted = self.predict(model, query_latent)\n        actual = 1.0 if success else 0.0\n        error = actual - predicted\n\n        # Update ability parameter\n        params.ability += learning_rate * error * query_latent.discrimination\n        params.ability = max(0.0, min(1.0, params.ability))\n\n        # Update domain-specific ability\n        domain = query_latent.domain_signature\n        if domain not in params.domain_abilities:\n            params.domain_abilities[domain] = params.ability\n        params.domain_abilities[domain] += learning_rate * error * 1.5\n        params.domain_abilities[domain] = max(0.0, min(1.0, params.domain_abilities[domain]))\n\n        self.save_params()\n\n\n# ============================================================\n# PRESSURE FIELD SELECTION\n# ============================================================\n\nclass PressureFieldSelector:\n    \"\"\"\n    Emergent model selection via pressure gradients.\n\n    Instead of explicit thresholds like \"if complexity > 0.7: opus\",\n    uses continuous pressure fields that naturally route:\n    - Simple queries → low cost models (cost pressure dominates)\n    - Complex queries → capable models (quality pressure dominates)\n\n    Based on Emergent Coordination (arXiv:2601.08129):\n    \"Implicit coordination through shared pressure gradients achieves\n    parity with explicit hierarchical control\"\n    \"\"\"\n\n    def __init__(self, weights: Optional[Dict[str, float]] = None):\n        self.weights = weights or DEFAULT_CONFIG[\"pressure_weights\"]\n\n    def compute_pressure(self,\n                         model: str,\n                         query_latent: LatentRepresentation,\n                         irt_prediction: float,\n                         budget: float = 1.0,\n                         deadline: float = 1.0) -> PressureField:\n        \"\"\"\n        Compute pressure field for a model on a query.\n\n        Lower pressure = better fit for this query.\n\n        Key insight from Emergent Coordination (arXiv:2601.08129):\n        Pressure gradients should naturally route based on query needs.\n        \"\"\"\n        profile = MODEL_PROFILES.get(model, {\"cost\": 1.0, \"latency\": 1.0, \"capability\": 0.5})\n        capability = profile[\"capability\"]\n        difficulty = query_latent.difficulty\n\n        # Cost pressure: higher for expensive models, but REDUCED for complex queries\n        # Complex queries NEED expensive models, so cost pressure drops\n        base_cost = profile[\"cost\"] / 5.0  # Normalize by opus cost (Opus 4.5 pricing)\n        difficulty_discount = math.exp(-3 * difficulty)  # Exponential decay with difficulty\n        cost_pressure = base_cost * difficulty_discount / budget\n\n        # Quality pressure: measures capability GAP\n        # If model capability < query difficulty, quality pressure is HIGH\n        # This is the key innovation: pressure from capability mismatch\n        capability_gap = max(0, difficulty - capability)\n        quality_pressure = capability_gap ** 2 * 5  # Quadratic penalty for under-capability\n        quality_pressure += (1 - irt_prediction) * difficulty * 0.5  # IRT contribution\n\n        # Latency pressure: based on model speed vs deadline\n        # But complex queries tolerate more latency (they take time anyway)\n        latency_tolerance = 1 + difficulty  # More tolerance for complex queries\n        latency_pressure = profile[\"latency\"] / (deadline * latency_tolerance)\n\n        # Total pressure (weighted sum)\n        total = (\n            self.weights[\"cost\"] * cost_pressure +\n            self.weights[\"quality\"] * quality_pressure +\n            self.weights[\"latency\"] * latency_pressure\n        )\n\n        return PressureField(\n            cost_pressure=round(cost_pressure, 3),\n            quality_pressure=round(quality_pressure, 3),\n            latency_pressure=round(latency_pressure, 3),\n            total_pressure=round(total, 3)\n        )\n\n    def select(self,\n               pressures: Dict[str, PressureField],\n               available_models: List[str]) -> Tuple[str, float]:\n        \"\"\"\n        Select model with minimum total pressure.\n        Returns (model, confidence).\n        \"\"\"\n        valid = [(m, p) for m, p in pressures.items() if m in available_models]\n        if not valid:\n            return \"sonnet\", 0.5  # Fallback\n\n        # Sort by total pressure (ascending)\n        valid.sort(key=lambda x: x[1].total_pressure)\n\n        best_model = valid[0][0]\n        best_pressure = valid[0][1].total_pressure\n\n        # Confidence based on pressure gap to second choice\n        if len(valid) > 1:\n            second_pressure = valid[1][1].total_pressure\n            gap = second_pressure - best_pressure\n            confidence = min(gap * 5, 1.0)  # Scale gap to confidence\n        else:\n            confidence = 0.8\n\n        return best_model, round(confidence, 2)\n\n\n# ============================================================\n# GÖDEL SELF-MODIFICATION ENGINE\n# ============================================================\n\nclass GodelEngine:\n    \"\"\"\n    Self-modification engine inspired by Gödel Agent.\n\n    Enables the router to modify its own parameters and logic\n    based on empirical validation, not formal proofs.\n\n    Based on:\n    - Gödel Agent (arXiv:2410.04444) - Self-referential improvement\n    - Darwin Gödel Machine (arXiv:2505.22954) - Empirical validation\n    \"\"\"\n\n    def __init__(self):\n        self.archive: List[Dict] = []\n        self.current_version = DEFAULT_CONFIG[\"version\"]\n        self._load_archive()\n\n    def _load_archive(self):\n        \"\"\"Load evolution archive from disk\"\"\"\n        if EVOLUTION_ARCHIVE.exists():\n            try:\n                with open(EVOLUTION_ARCHIVE) as f:\n                    for line in f:\n                        self.archive.append(json.loads(line))\n            except Exception:\n                pass\n\n    def _save_to_archive(self, entry: Dict):\n        \"\"\"Append entry to evolution archive\"\"\"\n        HSRGS_DIR.mkdir(parents=True, exist_ok=True)\n        with open(EVOLUTION_ARCHIVE, \"a\") as f:\n            f.write(json.dumps(entry) + \"\\n\")\n        self.archive.append(entry)\n\n        # Prune if too large\n        max_size = DEFAULT_CONFIG[\"archive_max_size\"]\n        if len(self.archive) > max_size:\n            self.archive = self.archive[-max_size:]\n            with open(EVOLUTION_ARCHIVE, \"w\") as f:\n                for entry in self.archive:\n                    f.write(json.dumps(entry) + \"\\n\")\n\n    def propose_mutation(self,\n                         selector: PressureFieldSelector,\n                         recent_outcomes: List[Dict]) -> Optional[Dict]:\n        \"\"\"\n        Propose a mutation to the routing parameters based on recent outcomes.\n\n        Returns mutation proposal or None if no improvement found.\n        \"\"\"\n        if len(recent_outcomes) < 10:\n            return None  # Need more data\n\n        # Analyze recent performance\n        successes = sum(1 for o in recent_outcomes if o.get(\"success\", False))\n        success_rate = successes / len(recent_outcomes)\n\n        # Analyze cost efficiency\n        total_cost = sum(o.get(\"cost\", 0) for o in recent_outcomes)\n        avg_cost = total_cost / len(recent_outcomes)\n\n        # Propose mutation based on analysis\n        mutation = {\n            \"timestamp\": int(time.time() * 1000),\n            \"type\": None,\n            \"old_value\": None,\n            \"new_value\": None,\n            \"reasoning\": None\n        }\n\n        if success_rate < 0.7:\n            # Quality too low - increase quality pressure weight\n            old_weight = selector.weights[\"quality\"]\n            new_weight = min(old_weight * 1.1, 0.8)\n            mutation.update({\n                \"type\": \"pressure_weight\",\n                \"param\": \"quality\",\n                \"old_value\": old_weight,\n                \"new_value\": new_weight,\n                \"reasoning\": f\"Success rate {success_rate:.1%} below target, increasing quality pressure\"\n            })\n        elif avg_cost > 5.0 and success_rate > 0.85:\n            # Cost too high with good success - increase cost pressure\n            old_weight = selector.weights[\"cost\"]\n            new_weight = min(old_weight * 1.1, 0.6)\n            mutation.update({\n                \"type\": \"pressure_weight\",\n                \"param\": \"cost\",\n                \"old_value\": old_weight,\n                \"new_value\": new_weight,\n                \"reasoning\": f\"Avg cost ${avg_cost:.2f} with {success_rate:.1%} success, increasing cost pressure\"\n            })\n        else:\n            return None  # No mutation needed\n\n        return mutation\n\n    def apply_mutation(self,\n                       mutation: Dict,\n                       selector: PressureFieldSelector) -> bool:\n        \"\"\"Apply a mutation to the selector\"\"\"\n        if mutation[\"type\"] == \"pressure_weight\":\n            param = mutation[\"param\"]\n            selector.weights[param] = mutation[\"new_value\"]\n\n            # Renormalize weights\n            total = sum(selector.weights.values())\n            for k in selector.weights:\n                selector.weights[k] /= total\n\n            self._save_to_archive(mutation)\n            return True\n\n        return False\n\n    def rollback_mutation(self,\n                          mutation: Dict,\n                          selector: PressureFieldSelector):\n        \"\"\"Rollback a mutation if it caused regression\"\"\"\n        if mutation[\"type\"] == \"pressure_weight\":\n            param = mutation[\"param\"]\n            selector.weights[param] = mutation[\"old_value\"]\n\n            rollback_entry = {\n                \"timestamp\": int(time.time() * 1000),\n                \"type\": \"rollback\",\n                \"original_mutation\": mutation\n            }\n            self._save_to_archive(rollback_entry)\n\n\n# ============================================================\n# MAIN ROUTER\n# ============================================================\n\nclass HSRGSRouter:\n    \"\"\"\n    Homeomorphic Self-Routing Gödel System\n\n    The main router that combines all components:\n    1. Homeomorphic encoder for universal latent space\n    2. IRT predictor for success probability\n    3. Pressure field selector for emergent routing\n    4. Gödel engine for self-modification\n    \"\"\"\n\n    def __init__(self, available_models: Optional[List[str]] = None):\n        self.encoder = HomeomorphicEncoder()\n        self.irt = IRTPredictor()\n        self.selector = PressureFieldSelector()\n        self.godel = GodelEngine()\n        self.available_models = available_models or list(MODEL_PROFILES.keys())\n        self.recent_outcomes: List[Dict] = []\n        self._load_config()\n\n    def _load_config(self):\n        \"\"\"Load configuration\"\"\"\n        HSRGS_DIR.mkdir(parents=True, exist_ok=True)\n        if CONFIG_FILE.exists():\n            try:\n                with open(CONFIG_FILE) as f:\n                    config = json.load(f)\n                self.selector.weights = config.get(\"pressure_weights\", DEFAULT_CONFIG[\"pressure_weights\"])\n            except Exception:\n                pass\n\n    def save_config(self):\n        \"\"\"Save configuration\"\"\"\n        config = {\n            **DEFAULT_CONFIG,\n            \"pressure_weights\": self.selector.weights\n        }\n        with open(CONFIG_FILE, \"w\") as f:\n            json.dump(config, f, indent=2)\n\n    def route(self,\n              query: str,\n              budget: float = 1.0,\n              deadline: float = 1.0) -> RoutingDecision:\n        \"\"\"\n        Route a query to the optimal model.\n\n        Args:\n            query: The user query\n            budget: Cost budget multiplier (1.0 = normal, 0.5 = half budget)\n            deadline: Latency deadline multiplier (1.0 = normal, 0.5 = need fast)\n\n        Returns:\n            RoutingDecision with full provenance\n        \"\"\"\n        # 1. Encode query into universal latent space\n        latent = self.encoder.encode_query(query)\n\n        # 2. Predict success probability for each model\n        irt_predictions = {}\n        for model in self.available_models:\n            irt_predictions[model] = self.irt.predict(model, latent)\n\n        # 3. Compute pressure field for each model\n        pressures = {}\n        for model in self.available_models:\n            pressures[model] = self.selector.compute_pressure(\n                model, latent, irt_predictions[model], budget, deadline\n            )\n\n        # 4. Select model with minimum pressure\n        selected, confidence = self.selector.select(pressures, self.available_models)\n\n        # 5. Build reasoning explanation\n        reasoning = self._build_reasoning(latent, irt_predictions, pressures, selected)\n\n        # 6. Create decision record\n        decision = RoutingDecision(\n            query_hash=hashlib.md5(query.encode()).hexdigest(),\n            selected_model=selected,\n            latent=latent,\n            pressures={m: asdict(p) for m, p in pressures.items()},\n            irt_predictions=irt_predictions,\n            confidence=confidence,\n            reasoning=reasoning,\n            timestamp=int(time.time() * 1000),\n            version=self.godel.current_version\n        )\n\n        # 7. Log decision\n        self._log_decision(query, decision)\n\n        return decision\n\n    def _build_reasoning(self,\n                         latent: LatentRepresentation,\n                         irt_predictions: Dict[str, float],\n                         pressures: Dict[str, PressureField],\n                         selected: str) -> str:\n        \"\"\"Build human-readable reasoning for the decision\"\"\"\n        parts = []\n\n        # Difficulty assessment\n        if latent.difficulty < 0.3:\n            parts.append(\"simple query\")\n        elif latent.difficulty < 0.6:\n            parts.append(\"moderate complexity\")\n        else:\n            parts.append(\"complex query\")\n\n        # Discrimination\n        if latent.discrimination > 0.5:\n            parts.append(\"high model differentiation\")\n\n        # IRT insight\n        top_irt = max(irt_predictions.items(), key=lambda x: x[1])\n        if top_irt[0] != selected:\n            parts.append(f\"IRT favored {top_irt[0]} ({top_irt[1]:.0%})\")\n\n        # Pressure insight\n        selected_pressure = pressures[selected]\n        if selected_pressure.cost_pressure < selected_pressure.quality_pressure:\n            parts.append(\"cost-optimized\")\n        else:\n            parts.append(\"quality-optimized\")\n\n        return \"; \".join(parts)\n\n    def _log_decision(self, query: str, decision: RoutingDecision):\n        \"\"\"Log routing decision for learning\"\"\"\n        HSRGS_DIR.mkdir(parents=True, exist_ok=True)\n\n        log_entry = {\n            \"ts\": decision.timestamp,\n            \"query_hash\": decision.query_hash,\n            \"query_preview\": query[:80] if len(query) > 80 else query,\n            \"model\": decision.selected_model,\n            \"difficulty\": float(decision.latent.difficulty),\n            \"discrimination\": float(decision.latent.discrimination),\n            \"irt_pred\": float(decision.irt_predictions.get(decision.selected_model, 0)),\n            \"confidence\": float(decision.confidence),\n            \"version\": decision.version\n        }\n\n        with open(ROUTING_LOG, \"a\") as f:\n            f.write(json.dumps(log_entry) + \"\\n\")\n\n        # Write IRT bridge file for cross-runtime consumption (Node.js DQ scorer)\n        self._write_irt_bridge(query, decision)\n\n        # Also log to coevo data pipeline for cross-system learning\n        self._log_to_coevo(query, decision)\n\n    def _write_irt_bridge(self, query: str, decision: RoutingDecision):\n        \"\"\"Write IRT difficulty data to bridge file for Node.js DQ scorer consumption.\"\"\"\n        try:\n            bridge_data = {\n                \"query_hash\": decision.query_hash,\n                \"difficulty\": float(decision.latent.difficulty),\n                \"discrimination\": float(decision.latent.discrimination),\n                \"domain_signature\": decision.latent.domain_signature,\n                \"irt_predictions\": {m: float(p) for m, p in decision.irt_predictions.items()},\n                \"selected_model\": decision.selected_model,\n                \"timestamp\": decision.timestamp\n            }\n            HSRGS_DIR.mkdir(parents=True, exist_ok=True)\n            with open(IRT_BRIDGE_FILE, \"w\") as f:\n                json.dump(bridge_data, f, indent=2)\n        except Exception:\n            pass  # Silent fail — don't break routing\n\n    def _log_to_coevo(self, query: str, decision: RoutingDecision):\n        \"\"\"Log to shared coevo data pipeline for meta-analyzer integration\"\"\"\n        try:\n            # Build alternatives from pressure rankings\n            alternatives = []\n            sorted_pressures = sorted(\n                decision.pressures.items(),\n                key=lambda x: x[1][\"total_pressure\"]\n            )\n            for model, pressure in sorted_pressures[1:4]:  # Top 3 alternatives\n                if model != decision.selected_model:\n                    # Estimate alternative DQ from IRT prediction\n                    alt_dq = decision.irt_predictions.get(model, 0.5)\n                    alternatives.append({\"model\": model, \"dq\": round(alt_dq, 2)})\n\n            coevo_record = {\n                \"ts\": decision.timestamp,\n                \"source\": \"hsrgs\",\n                \"version\": decision.version,\n                \"query_hash\": decision.query_hash,\n                \"query_preview\": query[:80] if len(query) > 80 else query,\n                \"complexity\": float(decision.latent.difficulty),\n                \"complexity_reasoning\": decision.reasoning,\n                \"model\": decision.selected_model,\n                \"dqScore\": float(decision.latent.difficulty),\n                \"dqComponents\": {\n                    \"validity\": 1.0,  # HSRGS validates via embedding\n                    \"specificity\": float(decision.latent.discrimination),\n                    \"correctness\": float(decision.irt_predictions.get(decision.selected_model, 0.5))\n                },\n                \"hsrgs_data\": {\n                    \"difficulty\": float(decision.latent.difficulty),\n                    \"discrimination\": float(decision.latent.discrimination),\n                    \"domain\": decision.latent.domain_signature,\n                    \"confidence\": float(decision.confidence),\n                    \"pressure_winner\": decision.selected_model,\n                    \"irt_prediction\": float(decision.irt_predictions.get(decision.selected_model, 0))\n                },\n                \"alternatives\": alternatives\n            }\n\n            COEVO_DQ_FILE.parent.mkdir(parents=True, exist_ok=True)\n            with open(COEVO_DQ_FILE, \"a\") as f:\n                f.write(json.dumps(coevo_record) + \"\\n\")\n        except Exception:\n            pass  # Silent fail - don't break routing\n\n    def record_outcome(self, query_hash: str, success: bool, cost: float = 0.0):\n        \"\"\"\n        Record outcome for learning.\n        Enables IRT parameter updates and Gödel self-modification.\n        \"\"\"\n        # Find the decision\n        if not ROUTING_LOG.exists():\n            return\n\n        decision = None\n        with open(ROUTING_LOG) as f:\n            for line in f:\n                entry = json.loads(line)\n                if entry[\"query_hash\"] == query_hash:\n                    decision = entry\n\n        if not decision:\n            return\n\n        # Update IRT parameters\n        # (Would need to reconstruct latent - simplified here)\n\n        # Record for Gödel engine\n        self.recent_outcomes.append({\n            \"query_hash\": query_hash,\n            \"model\": decision[\"model\"],\n            \"success\": success,\n            \"cost\": cost,\n            \"timestamp\": int(time.time() * 1000)\n        })\n\n        # Keep only recent outcomes\n        self.recent_outcomes = self.recent_outcomes[-100:]\n\n        # Check for self-modification opportunity\n        if len(self.recent_outcomes) >= 20:\n            mutation = self.godel.propose_mutation(self.selector, self.recent_outcomes)\n            if mutation:\n                self.godel.apply_mutation(mutation, self.selector)\n                self.save_config()\n\n    def get_status(self) -> Dict:\n        \"\"\"Get current router status\"\"\"\n        return {\n            \"version\": self.godel.current_version,\n            \"available_models\": self.available_models,\n            \"pressure_weights\": self.selector.weights,\n            \"evolution_entries\": len(self.godel.archive),\n            \"recent_outcomes\": len(self.recent_outcomes),\n            \"irt_models\": list(self.irt.model_params.keys())\n        }\n\n\n# ============================================================\n# CLI INTERFACE\n# ============================================================\n\ndef main():\n    \"\"\"CLI for testing HSRGS\"\"\"\n    import sys\n\n    router = HSRGSRouter()\n\n    if len(sys.argv) > 1:\n        query = \" \".join(sys.argv[1:])\n        decision = router.route(query)\n\n        print(f\"\\n{'='*60}\")\n        print(f\"HSRGS Routing Decision\")\n        print(f\"{'='*60}\")\n        print(f\"Query: {query[:60]}...\")\n        print(f\"{'─'*60}\")\n        print(f\"Difficulty:      {decision.latent.difficulty:.2f}\")\n        print(f\"Discrimination:  {decision.latent.discrimination:.2f}\")\n        print(f\"Domain:          {decision.latent.domain_signature}\")\n        print(f\"{'─'*60}\")\n        print(f\"Selected Model:  {decision.selected_model}\")\n        print(f\"Confidence:      {decision.confidence:.0%}\")\n        print(f\"IRT Prediction:  {decision.irt_predictions[decision.selected_model]:.0%}\")\n        print(f\"{'─'*60}\")\n        print(f\"Reasoning: {decision.reasoning}\")\n        print(f\"{'='*60}\\n\")\n\n        # Show pressure breakdown\n        print(\"Pressure Field:\")\n        for model, pressure in sorted(decision.pressures.items(),\n                                       key=lambda x: x[1][\"total_pressure\"]):\n            p = pressure\n            marker = \" ← selected\" if model == decision.selected_model else \"\"\n            print(f\"  {model:12} | cost:{p['cost_pressure']:.2f} quality:{p['quality_pressure']:.2f} \"\n                  f\"latency:{p['latency_pressure']:.2f} | total:{p['total_pressure']:.2f}{marker}\")\n        print()\n    else:\n        print(\"HSRGS Status:\")\n        status = router.get_status()\n        for k, v in status.items():\n            print(f\"  {k}: {v}\")\n\n\nif __name__ == \"__main__\":\n    main()\n","numLines":979,"startLine":1,"totalLines":979}}}
