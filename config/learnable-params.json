  "groups": {
    "graph_signal": {
      "constraint": "sumMustEqual",
      "target": 1.0,
      "description": "Graph signal composition weights for composite routing signal"
    },
    "dq_weights": {
      "constraint": "sumMustEqual",
      "target": 1.0,
      "description": "DQ scorer component weights: validity + specificity + correctness"
    },
    "agent_thresholds": {
      "constraint": "monotonic",
      "direction": "ascending",
      "description": "SUPERMAX v2 complexity thresholds for agent count scaling"
    },
    "free_mad": {
      "constraint": "independent",
      "description": "Free-MAD trajectory scoring: stability decay, sycophancy, disagreement"
    },
    "behavioral": {
      "constraint": "sumMustEqual",
      "target": 0.9,
      "description": "Behavioral outcome composite score weights (4 of 5 components)",
      "implicitRemainder": {
        "id": "no_followup",
        "value": "1.0 - sum(registered weights)",
        "reason": "no_followup (0.10) derived from remainder \u2014 not independently learnable"
      }
    },
    "reward_composition": {
      "constraint": "sumMustEqual",
      "target": 1.0,
      "description": "Reward function composition: DQ accuracy + cost efficiency + behavioral outcome"
    },
    "lrf_topology": {
      "constraint": "independent",
      "description": "LRF Topology: cluster count and structure parameters for contextual routing"
    },
    "exploration_schedule": {
      "constraint": "independent",
      "description": "Per-cluster exploration annealing: global floor for explore/exploit tradeoff"
    },
    "session_multipliers": {
      "constraint": "independent",
      "description": "Session-type reward multipliers: per-type scaling for DQ, cost, and behavioral reward components"
    }
  },
  "updated": "2026-03-18",
